---
import "../styles/app.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SawFleet",
  description = "Modern Fleet Management Platform"
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- Favicon / Theme -->
  <meta name="theme-color" content="#000000" />

  <!-- Leaflet Map CSS (Potrebno za mapu) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- Google Fonts: Prebacujemo na sans-serif (Inter ili default sistem) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="min-h-screen bg-[#000000] text-white antialiased selection:bg-green-500/30">

  <slot />

  <!-- Leaflet Map JS (Potrebno za mapu) -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
</body>
</html>