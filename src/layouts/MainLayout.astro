---
import "../styles/app.css";
import { supabase } from "../lib/supabase";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "SF Tree Removal | Premium Tree Service Dispatch Network",
  description = "Connect homeowners with trusted local tree service professionals and grapple saw truck operators across South Florida.",
  image = "/og-image.jpg", // Putanja do slike koja će se prikazati kada neko podeli link na Viberu/WhatsAppu/FB-u
  structuredData,
} = Astro.props;

// Generisanje kanoničnog URL-a za SEO (sprečava duplicate content penale)
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);

// Organization schema (sajtska, ne LocalBusiness — ovo je dispatch/
// marketplace platforma bez jedne fizičke adrese/telefona, pa ne
// izmišljamo te podatke; koristimo samo ono što stvarno znamo)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "SF Tree Removal",
  url: "https://sftreeremoval.com/",
  logo: "https://sftreeremoval.com/logo/logo.png",
  description:
    "Premium tree service dispatch network connecting South Florida homeowners with vetted, compliant tree service contractors.",
  areaServed: [
    { "@type": "AdministrativeArea", name: "Broward County" },
    { "@type": "AdministrativeArea", name: "City of Boca Raton" },
    { "@type": "AdministrativeArea", name: "City of Coral Gables" },
    { "@type": "AdministrativeArea", name: "City of Doral" },
    { "@type": "AdministrativeArea", name: "City of Fort Lauderdale" },
    { "@type": "AdministrativeArea", name: "City of Hallandale Beach" },
    { "@type": "AdministrativeArea", name: "City of Miami" },
    { "@type": "AdministrativeArea", name: "City of Miami Gardens" },
    { "@type": "AdministrativeArea", name: "City of Naples" },
    { "@type": "AdministrativeArea", name: "City of Oakland Park" },
    { "@type": "AdministrativeArea", name: "Collier County" },
    { "@type": "AdministrativeArea", name: "Miami-Dade County" },
    { "@type": "AdministrativeArea", name: "Palm Beach County" },
    { "@type": "AdministrativeArea", name: "Town of Jupiter" },
    { "@type": "AdministrativeArea", name: "Village of Wellington" },
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "SF Tree Removal",
  url: "https://sftreeremoval.com/",
};

// Povlačimo globalne skripte (Analytics, Pixel) koje si uneo kroz Settings panel
const { data: tracking } = await supabase
  .from('tracking_settings')
  .select('global_scripts')
  .eq('id', 1)
  .single();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- ============================================== -->
  <!-- PRIMARY SEO -->
  <!-- ============================================== -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Robot instrukcije (dozvoljavamo indeksiranje) -->
  <meta name="robots" content="index, follow" />

  <!-- ============================================== -->
  <!-- OPEN GRAPH / FACEBOOK (Za deljenje linkova) -->
  <!-- ============================================== -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- ============================================== -->
  <!-- TWITTER CARDS -->
  <!-- ============================================== -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.url)} />
  {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}

  <!-- ============================================== -->
  <!-- STRUCTURED DATA (schema.org) -->
  <!-- ============================================== -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>

  <!-- ============================================== -->
  <!-- THEME & ICONS -->
  <!-- ============================================== -->
  <meta name="theme-color" content="#ffffff" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- ============================================== -->
  <!-- ASSETS & FONTS -->
  <!-- ============================================== -->
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>

  <!-- ============================================== -->
  <!-- GLOBAL TRACKING SCRIPTS (Google Analytics, Meta Pixel) -->
  <!-- ============================================== -->
  {tracking?.global_scripts && (
    <Fragment set:html={tracking.global_scripts} />
  )}

</head>

<body class="min-h-screen flex flex-col bg-white text-slate-900 antialiased selection:bg-green-200 selection:text-slate-900">

  <!-- GLAVNI SADRŽAJ STRANICE -->
  <slot />

  <script>
    (() => {
      const storageKey = "sftr_analytics_session";
      let sessionId = "";
      try {
        sessionId = localStorage.getItem(storageKey) || crypto.randomUUID();
        localStorage.setItem(storageKey, sessionId);
      } catch {
        sessionId = crypto.randomUUID();
      }

      const url = new URL(window.location.href);
      const payload = {
        path: `${url.pathname}${url.search}`,
        title: document.title,
        sessionId,
        referrer: document.referrer || null,
        utmSource: url.searchParams.get("utm_source"),
        utmMedium: url.searchParams.get("utm_medium"),
        utmCampaign: url.searchParams.get("utm_campaign"),
      };
      fetch("/api/page-view", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
        keepalive: true,
      }).catch(() => {});
    })();
  </script>
</body>
</html>
