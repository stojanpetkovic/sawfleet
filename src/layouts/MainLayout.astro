---
import "../styles/app.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SawFleet",
  description = "Modern Fleet Management Platform"
} = Astro.props;
---

<!doctype html>

<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>

  <meta
    name="description"
    content={description} />

  <meta
    name="theme-color"
    content="#09090B" />

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com" />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin />

  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />

</head>

<body class="min-h-screen bg-zinc-950 font-[Manrope] text-white antialiased">

  <slot />

</body>

</html>