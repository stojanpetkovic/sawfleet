---
import '../styles/global.css';

interface Props {
  companyName?: string;
}

const { companyName = 'Contractor' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SawFleet | Contractor Dashboard</title>
  </head>
  <body class="bg-[#000000] text-zinc-100 antialiased font-sans min-h-screen pb-24 lg:pb-0">

    <header class="w-full h-20 border-b border-zinc-900 flex items-center justify-between px-4 lg:px-8 bg-[#000000]/80 backdrop-blur-md sticky top-0 z-30">
      <a href="/dashboard" class="flex items-center gap-2">
        <img src="/logo/logo.svg" alt="SawFleet" class="h-10 w-auto" />
      </a>
      <div class="flex items-center gap-4">
        <span id="companyNameLabel" class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-zinc-400 hidden sm:block">{companyName}</span>
        <button id="logoutBtn" class="h-10 px-4 flex items-center justify-center rounded-lg border border-red-900/30 bg-red-950/10 text-[10px] font-bold uppercase tracking-[0.2em] text-red-500 hover:bg-red-950/30 hover:border-red-900/50 transition-all">
          Sign out
        </button>
      </div>
    </header>

    <main class="max-w-4xl mx-auto w-full px-4 py-8 lg:py-12">
      <slot />
    </main>

    <script>
      import { supabase } from "../lib/supabase";
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
