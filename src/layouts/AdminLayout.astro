---
import '../styles/global.css';
import '../styles/app.css';
import {
  LayoutDashboard,
  Inbox,
  Users,
  Truck,
  Menu as MenuIcon,
} from "lucide-astro";

const currentPath = Astro.url.pathname;

const menuItems = [
  { name: 'Dashboard', path: '/admin', icon: LayoutDashboard },
  { name: 'Service Leads', path: '/admin/service-leads', icon: Inbox },
  { name: 'Contractors', path: '/admin/contractors', icon: Users },
  { name: 'Grapple Saw Trucks', path: '/admin/grapple-saw-trucks', icon: Truck },
  { name: 'Analytics', path: '/admin/analytics' }
];

// The four sections shown in the mobile bottom tab bar (app-style nav)
const tabItems = menuItems.slice(0, 4);
---
<!DOCTYPE HTML>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" />
    <title>SawFleet Admin</title>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased font-sans">

    <div id="mobileOverlay" class="fixed inset-0 bg-slate-900/30 backdrop-blur-sm z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex w-full h-screen overflow-hidden">

      <!-- SIDEBAR - ZAMRZNUT (FIXED) -->
      <aside
        id="sidebar"
        class="fixed inset-y-0 left-0 z-50 w-64 border-r border-slate-200 bg-white p-6 flex flex-col justify-between h-screen transform -translate-x-full lg:relative lg:translate-x-0 transition-transform duration-300 ease-in-out shrink-0 pt-safe"
      >
        <div>
          <div class="flex items-center justify-between mb-16 px-2">
            <a href="/admin" class="flex items-center gap-2">
              <img src="/logo/logo.svg" alt="SawFleet" class="h-14 lg:h-24 w-auto" />
            </a>
            <button id="closeMenuBtn" class="lg:hidden text-slate-400 hover:text-slate-900">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <nav class="space-y-1">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-4 px-3">Menu</p>
            {menuItems.map((item) => {
              const isActive = currentPath === item.path || currentPath === item.path + '/';
              const Icon = item.icon;
              return (
                <a href={item.path} class={`flex items-center gap-3 px-3 py-3 rounded-lg text-[10px] font-mono font-bold uppercase tracking-[0.2em] transition-all duration-200 ${isActive ? 'bg-green-50 text-green-700 border border-green-600/15' : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50 border border-transparent'}`}>
                  {Icon && <Icon size={15} strokeWidth={1.75} />}
                  {item.name}
                </a>
              )
            })}
          </nav>
        </div>

        <div class="flex flex-col gap-4 border-t border-slate-200 pt-6 mt-8">
          <a href="/admin/settings" class={`block px-3 py-3 rounded-lg text-[10px] font-mono font-bold uppercase tracking-[0.2em] transition-all duration-200 ${currentPath.includes('/admin/settings') ? 'bg-green-50 text-green-700 border border-green-600/15' : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50 border border-transparent'}`}>
            Settings
          </a>
          <button id="logoutBtn" class="h-11 px-4 w-full flex items-center justify-center rounded-lg border border-red-200 bg-red-50 text-[10px] font-bold uppercase tracking-[0.2em] text-red-600 hover:bg-red-100 hover:border-red-300 transition-all">
            Sign out
          </button>
        </div>
      </aside>

      <!-- MAIN CONTENT AREA - SKROLUJE SE -->
      <div class="flex-1 flex flex-col min-w-0 h-screen overflow-y-auto pb-20 lg:pb-0">
        <!-- HEADER - STICKY -->
        <header class="w-full h-16 lg:h-20 border-b border-slate-200 flex items-center justify-between px-4 lg:px-8 bg-white/80 backdrop-blur-md sticky top-0 z-30 shrink-0 pt-safe">

          <div class="flex items-center gap-4">
            <button id="openMenuBtn" class="lg:hidden text-slate-400 hover:text-slate-900 focus:outline-none">
              <MenuIcon size={22} strokeWidth={1.75} />
            </button>
            <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-slate-400 hidden sm:inline">Platform Overview</span>
            <span class="text-sm font-bold text-slate-900 sm:hidden">SawFleet</span>
          </div>

          <div class="flex items-center gap-4 lg:gap-6">
            <div class="relative">
              <button id="notifBtn" class="text-slate-400 hover:text-slate-900 transition-colors relative mt-1">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
                <span id="notificationBadge" class="hidden absolute -top-1 -right-1 h-4 min-w-[16px] px-1 rounded-full bg-red-500 text-[9px] font-bold text-white flex items-center justify-center">0</span>
              </button>
              <div id="notifDropdown" class="hidden absolute right-0 mt-2 w-64 bg-white border border-slate-200 rounded-xl shadow-soft-lg z-50">
                <div class="px-4 py-3 border-b border-slate-100 bg-slate-50 rounded-t-xl"><h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500">Action Required</h3></div>
                <div class="p-2 space-y-1">
                  <a href="/admin/service-leads" class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors"><span class="text-xs text-slate-600">New Leads</span><span id="badge-leads" class="text-[10px] font-mono text-green-700 bg-green-50 px-2 py-0.5 rounded">0</span></a>
                  <a href="/admin/contractors" class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors"><span class="text-xs text-slate-600">Pending Contractors</span><span id="badge-contractors" class="text-[10px] font-mono text-blue-600 bg-blue-50 px-2 py-0.5 rounded">0</span></a>
                  <a href="/admin/grapple-saw-trucks" class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors"><span class="text-xs text-slate-600">Pending Assets</span><span id="badge-trucks" class="text-[10px] font-mono text-purple-600 bg-purple-50 px-2 py-0.5 rounded">0</span></a>
                </div>
              </div>
            </div>
            <div class="hidden sm:flex items-center gap-3 border-l border-slate-200 pl-6">
              <span class="text-[10px] font-mono font-bold uppercase text-slate-600">Stojan M.</span>
              <div class="w-7 h-7 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-[10px] text-slate-700">SM</div>
            </div>
          </div>
        </header>

        <main class="p-4 sm:p-6 lg:p-8 w-full flex-grow">
          <slot />
        </main>
      </div>
    </div>

    <!-- MOBILE BOTTOM TAB BAR (app-style navigation) -->
    <nav class="lg:hidden fixed bottom-0 left-0 right-0 z-40 border-t border-slate-200 bg-white/95 backdrop-blur-md safe-bottom-nav">
      <div class="flex items-center justify-around h-16">
        {tabItems.map((item) => {
          const isActive = currentPath === item.path || currentPath === item.path + '/';
          const Icon = item.icon;
          return (
            <a href={item.path} class={`flex flex-col items-center justify-center gap-1 w-16 h-full transition-colors ${isActive ? 'text-green-700' : 'text-slate-400 hover:text-slate-600'}`}>
              {Icon && <Icon size={20} strokeWidth={isActive ? 2 : 1.75} />}
              <span class="text-[9px] font-mono font-bold uppercase tracking-wide">{item.name.split(' ')[0]}</span>
            </a>
          )
        })}
        <button id="openMenuBtnTab" class="flex flex-col items-center justify-center gap-1 w-16 h-full text-slate-400 hover:text-slate-600 transition-colors">
          <MenuIcon size={20} strokeWidth={1.75} />
          <span class="text-[9px] font-mono font-bold uppercase tracking-wide">More</span>
        </button>
      </div>
    </nav>

    <script>
      import { supabase } from "../lib/supabase";

      // Zaštita: samo pravi admin nalozi (upisani u admins tabeli)
      // smeju da vide /admin. Svi ostali (kontraktori, neulogovani,
      // nepoznati) se izbacuju.
      async function guardSession() {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          window.location.replace('/admin/login');
          return;
        }
        const { data: isAdmin } = await supabase.rpc('is_admin');
        if (!isAdmin) {
          window.location.replace('/admin/login');
        }
      }
      guardSession();
      supabase.auth.onAuthStateChange((event) => {
        if (event === 'SIGNED_OUT') window.location.replace('/admin/login');
      });

      const sidebar = document.getElementById('sidebar');
      const mobileOverlay = document.getElementById('mobileOverlay');
      const toggle = () => { sidebar?.classList.toggle('-translate-x-full'); mobileOverlay?.classList.toggle('hidden'); };
      document.getElementById('openMenuBtn')?.addEventListener('click', toggle);
      document.getElementById('openMenuBtnTab')?.addEventListener('click', toggle);
      document.getElementById('closeMenuBtn')?.addEventListener('click', toggle);
      mobileOverlay?.addEventListener('click', toggle);
      document.getElementById('logoutBtn')?.addEventListener('click', async () => { await supabase.auth.signOut(); window.location.href = '/admin/login'; });

      // Notification dropdown — click-to-toggle so it works on touch devices too
      const notifBtn = document.getElementById('notifBtn');
      const notifDropdown = document.getElementById('notifDropdown');
      notifBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        notifDropdown?.classList.toggle('hidden');
      });
      document.addEventListener('click', (e) => {
        if (notifDropdown && !notifDropdown.classList.contains('hidden') && !notifDropdown.contains(e.target as Node) && e.target !== notifBtn) {
          notifDropdown.classList.add('hidden');
        }
      });

      async function fetchNotifications() {
        const { count: leads } = await supabase.from('leads').select('*', { count: 'exact', head: true }).eq('status', 'new');
        const { count: contr } = await supabase.from('contractors').select('*', { count: 'exact', head: true }).eq('status', 'pending');
        const { count: trucks } = await supabase.from('grapple_saw_trucks').select('*', { count: 'exact', head: true }).eq('approval_status', 'pending');
        const total = (leads || 0) + (contr || 0) + (trucks || 0);
        const badge = document.getElementById('notificationBadge');
        if (total > 0 && badge) { badge.textContent = total.toString(); badge.classList.remove('hidden'); }
        document.getElementById('badge-leads')!.textContent = (leads || 0).toString();
        document.getElementById('badge-contractors')!.textContent = (contr || 0).toString();
        document.getElementById('badge-trucks')!.textContent = (trucks || 0).toString();
      }
      document.addEventListener('astro:page-load', fetchNotifications);
    </script>
  </body>
</html>
