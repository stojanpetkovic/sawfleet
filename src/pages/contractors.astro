---
import MainLayout from "../layouts/MainLayout.astro";
import ContractorHeader from "../components/layout/ContractorHeader.astro";
import ContractorBottomNav from "../components/layout/ContractorBottomNav.astro";
import Footer from "../components/layout/Footer.astro";

import Hero from "../components/contractors/Hero/Hero.astro";
import HowItWorks from "../components/contractors/HowItWorks/HowItWorks.astro";
---

<MainLayout title="Join the SawFleet Contractor Network">
  <ContractorHeader />

  <!-- Uklonjen pt-20, main sada počinje odmah ispod headera -->
  <main> 

    <!-- Uklonjen py-12, stavljamo pt-24 da kompenzujemo fiksni header -->
    <section>
       <Hero />
    </section>

    <!-- How it Works: ostaje py-12 ili smanji na py-8 ako želiš veću kompaktnost -->
    <section>
       <HowItWorks />
    </section>

  </main>
  
  <Footer />
  <ContractorBottomNav />
</MainLayout>