---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { supabase } from "../lib/supabase";

export const prerender = false;

// Povlačimo isključivo konverzione skripte za ovu stranu
const { data: tracking } = await supabase
  .from('tracking_settings')
  .select('conversion_scripts')
  .eq('id', 1)
  .single();
---

<MainLayout title="Thank You | SF Tree Removal">
  <Header />

  <main class="relative min-h-screen bg-white flex items-center justify-center pt-20 px-4 sm:px-8">
    
    <!-- Centralni Glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] sm:w-[500px] h-[300px] sm:h-[500px] bg-green-500/10 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-lg text-center">
      
      <!-- Checkmark Ikona -->
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-green-500/30 bg-green-500/10 mb-8">
        <svg class="h-10 w-10 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold tracking-tighter text-slate-900 mb-4">Request Received.</h1>
      
      <p class="text-base text-slate-600 leading-relaxed mb-10">
        Thank you for submitting your details. Our system is currently matching your request with qualified professionals. You will be contacted shortly.
      </p>

      <a href="/" class="inline-flex h-12 px-8 items-center justify-center rounded-xl border border-slate-300 bg-slate-100 text-sm font-bold text-slate-900 transition-all hover:bg-slate-200 hover:border-slate-400">
        ← Return to Homepage
      </a>
    </div>

  </main>
  
  <Footer />

  <!-- OVDE SE INJEKTUJE TVOJ GOOGLE ADS / META CONVERSION KOD -->
  {tracking?.conversion_scripts && (
    <Fragment set:html={tracking.conversion_scripts} />
  )}

</MainLayout>