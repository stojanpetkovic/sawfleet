---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<MainLayout title="Register as a Fleet Owner | SF Tree Removal">
  <Header />

  <main class="min-h-screen bg-white">

    <!-- Hero Sekcija — VIDEO POZADINA + FORMA -->
    <section class="relative isolate overflow-hidden pt-28 pb-20 lg:pt-36 lg:pb-28 px-4 sm:px-8 lg:min-h-[80vh] lg:flex lg:items-center bg-slate-900">

      <div class="absolute inset-0 -z-20">
        <video
          autoplay muted loop playsinline preload="metadata"
          poster="/videos/hero-fleet-poster.webp"
          class="h-full w-full object-cover"
        >
          <source src="/videos/hero-optimized.webm" type="video/webm" media="(min-width: 640px) and (prefers-reduced-motion: no-preference)" />
          <source src="/videos/hero-optimized.mp4" type="video/mp4" media="(min-width: 640px) and (prefers-reduced-motion: no-preference)" />
        </video>
      </div>
      <div class="absolute inset-0 -z-10 bg-slate-950/45"></div>

      <div class="mx-auto max-w-[1320px] w-full relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-start lg:items-center">

          <!-- Leva strana (Tekst) -->
          <section class="max-w-[640px] font-sans lg:pt-8">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md px-3 py-1.5 shadow-soft">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
              </span>
              <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/90">Dispatch Network</span>
            </div>

            <!-- Heading -->
            <h1 class="mt-6 text-[2.5rem] sm:text-[3.5rem] font-bold leading-[1.1] tracking-tighter text-white">
              Become a
              <span class="block mt-1 bg-gradient-to-r from-green-400 to-emerald-400 bg-clip-text text-transparent">Fleet Owner.</span>
            </h1>

            <!-- Expanded Description -->
            <div class="mt-6 space-y-4">
              <p class="text-base text-white/85 font-medium leading-relaxed">
                Create your free fleet owner account first. Once you're in, you can add as many grapple saw trucks as you own straight from your dashboard — each one gets its own availability and approval status.
              </p>
              <p class="text-sm text-white/60 leading-relaxed border-l-2 border-white/20 pl-4">
                Our platform eliminates the friction of traditional dispatching, providing you with real-time visibility into project demand within the exact counties and territories you serve.
              </p>
            </div>

            <!-- Expanded Benefits Grid -->
            <div class="mt-10 space-y-5 border-t border-white/15 pt-8">
              {[
                { title: "One Account, Many Trucks", desc: "Register once, then list every asset you own from your dashboard — no re-signing up." },
                { title: "Per-Truck Availability", desc: "Mark each truck Available or Busy independently as your schedule changes." },
                { title: "Direct Dispatch", desc: "Remove the middleman. Access a steady pipeline of inbound requests ready for immediate scheduling." },
                { title: "Smart Utilization", desc: "Data-driven routing maximizes your billable hours while minimizing transit and logistics overhead." }
              ].map((item, i) => (
                <div class="flex items-start gap-4 group">
                  <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded border border-white/20 bg-white/10 backdrop-blur-md text-[10px] font-mono text-green-400 group-hover:border-green-400/50 transition-colors">0{i + 1}</div>
                  <div>
                    <h3 class="text-xs font-bold text-white uppercase tracking-wider">{item.title}</h3>
                    <p class="mt-1 text-[11px] leading-relaxed text-white/60">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Desna strana (Forma) — Bela "glass" kartica -->
          <section class="w-full max-w-[520px] lg:ml-auto rounded-2xl sm:rounded-3xl border border-white/40 bg-white/95 backdrop-blur-xl p-6 sm:p-8 shadow-2xl ring-1 ring-black/5 relative overflow-hidden">
            <!-- Akcentna traka na vrhu forme -->
            <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-green-500 via-emerald-500 to-green-500"></div>

            <!-- Dekorativni sjaj u pozadini forme -->
            <div class="absolute top-0 right-0 -mr-16 -mt-16 w-32 h-32 bg-green-500/10 blur-[50px] rounded-full pointer-events-none"></div>

            <div class="border-b border-slate-200 pb-5 mb-6 relative">
              <div class="flex items-center justify-between gap-3">
                <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Fleet Owner Signup</span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 border border-green-200 px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider text-green-700">
                  <span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Free account
                </span>
              </div>
              <h2 class="mt-2 text-2xl font-bold text-slate-900 tracking-tight">Create Your Account</h2>
              <p class="text-xs text-slate-500 mt-1">Add your trucks after you sign in — takes a minute per truck.</p>
            </div>

            <!-- Prikazano ako je neko već ulogovan — nema potrebe da se ponovo registruje -->
            <div id="alreadyOwnerBanner" class="hidden rounded-xl border border-blue-200 bg-blue-50 px-4 py-4 text-xs text-blue-800 leading-relaxed">
              You're already signed in as <span id="alreadyOwnerEmail" class="font-bold"></span>.
              <a href="/truck-dashboard" class="mt-3 flex h-11 w-full items-center justify-center rounded-lg bg-blue-600 text-white text-xs font-bold hover:bg-blue-700 transition-colors">Go to your dashboard →</a>
            </div>

            <form id="ownerForm" class="space-y-5 relative">
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="companyName" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Company Name <span class="text-slate-400">(optional)</span></label>
                  <input id="companyName" name="companyName" type="text" placeholder="e.g. South Florida Heavy Equipment" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none transition-all focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
                </div>
                <div>
                  <label for="contactName" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Contact Name</label>
                  <input id="contactName" name="contactName" type="text" required placeholder="John Doe" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none transition-all focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="email" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Email</label>
                  <input id="email" name="email" type="email" required placeholder="owner@email.com" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none transition-all focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
                </div>
                <div>
                  <label for="phone" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Phone</label>
                  <input id="phone" name="phone" type="tel" required placeholder="(555) 000-0000" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none transition-all focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
                </div>
              </div>

              <div>
                <label for="password" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Password</label>
                <input id="password" name="password" type="password" required minlength="6" placeholder="min. 6 characters" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none transition-all focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
              </div>

              <!-- SUBMIT -->
              <button type="submit" id="submitBtn" class="mt-6 flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-green-500 text-sm font-bold text-white transition-all hover:bg-green-600 active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(34,197,94,0.5)] hover:shadow-[0_12px_28px_-6px_rgba(34,197,94,0.6)]">
                <span id="submitBtnLabel">Create Account →</span>
              </button>
              <p class="text-center text-[10px] text-slate-400 pt-1">
                Already registered? <a href="/truck-login" class="text-slate-700 hover:text-slate-900 underline">Fleet Owner Login</a>
              </p>
            </form>
          </section>
        </div>
      </div>
    </section>

    <section class="border-t border-slate-200 bg-white px-4 py-12 sm:px-8 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-[1200px]">
        <div class="mb-8 max-w-2xl sm:mb-10">
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-blue-700">// Fleet listing workflow</span>
          <h2 class="mt-3 text-2xl font-bold tracking-tighter text-slate-950 sm:text-3xl">Keep every approved asset visible and current.</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">One fleet owner account can manage multiple trucks. Each listing carries its own specifications, review status and availability.</p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { n: "01", t: "One Fleet Account", d: "Manage company details and all equipment from a single dashboard." },
            { n: "02", t: "Asset-Level Review", d: "Every truck is submitted and reviewed as an individual listing." },
            { n: "03", t: "Clear Specifications", d: "Record equipment type, lift capacity, height, access and location." },
            { n: "04", t: "Live Availability", d: "Update approved equipment when it becomes available or unavailable." }
          ].map(item => (
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft transition-all hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-soft-lg">
              <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-blue-50 text-[10px] font-mono font-bold text-blue-700">{item.n}</div>
              <h3 class="mt-4 text-xs font-bold uppercase tracking-wide text-slate-900">{item.t}</h3>
              <p class="mt-2 text-[11px] leading-relaxed text-slate-600">{item.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 sm:px-8 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-[1200px]">
        <div class="mb-8 max-w-2xl"><span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-blue-700">// What happens next</span><h2 class="mt-3 text-2xl font-bold tracking-tighter text-slate-950 sm:text-3xl">From registration to an active listing.</h2></div>
        <div class="grid gap-4 lg:grid-cols-3">
          {[
            { step: "Step 01", title: "Create and confirm", text: "Create the fleet owner account, confirm the email address and sign in to the dashboard." },
            { step: "Step 02", title: "Add equipment", text: "Enter each truck separately so dispatch can understand its capability and operating location." },
            { step: "Step 03", title: "Review and update", text: "Administrators review submitted listings. Once approved, keep availability accurate from the dashboard." }
          ].map((item, index) => (
            <article class={`rounded-2xl border p-5 sm:p-6 ${index === 1 ? 'border-blue-200 bg-blue-50' : 'border-slate-200 bg-white shadow-soft'}`}>
              <span class={`text-[9px] font-bold uppercase tracking-[0.18em] ${index === 1 ? 'text-blue-700' : 'text-slate-400'}`}>{item.step}</span>
              <h3 class="mt-3 text-base font-bold text-slate-950">{item.title}</h3><p class="mt-2 text-xs leading-relaxed text-slate-600">{item.text}</p>
            </article>
          ))}
        </div>
        <div class="mt-6 flex flex-col items-start justify-between gap-4 rounded-2xl border border-slate-200 bg-white p-5 sm:flex-row sm:items-center sm:p-6">
          <div><h3 class="text-sm font-bold text-slate-950">Have your login details ready?</h3><p class="mt-1 text-xs text-slate-500">Create the owner account above, then add equipment from the Fleet dashboard.</p></div>
          <a href="#ownerForm" class="inline-flex h-11 w-full items-center justify-center rounded-xl bg-blue-700 px-5 text-[10px] font-bold uppercase tracking-[0.15em] text-white hover:bg-blue-800 sm:w-auto">Back to registration ↑</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById('ownerForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const btnLabel = document.getElementById('submitBtnLabel') as HTMLElement;
  const claimSlug = new URLSearchParams(window.location.search).get('claim');

  async function prefillClaimedProfile() {
    if (!claimSlug) return;
    const { data: profile } = await supabase
      .from('unclaimed_truck_directory')
      .select('company_name,contact_name,equipment_name,location_city,location_state')
      .eq('slug', claimSlug)
      .maybeSingle();
    if (!profile) return;
    (document.getElementById('companyName') as HTMLInputElement).value = profile.company_name || '';
    (document.getElementById('contactName') as HTMLInputElement).value = profile.contact_name || '';
    const header = form.previousElementSibling;
    const heading = header?.querySelector('h2');
    const intro = header?.querySelector('p');
    if (heading) heading.textContent = 'Claim Your Fleet Profile';
    if (intro) intro.textContent = `${profile.equipment_name} · ${[profile.location_city, profile.location_state].filter(Boolean).join(', ')}. Create an account to submit ownership verification.`;
  }
  prefillClaimedProfile();

  // Ako je neko VEĆ ulogovan kao fleet owner, ova stranica više nije za
  // njega — registracija je jednokratna, dodavanje kamiona se radi u
  // dashboard-u. Samo ga uputimo tamo.
  async function redirectIfAlreadyOwner() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    form.classList.add('hidden');
    document.getElementById('alreadyOwnerBanner')?.classList.remove('hidden');
    const emailLabel = document.getElementById('alreadyOwnerEmail');
    if (emailLabel) emailLabel.textContent = session.user.email ?? '';
  }
  redirectIfAlreadyOwner();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btnLabel.textContent = 'Creating account...';

    const fd = new FormData(form);
    const email = (fd.get('email') as string).trim().toLowerCase();
    const password = fd.get('password') as string;

    const { data: signUpData, error: signUpError } = await supabase.auth.signUp({
      email,
      password,
      options: { emailRedirectTo: `${window.location.origin}/truck-login` },
    });

    if (signUpError) {
      alert(signUpError.message.includes('already registered')
        ? 'This email is already registered. Sign in at /truck-login instead.'
        : 'Error: ' + signUpError.message);
      btn.disabled = false;
      btnLabel.textContent = 'Create Account →';
      return;
    }

    const ownerId = signUpData.user?.id;

    // Supabase namerno NE baca grešku kad se signUp ponovo pošalje za
    // email koji već postoji ali još nije potvrđen (da ne otkrije da
    // nalog postoji) — umesto toga vraća user objekat sa praznim
    // identities nizom, i taj id NE odgovara stvarnom redu u auth.users.
    // Ako bismo tim id-jem pokušali upis u truck_owners, pukne na
    // foreign key constraint. Prepoznajemo ovo OVDE i jasno objašnjavamo
    // umesto nejasne greške posle.
    const looksUnconfirmedRetry = Array.isArray(signUpData.user?.identities) && signUpData.user!.identities!.length === 0;

    if (looksUnconfirmedRetry) {
      alert('This email is already registered but not yet confirmed. Check your inbox for the confirmation link, or use "Forgot password" on the login page if you need a new one.');
      window.location.href = '/truck-login';
      return;
    }

    // Napravi profil vlasnika preko servera (service_role) — ne zavisi
    // od toga da li postoji aktivna sesija odmah posle signUp-a. Ako je
    // u Supabase Auth uključeno "Confirm email", signUp NE vraća sesiju
    // dok korisnik ne potvrdi mejl, pa bi direktan insert sa browser
    // klijenta pukao na RLS (auth.uid() bio bi null).
    if (ownerId) {
      try {
        const res = await fetch('/api/create-owner-profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ownerId,
            email,
            companyName: fd.get('companyName') || null,
            contactName: fd.get('contactName'),
            phone: fd.get('phone'),
            claimSlug,
          }),
        });
        const result = await res.json();
        if (!res.ok) {
          alert('Account created, but saving your profile failed: ' + (result.message || result.error) + '\nYou can still log in and add trucks.');
        }
      } catch (err) {
        alert('Account created, but saving your profile failed. You can still log in and add trucks.');
      }
    }

    // Obavesti admine mejlom o novoj prijavi vlasnika (best effort — ne
    // blokira redirect ako padne)
    fetch('/api/notify-new-truck-owner', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ownerName: fd.get('contactName'),
        companyName: fd.get('companyName'),
      }),
    }).catch((err) => console.error('notify-new-truck-owner failed:', err));

    // REDIRECT TO THANK YOU PAGE (fires pixel/ads conversion)
    window.location.href = '/thank-you';
  });
</script>
