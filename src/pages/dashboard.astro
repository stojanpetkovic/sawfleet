---
import ContractorLayout from "../layouts/ContractorLayout.astro";
import { supabase } from "../lib/supabase";
import { Inbox, CheckCircle2, Truck, UserCircle } from "lucide-astro";

const { data: territories } = await supabase
  .from('service_territories')
  .select('*')
  .order('name', { ascending: true });

const navItems = [
  { label: 'Available', tab: 'available', icon: Inbox },
  { label: 'Claimed', tab: 'claimed', icon: CheckCircle2 },
  { label: 'Truck network', tab: 'trucks', icon: Truck },
  { label: 'Profile', tab: 'profile', icon: UserCircle },
];
---

<ContractorLayout navItems={navItems} activeTab="available">
  <!-- STATE: LOADING -->
  <div id="stateLoading" class="flex flex-col items-center justify-center py-32 text-center">
    <div class="w-8 h-8 border-2 border-zinc-200 border-t-green-500 rounded-full animate-spin"></div>
    <p class="mt-4 text-xs text-zinc-500 font-mono uppercase tracking-widest">Loading dashboard...</p>
  </div>

  <!-- STATE: NOT LOGGED IN / NOT A CONTRACTOR -->
  <div id="stateNoAccess" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto px-4">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-red-600">// Access Denied</span>
    <h1 class="mt-4 text-2xl font-bold text-slate-900">Account not registered</h1>
    <p class="mt-3 text-sm text-slate-600">If you believe this is an error, please contact the administrator.</p>
    <a href="/login" class="mt-8 inline-flex h-12 px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-50 hover:bg-green-400 transition-all w-full sm:w-auto">Back to login</a>
  </div>

  <!-- STATE: PENDING APPROVAL -->
  <div id="statePending" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto px-4">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-amber-600">// Pending Approval</span>
    <h1 class="mt-4 text-2xl font-bold text-slate-900">Awaiting approval</h1>
    <p class="mt-3 text-sm text-slate-600">The administrator has not yet activated your account.</p>
  </div>

  <!-- STATE: ACTIVE DASHBOARD -->
  <div id="stateActive" class="hidden flex-col space-y-6 w-full">

    <div class="border-b border-slate-200 pb-7">
      <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Quick Claim Pipeline</span>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">Lead workspace</h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-500">The first contractor to claim a lead gains exclusive access. Others will see it as taken.</p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-[9px] font-bold uppercase tracking-[0.18em] text-slate-400">Available now</p>
        <p id="overviewAvailable" class="mt-3 text-3xl font-bold tabular-nums text-slate-950">-</p>
        <p class="mt-1 text-xs text-slate-500">Matched to your territory</p>
      </div>
      <div class="rounded-2xl border border-green-200 bg-gradient-to-br from-white to-green-50/70 p-5 shadow-sm">
        <p class="text-[9px] font-bold uppercase tracking-[0.18em] text-green-700">Claimed</p>
        <p id="overviewClaimed" class="mt-3 text-3xl font-bold tabular-nums text-slate-950">-</p>
        <p class="mt-1 text-xs text-slate-500">Total secured opportunities</p>
      </div>
    </div>

    <section id="panelAvailable">
      <div id="availableLeadsContainer" class="space-y-4"></div>
      <div id="noAvailableLeads" class="hidden p-8 border border-slate-200 border-dashed rounded-2xl text-center">
        <p class="text-slate-400 text-sm">No requests in your territory at the moment.</p>
      </div>
    </section>

    <section id="panelClaimed" class="hidden">
      <div id="claimedLeadsContainer" class="space-y-4"></div>
      <p id="noClaimedLeads" class="hidden text-slate-400 text-xs italic p-8 text-center border border-slate-200 border-dashed rounded-2xl">You haven't claimed any leads yet.</p>
    </section>

    <section id="panelTrucks" class="hidden">
      <div class="mb-5">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-blue-700">// Heavy job support</span>
        <h2 class="mt-2 text-xl font-bold text-slate-950">Available truck partners</h2>
        <p class="mt-1 text-sm text-slate-500">Approved equipment owners serving your territory. Contact them when a claimed job needs heavy equipment.</p>
      </div>
      <div id="recommendedTrucksContainer" class="grid gap-4 lg:grid-cols-2"></div>
      <div id="noRecommendedTrucks" class="hidden p-8 border border-slate-200 border-dashed rounded-2xl text-center text-sm text-slate-400">No approved truck partners are currently available in your territory.</div>
    </section>

    <section id="panelProfile" class="hidden">
      <!-- Sadržaj centriran na velikim ekranima: forma levo/u sredini, bitne informacije desno -->
      <div class="max-w-5xl mx-auto grid lg:grid-cols-3 gap-6 lg:gap-8 items-start">

        <!-- FORMA ZA PODATKE -->
        <div class="lg:col-span-2 relative overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
          <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-green-500 via-emerald-500 to-green-500"></div>
          <div class="p-6 sm:p-8 space-y-5">
            <div class="pb-2">
              <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Account Settings</span>
              <h2 class="mt-1 text-xl font-bold text-slate-900">Company Profile</h2>
              <p class="mt-1 text-xs text-slate-500">Keep this up to date — it's what determines which leads reach you.</p>
            </div>
            <div>
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Company Name</label>
              <input id="profileCompany" type="text" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all"/>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Contact Name</label>
                <input id="profileContact" type="text" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all"/>
              </div>
              <div>
                <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Phone</label>
                <input id="profilePhone" type="tel" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all"/>
              </div>
            </div>
            <div>
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Territory</label>
              <select id="profileTerritory" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all">
                {territories?.map((t) => <option value={t.name}>{t.name}</option>)}
              </select>
            </div>
            <div class="pt-2 border-t border-slate-100">
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Login Email</label>
              <input id="profileEmail" type="email" disabled class="h-12 w-full rounded-xl border border-slate-200 bg-slate-100 px-4 text-sm text-slate-500 outline-none cursor-not-allowed"/>
              <p class="mt-1.5 text-[10px] text-slate-400">Contact the administrator to change your login email.</p>
            </div>
            <button id="saveProfileBtn" class="h-12 w-full rounded-xl bg-green-500 text-sm font-bold text-white hover:bg-green-600 transition-all active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(34,197,94,0.4)]">Save Changes</button>
            <p id="profileMsg" class="text-[11px]"></p>
          </div>
        </div>

        <!-- BITNE INFORMACIJE (desna kolona na velikim ekranima) -->
        <aside class="space-y-4 lg:sticky lg:top-24">
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Account Status</p>
            <div class="mt-2 flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-sm font-bold text-slate-900">Active</span>
            </div>
            <p class="mt-1.5 text-xs text-slate-500 leading-relaxed">Your account is verified and currently receiving leads in your territory.</p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 mb-3">Your Activity</p>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-xs text-slate-600">Available in territory</span>
                <span id="statAvailable" class="text-sm font-mono font-bold text-slate-900">-</span>
              </div>
              <div class="flex items-center justify-between pt-3 border-t border-slate-100">
                <span class="text-xs text-slate-600">Total claimed</span>
                <span id="statClaimed" class="text-sm font-mono font-bold text-slate-900">-</span>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-green-200 bg-green-50 p-5">
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-green-700 mb-2">💡 Tip</p>
            <p class="text-xs text-green-800 leading-relaxed">Leads are matched automatically by territory — the more accurate this setting, the faster you'll see new requests.</p>
          </div>
        </aside>

      </div>
    </section>

  </div>

  <!-- TOAST NOTIFIKACIJE -->
  <div id="toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-[999] px-5 py-3 rounded-xl border text-xs font-bold uppercase tracking-wider shadow-2xl transition-all"></div>
</ContractorLayout>

<script>
  import { supabase } from "../lib/supabase";

  type AvailableLead = { id: string; county: string; details: string; created_at: string; status: string; contractor_id: string | null };
  type ClaimedLead = { id: string; county: string; phone: string; email: string | null; details: string; claimed_at: string | null; created_at: string };
  type RecommendedTruck = { truck_id: string; company_name: string | null; contact_name: string | null; phone: string | null; email: string | null; equipment_type: string; lift_capacity_tons: number | null; working_height_ft: number | null; access_type: string | null; listing_type: string | null; location: string };

  let contractorId: string | null = null;
  let pollTimer: ReturnType<typeof setInterval> | null = null;
  let knownAvailableIds = new Set<string>();

  // Menja koji panel je vidljiv. NE dispatch-uje event — samo reaguje na
  // 'layout:tab-change' (koji šalje ContractorLayout na klik, ili mi sami
  // kad treba programski da promenimo tab, npr. iz notifikacije).
  function setActiveTab(tab: 'available' | 'claimed' | 'trucks' | 'profile') {
    const panels: Record<string, HTMLElement> = {
      available: document.getElementById('panelAvailable')!,
      claimed: document.getElementById('panelClaimed')!,
      trucks: document.getElementById('panelTrucks')!,
      profile: document.getElementById('panelProfile')!,
    };
    Object.entries(panels).forEach(([key, panel]) => {
      panel.classList.toggle('hidden', key !== tab);
    });
  }

  function goToTab(tab: 'available' | 'claimed' | 'trucks' | 'profile') {
    document.dispatchEvent(new CustomEvent('layout:tab-change', { detail: { tab } }));
  }

  document.addEventListener('layout:tab-change', (e) => {
    const tab = (e as CustomEvent).detail?.tab;
    if (tab) setActiveTab(tab);
  });

  function show(id: string) {
    ['stateLoading', 'stateNoAccess', 'statePending', 'stateActive'].forEach((s) => {
      document.getElementById(s)?.classList.add('hidden');
    });
    const el = document.getElementById(id);
    el?.classList.remove('hidden');
    el?.classList.add('flex');
  }

  function toast(message: string, kind: 'success' | 'error' | 'info' = 'info') {
    const el = document.getElementById('toast');
    if (!el) return;
    const colors = {
      success: 'bg-green-50 border-green-800 text-green-700',
      error: 'bg-red-50 border-red-800 text-red-600',
      info: 'bg-zinc-100/90 border-zinc-300 text-zinc-700',
    };
    el.className = `fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] md:w-auto text-center z-[999] px-5 py-3 rounded-xl border text-[10px] md:text-xs font-bold uppercase tracking-wider shadow-2xl ${colors[kind]}`;
    el.textContent = message;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 3500);
  }

  function updateNotificationBell(availableCount: number) {
    const badge = document.getElementById('notificationBadge');
    const content = document.getElementById('notifContent');
    if (badge) {
      if (availableCount > 0) {
        badge.textContent = availableCount.toString();
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }
    if (content) {
      content.innerHTML = availableCount > 0
        ? `<button id="notifGoToAvailable" class="w-full text-left px-3 py-2.5 rounded-lg hover:bg-zinc-100 transition-colors">
             <p class="text-xs text-slate-900 font-bold">${availableCount} lead${availableCount === 1 ? '' : 's'} available</p>
             <p class="text-[10px] text-zinc-500 mt-0.5">In your territory, waiting to be claimed.</p>
           </button>`
        : `<p class="px-3 py-4 text-[11px] text-zinc-400 text-center">No new leads right now.</p>`;
      document.getElementById('notifGoToAvailable')?.addEventListener('click', () => {
        goToTab('available');
        document.getElementById('notifDropdown')?.classList.add('hidden');
      });
    }
  }

  function timeAgo(dateInput: string) {
    const diff = Math.floor((Date.now() - new Date(dateInput).getTime()) / 1000);
    if (diff < 60) return 'Just now';
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    return `${Math.floor(diff / 86400)}d ago`;
  }

  function renderAvailableLead(lead: AvailableLead) {
    const isClaimed = lead.status === 'claimed';
    const wrapper = document.createElement('div');
    wrapper.id = `avail-${lead.id}`;
    wrapper.className = `relative p-4 md:p-6 bg-white border ${isClaimed ? 'border-slate-200 opacity-70' : 'border-slate-200 shadow-sm'} rounded-2xl overflow-hidden group ${!isClaimed ? 'hover:-translate-y-0.5 hover:border-green-300 hover:shadow-md' : ''} transition-all`;
    
    // Prilagođeno za mobilne (flex-col na malim ekranima, flex-row na velikim)
    wrapper.innerHTML = `
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[9px] font-mono ${isClaimed ? 'text-zinc-500' : 'text-green-700'} uppercase tracking-widest">${lead.county}</span>
            <span class="text-[9px] font-mono text-zinc-400">// ${timeAgo(lead.created_at)}</span>
            ${isClaimed ? '<span class="px-1.5 py-0.5 bg-zinc-100 text-zinc-500 text-[8px] font-bold uppercase rounded border border-zinc-200">Taken</span>' : ''}
          </div>
          <p class="mt-3 text-sm text-slate-700 select-none blur-[6px] ${!isClaimed ? 'group-hover:blur-[5px]' : ''} transition-all max-w-md">
            ${isClaimed ? 'Another contractor has already claimed this project.' : (lead.details || 'Project description available after claiming.')}
          </p>
          <p class="mt-2 flex items-center gap-1.5 text-[10px] font-mono text-slate-500">
            🔒 Contact details locked
          </p>
        </div>
        ${!isClaimed ? `
          <button
            data-lead-id="${lead.id}"
            class="claim-btn w-full md:w-auto shrink-0 px-6 py-3 md:py-4 bg-green-500 text-slate-50 text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-green-400 transition-all active:scale-95 whitespace-nowrap"
          >
            Claim Now →
          </button>
        ` : `
          <button disabled class="w-full md:w-auto shrink-0 px-6 py-3 md:py-4 bg-zinc-100 text-zinc-400 border border-zinc-200 text-[10px] font-bold uppercase tracking-widest rounded-xl cursor-not-allowed whitespace-nowrap">
            Claimed
          </button>
        `}
      </div>
    `;

    if (!isClaimed) {
      wrapper.querySelector('.claim-btn')?.addEventListener('click', (e) => claimLead(lead.id, e.currentTarget as HTMLButtonElement));
    }
    return wrapper;
  }

  function renderClaimedLead(lead: ClaimedLead) {
    const wrapper = document.createElement('div');
    wrapper.className = 'p-4 md:p-6 bg-gradient-to-br from-white to-green-50/50 border border-green-200 rounded-2xl shadow-sm';
    wrapper.innerHTML = `
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
        <span class="text-[9px] font-mono text-green-700 uppercase tracking-widest">${lead.county}</span>
        <span class="text-[9px] text-green-600 font-bold uppercase italic">Claimed ${lead.claimed_at ? timeAgo(lead.claimed_at) : ''}</span>
      </div>
      <p class="mt-3 text-sm text-slate-700">${lead.details || ''}</p>
      <div class="mt-4 flex flex-wrap gap-3 md:gap-6 pt-4 border-t border-slate-200/50 text-[11px] font-mono">
        <a href="tel:${lead.phone}" class="text-slate-600 hover:text-green-700 flex items-center gap-2 transition-colors">
          <svg class="w-3 h-3 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span class="text-slate-900 underline decoration-dotted underline-offset-2">${lead.phone || 'N/A'}</span>
        </a>
        ${lead.email ? `
        <a href="mailto:${lead.email}" class="text-slate-600 hover:text-green-700 flex items-center gap-2 transition-colors">
          <svg class="w-3 h-3 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span class="text-slate-900 underline decoration-dotted underline-offset-2">${lead.email}</span>
        </a>` : ''}
      </div>
    `;
    return wrapper;
  }

  async function loadAvailableLeads() {
    const { data, error } = await supabase.rpc('get_available_leads');
    const container = document.getElementById('availableLeadsContainer')!;
    const empty = document.getElementById('noAvailableLeads')!;
    if (error) return;
    
    // Filtriramo lidove: ne prikazujemo u gornjoj listi one koje je OVAJ korisnik preuzeo
    // (jer oni idu u donju listu "My claimed leads")
    const leads: AvailableLead[] = (data || []).filter((l: AvailableLead) => l.contractor_id !== contractorId);
    const freshIds = new Set(leads.map((l) => l.id));

    // Uklanjanje starih
    knownAvailableIds.forEach((id) => {
      if (!freshIds.has(id)) {
        const el = document.getElementById(`avail-${id}`);
        if (el) {
          el.style.opacity = '0';
          setTimeout(() => el.remove(), 300);
        }
      }
    });

    // Dodavanje/Ažuriranje novih
    leads.forEach((lead) => {
      const existing = document.getElementById(`avail-${lead.id}`);
      if (!existing) {
        container.appendChild(renderAvailableLead(lead));
      } else if (existing && lead.status === 'claimed' && existing.innerHTML.includes('Claim Now')) {
        // Ako je lid na ekranu bio dostupan, a sad je preuzet od strane drugog - osveži karticu
        container.replaceChild(renderAvailableLead(lead), existing);
      }
    });

    knownAvailableIds = freshIds;
    empty.classList.toggle('hidden', leads.length > 0);
    updateNotificationBell(leads.length);

    const statAvailable = document.getElementById('statAvailable');
    if (statAvailable) statAvailable.textContent = leads.length.toString();
    document.getElementById('overviewAvailable')!.textContent = leads.length.toString();
  }

  async function loadClaimedLeads() {
    const { data, error } = await supabase.rpc('get_my_claimed_leads');
    if (error) return;
    
    const leads: ClaimedLead[] = (data || []).filter((l: any) => l.status === 'claimed' || l.status === 'completed');
    const container = document.getElementById('claimedLeadsContainer')!;
    const empty = document.getElementById('noClaimedLeads')!;
    
    container.innerHTML = '';
    leads.forEach((lead) => container.appendChild(renderClaimedLead(lead)));
    empty.classList.toggle('hidden', leads.length > 0);

    const statClaimed = document.getElementById('statClaimed');
    if (statClaimed) statClaimed.textContent = leads.length.toString();
    document.getElementById('overviewClaimed')!.textContent = leads.length.toString();
  }

  async function loadRecommendedTrucks() {
    const { data, error } = await supabase.rpc('get_recommended_trucks');
    if (error) return;
    const trucks: RecommendedTruck[] = data || [];
    const container = document.getElementById('recommendedTrucksContainer')!;
    const empty = document.getElementById('noRecommendedTrucks')!;
    container.innerHTML = trucks.map((truck) => `
      <article class="rounded-2xl border border-blue-200 bg-gradient-to-br from-white to-blue-50/40 p-5 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-[9px] font-bold uppercase tracking-[0.18em] text-blue-700">${truck.location}</p>
            <h3 class="mt-1 text-base font-bold text-slate-950">${truck.company_name || truck.contact_name || 'Truck partner'}</h3>
            <p class="mt-1 text-xs text-slate-500">${truck.equipment_type || 'Heavy equipment'}</p>
          </div>
          <span class="rounded-full border border-green-200 bg-green-50 px-2.5 py-1 text-[9px] font-bold uppercase text-green-700">Available</span>
        </div>
        <div class="mt-4 flex flex-wrap gap-2 text-[10px] text-slate-600">
          ${truck.lift_capacity_tons ? `<span class="rounded-lg bg-white border border-slate-200 px-2.5 py-1.5">${truck.lift_capacity_tons} ton lift</span>` : ''}
          ${truck.working_height_ft ? `<span class="rounded-lg bg-white border border-slate-200 px-2.5 py-1.5">${truck.working_height_ft} ft reach</span>` : ''}
          ${truck.access_type ? `<span class="rounded-lg bg-white border border-slate-200 px-2.5 py-1.5">${truck.access_type}</span>` : ''}
          ${truck.listing_type ? `<span class="rounded-lg bg-white border border-slate-200 px-2.5 py-1.5">${truck.listing_type}</span>` : ''}
        </div>
        <div class="mt-5 flex flex-wrap gap-2 border-t border-blue-100 pt-4">
          ${truck.phone ? `<a href="tel:${truck.phone}" class="inline-flex h-9 items-center rounded-lg bg-blue-600 px-4 text-[10px] font-bold uppercase text-white hover:bg-blue-700">Call owner</a>` : ''}
          ${truck.email ? `<a href="mailto:${truck.email}" class="inline-flex h-9 items-center rounded-lg border border-blue-200 bg-white px-4 text-[10px] font-bold uppercase text-blue-700 hover:bg-blue-50">Email</a>` : ''}
        </div>
      </article>
    `).join('');
    empty.classList.toggle('hidden', trucks.length > 0);
  }

  async function claimLead(leadId: string, btn: HTMLButtonElement) {
    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = 'CLAIMING...';

    const { data: success, error } = await supabase.rpc('claim_lead', { p_lead_id: leadId });

    if (error || !success) {
      toast('Too slow! Someone else already claimed this lead.', 'error');
      await loadAvailableLeads(); // Osveži da prebaci u status "Claimed"
    } else {
      toast('Lead successfully claimed — contact details unlocked below.', 'success');
      await Promise.all([loadAvailableLeads(), loadClaimedLeads()]); // Briše iz gornje, dodaje u donju
    }
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }

    const { data: contractor, error } = await supabase.rpc('link_contractor_account');
    if (error || !contractor) { show('stateNoAccess'); return; }

    contractorId = session.user.id;

    const nameLabel = document.getElementById('companyNameLabel');
    if (nameLabel && contractor.company_name) nameLabel.textContent = contractor.company_name;

    if (contractor.status === 'pending') { show('statePending'); return; }
    if (contractor.status !== 'active') { show('statePending'); return; }

    // Popuni formu za profil
    (document.getElementById('profileCompany') as HTMLInputElement).value = contractor.company_name || '';
    (document.getElementById('profileContact') as HTMLInputElement).value = contractor.contact_name || '';
    (document.getElementById('profilePhone') as HTMLInputElement).value = contractor.phone || '';
    (document.getElementById('profileTerritory') as HTMLSelectElement).value = contractor.territory || '';
    (document.getElementById('profileEmail') as HTMLInputElement).value = contractor.email || '';

    document.getElementById('saveProfileBtn')?.addEventListener('click', async () => {
      const msg = document.getElementById('profileMsg')!;
      const btn = document.getElementById('saveProfileBtn') as HTMLButtonElement;
      btn.disabled = true;
      msg.textContent = 'Saving...';
      msg.className = 'text-[11px] text-slate-600';

      const { error: updateError } = await supabase.from('contractors').update({
        company_name: (document.getElementById('profileCompany') as HTMLInputElement).value,
        contact_name: (document.getElementById('profileContact') as HTMLInputElement).value,
        phone: (document.getElementById('profilePhone') as HTMLInputElement).value,
        territory: (document.getElementById('profileTerritory') as HTMLSelectElement).value,
      }).eq('id', contractor.id);

      if (updateError) {
        msg.textContent = '❌ ' + updateError.message;
        msg.className = 'text-[11px] text-red-600';
      } else {
        msg.textContent = '✅ Profile updated.';
        msg.className = 'text-[11px] text-green-700';
      }
      btn.disabled = false;
    });

    show('stateActive');
    goToTab('available');
    await Promise.all([loadAvailableLeads(), loadClaimedLeads(), loadRecommendedTrucks()]);

    pollTimer = setInterval(loadAvailableLeads, 8000); // Proverava svakih 8 sekundi
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:before-swap', () => {
    if (pollTimer) clearInterval(pollTimer);
  });
</script>
