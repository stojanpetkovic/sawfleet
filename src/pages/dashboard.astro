---
import ContractorLayout from "../layouts/ContractorLayout.astro";
---

<ContractorLayout>
  <!-- STANJE: UČITAVANJE -->
  <div id="stateLoading" class="flex flex-col items-center justify-center py-32 text-center">
    <div class="w-8 h-8 border-2 border-zinc-800 border-t-green-500 rounded-full animate-spin"></div>
    <p class="mt-4 text-xs text-zinc-500 font-mono uppercase tracking-widest">Loading dashboard...</p>
  </div>

  <!-- STANJE: NIJE ULOGOVAN / NIJE KONTRAKTOR -->
  <div id="stateNoAccess" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-red-500">// Access Denied</span>
    <h1 class="mt-4 text-2xl font-bold text-white">Ovaj nalog nije registrovan kao izvođač</h1>
    <p class="mt-3 text-sm text-slate-400">Ako misliš da je ovo greška, kontaktiraj administratora da poveže tvoj email sa profilom izvođača.</p>
    <a href="/login" class="mt-8 inline-flex h-12 px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-950 hover:bg-green-400 transition-all">Nazad na login</a>
  </div>

  <!-- STANJE: NALOG ČEKA ODOBRENJE -->
  <div id="statePending" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-amber-500">// Pending Approval</span>
    <h1 class="mt-4 text-2xl font-bold text-white">Tvoj profil čeka odobrenje</h1>
    <p class="mt-3 text-sm text-slate-400">Administrator još nije aktivirao tvoj nalog. Čim bude aktivan, ovde ćeš videti dostupne lidove.</p>
  </div>

  <!-- STANJE: NALOG ODBIJEN -->
  <div id="stateRejected" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-red-500">// Account Rejected</span>
    <h1 class="mt-4 text-2xl font-bold text-white">Tvoj profil nije odobren</h1>
    <p class="mt-3 text-sm text-slate-400">Kontaktiraj administratora za više informacija.</p>
  </div>

  <!-- STANJE: AKTIVAN DASHBOARD -->
  <div id="stateActive" class="hidden flex-col space-y-12">

    <div>
      <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Quick Claim Pipeline</span>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-white sm:text-3xl">Dostupni lidovi</h1>
      <p class="mt-2 text-sm text-slate-400">Prvi izvođač koji preuzme lid jedini vidi kontakt podatke. Ostali dobijaju info da je preuzet.</p>
    </div>

    <section>
      <div id="availableLeadsContainer" class="space-y-4"></div>
      <div id="noAvailableLeads" class="hidden p-8 border border-slate-800 border-dashed rounded-2xl text-center">
        <p class="text-slate-600 text-sm">Trenutno nema novih zahteva u tvojoj teritoriji.</p>
      </div>
    </section>

    <section>
      <div class="mb-6">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-zinc-500">// My Claimed Leads</span>
        <h2 class="mt-2 text-xl font-bold text-white">Moji preuzeti lidovi</h2>
      </div>
      <div id="claimedLeadsContainer" class="space-y-4"></div>
      <p id="noClaimedLeads" class="hidden text-slate-700 text-xs italic">Još uvek nisi preuzeo nijedan lid.</p>
    </section>

  </div>

  <!-- TOAST -->
  <div id="toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-[999] px-5 py-3 rounded-xl border text-xs font-bold uppercase tracking-wider shadow-2xl"></div>
</ContractorLayout>

<script>
  import { supabase } from "../lib/supabase";

  type AvailableLead = { id: string; county: string; details: string; created_at: string };
  type ClaimedLead = { id: string; county: string; phone: string; email: string | null; details: string; claimed_at: string | null; created_at: string };

  let contractorId: string | null = null;
  let pollTimer: ReturnType<typeof setInterval> | null = null;
  let knownAvailableIds = new Set<string>();

  function show(id: string) {
    ['stateLoading', 'stateNoAccess', 'statePending', 'stateRejected', 'stateActive'].forEach((s) => {
      document.getElementById(s)?.classList.add('hidden');
    });
    const el = document.getElementById(id);
    el?.classList.remove('hidden');
    el?.classList.add('flex');
  }

  function toast(message: string, kind: 'success' | 'error' | 'info' = 'info') {
    const el = document.getElementById('toast');
    if (!el) return;
    const colors = {
      success: 'bg-green-950/80 border-green-800 text-green-400',
      error: 'bg-red-950/80 border-red-800 text-red-400',
      info: 'bg-zinc-900 border-zinc-700 text-zinc-300',
    };
    el.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[999] px-5 py-3 rounded-xl border text-xs font-bold uppercase tracking-wider shadow-2xl ${colors[kind]}`;
    el.textContent = message;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 3500);
  }

  function timeAgo(dateInput: string) {
    const diff = Math.floor((Date.now() - new Date(dateInput).getTime()) / 1000);
    if (diff < 60) return 'Upravo sada';
    if (diff < 3600) return `Pre ${Math.floor(diff / 60)} min`;
    if (diff < 86400) return `Pre ${Math.floor(diff / 3600)}h`;
    return `Pre ${Math.floor(diff / 86400)}d`;
  }

  function renderAvailableLead(lead: AvailableLead) {
    const wrapper = document.createElement('div');
    wrapper.id = `avail-${lead.id}`;
    wrapper.className = 'relative p-6 bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden group hover:border-green-500/50 transition-all';
    wrapper.innerHTML = `
      <div class="flex items-center justify-between gap-4">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2">
            <span class="text-[9px] font-mono text-green-500 uppercase tracking-widest">${lead.county}</span>
            <span class="text-[9px] font-mono text-zinc-600">// ${timeAgo(lead.created_at)}</span>
          </div>
          <p class="mt-3 text-sm text-slate-300 select-none blur-[6px] group-hover:blur-[5px] transition-all max-w-md">
            ${lead.details || 'Opis projekta dostupan nakon preuzimanja.'}
          </p>
          <p class="mt-2 flex items-center gap-1.5 text-[10px] font-mono text-slate-500">
            🔒 Kontakt podaci se otključavaju nakon preuzimanja
          </p>
        </div>
        <button
          data-lead-id="${lead.id}"
          class="claim-btn shrink-0 px-6 py-3 bg-green-500 text-slate-950 text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-green-400 transition-all active:scale-95 whitespace-nowrap"
        >
          Preuzmi →
        </button>
      </div>
    `;
    wrapper.querySelector('.claim-btn')?.addEventListener('click', (e) => claimLead(lead.id, e.currentTarget as HTMLButtonElement));
    return wrapper;
  }

  function renderClaimedLead(lead: ClaimedLead) {
    const wrapper = document.createElement('div');
    wrapper.className = 'p-6 bg-slate-950 border border-green-900/30 rounded-2xl';
    wrapper.innerHTML = `
      <div class="flex items-center justify-between">
        <span class="text-[9px] font-mono text-green-500 uppercase tracking-widest">${lead.county}</span>
        <span class="text-[9px] text-green-600 font-bold uppercase italic">Preuzeto ${lead.claimed_at ? timeAgo(lead.claimed_at) : ''}</span>
      </div>
      <p class="mt-3 text-sm text-slate-300">${lead.details || ''}</p>
      <div class="mt-4 flex flex-wrap gap-4 pt-4 border-t border-slate-800 text-[11px] font-mono">
        <span class="text-slate-400">📞 <span class="text-white">${lead.phone || 'N/A'}</span></span>
        ${lead.email ? `<span class="text-slate-400">✉️ <span class="text-white">${lead.email}</span></span>` : ''}
      </div>
    `;
    return wrapper;
  }

  async function loadAvailableLeads() {
    const { data, error } = await supabase.rpc('get_available_leads');
    const container = document.getElementById('availableLeadsContainer')!;
    const empty = document.getElementById('noAvailableLeads')!;
    if (error) {
      console.error(error);
      return;
    }
    const leads: AvailableLead[] = data || [];
    const freshIds = new Set(leads.map((l) => l.id));

    // Ukloni kartice koje su u međuvremenu preuzeli drugi
    knownAvailableIds.forEach((id) => {
      if (!freshIds.has(id)) {
        const el = document.getElementById(`avail-${id}`);
        if (el) {
          el.style.transition = 'opacity 0.3s';
          el.style.opacity = '0';
          setTimeout(() => el.remove(), 300);
          toast('Jedan lid je upravo preuzeo drugi izvođač', 'info');
        }
      }
    });

    // Dodaj nove
    leads.forEach((lead) => {
      if (!knownAvailableIds.has(lead.id)) {
        container.appendChild(renderAvailableLead(lead));
      }
    });

    knownAvailableIds = freshIds;
    empty.classList.toggle('hidden', leads.length > 0);
  }

  async function loadClaimedLeads() {
    const { data, error } = await supabase.rpc('get_my_claimed_leads');
    if (error) {
      console.error(error);
      return;
    }
    const leads: ClaimedLead[] = (data || []).filter((l: any) => l.status === 'claimed' || l.status === 'completed');
    const container = document.getElementById('claimedLeadsContainer')!;
    const empty = document.getElementById('noClaimedLeads')!;
    container.innerHTML = '';
    leads.forEach((lead) => container.appendChild(renderClaimedLead(lead)));
    empty.classList.toggle('hidden', leads.length > 0);
  }

  async function claimLead(leadId: string, btn: HTMLButtonElement) {
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = 'Preuzimam...';

    const { data, error } = await supabase.rpc('claim_lead', { p_lead_id: leadId });

    if (error || !data) {
      toast('Prekasno! Neko drugi je već preuzeo ovaj lid.', 'error');
      document.getElementById(`avail-${leadId}`)?.remove();
      knownAvailableIds.delete(leadId);
    } else {
      toast('Lid uspešno preuzet — kontakt podaci su ispod.', 'success');
      document.getElementById(`avail-${leadId}`)?.remove();
      knownAvailableIds.delete(leadId);
      await loadClaimedLeads();
    }

    btn.disabled = false;
    btn.textContent = original;
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/login';
      return;
    }

    const { data: contractor, error } = await supabase.rpc('link_contractor_account');

    if (error || !contractor) {
      show('stateNoAccess');
      return;
    }

    contractorId = session.user.id;

    const label = document.getElementById('companyNameLabel');
    if (label && contractor.company_name) label.textContent = contractor.company_name;

    if (contractor.status === 'pending') {
      show('statePending');
      return;
    }
    if (contractor.status === 'rejected') {
      show('stateRejected');
      return;
    }
    if (contractor.status !== 'active') {
      show('statePending');
      return;
    }

    show('stateActive');
    await Promise.all([loadAvailableLeads(), loadClaimedLeads()]);

    // Osveži dostupne lidove periodično da bi se videlo kad ih neko preuzme
    pollTimer = setInterval(loadAvailableLeads, 12000);
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:before-swap', () => {
    if (pollTimer) clearInterval(pollTimer);
  });
</script>
