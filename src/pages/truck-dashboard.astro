---
import ContractorLayout from "../layouts/ContractorLayout.astro";
import { supabase } from "../lib/supabase";
import { ClipboardCheck, Inbox, Truck as TruckIcon, UserCog2 } from "lucide-astro";

const { data: territories } = await supabase
  .from('service_territories')
  .select('*')
  .order('name', { ascending: true });

const navItems = [
  { label: 'Leads', tab: 'leads', icon: Inbox },
  { label: 'Applications', tab: 'applications', icon: ClipboardCheck },
  { label: 'Equipment', tab: 'equipment', icon: TruckIcon },
  { label: 'Profile', tab: 'profile', icon: UserCog2 },
];
---

<ContractorLayout companyName="Fleet Owner" homeHref="/truck-dashboard" loginHref="/truck-login" navItems={navItems} activeTab="leads">
  <!-- ADD TRUCK MODAL -->
  <div id="addTruckModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4 overflow-y-auto">
    <div class="bg-white border border-slate-200 shadow-2xl p-6 sm:p-8 rounded-2xl max-w-lg w-full my-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// New Equipment</span>
          <h2 class="mt-1 text-xl font-bold text-slate-900">Add a Truck</h2>
        </div>
        <button type="button" id="closeAddTruckModal" class="text-slate-400 hover:text-slate-900 text-xl leading-none">&times;</button>
      </div>
      <form id="addTruckForm" class="space-y-4">
        <div>
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Equipment Type</label>
          <input id="addEquipmentType" type="text" required placeholder="e.g. Knuckleboom, Grapple Saw..." class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white"/>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Lift Capacity <span class="text-slate-400">(tons)</span></label>
            <input id="addCapacity" type="number" placeholder="e.g. 35" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white"/>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Working Height <span class="text-slate-400">(ft)</span></label>
            <input id="addHeight" type="number" placeholder="e.g. 110" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white"/>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Access Type</label>
            <select id="addAccess" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white">
              <option value="Wheeled">Wheeled</option>
              <option value="Tracked">Tracked</option>
            </select>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Listing Type</label>
            <select id="addListing" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white">
              <option value="Rent">Rent</option>
              <option value="Sale">Sale</option>
            </select>
          </div>
        </div>
        <div>
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Location</label>
          <select id="addLocation" required class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white">
            <option value="" selected disabled>Select Location</option>
            {territories?.map((t) => <option value={t.name}>{t.name}</option>)}
          </select>
        </div>
        <div>
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Contact Phone for this truck</label>
          <input id="addOwnerPhone" type="tel" placeholder="(555) 000-0000" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white"/>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="cancelAddTruck" class="flex-1 h-12 rounded-xl bg-slate-100 text-slate-900 text-[10px] font-bold uppercase tracking-wider hover:bg-slate-200 transition-colors">Cancel</button>
          <button type="submit" id="addTruckSubmitBtn" class="flex-1 h-12 rounded-xl bg-green-500 text-white text-[10px] font-bold uppercase tracking-wider hover:bg-green-600 transition-colors shadow-[0_8px_24px_-6px_rgba(34,197,94,0.4)]">Add Truck</button>
        </div>
        <p id="addTruckMsg" class="text-[11px]"></p>
      </form>
    </div>
  </div>

  <!-- EDIT MODAL -->
  <div id="editTruckModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-slate-100 border border-slate-200 p-6 sm:p-8 rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
      <h2 class="text-slate-900 font-bold mb-6">Edit Equipment</h2>
      <form id="editTruckForm" class="space-y-4">
        <input type="hidden" id="editTruckId" />
        <div>
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Equipment Type</label>
          <input id="editEquipmentType" type="text" required class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500"/>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Lift Capacity (tons)</label>
            <input id="editCapacity" type="number" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500"/>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Working Height (ft)</label>
            <input id="editHeight" type="number" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500"/>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Access Type</label>
            <select id="editAccess" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500">
              <option value="Wheeled">Wheeled</option>
              <option value="Tracked">Tracked</option>
            </select>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Listing Type</label>
            <select id="editListing" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500">
              <option value="Rent">Rent</option>
              <option value="Sale">Sale</option>
            </select>
          </div>
        </div>
        <div>
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Location</label>
          <select id="editLocation" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500">
            {territories?.map((t) => <option value={t.name}>{t.name}</option>)}
          </select>
        </div>
        <div>
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Owner Phone</label>
          <input id="editOwnerPhone" type="tel" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500"/>
        </div>
        <div id="editAvailabilityWrap">
          <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Availability</label>
          <select id="editAvailability" class="h-11 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500">
            <option value="Available">Available</option>
            <option value="Unavailable">Unavailable</option>
          </select>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="closeEditTruckModal" class="flex-1 h-11 rounded-xl bg-slate-200 text-slate-900 text-[10px] font-bold uppercase tracking-wider hover:bg-slate-300 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 h-11 rounded-xl bg-green-500 text-slate-50 text-[10px] font-bold uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
        <p id="editTruckMsg" class="text-[11px]"></p>
      </form>
    </div>
  </div>

  <div id="stateLoading" class="flex flex-col items-center justify-center py-32 text-center">
    <div class="w-8 h-8 border-2 border-zinc-200 border-t-green-500 rounded-full animate-spin"></div>
    <p class="mt-4 text-xs text-zinc-500 font-mono uppercase tracking-widest">Loading your listings...</p>
  </div>

  <div id="stateNoAccess" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto px-4">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-red-600">// Access Denied</span>
    <h1 class="mt-4 text-2xl font-bold text-slate-900">Something went wrong</h1>
    <p class="mt-3 text-sm text-slate-600">We couldn't load your fleet owner account. Try logging in again.</p>
    <a href="/truck-login" class="mt-8 inline-flex h-12 px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-50 hover:bg-green-400 transition-all w-full sm:w-auto">Back to login</a>
  </div>

  <!-- STATE: PENDING APPROVAL (nalog vlasnika još nije odobren) -->
  <div id="statePending" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto px-4">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-amber-600">// Pending Approval</span>
    <h1 class="mt-4 text-2xl font-bold text-slate-900">Awaiting approval</h1>
    <p class="mt-3 text-sm text-slate-600">The administrator hasn't activated your fleet owner account yet. You'll be able to add trucks as soon as you're approved.</p>
  </div>

  <!-- STATE: REJECTED -->
  <div id="stateRejected" class="hidden flex-col items-center justify-center py-32 text-center max-w-md mx-auto px-4">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-red-600">// Account Rejected</span>
    <h1 class="mt-4 text-2xl font-bold text-slate-900">Account not approved</h1>
    <p class="mt-3 text-sm text-slate-600">Your fleet owner account wasn't approved. Contact the administrator for details.</p>
  </div>

  <div id="stateActive" class="hidden flex-col space-y-6 w-full">

    <div id="panelLeads" class="space-y-6">
      <div class="border-b border-slate-200 pb-7">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-blue-700">// Equipment opportunities</span>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">Lead workspace</h1>
        <p class="mt-2 max-w-2xl text-sm text-slate-500">Jobs in territories covered by your approved, available trucks. Apply to offer equipment support.</p>
      </div>
      <div id="truckStatsGrid" class="grid grid-cols-2 gap-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"><p class="text-[9px] font-bold uppercase tracking-[0.18em] text-slate-400">Available</p><p id="truckLeadCount" class="mt-3 text-3xl font-bold tabular-nums text-slate-950">-</p></div>
        <div class="rounded-2xl border border-blue-200 bg-blue-50/50 p-5 shadow-sm"><p class="text-[9px] font-bold uppercase tracking-[0.18em] text-blue-700">Applied</p><p id="truckApplicationCount" class="mt-3 text-3xl font-bold tabular-nums text-slate-950">-</p></div>
        <div id="truckCreditsCard" class="hidden rounded-2xl border border-green-200 bg-green-50/50 p-5 shadow-sm"><p class="text-[9px] font-bold uppercase tracking-[0.18em] text-green-700">Credits</p><p id="truckCreditBalance" class="mt-3 text-3xl font-bold tabular-nums text-slate-950">-</p></div>
      </div>
      <div id="truckLeadsContainer" class="space-y-4"></div>
      <div id="noTruckLeads" class="hidden rounded-2xl border border-dashed border-slate-300 p-10 text-center text-sm text-slate-400">No matching leads are available right now.</div>
    </div>

    <div id="panelApplications" class="hidden space-y-6">
      <div><span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-blue-700">// Your responses</span><h2 class="mt-2 text-2xl font-bold text-slate-950">Lead applications</h2><p class="mt-1 text-sm text-slate-500">Track equipment support offers submitted from this account.</p></div>
      <div id="truckApplicationsContainer" class="space-y-4"></div>
      <div id="noTruckApplications" class="hidden rounded-2xl border border-dashed border-slate-300 p-10 text-center text-sm text-slate-400">You have not applied to any leads yet.</div>
    </div>

    <!-- PANEL: EQUIPMENT -->
    <div id="panelEquipment" class="hidden space-y-6">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 border-b border-slate-200 pb-7">
        <div>
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-blue-700">// Fleet workspace</span>
          <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">Your equipment</h1>
          <p class="mt-2 text-sm text-slate-500">Manage listings and monitor their approval and availability status.</p>
        </div>
        <button id="openAddTruckModal" class="shrink-0 flex items-center justify-center gap-2 h-12 px-6 rounded-xl bg-green-500 text-white text-xs font-bold uppercase tracking-wider hover:bg-green-600 transition-all active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(34,197,94,0.4)]">
          <span class="text-lg leading-none">+</span> Add Truck
        </button>
      </div>

      <!-- QUICK STATS -->
      <div class="grid grid-cols-3 gap-3">
        <div class="p-5 bg-white border border-slate-200 rounded-2xl text-left shadow-sm">
          <p id="statTotal" class="text-2xl font-mono font-bold text-slate-900">0</p>
          <p class="text-[9px] font-bold uppercase tracking-wider text-slate-500 mt-1">Total</p>
        </div>
        <div class="p-5 bg-gradient-to-br from-white to-green-50/70 border border-green-200 rounded-2xl text-left shadow-sm">
          <p id="statApproved" class="text-2xl font-mono font-bold text-green-700">0</p>
          <p class="text-[9px] font-bold uppercase tracking-wider text-slate-500 mt-1">Approved</p>
        </div>
        <div class="p-5 bg-gradient-to-br from-white to-amber-50/70 border border-amber-200 rounded-2xl text-left shadow-sm">
          <p id="statPending" class="text-2xl font-mono font-bold text-amber-600">0</p>
          <p class="text-[9px] font-bold uppercase tracking-wider text-slate-500 mt-1">Pending</p>
        </div>
      </div>

      <div id="trucksContainer" class="space-y-4"></div>
    </div>

    <!-- PANEL: PROFILE (generalije vlasnika) -->
    <div id="panelProfile" class="hidden max-w-2xl space-y-6">
      <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-green-500 via-emerald-500 to-green-500"></div>
        <div class="p-6 sm:p-8 space-y-5">
          <div class="pb-2">
            <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Account Settings</span>
            <h2 class="mt-1 text-xl font-bold text-slate-900">Company Profile</h2>
            <p class="mt-1 text-xs text-slate-500">Keep this up to date — it's what dispatch and admin see for your account.</p>
          </div>
          <form id="profileForm" class="space-y-5">
            <div>
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Company Name</label>
              <input id="profileCompany" type="text" placeholder="e.g. South Florida Heavy Equipment" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all"/>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Contact Name</label>
                <input id="profileContact" type="text" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all"/>
              </div>
              <div>
                <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Phone</label>
                <input id="profilePhone" type="tel" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white transition-all"/>
              </div>
            </div>
            <div class="pt-2 border-t border-slate-100">
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Login Email</label>
              <input id="profileEmail" type="email" disabled class="h-12 w-full rounded-xl border border-slate-200 bg-slate-100 px-4 text-sm text-slate-500 outline-none cursor-not-allowed"/>
              <p class="mt-1.5 text-[10px] text-slate-400">Contact the administrator to change your login email.</p>
            </div>
            <button type="submit" id="saveProfileBtn" class="h-12 w-full rounded-xl bg-green-500 text-sm font-bold text-white hover:bg-green-600 transition-all active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(34,197,94,0.4)]">Save Changes</button>
            <p id="profileMsg" class="text-[11px]"></p>
          </form>
        </div>
      </div>

      <!-- CREDITS -->
      <div id="creditsCard" class="hidden relative overflow-hidden rounded-2xl border border-emerald-200 bg-gradient-to-br from-white to-emerald-50/60 shadow-soft">
        <div class="p-6 sm:p-8">
          <div class="flex items-center justify-between">
            <div>
              <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-emerald-700">// Credits</span>
              <h2 class="mt-1 text-xl font-bold text-slate-900">Credit balance</h2>
            </div>
            <span class="text-[9px] font-bold uppercase tracking-wider text-emerald-600/70">$1 = 1 credit</span>
          </div>
          <p id="profileCreditBalance" class="mt-3 text-4xl font-bold tabular-nums text-slate-950">$-</p>
          <p class="mt-1 text-xs text-slate-500">Spent automatically each time you apply for a job.</p>

          <div id="creditPendingNotice" class="hidden mt-5 rounded-xl border border-amber-200 bg-amber-50 p-3">
            <p class="text-[11px] font-bold text-amber-800">Request pending</p>
            <p id="creditPendingText" class="mt-1 text-[11px] text-amber-700 leading-relaxed"></p>
          </div>

          <form id="creditRequestForm" class="mt-5 grid gap-3 sm:grid-cols-2">
            <input id="creditRequestAmount" type="number" min="1" step="1" placeholder="Amount requested ($, optional)" class="h-11 w-full rounded-xl border border-emerald-200 bg-white px-4 text-sm text-slate-900 outline-none focus:border-emerald-500" />
            <input id="creditRequestNote" type="text" placeholder="Note (optional)" class="h-11 w-full rounded-xl border border-emerald-200 bg-white px-4 text-sm text-slate-900 outline-none focus:border-emerald-500" />
            <button id="creditRequestBtn" type="submit" class="h-11 w-full rounded-xl bg-emerald-600 text-xs font-bold uppercase tracking-wider text-white hover:bg-emerald-500 transition-all sm:col-span-2">Request more credit</button>
          </form>
          <p id="creditRequestMsg" class="mt-2 text-[11px]"></p>

          <p class="mt-5 border-t border-emerald-100 pt-3 text-[10px] text-emerald-700/70 leading-relaxed">💳 Buying credit online is coming soon — for now, requests are reviewed by the administrator.</p>
        </div>
      </div>
    </div>

  </div>
</ContractorLayout>

<script>
  import { supabase } from "../lib/supabase";

  type Truck = {
    id: string; equipment_type: string; lift_capacity_tons: number; working_height_ft: number;
    location: string; approval_status: string; availability_status: string; created_at: string;
    access_type?: string; listing_type?: string; owner_phone?: string;
  };
  type TruckLead = { id: string; county: string; details: string | null; source: string; created_at: string; application_status: string | null };
  let ownerTrucks: Truck[] = [];
  let truckLeadPoll: ReturnType<typeof setInterval> | null = null;

  function show(id: string) {
    ['stateLoading', 'stateNoAccess', 'statePending', 'stateRejected', 'stateActive'].forEach((s) => document.getElementById(s)?.classList.add('hidden'));
    const el = document.getElementById(id);
    el?.classList.remove('hidden');
    el?.classList.add('flex');
  }

  function showTab(tab: 'leads' | 'applications' | 'equipment' | 'profile') {
    document.getElementById('panelLeads')?.classList.toggle('hidden', tab !== 'leads');
    document.getElementById('panelApplications')?.classList.toggle('hidden', tab !== 'applications');
    document.getElementById('panelEquipment')?.classList.toggle('hidden', tab !== 'equipment');
    document.getElementById('panelProfile')?.classList.toggle('hidden', tab !== 'profile');
  }
  document.addEventListener('layout:tab-change', (e) => {
    const tab = (e as CustomEvent).detail?.tab;
    if (tab === 'leads' || tab === 'applications' || tab === 'equipment' || tab === 'profile') showTab(tab);
  });

  function renderTruck(t: Truck) {
    const status = t.approval_status || 'pending';
    const badge = status === 'approved' ? 'bg-green-500/10 border-green-500/20 text-green-700' :
                  status === 'rejected' ? 'bg-red-500/10 border-red-500/20 text-red-600' :
                  'bg-amber-500/10 border-amber-500/20 text-amber-600';
    const wrapper = document.createElement('div');
    wrapper.className = 'p-5 sm:p-6 bg-white border border-slate-200 rounded-2xl shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md';
    wrapper.innerHTML = `
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="text-slate-900 font-bold truncate">${t.equipment_type || 'Equipment'}</p>
          <p class="mt-1 text-[11px] font-mono text-slate-500">${[t.location, t.lift_capacity_tons ? t.lift_capacity_tons + ' tons' : '', t.working_height_ft ? t.working_height_ft + ' ft' : ''].filter(Boolean).join(' · ')}</p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <span class="px-2.5 py-1 rounded-md text-[9px] font-bold uppercase border tracking-wider ${badge}">${status}</span>
          <button class="edit-truck-btn w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-slate-900 hover:bg-zinc-200 transition-colors" title="Edit">✏️</button>
        </div>
      </div>
      ${status === 'approved' ? `<p class="mt-3 pt-3 border-t border-slate-200/50 text-[11px] text-slate-600">Availability: <span class="text-slate-900 font-bold">${t.availability_status || 'Available'}</span></p>` : ''}
      ${status === 'pending' ? `<p class="mt-3 pt-3 border-t border-slate-200/50 text-[11px] text-slate-500">Waiting for administrator review.</p>` : ''}
      ${status === 'rejected' ? `<p class="mt-3 pt-3 border-t border-slate-200/50 text-[11px] text-slate-500">This listing wasn't approved. Contact the administrator for details.</p>` : ''}
    `;
    wrapper.querySelector('.edit-truck-btn')?.addEventListener('click', () => openEditModal(t));
    return wrapper;
  }

  function renderTruckLead(lead: TruckLead) {
    const applied = !!lead.application_status && lead.application_status !== 'withdrawn';
    const eligibleTrucks = ownerTrucks.filter((truck) =>
      truck.approval_status === 'approved' &&
      (truck.availability_status || 'Available').toLowerCase() === 'available' &&
      truck.location?.trim().toLowerCase() === lead.county?.trim().toLowerCase()
    );
    const wrapper = document.createElement('article');
    wrapper.className = 'rounded-2xl border border-slate-200 bg-white p-5 shadow-sm';
    wrapper.innerHTML = `
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-2"><span class="text-[9px] font-bold uppercase tracking-[0.18em] text-blue-700">${lead.county}</span><span class="text-[9px] text-slate-400">${new Date(lead.created_at).toLocaleDateString()}</span></div>
          <p class="mt-3 max-w-xl select-none text-sm text-slate-600 blur-[5px]">${lead.details || 'Project details available through dispatch.'}</p>
          <p class="mt-2 text-[10px] text-slate-400">🔒 Homeowner contact remains protected. Applying alerts dispatch that your equipment is available.</p>
        </div>
        <div class="w-full shrink-0 space-y-2 sm:w-56">
          ${applied
            ? `<div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-center text-[10px] font-bold uppercase text-blue-700">Application ${lead.application_status}</div>`
            : `<select class="truck-choice h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-[11px]" aria-label="Select equipment">
                ${eligibleTrucks.map((truck) => `<option value="${truck.id}">${truck.equipment_type}</option>`).join('')}
              </select>
              <button class="apply-truck-lead h-11 w-full rounded-xl bg-blue-600 text-[10px] font-bold uppercase tracking-wider text-white hover:bg-blue-700" data-lead-id="${lead.id}">Apply for job</button>`
          }
        </div>
      </div>
    `;
    wrapper.querySelector('.apply-truck-lead')?.addEventListener('click', async (event) => {
      const button = event.currentTarget as HTMLButtonElement;
      const truckId = (wrapper.querySelector('.truck-choice') as HTMLSelectElement)?.value || null;
      button.disabled = true;
      button.textContent = 'Applying…';
      const message = window.prompt('Optional note for dispatch about availability or equipment:') || '';
      const { error } = await supabase.rpc('apply_for_truck_lead', { p_lead_id: lead.id, p_truck_id: truckId, p_message: message });
      if (error) {
        alert(error.message?.includes('insufficient_credits')
          ? 'Not enough credit balance ($) to apply for this job — contact the administrator to top up.'
          : 'Could not apply: ' + error.message);
        button.disabled = false;
        button.textContent = 'Apply for job';
        return;
      }
      await loadTruckLeads();
      await refreshCreditBalance();
    });
    return wrapper;
  }

  async function loadTruckLeads() {
    const { data, error } = await supabase.rpc('get_available_truck_leads');
    if (error) return;
    const leads: TruckLead[] = data || [];
    const available = leads.filter((lead) => !lead.application_status || lead.application_status === 'withdrawn');
    const applied = leads.filter((lead) => !!lead.application_status && lead.application_status !== 'withdrawn');
    const leadContainer = document.getElementById('truckLeadsContainer')!;
    const applicationContainer = document.getElementById('truckApplicationsContainer')!;
    leadContainer.innerHTML = '';
    available.forEach((lead) => leadContainer.appendChild(renderTruckLead(lead)));
    applicationContainer.innerHTML = '';
    applied.forEach((lead) => applicationContainer.appendChild(renderTruckLead(lead)));
    document.getElementById('noTruckLeads')?.classList.toggle('hidden', available.length > 0);
    document.getElementById('noTruckApplications')?.classList.toggle('hidden', applied.length > 0);
    document.getElementById('truckLeadCount')!.textContent = available.length.toString();
    document.getElementById('truckApplicationCount')!.textContent = applied.length.toString();
    updateFleetNotifications(available.length);
  }

  async function updateFleetNotifications(leadCount: number) {
    const pendingCount = ownerTrucks.filter((truck) => truck.approval_status !== 'approved' && truck.approval_status !== 'rejected').length;

    let creditNotices: { id: string; status: string }[] = [];
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      const { data } = await supabase
        .from('credit_requests')
        .select('id, status')
        .eq('account_type', 'truck_owner')
        .eq('account_id', session.user.id)
        .in('status', ['fulfilled', 'dismissed'])
        .eq('seen_by_requester', false);
      creditNotices = data || [];
    }

    const total = leadCount + pendingCount + creditNotices.length;
    const badge = document.getElementById('notificationBadge');
    const content = document.getElementById('notifContent');
    badge?.classList.toggle('hidden', total === 0);
    if (badge) badge.textContent = total.toString();
    if (content) {
      const creditHtml = creditNotices.map((notice) => `
        <button class="notif-credit-item w-full rounded-lg px-3 py-2.5 text-left hover:bg-slate-50" data-id="${notice.id}">
          <p class="text-xs font-bold text-slate-900">${notice.status === 'fulfilled' ? '✅ Credit request approved' : 'Credit request declined'}</p>
          <p class="mt-0.5 text-[10px] text-slate-500">${notice.status === 'fulfilled' ? 'Your balance has been topped up.' : 'Contact the administrator for details.'}</p>
        </button>
      `).join('');
      content.innerHTML = `${leadCount ? `<button id="goToTruckLeads" class="w-full rounded-lg px-3 py-2.5 text-left hover:bg-slate-50"><p class="text-xs font-bold text-slate-900">${leadCount} matching lead${leadCount === 1 ? '' : 's'}</p><p class="mt-0.5 text-[10px] text-slate-500">Available for equipment applications.</p></button>` : ''}${pendingCount ? `<div class="px-3 py-2.5"><p class="text-xs font-bold text-slate-900">${pendingCount} listing${pendingCount === 1 ? '' : 's'} pending</p></div>` : ''}${creditHtml}` || '<p class="px-3 py-4 text-center text-[11px] text-slate-400">All caught up.</p>';
      document.getElementById('goToTruckLeads')?.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('layout:tab-change', { detail: { tab: 'leads' } }));
        document.getElementById('notifDropdown')?.classList.add('hidden');
      });
      content.querySelectorAll<HTMLButtonElement>('.notif-credit-item').forEach((btn) => {
        btn.addEventListener('click', async () => {
          document.getElementById('notifDropdown')?.classList.add('hidden');
          document.dispatchEvent(new CustomEvent('layout:tab-change', { detail: { tab: 'profile' } }));
          await supabase.from('credit_requests').update({ seen_by_requester: true }).eq('id', btn.dataset.id);
          await refreshCreditBalance();
        });
      });
    }
  }

  function openEditModal(t: Truck & { access_type?: string; listing_type?: string; owner_phone?: string }) {
    (document.getElementById('editTruckId') as HTMLInputElement).value = t.id;
    (document.getElementById('editEquipmentType') as HTMLInputElement).value = t.equipment_type || '';
    (document.getElementById('editCapacity') as HTMLInputElement).value = (t.lift_capacity_tons ?? '') as string;
    (document.getElementById('editHeight') as HTMLInputElement).value = (t.working_height_ft ?? '') as string;
    (document.getElementById('editAccess') as HTMLSelectElement).value = t.access_type || 'Wheeled';
    (document.getElementById('editListing') as HTMLSelectElement).value = t.listing_type || 'Rent';
    (document.getElementById('editLocation') as HTMLSelectElement).value = t.location || '';
    (document.getElementById('editOwnerPhone') as HTMLInputElement).value = t.owner_phone || '';
    (document.getElementById('editAvailability') as HTMLSelectElement).value = t.availability_status || 'Available';

    const availWrap = document.getElementById('editAvailabilityWrap')!;
    availWrap.classList.toggle('hidden', t.approval_status !== 'approved');

    document.getElementById('editTruckMsg')!.textContent = '';
    document.getElementById('editTruckModal')?.classList.remove('hidden');
  }

  let ownerHadNoRow = false;

  async function refreshCreditBalance() {
    const card = document.getElementById('truckCreditsCard');
    const grid = document.getElementById('truckStatsGrid');
    const label = document.getElementById('truckCreditBalance');
    const profileCard = document.getElementById('creditsCard');
    const profileLabel = document.getElementById('profileCreditBalance');
    if (!card || !grid || !label) return;
    const { data: enabled } = await supabase.rpc('is_credit_system_enabled');
    if (!enabled) {
      card.classList.add('hidden'); grid.classList.remove('grid-cols-3'); grid.classList.add('grid-cols-2');
      profileCard?.classList.add('hidden');
      return;
    }
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    const { data: o } = await supabase.from('truck_owners').select('credit_balance').eq('id', session.user.id).maybeSingle();
    const balanceText = `$${o?.credit_balance ?? 0}`;
    label.textContent = balanceText;
    if (profileLabel) profileLabel.textContent = balanceText;
    card.classList.remove('hidden');
    grid.classList.remove('grid-cols-2');
    grid.classList.add('grid-cols-3');
    profileCard?.classList.remove('hidden');

    await refreshPendingCreditRequest(session.user.id);
  }

  async function refreshPendingCreditRequest(ownerId: string) {
    const notice = document.getElementById('creditPendingNotice');
    const noticeText = document.getElementById('creditPendingText');
    const form = document.getElementById('creditRequestForm');
    if (!notice || !noticeText || !form) return;

    const { data: pending } = await supabase
      .from('credit_requests')
      .select('requested_amount, created_at')
      .eq('account_type', 'truck_owner')
      .eq('account_id', ownerId)
      .eq('status', 'pending')
      .order('created_at', { ascending: false })
      .maybeSingle();

    if (pending) {
      noticeText.textContent = pending.requested_amount
        ? `You requested $${pending.requested_amount} on ${new Date(pending.created_at).toLocaleDateString()} — waiting for admin review.`
        : `Sent on ${new Date(pending.created_at).toLocaleDateString()} — waiting for admin review.`;
      notice.classList.remove('hidden');
      form.classList.add('hidden');
    } else {
      notice.classList.add('hidden');
      form.classList.remove('hidden');
    }
  }

  document.getElementById('creditRequestForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    const btn = document.getElementById('creditRequestBtn') as HTMLButtonElement;
    const msg = document.getElementById('creditRequestMsg')!;
    const amountInput = document.getElementById('creditRequestAmount') as HTMLInputElement;
    const noteInput = document.getElementById('creditRequestNote') as HTMLInputElement;
    const requested_amount = amountInput.value ? Number(amountInput.value) : null;
    const note = noteInput.value.trim() || null;

    btn.disabled = true;
    btn.textContent = 'Sending...';
    try {
      const { data: inserted, error } = await supabase
        .from('credit_requests')
        .insert([{ account_type: 'truck_owner', account_id: session.user.id, requested_amount, note, status: 'pending' }])
        .select('id')
        .single();
      if (error || !inserted) throw error || new Error('insert_failed');

      await fetch('/api/notify-credit-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ requestId: inserted.id }),
      }).catch(() => {});

      msg.textContent = '✅ Request sent — the administrator will review it shortly.';
      msg.className = 'mt-2 text-[11px] text-green-700';
      amountInput.value = '';
      noteInput.value = '';
      await refreshPendingCreditRequest(session.user.id);
    } catch (err) {
      msg.textContent = '❌ Could not send request. Please try again.';
      msg.className = 'mt-2 text-[11px] text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Request more credit';
    }
  });

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/truck-login'; return; }

    // Prvo proveri profil/status vlasnika. Ako nalog nije odobren, ne
    // učitavamo kamione uopšte — samo obaveštavamo vlasnika o statusu.
    const { data: owner, error: ownerError } = await supabase
      .from('truck_owners')
      .select('*')
      .eq('id', session.user.id)
      .maybeSingle();

    if (ownerError) {
      show('stateNoAccess');
      return;
    }

    if (owner) {
      (document.getElementById('profileCompany') as HTMLInputElement).value = owner.company_name || '';
      (document.getElementById('profileContact') as HTMLInputElement).value = owner.contact_name || '';
      (document.getElementById('profilePhone') as HTMLInputElement).value = owner.phone || '';
      (document.getElementById('profileEmail') as HTMLInputElement).value = owner.email || session.user.email || '';

      if (owner.status === 'pending') { show('statePending'); return; }
      if (owner.status === 'rejected') { show('stateRejected'); return; }
      refreshCreditBalance();
    } else {
      // Nema truck_owners reda (npr. nalog napravljen pre ove migracije) —
      // ne blokiramo, samo popuni email iz sesije.
      ownerHadNoRow = true;
      (document.getElementById('profileEmail') as HTMLInputElement).value = session.user.email || '';
    }

    const { data: trucks, error } = await supabase.rpc('link_truck_owner_account');

    // Samo prava greška vodi na "Access Denied". Prazna lista (npr. tek
    // registrovan vlasnik koji još nije dodao nijedan kamion) je validno
    // stanje — pokazujemo prazan dashboard sa pozivom da doda prvi kamion.
    if (error) {
      show('stateNoAccess');
      return;
    }

    const list: Truck[] = trucks || [];
    ownerTrucks = list;
    const pendingCount = list.filter((t) => t.approval_status !== 'approved' && t.approval_status !== 'rejected').length;
    document.getElementById('statTotal')!.textContent = list.length.toString();
    document.getElementById('statApproved')!.textContent = list.filter((t) => t.approval_status === 'approved').length.toString();
    document.getElementById('statPending')!.textContent = pendingCount.toString();

    const container = document.getElementById('trucksContainer')!;
    container.innerHTML = '';
    if (list.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'p-10 border border-dashed border-slate-300 rounded-2xl text-center';
      empty.innerHTML = `
        <p class="text-sm font-bold text-slate-900">You haven't added any trucks yet</p>
        <p class="mt-1.5 text-xs text-slate-500">List your first piece of equipment to start receiving dispatches.</p>
        <button id="emptyStateAddTruckBtn" class="mt-5 inline-flex items-center gap-2 h-11 px-6 rounded-xl bg-green-500 text-white text-xs font-bold uppercase tracking-wider hover:bg-green-600 transition-all">+ Add Your First Truck</button>
      `;
      container.appendChild(empty);
      document.getElementById('emptyStateAddTruckBtn')?.addEventListener('click', openAddTruckModal);
    } else {
      list.forEach((t) => container.appendChild(renderTruck(t)));
    }
    await loadTruckLeads();
    showTab('leads');
    show('stateActive');
    if (truckLeadPoll) clearInterval(truckLeadPoll);
    truckLeadPoll = setInterval(loadTruckLeads, 8000);
  }

  // -- DODAVANJE NOVOG KAMIONA --
  function openAddTruckModal() {
    (document.getElementById('addTruckForm') as HTMLFormElement).reset();
    document.getElementById('addTruckMsg')!.textContent = '';
    document.getElementById('addTruckModal')?.classList.remove('hidden');
  }
  function closeAddTruckModal() {
    document.getElementById('addTruckModal')?.classList.add('hidden');
  }

  document.getElementById('openAddTruckModal')?.addEventListener('click', openAddTruckModal);
  document.getElementById('cancelAddTruck')?.addEventListener('click', closeAddTruckModal);
  document.getElementById('closeAddTruckModal')?.addEventListener('click', closeAddTruckModal);

  document.getElementById('addTruckForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('addTruckMsg')!;
    const submitBtn = document.getElementById('addTruckSubmitBtn') as HTMLButtonElement;
    submitBtn.disabled = true;
    msg.textContent = 'Saving...';
    msg.className = 'text-[11px] text-slate-600';

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      msg.textContent = 'Your session expired — please log in again.';
      msg.className = 'text-[11px] text-red-600';
      submitBtn.disabled = false;
      return;
    }

    const { error } = await supabase.from('grapple_saw_trucks').insert([{
      equipment_type: (document.getElementById('addEquipmentType') as HTMLInputElement).value,
      lift_capacity_tons: (document.getElementById('addCapacity') as HTMLInputElement).value || null,
      working_height_ft: (document.getElementById('addHeight') as HTMLInputElement).value || null,
      access_type: (document.getElementById('addAccess') as HTMLSelectElement).value,
      listing_type: (document.getElementById('addListing') as HTMLSelectElement).value,
      location: (document.getElementById('addLocation') as HTMLSelectElement).value,
      owner_phone: (document.getElementById('addOwnerPhone') as HTMLInputElement).value,
      owner_email: session.user.email,
      owner_user_id: session.user.id,
      approval_status: 'pending',
      availability_status: 'Available',
    }]);

    submitBtn.disabled = false;

    if (error) {
      msg.textContent = '❌ ' + error.message;
      msg.className = 'text-[11px] text-red-600';
      return;
    }

    closeAddTruckModal();
    await init();
  });

  document.getElementById('closeEditTruckModal')?.addEventListener('click', () => {
    document.getElementById('editTruckModal')?.classList.add('hidden');
  });

  document.getElementById('editTruckForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('editTruckMsg')!;
    const truckId = (document.getElementById('editTruckId') as HTMLInputElement).value;
    msg.textContent = 'Saving...';
    msg.className = 'text-[11px] text-slate-600';

    const availWrap = document.getElementById('editAvailabilityWrap')!;
    const updates: Record<string, unknown> = {
      equipment_type: (document.getElementById('editEquipmentType') as HTMLInputElement).value,
      lift_capacity_tons: (document.getElementById('editCapacity') as HTMLInputElement).value || null,
      working_height_ft: (document.getElementById('editHeight') as HTMLInputElement).value || null,
      access_type: (document.getElementById('editAccess') as HTMLSelectElement).value,
      listing_type: (document.getElementById('editListing') as HTMLSelectElement).value,
      location: (document.getElementById('editLocation') as HTMLSelectElement).value,
      owner_phone: (document.getElementById('editOwnerPhone') as HTMLInputElement).value,
    };
    if (!availWrap.classList.contains('hidden')) {
      updates.availability_status = (document.getElementById('editAvailability') as HTMLSelectElement).value;
    }

    const { error } = await supabase.from('grapple_saw_trucks').update(updates).eq('id', truckId);

    if (error) {
      msg.textContent = '❌ ' + error.message;
      msg.className = 'text-[11px] text-red-600';
      return;
    }

    document.getElementById('editTruckModal')?.classList.add('hidden');
    await init();
  });

  document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('profileMsg')!;
    const saveBtn = document.getElementById('saveProfileBtn') as HTMLButtonElement;
    saveBtn.disabled = true;
    msg.textContent = 'Saving...';
    msg.className = 'text-[11px] text-slate-600';

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      msg.textContent = 'Your session expired — please log in again.';
      msg.className = 'text-[11px] text-red-600';
      saveBtn.disabled = false;
      return;
    }

    const { error } = await supabase.from('truck_owners').upsert({
      id: session.user.id,
      email: session.user.email,
      company_name: (document.getElementById('profileCompany') as HTMLInputElement).value || null,
      contact_name: (document.getElementById('profileContact') as HTMLInputElement).value || null,
      phone: (document.getElementById('profilePhone') as HTMLInputElement).value || null,
      // Ako ovo tek SADA pravi red (nalog iz vremena pre nego što je
      // odobravanje uvedeno), ne blokiramo retroaktivno nekoga ko je već
      // imao pristup dashboard-u — samo update ne bi ni pipnuo status,
      // ali upsert bez ovoga bi upisao default 'pending' pri prvom insertu.
      ...(ownerHadNoRow ? { status: 'approved' } : {}),
    }, { onConflict: 'id' });

    saveBtn.disabled = false;

    if (error) {
      msg.textContent = '❌ ' + error.message;
      msg.className = 'text-[11px] text-red-600';
      return;
    }

    msg.textContent = '✅ Saved.';
    msg.className = 'text-[11px] text-green-700';
  });

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:before-swap', () => {
    if (truckLeadPoll) clearInterval(truckLeadPoll);
  });
</script>
