---
import MainLayout from "../layouts/MainLayout.astro";

import Header from "../components/layout/Header.astro";
import MobileNav from "../components/layout/MobileNav.astro";
import Footer from "../components/layout/Footer.astro"; // Uvezen Footer

// Postojeće komponente
import Hero from "../components/home/Hero/Hero.astro";

// Nove premium komponente dodate u Home folder
import HomeownerSpecs from "../components/home/HomeownerSpecs.astro";
import TrustCompliance from "../components/home/TrustCompliance.astro";
---

<MainLayout
  title="SawFleet | Find Trusted Tree Service Professionals"
  description="Connect homeowners with trusted local tree service professionals across South Florida.">

  <Header />

  <main>

    <!-- Hero (Sadrži Homeowner/Contractor tekst i formu) -->
    <Hero />

    <!-- Homeowner Specs (Usluge, gradovi u South Florida i Anti-Spam protokol) -->
    <HomeownerSpecs />

    <!-- Trust & Compliance (Osiguranje i licence) -->
    <TrustCompliance />

  </main>

  <!-- Univerzalni Footer -->
  <Footer />

  <!-- Mobile Bottom Navigation -->
  <MobileNav />

</MainLayout>