---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import MobileNav from "../components/layout/MobileNav.astro";
import Footer from "../components/layout/Footer.astro";
import { supabase } from "../lib/supabase";

// 1. Učitavamo teritorije iz baze za formu
const { data: territories } = await supabase
  .from('service_territories')
  .select('*')
  .order('name', { ascending: true });
---

<MainLayout
  title="SawFleet | Find Trusted Tree Service Professionals"
  description="Connect homeowners with trusted local tree service professionals across South Florida.">

  <Header />

  <!-- POZADINA JE SADA ČISTO CRNA -->
  <main class="bg-[#000000]">

    <!-- ============================================== -->
    <!-- 1. HERO SEKCIJA SA FORMOM -->
    <!-- ============================================== -->
    <section class="relative pt-32 pb-16 px-4 sm:px-8">
      <!-- Glow u pozadini -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[400px] bg-green-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="mx-auto max-w-[1320px] grid lg:grid-cols-2 gap-12 items-center relative z-10">
        
        <!-- LEVO: Tekstualni deo (Editorial Heading) -->
        <div class="max-w-[640px] font-sans selection:bg-green-500/30 selection:text-white">
          <!-- Premium Minimal Badge (Slate) -->
          <div class="inline-flex items-center gap-2 rounded-md border border-slate-700 bg-slate-800 px-3 py-1.5 shadow-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-300">
              Serving South Florida
            </span>
          </div>

          <!-- Editorial Heading -->
          <h1 class="mt-6 text-[2.75rem] sm:text-[3.5rem] lg:text-[4rem] font-bold leading-[1.05] tracking-tighter text-white">
            Need a Tree
            <span class="block mt-1 bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
              Removed?
            </span>
          </h1>

          <!-- High-Contrast Subtitle -->
          <p class="mt-6 text-base sm:text-lg leading-relaxed text-slate-300 font-medium">
            Submit one request and we'll connect you with the right tree service professional for your project.
          </p>

          <!-- Clean System Description -->
          <p class="mt-6 text-sm leading-relaxed text-slate-400 border-l-2 border-slate-700 pl-4 py-1">
            Stop calling multiple companies. Describe your needs once, and our dispatch system matches you with a verified local contractor active in your area.
          </p>

          <!-- Premium CTA Block -->
          <div class="mt-10">
            <a href="#how-it-works" class="flex h-12 w-fit px-8 items-center justify-center rounded-xl border border-slate-700 bg-slate-800 text-[11px] font-bold uppercase tracking-wider text-slate-300 transition-all hover:border-slate-600 hover:text-white hover:bg-slate-700">
              Learn More
            </a>
          </div>

          <!-- Minimalist Trust Bar -->
          <div class="mt-12 flex flex-col sm:flex-row gap-y-3 sm:items-center sm:gap-x-6 border-t border-slate-800 pt-6 text-[10px] font-mono font-bold uppercase tracking-[0.15em] text-slate-500">
            <div class="flex items-center gap-2">
              <span class="text-green-500">//</span> 100% Free Estimate
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-500">//</span> Qualified Contractors
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-500">//</span> No Obligation
            </div>
          </div>
        </div>

        <!-- DESNO: Forma (SLATE BOJA) -->
        <div id="quote" class="w-full max-w-[520px] lg:ml-auto rounded-2xl sm:rounded-3xl border border-slate-700 bg-slate-900 p-6 sm:p-8 font-sans shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)] relative overflow-hidden">
          
          <!-- Dekorativni sjaj -->
          <div class="absolute top-0 right-0 -mr-16 -mt-16 w-32 h-32 bg-green-500/10 blur-[50px] rounded-full pointer-events-none"></div>

          <!-- Header Forme -->
          <div class="border-b border-slate-700/50 pb-5 mb-6 relative">
            <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-400">
              // Dispatch Pipeline
            </span>
            <h2 class="mt-2 text-2xl font-bold tracking-tight text-white">
              Request a Free Estimate
            </h2>
            <p class="mt-1 text-xs text-slate-400">
              Serving our active service territories.
            </p>
          </div>

          <!-- Forma -->
          <form id="leadForm" class="space-y-5 relative">
            <!-- County -->
            <div>
              <label for="county" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">
                Where is your property?
              </label>
              <div class="relative">
                <select id="county" name="county" required class="h-12 w-full appearance-none rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none transition-all focus:border-green-500 focus:ring-1 focus:ring-green-500">
                  <option value="" selected disabled class="text-slate-400">Select County</option>
                  {territories?.map((t) => (
                    <option value={t.name}>{t.name}</option>
                  ))}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
              </div>
            </div>

            <!-- Phone + Email -->
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="phone" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Phone Number</label>
                <input id="phone" name="phone" type="tel" required placeholder="(555) 123-4567" class="h-12 w-full rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 placeholder:text-slate-500"/>
              </div>
              <div>
                <label for="email" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Email (Optional)</label>
                <input id="email" name="email" type="email" placeholder="you@email.com" class="h-12 w-full rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 placeholder:text-slate-500"/>
              </div>
            </div>

            <!-- Description -->
            <div>
              <label for="details" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Project Details</label>
              <textarea id="details" name="details" rows="3" required placeholder="Describe the tree, location on property, urgency..." class="min-h-[100px] w-full rounded-xl border border-slate-600 bg-slate-800 px-4 py-3 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 placeholder:text-slate-500"></textarea>
            </div>

            <!-- Submit Button -->
            <button type="submit" id="submitBtn" class="mt-6 flex h-14 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-950 transition-all hover:bg-green-400 active:scale-[0.98] shadow-[0_0_20px_rgba(34,197,94,0.2)]">
              Request Free Estimate →
            </button>
          </form>

          <!-- Footer Forme -->
          <div class="mt-6 flex items-center justify-center gap-2 border-t border-slate-700 pt-5 text-[9px] font-mono font-bold uppercase tracking-[0.2em] text-slate-500">
            <span>🔒 Secure Protocol Active</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================== -->
    <!-- 2. CAPABILITIES & REGIONAL BOUNDS -->
    <!-- ============================================== -->
    <!-- VRAĆENA CRNA POZADINA bg-[#000000] -->
    <section id="how-it-works" class="border-t border-slate-800 bg-[#000000] py-16 lg:py-24 px-4 sm:px-8 font-sans selection:bg-green-500/30 selection:text-white">
      <div class="mx-auto max-w-[1320px]">
        
        <div class="grid gap-12 lg:gap-16 lg:grid-cols-2">
          
          <!-- LEVO: Obim Usluga -->
          <div>
            <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Capabilities</span>
            <h3 class="mt-3 text-2xl font-bold tracking-tight text-white sm:text-3xl">Professional Tree Services.</h3>
            
            <div class="mt-8 grid gap-4 sm:grid-cols-2">
              {[
                { t: "Tree Removal", d: "Safe extraction of dead, dying, or hazardous trees near foundations." },
                { t: "Trimming & Pruning", d: "Precision cutting for canopy health, aesthetics, and storm mitigation prep." },
                { t: "Stump Grinding", d: "Complete below-grade grinding to clear land for replanting or construction." },
                { t: "Lot Clearing", d: "Full-scale vegetative removal and site preparation for residential projects." }
              ].map((item) => (
                // SLATE KARTICE
                <div class="rounded-xl border border-slate-700 bg-slate-900 p-5 hover:border-slate-600 transition-colors">
                  <div class="text-xs font-bold text-white uppercase tracking-wider">{item.t}</div>
                  <p class="text-[11px] text-slate-400 mt-2 leading-relaxed">{item.d}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- DESNO: Regional Bounds -->
          <div class="flex flex-col justify-center">
            <div>
              <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Regional Bounds</span>
              <h3 class="mt-3 text-2xl font-bold tracking-tight text-white sm:text-3xl">Active South Florida Dispatch.</h3>
              <p class="mt-4 text-sm leading-relaxed text-slate-400">
                Our dispatch logistics span the entire tri-county area. Verified crews are stationed locally for rapid deployment.
              </p>
              
              <!-- Gradovi -->
              <div class="mt-6 flex flex-wrap gap-2.5">
                {['Miami', 'Fort Lauderdale', 'West Palm Beach', 'Boca Raton', 'Hollywood', 'Coral Gables'].map(city => (
                  <span class="rounded-md bg-slate-900 border border-slate-700 px-3 py-1.5 text-[11px] font-mono text-slate-400 hover:border-slate-600 transition-colors">
                    {city}
                  </span>
                ))}
              </div>
            </div>

            <!-- Protokol -->
            <div class="mt-10 rounded-xl border border-green-500/20 bg-slate-900 p-5 text-[11px] leading-relaxed text-slate-300 relative overflow-hidden">
              <div class="absolute top-0 right-0 w-32 h-32 bg-green-500/5 blur-[40px] rounded-full pointer-events-none"></div>
              <strong class="text-green-500 block mb-1 uppercase tracking-wider">🔒 Anti-Spam Guarantee:</strong>
              Secure routing queue. We match your project with a maximum of 3 highly qualified local specialists. No infinite calls, no sold leads.
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================== -->
    <!-- 3. TRUST & COMPLIANCE -->
    <!-- ============================================== -->
    <!-- VRAĆENA CRNA POZADINA bg-[#000000] -->
    <section class="relative overflow-hidden bg-[#000000] py-16 lg:py-24 px-4 sm:px-8 border-t border-slate-800 font-sans selection:bg-green-500/30 selection:text-white">
      
      <!-- Suptilan Glow centar -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[400px] w-[400px] rounded-full bg-green-500/[0.03] blur-[120px] pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-[1320px]">
        
        <div class="text-center mb-12">
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Trust & Compliance</span>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-white sm:text-3xl">Zero Risk. Complete Coverage.</h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Guard 1 (SLATE KARTICE) -->
          <div class="rounded-2xl border border-slate-700 bg-slate-900 p-6 hover:border-slate-600 transition-colors">
            <div class="text-xs font-mono text-green-500 font-bold mb-3">// 01</div>
            <h4 class="text-sm font-bold text-white uppercase tracking-wider">Verified Liability</h4>
            <p class="mt-2 text-[11px] leading-relaxed text-slate-400">
              Every contractor on our platform undergoes active screening for up-to-date insurance coverage.
            </p>
          </div>

          <!-- Guard 2 -->
          <div class="rounded-2xl border border-slate-700 bg-slate-900 p-6 hover:border-slate-600 transition-colors">
            <div class="text-xs font-mono text-green-500 font-bold mb-3">// 02</div>
            <h4 class="text-sm font-bold text-white uppercase tracking-wider">Workers' Comp</h4>
            <p class="mt-2 text-[11px] leading-relaxed text-slate-400">
              Zero homeowner liability. We filter networks to ensure crew members are fully covered on-site.
            </p>
          </div>

          <!-- Guard 3 -->
          <div class="rounded-2xl border border-slate-700 bg-slate-900 p-6 sm:col-span-2 lg:col-span-1 hover:border-slate-600 transition-colors">
            <div class="text-xs font-mono text-green-500 font-bold mb-3">// 03</div>
            <h4 class="text-sm font-bold text-white uppercase tracking-wider">County Compliance</h4>
            <p class="mt-2 text-[11px] leading-relaxed text-slate-400">
              All partners hold arboricultural licenses matching South Florida's municipal safety laws.
            </p>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
  <MobileNav />

</MainLayout>

<script>
  import { supabase } from "../lib/supabase";

  // FUNKCIJA ZA HVATANJE IZVORA SAOBRAĆAJA
  function getTrafficSource() {
    const params = new URLSearchParams(window.location.search);
    const utmSource = params.get('utm_source');
    if (utmSource) return utmSource.toLowerCase();

    const referrer = document.referrer.toLowerCase();
    if (referrer.includes('google')) return 'google';
    if (referrer.includes('facebook') || referrer.includes('fb.com') || referrer.includes('instagram')) return 'facebook';
    if (referrer.includes('bing')) return 'bing';
    
    return 'organic';
  }

  const form = document.getElementById('leadForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.innerText = "Sending...";

    const formData = new FormData(form);
    const trafficSource = getTrafficSource(); // Hvatamo izvor
    
    const { error } = await supabase.from('leads').insert([
      { 
        county: formData.get('county'),
        phone: formData.get('phone'),
        email: formData.get('email'),
        details: formData.get('details'),
        status: 'new',
        source: trafficSource // Upisujemo izvor u bazu
      },
    ]);

    if (error) {
      alert("Error: " + error.message);
      btn.disabled = false;
      btn.innerText = "Request Free Estimate →";
    } else {
      // OVO JE KLJUČNA PROMENA: Uspešan upis sada vodi na Thank You stranu
      window.location.href = '/thank-you';
    }
  });
</script>