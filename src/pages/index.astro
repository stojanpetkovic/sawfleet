---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import MobileNav from "../components/layout/MobileNav.astro";
import Footer from "../components/layout/Footer.astro";
import { supabase } from "../lib/supabase";

// 1. Učitavamo teritorije iz baze za formu
const { data: territories } = await supabase
  .from('service_territories')
  .select('*')
  .order('name', { ascending: true });
---

<MainLayout
  title="SF Tree Removal | Find Trusted Tree Service Professionals"
  description="Connect homeowners with trusted local tree service professionals across South Florida.">

  <Header />

  <!-- Svetla pozadina -->
  <main class="bg-white">

    <!-- ============================================== -->
    <!-- 1. HERO SEKCIJA — VIDEO POZADINA + FORMA -->
    <!-- ============================================== -->
    <section class="relative isolate overflow-hidden pt-28 pb-20 lg:pt-36 lg:pb-28 px-4 sm:px-8 lg:min-h-[88vh] lg:flex lg:items-center bg-slate-900">

      <!-- Video pozadina -->
      <div class="absolute inset-0 -z-20">
        <video
          autoplay muted loop playsinline preload="metadata"
          poster="/videos/hero-tree-service-poster.webp"
          class="h-full w-full object-cover"
        >
          <source src="/videos/hero-optimized.webm" type="video/webm" media="(min-width: 640px) and (prefers-reduced-motion: no-preference)" />
          <source src="/videos/hero-optimized.mp4" type="video/mp4" media="(min-width: 640px) and (prefers-reduced-motion: no-preference)" />
        </video>
      </div>
      <!-- Ravnomeran tamni sloj radi čitljivosti teksta preko blurovanog videa -->
      <div class="absolute inset-0 -z-10 bg-slate-950/45"></div>

      <div class="mx-auto max-w-[1320px] grid lg:grid-cols-2 gap-12 items-center relative z-10 w-full">

        <!-- LEVO: Tekstualni deo (Editorial Heading) -->
        <div class="max-w-[640px] font-sans selection:bg-green-500/30 selection:text-white">
          <!-- Premium Minimal Badge (Glass) -->
          <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md px-3 py-1.5 shadow-soft">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
            </span>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/90">
              Serving South Florida
            </span>
          </div>

          <!-- Editorial Heading -->
          <h1 class="mt-6 text-[2.75rem] sm:text-[3.5rem] lg:text-[4rem] font-bold leading-[1.05] tracking-tighter text-white">
            Need a Tree
            <span class="block mt-1 bg-gradient-to-r from-green-400 to-emerald-400 bg-clip-text text-transparent">
              Removed?
            </span>
          </h1>

          <!-- High-Contrast Subtitle -->
          <p class="mt-6 text-base sm:text-lg leading-relaxed text-white/85 font-medium">
            Submit one request and we'll connect you with the right tree service professional for your project.
          </p>

          <!-- Clean System Description -->
          <p class="mt-6 text-sm leading-relaxed text-white/60 border-l-2 border-white/20 pl-4 py-1">
            Stop calling multiple companies. Describe your needs once, and our dispatch system matches you with a verified local contractor active in your area.
          </p>

          <!-- Premium CTA Block -->
          <div class="mt-10">
            <a href="#how-it-works" class="flex h-12 w-fit px-8 items-center justify-center rounded-xl border border-white/20 bg-white/10 backdrop-blur-md text-[11px] font-bold uppercase tracking-wider text-white/90 transition-all hover:border-white/30 hover:bg-white/20">
              Learn More
            </a>
          </div>

          <!-- Minimalist Trust Bar -->
          <div class="mt-12 flex flex-col sm:flex-row gap-y-3 sm:items-center sm:gap-x-6 border-t border-white/15 pt-6 text-[10px] font-mono font-bold uppercase tracking-[0.15em] text-white/60">
            <div class="flex items-center gap-2">
              <span class="text-green-400">//</span> 100% Free Estimate
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-400">//</span> Qualified Contractors
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-400">//</span> No Obligation
            </div>
          </div>
        </div>

        <!-- DESNO: Forma — Bela "glass" kartica, ističe se na video pozadini -->
        <div id="quote" class="w-full max-w-[520px] lg:ml-auto rounded-2xl sm:rounded-3xl border border-white/40 bg-white/95 backdrop-blur-xl p-6 sm:p-8 font-sans shadow-2xl ring-1 ring-black/5 relative overflow-hidden">

          <!-- Akcentna traka na vrhu forme — vizuelno izdvaja formu -->
          <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-green-500 via-emerald-500 to-green-500"></div>

          <!-- Dekorativni sjaj -->
          <div class="absolute top-0 right-0 -mr-16 -mt-16 w-32 h-32 bg-green-500/10 blur-[50px] rounded-full pointer-events-none"></div>

          <!-- Header Forme -->
          <div class="border-b border-slate-200 pb-5 mb-6 relative">
            <div class="flex items-center justify-between gap-3">
              <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">
                // Dispatch Pipeline
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 border border-green-200 px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider text-green-700">
                <span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
                Free · No obligation
              </span>
            </div>
            <h2 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">
              Request a Free Estimate
            </h2>
            <p class="mt-1 text-xs text-slate-500">
              Serving our active service territories. Takes under a minute.
            </p>
          </div>

          <!-- Forma -->
          <form id="leadForm" class="space-y-5 relative">
            <!-- County -->
            <div>
              <label for="county" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">
                Where is your property?
              </label>
              <div class="relative">
                <select id="county" name="county" required class="h-12 w-full appearance-none rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none transition-all focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white">
                  <option value="" selected disabled class="text-slate-400">Select County</option>
                  {territories?.map((t) => (
                    <option value={t.name}>{t.name}</option>
                  ))}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
              </div>
            </div>

            <!-- Phone + Email -->
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="phone" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Phone Number</label>
                <input id="phone" name="phone" type="tel" required placeholder="(555) 123-4567" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
              </div>
              <div>
                <label for="email" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Email (Optional)</label>
                <input id="email" name="email" type="email" placeholder="you@email.com" class="h-12 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"/>
              </div>
            </div>

            <!-- Description -->
            <div>
              <label for="details" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500">Project Details</label>
              <textarea id="details" name="details" rows="3" required placeholder="Describe the tree, location on property, urgency..." class="min-h-[100px] w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:bg-white placeholder:text-slate-400"></textarea>
            </div>

            <!-- Submit Button -->
            <button type="submit" id="submitBtn" class="mt-6 flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-green-500 text-sm font-bold text-white transition-all hover:bg-green-600 active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(34,197,94,0.5)] hover:shadow-[0_12px_28px_-6px_rgba(34,197,94,0.6)]">
              Request Free Estimate →
            </button>
          </form>

          <!-- Footer Forme -->
          <div class="mt-6 flex items-center justify-center gap-2 border-t border-slate-200 pt-5 text-[9px] font-mono font-bold uppercase tracking-[0.2em] text-slate-400">
            <span>🔒 Secure Protocol Active</span>
          </div>
        </div>

      </div>
    </section>


    <!-- ============================================== -->
    <!-- 2. CAPABILITIES & REGIONAL BOUNDS -->
    <!-- ============================================== -->
    <!-- Svetla pozadina -->
    <section id="how-it-works" class="border-t border-slate-200 bg-white px-4 py-12 sm:px-8 sm:py-16 lg:py-20 font-sans selection:bg-green-500/30 selection:text-slate-900">
      <div class="mx-auto max-w-[1200px]">
        
        <div class="mb-8 max-w-2xl sm:mb-10">
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// One request, local response</span>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">Everything starts with the right project details.</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">We route your request by location and service need so you spend less time calling around and more time comparing the right options.</p>
        </div>

        <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
          
          <!-- LEVO: Obim Usluga -->
          <div>
            <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-slate-400">Services we route</span>
            <h3 class="mt-2 text-xl font-bold tracking-tight text-slate-900 sm:text-2xl">Projects large and small.</h3>
            
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {[
                { t: "Tree Removal", d: "Safe extraction of dead, dying, or hazardous trees near foundations." },
                { t: "Trimming & Pruning", d: "Precision cutting for canopy health, aesthetics, and storm mitigation prep." },
                { t: "Stump Grinding", d: "Complete below-grade grinding to clear land for replanting or construction." },
                { t: "Lot Clearing", d: "Full-scale vegetative removal and site preparation for residential projects." }
              ].map((item) => (
                // SLATE KARTICE
                <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-soft hover:shadow-soft-lg hover:border-slate-300 transition-all">
                  <div class="text-xs font-bold text-slate-900 uppercase tracking-wider">{item.t}</div>
                  <p class="text-[11px] text-slate-600 mt-2 leading-relaxed">{item.d}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- DESNO: Regional Bounds -->
          <div class="flex flex-col justify-center rounded-2xl border border-slate-200 bg-slate-50 p-5 sm:p-7">
            <div>
              <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Local coverage</span>
              <h3 class="mt-2 text-xl font-bold tracking-tight text-slate-900 sm:text-2xl">Built around South Florida.</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">
                Requests are matched by active territory, helping local professionals respond with realistic availability and travel time.
              </p>
              
              <!-- Gradovi -->
              <div class="mt-5 flex flex-wrap gap-2">
                {['Miami', 'Fort Lauderdale', 'West Palm Beach', 'Boca Raton', 'Hollywood', 'Coral Gables'].map(city => (
                  <span class="rounded-full bg-white border border-slate-200 px-3 py-1.5 text-[10px] font-mono text-slate-600 hover:border-slate-300 transition-colors">
                    {city}
                  </span>
                ))}
              </div>
            </div>

            <!-- Protokol -->
            <div class="mt-6 rounded-xl border border-green-200 bg-green-50 p-4 text-[11px] leading-relaxed text-slate-700 relative overflow-hidden">
              <div class="absolute top-0 right-0 w-32 h-32 bg-green-500/5 blur-[40px] rounded-full pointer-events-none"></div>
              <strong class="text-green-700 block mb-1 uppercase tracking-wider">Respectful matching</strong>
              Your request is shared with a limited number of relevant local professionals—not an endless list of callers.
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================== -->
    <!-- 3. TRUST & COMPLIANCE -->
    <!-- ============================================== -->
    <!-- Svetla pozadina -->
    <section class="relative overflow-hidden bg-slate-50 py-12 sm:py-16 lg:py-20 px-4 sm:px-8 border-t border-slate-200 font-sans selection:bg-green-500/30 selection:text-slate-900">
      
      <!-- Suptilan Glow centar -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[400px] w-[400px] rounded-full bg-green-500/[0.03] blur-[120px] pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-[1200px]">
        
        <div class="max-w-2xl mb-8 sm:mb-10">
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Trust & Compliance</span>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Clear expectations before work begins.</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">The platform supports better matching and account review. Always confirm current project-specific credentials directly with the provider.</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Guard 1 (SLATE KARTICE) -->
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft hover:shadow-soft-lg hover:border-slate-300 transition-all">
            <div class="text-xs font-mono text-green-700 font-bold mb-3">// 01</div>
            <h4 class="text-sm font-bold text-slate-900 uppercase tracking-wider">Verified Liability</h4>
            <p class="mt-2 text-[11px] leading-relaxed text-slate-600">
              Provider information is reviewed during account approval; homeowners should confirm current project-specific coverage.
            </p>
          </div>

          <!-- Guard 2 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft hover:shadow-soft-lg hover:border-slate-300 transition-all">
            <div class="text-xs font-mono text-green-700 font-bold mb-3">// 02</div>
            <h4 class="text-sm font-bold text-slate-900 uppercase tracking-wider">Workers' Comp</h4>
            <p class="mt-2 text-[11px] leading-relaxed text-slate-600">
              Ask the selected contractor which crew and workplace protections apply to your specific job before scheduling.
            </p>
          </div>

          <!-- Guard 3 -->
          <div class="rounded-2xl border border-slate-200 bg-white p-5 sm:col-span-2 lg:col-span-1 shadow-soft hover:shadow-soft-lg hover:border-slate-300 transition-all">
            <div class="text-xs font-mono text-green-700 font-bold mb-3">// 03</div>
            <h4 class="text-sm font-bold text-slate-900 uppercase tracking-wider">County Compliance</h4>
            <p class="mt-2 text-[11px] leading-relaxed text-slate-600">
              Local permit and licensing needs vary by property and municipality and should be confirmed before work starts.
            </p>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
  <MobileNav />

</MainLayout>

<script>
  import { supabase } from "../lib/supabase";

  // FUNKCIJA ZA HVATANJE IZVORA SAOBRAĆAJA
  function getTrafficSource() {
    const params = new URLSearchParams(window.location.search);
    const utmSource = params.get('utm_source');
    if (utmSource) return utmSource.toLowerCase();

    const referrer = document.referrer.toLowerCase();
    if (referrer.includes('google')) return 'google';
    if (referrer.includes('facebook') || referrer.includes('fb.com') || referrer.includes('instagram')) return 'facebook';
    if (referrer.includes('bing')) return 'bing';
    
    return 'organic';
  }

  const form = document.getElementById('leadForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.innerText = "Sending...";

    const formData = new FormData(form);
    const trafficSource = getTrafficSource(); // Hvatamo izvor
    
    const { error } = await supabase.from('leads').insert([
      { 
        county: formData.get('county'),
        phone: formData.get('phone'),
        email: formData.get('email'),
        details: formData.get('details'),
        status: 'new',
        source: trafficSource // Upisujemo izvor u bazu
      },
    ]);

    if (error) {
      alert("Error: " + error.message);
      btn.disabled = false;
      btn.innerText = "Request Free Estimate →";
    } else {
      // OVO JE KLJUČNA PROMENA: Uspešan upis sada vodi na Thank You stranu
      window.location.href = '/thank-you';
    }
  });
</script>
