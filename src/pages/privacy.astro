---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MobileNav from "../components/layout/MobileNav.astro";
const sections = [
  ["Information we collect", "We may collect contact information, property location, project descriptions, account details, equipment information, uploaded media, consent records and technical data such as referral source and device information."],
  ["How we use information", "We use information to operate the dispatch platform, route requests, provide account access, communicate about submissions, prevent abuse, improve performance and comply with legal obligations."],
  ["How information is shared", "Homeowner request details may be shared with contractors serving the selected territory. Fleet listing information may be shown to platform administrators and relevant users. We may also use service providers that support hosting, authentication, analytics and communications."],
  ["SMS and communications", "When you provide consent, we may send service-related messages about request status, appointments or account activity. Message and data rates may apply. Consent is not a condition of purchase, and you may opt out as described in the message."],
  ["Retention and security", "We retain information for as long as reasonably necessary to operate the service, resolve disputes and meet legal requirements. We use reasonable administrative and technical safeguards, but no online system can guarantee absolute security."],
  ["Your choices", "You may request access, correction or deletion of personal information, subject to legal and operational limitations. You can also disable non-essential browser tracking and opt out of marketing communications."],
  ["Children's privacy", "The platform is intended for adults and is not directed to children under 13. We do not knowingly collect personal information from children."],
  ["Changes to this policy", "We may update this policy as the platform changes. The effective date below identifies the latest published version."],
];
---
<MainLayout title="Privacy Policy | SF Tree Removal" description="Privacy practices for the SF Tree Removal dispatch platform."><Header /><main class="bg-white pt-28 lg:pt-32"><section class="px-4 py-16 sm:px-8 lg:py-20"><div class="mx-auto max-w-3xl"><span class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-green-700">// Legal</span><h1 class="mt-4 text-4xl font-bold tracking-tighter text-slate-950 sm:text-5xl">Privacy Policy</h1><p class="mt-4 text-sm text-slate-500">Effective July 21, 2026</p><p class="mt-8 text-base leading-relaxed text-slate-600">This policy explains how SF Tree Removal collects, uses and shares information when you use our website, request dispatch assistance or access a platform account.</p><div class="mt-12 space-y-10">{sections.map(([title, text]) => <section><h2 class="text-lg font-bold text-slate-950">{title}</h2><p class="mt-3 text-sm leading-7 text-slate-600">{text}</p></section>)}</div><div class="mt-12 rounded-2xl border border-slate-200 bg-slate-50 p-6 text-sm text-slate-600">Questions or privacy requests can be initiated through our <a href="/support" class="font-bold text-green-700">Support page</a>.</div></div></section></main><Footer /><MobileNav /></MainLayout>
