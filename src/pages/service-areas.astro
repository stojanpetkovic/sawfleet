---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<MainLayout title="Service Areas | SawFleet">
  <Header />

  <main class="pt-28 lg:pt-24 pb-20 bg-[#000000] min-h-screen">
    <div class="mx-auto max-w-[1320px] px-4 sm:px-8">
      
      <!-- Naslov -->
      <div class="mb-16">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Operational Territories</span>
        <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-white tracking-tighter">Service Coverage</h1>
        <p class="mt-4 text-sm text-zinc-400 max-w-md">SawFleet dispatches localized requests across major South Florida counties with real-time contractor availability.</p>
      </div>

      <!-- Grid -->
      <div class="grid lg:grid-cols-[380px_1fr] gap-12 items-start">
        
        <!-- Lista okruga -->
        <div class="space-y-3">
          {[
            { name: "Miami-Dade County", color: "#22c55e" },
            { name: "Broward County", color: "#3b82f6" },
            { name: "Palm Beach County", color: "#a855f7" }
          ].map((county) => (
            <div class="rounded-xl border border-zinc-900 bg-[#070a08] p-5">
              <div class="flex justify-between items-center">
                <h3 class="text-sm font-bold text-white">{county.name}</h3>
                <span class="h-2 w-2 rounded-full shadow-[0_0_8px]" style={`background-color: ${county.color}; box-shadow: 0 0 8px ${county.color}`}></span>
              </div>
            </div>
          ))}
        </div>

        <!-- Mapa -->
        <div id="map" class="relative aspect-video lg:aspect-[16/10] rounded-3xl border border-zinc-900 bg-[#070a08] overflow-hidden shadow-2xl">
          <div class="absolute bottom-6 left-6 z-[400] rounded-lg bg-black/60 backdrop-blur border border-zinc-800 p-4">
            <p class="text-[10px] font-mono uppercase text-white tracking-[0.15em]">Miami Metropolitan Area</p>
            <p class="text-[9px] text-zinc-500 mt-1">Real-time dispatch synchronization</p>
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</MainLayout>

<script is:inline>
  window.addEventListener('load', () => {
    if (typeof L !== 'undefined') {
      const map = L.map('map', { zoomControl: false }).setView([26.1, -80.2], 9);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

      // Definicija zona
      const zones = [
        { name: "Miami-Dade Hub", lat: 25.76, lng: -80.19, radius: 45000, color: "#22c55e" }, 
        { name: "Broward Hub", lat: 26.12, lng: -80.14, radius: 45000, color: "#3b82f6" },
        { name: "Palm Beach Hub", lat: 26.71, lng: -80.05, radius: 45000, color: "#a855f7" }
      ];

      zones.forEach(zone => {
        L.circle([zone.lat, zone.lng], {
          radius: zone.radius,
          color: zone.color,
          fillColor: zone.color,
          fillOpacity: 0.15,
          weight: 1
        })
         .addTo(map)
         .bindPopup(zone.name + " Coverage Zone");
      });
    }
  });
</script>

<style>
  #map { filter: grayscale(0.2) contrast(1.1); }
</style>