---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";

const { id } = Astro.params;

// Dohvati kontraktora
const { data: contractor } = await supabase.from('contractors').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await supabase.from('contractor_logs').select('*').eq('contractor_id', id).order('created_at', { ascending: false });

// POVLAČIMO TERITORIJE IZ BAZE
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

if (!contractor) return Astro.redirect('/admin/contractors');
---

<AdminLayout>
  <!-- MODAL ZA IZMENU KONTRAKTORA -->
  <div id="editModal" class="hidden fixed inset-0 bg-black/80 z-[200] flex items-center justify-center p-4">
    <div class="bg-[#050505] border border-zinc-800 p-8 rounded-xl max-w-md w-full shadow-2xl">
      <h2 class="text-white font-bold mb-6">Edit Contractor</h2>
      <form id="editForm" class="space-y-4">
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Company Name</label>
          <input type="text" id="editName" value={contractor.company_name} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Contact Name</label>
          <input type="text" id="editContact" value={contractor.contact_name} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Phone</label>
          <input type="text" id="editPhone" value={contractor.phone} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Login Email</label>
          <input type="email" id="editEmail" value={contractor.email} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Territory</label>
          
          <!-- DINAMIČKI PADAKUĆI MENI ZA EDIT -->
          <select id="editTerritory" class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required>
            <option value="" disabled>Select Territory</option>
            {territories?.map(t => (
              <option value={t.name} selected={contractor.territory === t.name}>{t.name}</option>
            ))}
          </select>

        </div>
        <div class="flex gap-4 mt-8 pt-4 border-t border-zinc-900/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-800 p-3 rounded text-white font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-700 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-black font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="w-full grid grid-cols-1 xl:grid-cols-12 gap-8">
    <div class="xl:col-span-8 space-y-6">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-xl font-bold text-white tracking-wide">Contractor Management</h1>
          <p class="text-[10px] font-mono text-zinc-500 mt-1 uppercase">ID: {contractor.id.split('-')[0]}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button id="editBtn" class="text-[10px] text-zinc-400 hover:text-white uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-900">Edit</button>
          <button id="deleteBtn" class="text-[10px] text-red-500/70 hover:text-red-500 uppercase font-bold tracking-[0.2em] transition-colors border border-red-900/30 px-4 py-2 rounded-lg hover:bg-red-950/30">Delete</button>
          <a href="/admin/contractors" class="text-[10px] text-zinc-500 hover:text-white uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-900">← Back</a>
        </div>
      </div>
      
      <div class="bg-[#050505] border border-zinc-900 p-8 rounded-xl space-y-8 shadow-2xl">
        <div class="pb-6 border-b border-zinc-900">
          <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600 mb-2">Current Status</p>
          <span class={`px-3 py-1.5 rounded text-[10px] font-bold border uppercase tracking-wider
            ${contractor.status === 'active' ? 'border-green-700/50 text-green-500 bg-green-500/10' : 
              contractor.status === 'rejected' ? 'border-red-700/50 text-red-500 bg-red-500/10' : 'border-zinc-700 text-zinc-400 bg-zinc-800/50'}`}>
            {contractor.status || 'pending'}
          </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Company</p><p class="text-white font-mono mt-1 font-bold text-lg">{contractor.company_name}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Contact</p><p class="text-white font-mono mt-1 text-lg">{contractor.contact_name}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Phone</p><p class="text-white font-mono mt-1 text-lg">{contractor.phone || 'N/A'}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Login Email</p><p class="text-white font-mono mt-1 text-lg">{contractor.email || 'N/A'}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Territory</p><p class="text-white font-mono mt-1 text-lg">{contractor.territory || 'N/A'}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Account Linked</p><p class="text-white font-mono mt-1 text-lg">{contractor.user_id ? '✅ Yes' : '⏳ Not yet — waiting for first login'}</p></div>
        </div>

        <div class="pt-6 border-t border-zinc-900 mt-8">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2"><span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Approval Controls</p>
          <div class="flex gap-4">
            <button id="approveBtn" class="flex-1 h-12 rounded-lg bg-green-500/10 border border-green-500/30 text-green-500 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-green-500 hover:text-black transition-all">Approve Contractor</button>
            <button id="rejectBtn" class="flex-1 h-12 rounded-lg bg-red-950/20 border border-red-900/30 text-red-500 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-red-900/40 transition-all">Reject Contractor</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Logovi -->
    <div class="xl:col-span-4 bg-[#050505] border border-zinc-900 p-6 rounded-xl self-start sticky top-8 shadow-2xl">
      <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white mb-8 border-b border-zinc-900 pb-4">Activity Timeline</h3>
      <div class="space-y-6">
        {logs?.map(log => (
          <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-800 before:border-2 before:border-[#050505] before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-20px] after:w-[2px] after:bg-zinc-900 last:after:hidden">
            <p class="text-[11px] text-white font-bold leading-tight">{log.action}</p>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-300 font-bold tracking-wider uppercase">{log.changed_by || 'Stojan M.'}</span></span>
              <span class="text-[7px] text-zinc-700">●</span>
              <span class="text-[9px] text-zinc-600">{new Date(log.created_at).toLocaleDateString()} {new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            </div>
          </div>
        ))}
        {(!logs || logs.length === 0) && <p class="text-[10px] text-zinc-600 italic">No activity recorded yet.</p>}
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M."; 

  async function updateStatus(newStatus: string) {
    if (!id) return;
    document.body.style.opacity = '0.5';
    await supabase.from('contractors').update({ status: newStatus }).eq('id', id);
    await supabase.from('contractor_logs').insert([{ contractor_id: id, action: `Status changed to ${newStatus}`, changed_by: currentUser }]);
    window.location.reload();
  }

  document.getElementById('approveBtn')?.addEventListener('click', () => updateStatus('active'));
  document.getElementById('rejectBtn')?.addEventListener('click', () => updateStatus('rejected'));

  document.getElementById('editBtn')?.addEventListener('click', () => document.getElementById('editModal')?.classList.remove('hidden'));
  document.getElementById('closeEditModal')?.addEventListener('click', () => document.getElementById('editModal')?.classList.add('hidden'));

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      company_name: (document.getElementById('editName') as HTMLInputElement).value,
      contact_name: (document.getElementById('editContact') as HTMLInputElement).value,
      phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      email: (document.getElementById('editEmail') as HTMLInputElement).value,
      territory: (document.getElementById('editTerritory') as HTMLSelectElement).value,
    };

    await supabase.from('contractors').update(updates).eq('id', id);
    await supabase.from('contractor_logs').insert([{ contractor_id: id, action: 'Updated contractor details', changed_by: currentUser }]);
    window.location.reload();
  });

  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this contractor? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      await supabase.from('contractor_logs').delete().eq('contractor_id', id);
      await supabase.from('contractors').delete().eq('id', id);
      window.location.href = '/admin/contractors';
    }
  });
</script>