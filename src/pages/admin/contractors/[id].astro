---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;

// Ove strane su već zaštićene AdminLayout proverom na klijentu, ali
// SAM frontmatter (SSR) nema pristup toj sesiji — zato ovde koristimo
// supabaseAdmin (service_role) da RLS ne blokira čitanje.
const db = supabaseAdmin ?? supabase;

// Dohvati kontraktora
const { data: contractor } = await db.from('contractors').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await db.from('contractor_logs').select('*').eq('contractor_id', id).order('created_at', { ascending: false });

// POVLAČIMO TERITORIJE IZ BAZE
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

// Lidovi koje je OVAJ kontraktor preuzeo (contractor_id je auth user_id, ne contractors.id)
const { data: claimedLeads } = contractor?.user_id
  ? await db.from('leads').select('*').eq('contractor_id', contractor.user_id).order('claimed_at', { ascending: false, nullsFirst: false })
  : { data: [] };

if (!contractor) return Astro.redirect('/admin/contractors');
---

<AdminLayout>
  <!-- MODAL ZA IZMENU KONTRAKTORA -->
  <div id="editModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-white border border-zinc-200 p-8 rounded-xl max-w-md w-full shadow-2xl">
      <h2 class="text-slate-900 font-bold mb-6">Edit Contractor</h2>
      <form id="editForm" class="space-y-4">
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Company Name</label>
          <input type="text" id="editName" value={contractor.company_name} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Contact Name</label>
          <input type="text" id="editContact" value={contractor.contact_name} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Phone</label>
          <input type="text" id="editPhone" value={contractor.phone} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Login Email</label>
          <input type="email" id="editEmail" value={contractor.email} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Territory</label>
          
          <!-- DINAMIČKI PADAKUĆI MENI ZA EDIT -->
          <select id="editTerritory" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required>
            <option value="" disabled>Select Territory</option>
            {territories?.map(t => (
              <option value={t.name} selected={contractor.territory === t.name}>{t.name}</option>
            ))}
          </select>

        </div>
        <div class="flex gap-4 mt-8 pt-4 border-t border-zinc-100/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-200 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-300 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="dash-shell flex-1"><div class="dash-scroll">
  <div class="w-full grid grid-cols-1 xl:grid-cols-12 gap-8">
    <div class="xl:col-span-8 space-y-6">
      <div class="flex items-center gap-3">
        <a href="/admin/contractors" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">← Back</a>
        <div>
          <span class="dash-eyebrow text-blue-700">// Network partner</span>
          <h1 class="mt-1.5 text-2xl font-bold text-slate-950 tracking-tight">Contractor management</h1>
          <p class="text-[10px] font-mono text-slate-400 mt-1 uppercase">ID: {contractor.id.split('-')[0]}</p>
        </div>
      </div>
      
      <div class="bg-white border border-zinc-100 p-8 rounded-xl space-y-8 shadow-2xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Company</p><p class="text-slate-900 font-mono mt-1 font-bold text-lg">{contractor.company_name}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Contact</p><p class="text-slate-900 font-mono mt-1 text-lg">{contractor.contact_name}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Phone</p>{contractor.phone ? <a href={`tel:${contractor.phone}`} class="text-slate-900 font-mono mt-1 text-lg block hover:text-green-700 transition-colors">{contractor.phone}</a> : <p class="text-slate-900 font-mono mt-1 text-lg">N/A</p>}</div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Login Email</p>{contractor.email ? <a href={`mailto:${contractor.email}`} class="text-slate-900 font-mono mt-1 text-lg block hover:text-green-700 transition-colors break-all">{contractor.email}</a> : <p class="text-slate-900 font-mono mt-1 text-lg">N/A</p>}</div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Territory</p><p class="text-slate-900 font-mono mt-1 text-lg">{contractor.territory || 'N/A'}</p></div>
          <div><p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Account Linked</p><p class="text-slate-900 font-mono mt-1 text-lg">{contractor.user_id ? '✅ Yes' : '⏳ Not yet — waiting for first login'}</p></div>
        </div>
      </div>

      <!-- LIDOVI KOJE JE OVAJ KONTRAKTOR PREUZEO -->
      <div class="bg-white border border-zinc-100 rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-zinc-100">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Claimed Leads ({claimedLeads?.length || 0})</h3>
        </div>
        <div id="claimedLeadsList" class="p-3 space-y-2">
          {claimedLeads && claimedLeads.length > 0 ? claimedLeads.map((lead: any, i: number) => (
            <div class="claimed-lead-row flex items-center gap-3 p-3 rounded-xl hover:bg-zinc-100/40 transition-colors cursor-pointer" data-index={i} onclick={`window.location.href='/admin/leads/${lead.id}'`}>
              <div class="w-9 h-9 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0 text-[10px] font-bold text-zinc-600">
                {(lead.email || '?').charAt(0).toUpperCase()}
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-[13px] font-bold text-slate-900 truncate">{lead.email || 'No email'}</p>
                <p class="text-[10px] text-zinc-500 font-mono truncate">{lead.county || 'N/A'} · Claimed {lead.claimed_at ? new Date(lead.claimed_at).toLocaleDateString() : 'N/A'}</p>
              </div>
              <div class="flex items-center gap-1.5 shrink-0">
                {lead.phone && <a href={`tel:${lead.phone}`} onclick="event.stopPropagation()" class="w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title={lead.phone}>📞</a>}
                <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide bg-blue-500/10 text-blue-600 border-blue-500/20">{lead.status}</span>
              </div>
            </div>
          )) : (
            <div class="p-8 text-center text-zinc-400 text-sm">This contractor hasn't claimed any leads yet.</div>
          )}
        </div>

        {claimedLeads && claimedLeads.length > 5 && (
          <div class="flex items-center justify-between px-5 py-4 border-t border-zinc-100">
            <button id="claimedPrevBtn" class="h-9 px-4 rounded-full bg-zinc-100 border border-zinc-200 text-[10px] font-bold text-zinc-700 hover:text-slate-900 hover:border-zinc-300 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">← Prev</button>
            <span id="claimedPageInfo" class="text-[10px] text-zinc-500 font-mono">Page 1</span>
            <button id="claimedNextBtn" class="h-9 px-4 rounded-full bg-zinc-100 border border-zinc-200 text-[10px] font-bold text-zinc-700 hover:text-slate-900 hover:border-zinc-300 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">Next →</button>
          </div>
        )}
      </div>
    </div>

    <!-- Sidebar: Status / Actions / Manage / Activity Log -->
    <div class="xl:col-span-4 detail-sidebar">
      <!-- Current Status -->
      <div class="detail-card">
        <h3 class="detail-card__title">Current Status</h3>
        <span class={`inline-block px-3 py-2 rounded-full text-[11px] font-bold uppercase tracking-wide border
          ${contractor.status === 'active' ? 'border-green-700/50 text-green-700 bg-green-500/10' : 
            contractor.status === 'rejected' ? 'border-red-700/50 text-red-600 bg-red-500/10' : 'border-zinc-300 text-zinc-600 bg-zinc-200/50'}`}>
          {contractor.status || 'pending'}
        </span>
      </div>

      <!-- Credits -->
      <div class="detail-card">
        <h3 class="detail-card__title">Credits</h3>
        <p class="text-2xl font-bold text-slate-900 font-mono">${contractor.credit_balance ?? 0}</p>
        <p class="text-[10px] text-zinc-400 mb-3">$1 = 1 credit, spent automatically when this contractor claims a lead (if the credit system is enabled in Settings).</p>
        {contractor.user_id ? (
          <div class="flex gap-2">
            <input id="creditAdjustAmount" type="number" step="1" placeholder="e.g. 10 or -5 ($)" class="w-full rounded-lg border border-zinc-200 p-2.5 text-sm text-slate-900" />
            <button id="creditAdjustBtn" data-account-id={contractor.user_id} class="shrink-0 h-10 px-4 rounded-lg bg-green-600 text-white text-[10px] font-bold uppercase tracking-wider hover:bg-green-500">Add</button>
          </div>
        ) : (
          <p class="text-[11px] text-amber-600">Account not linked yet — credits can be adjusted once the contractor logs in for the first time.</p>
        )}
        <p id="creditAdjustMsg" class="text-[11px] mt-2"></p>
      </div>

      <!-- Actions -->
      <div class="detail-card">
        <h3 class="detail-card__title">Actions</h3>
        <div class="space-y-2">
          {contractor.phone && (
            <a href={`tel:${contractor.phone}`} class="detail-btn detail-btn--primary">📞 Call</a>
          )}
          {contractor.email && (
            <a href={`mailto:${contractor.email}`} class="detail-btn detail-btn--ghost">✉️ Email</a>
          )}
          <button id="editBtn" class="detail-btn detail-btn--ghost">✏️ Edit details</button>
          <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 pt-2">Update status</p>
          <div class="grid grid-cols-2 gap-2">
            <button id="approveBtn" class="h-10 rounded-lg bg-green-500/10 border border-green-500/30 text-green-700 font-bold uppercase tracking-wider text-[9px] hover:bg-green-500 hover:text-white transition-all">✓ Approve</button>
            <button id="rejectBtn" class="h-10 rounded-lg bg-red-50 border border-red-200 text-red-600 font-bold uppercase tracking-wider text-[9px] hover:bg-red-500 hover:text-white transition-all">✕ Reject</button>
          </div>

          {contractor.user_id && (
            <>
              <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 pt-2">Account access</p>
              <button id="resetPasswordBtn" data-contractor-user-id={contractor.user_id} class="detail-btn detail-btn--ghost">
                🔑 Set New Password
              </button>
              <div id="resetPasswordForm" class="hidden p-4 bg-zinc-50 border border-zinc-200 rounded-xl space-y-3">
                <p class="text-[11px] text-zinc-600">Set a new password for this contractor's account. Share it with them directly — this does not send an email.</p>
                <div class="flex flex-col gap-2">
                  <input id="newPasswordInput" type="text" placeholder="New password (min. 6 characters)" class="w-full bg-white border border-zinc-200 p-2.5 rounded-lg text-slate-900 text-sm" />
                  <button id="generatePasswordBtn" type="button" class="px-4 py-2 rounded-lg bg-zinc-200 text-zinc-700 text-[10px] font-bold uppercase hover:bg-zinc-300 transition-colors">Generate</button>
                </div>
                <div class="flex gap-2">
                  <button id="cancelResetBtn" type="button" class="flex-1 h-10 rounded-lg bg-zinc-200 text-slate-900 text-[10px] font-bold uppercase tracking-wider hover:bg-zinc-300 transition-colors">Cancel</button>
                  <button id="confirmResetBtn" type="button" class="flex-1 h-10 rounded-lg bg-blue-500 text-white text-[10px] font-bold uppercase tracking-wider hover:bg-blue-400 transition-colors">Save</button>
                </div>
                <p id="resetPasswordMsg" class="text-[11px]"></p>
              </div>
            </>
          )}
        </div>
      </div>

      <!-- Manage Lead -->
      <div class="detail-card detail-card--danger">
        <h3 class="detail-card__title detail-card__title--danger">Manage</h3>
        <button id="deleteBtn" class="detail-btn detail-btn--danger">
          🗑️ Delete Contractor
        </button>
      </div>

      <!-- Activity Log -->
      <div class="detail-card">
        <h3 class="detail-card__title">Activity Log</h3>
        <div class="detail-log">
          {logs?.map(log => (
            <div class="detail-log__entry">
              <div class="detail-log__dot" style="background:#3b82f6"></div>
              <div>
                <p class="text-sm text-slate-900">{log.action}</p>
                <p class="text-[10px] text-zinc-400 mt-0.5 font-mono">by {log.changed_by || 'Stojan M.'} · {new Date(log.created_at).toLocaleDateString()} {new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</p>
              </div>
            </div>
          ))}
          {(!logs || logs.length === 0) && <p class="text-[11px] text-zinc-400 italic">No activity recorded yet.</p>}
        </div>
      </div>
    </div>
  </div>
  </div></div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M."; 

  async function updateStatus(newStatus: string) {
    if (!id) return;
    document.body.style.opacity = '0.5';
    await supabase.from('contractors').update({ status: newStatus }).eq('id', id);
    await supabase.from('contractor_logs').insert([{ contractor_id: id, action: `Status changed to ${newStatus}`, changed_by: currentUser }]);

    try {
      const { data: { session } } = await supabase.auth.getSession();
      await fetch('/api/notify-contractor-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session?.access_token}` },
        keepalive: true,
        body: JSON.stringify({ contractorId: id, status: newStatus }),
      });
    } catch (e) {
      console.error('notify-contractor-status failed:', e);
    }

    window.location.reload();
  }

  document.getElementById('approveBtn')?.addEventListener('click', () => updateStatus('active'));
  document.getElementById('rejectBtn')?.addEventListener('click', () => updateStatus('rejected'));

  document.getElementById('editBtn')?.addEventListener('click', () => document.getElementById('editModal')?.classList.remove('hidden'));
  document.getElementById('closeEditModal')?.addEventListener('click', () => document.getElementById('editModal')?.classList.add('hidden'));

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      company_name: (document.getElementById('editName') as HTMLInputElement).value,
      contact_name: (document.getElementById('editContact') as HTMLInputElement).value,
      phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      email: (document.getElementById('editEmail') as HTMLInputElement).value,
      territory: (document.getElementById('editTerritory') as HTMLSelectElement).value,
    };

    await supabase.from('contractors').update(updates).eq('id', id);
    await supabase.from('contractor_logs').insert([{ contractor_id: id, action: 'Updated contractor details', changed_by: currentUser }]);
    window.location.reload();
  });

  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this contractor? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      await supabase.from('contractor_logs').delete().eq('contractor_id', id);
      await supabase.from('contractors').delete().eq('id', id);
      window.location.href = '/admin/contractors';
    }
  });

  // --- RESET PASSWORD ---
  const resetForm = document.getElementById('resetPasswordForm');
  const resetMsg = document.getElementById('resetPasswordMsg')!;
  const resetBtn = document.getElementById('resetPasswordBtn') as HTMLButtonElement | null;
  const contractorUserId = resetBtn?.dataset.contractorUserId || '';

  document.getElementById('resetPasswordBtn')?.addEventListener('click', () => {
    resetForm?.classList.remove('hidden');
  });
  document.getElementById('cancelResetBtn')?.addEventListener('click', () => {
    resetForm?.classList.add('hidden');
    resetMsg.textContent = '';
    (document.getElementById('newPasswordInput') as HTMLInputElement).value = '';
  });

  document.getElementById('generatePasswordBtn')?.addEventListener('click', () => {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789';
    let pwd = '';
    for (let i = 0; i < 10; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
    (document.getElementById('newPasswordInput') as HTMLInputElement).value = pwd;
  });

  document.getElementById('confirmResetBtn')?.addEventListener('click', async () => {
    const newPassword = (document.getElementById('newPasswordInput') as HTMLInputElement).value;
    if (!newPassword || newPassword.length < 6) {
      resetMsg.textContent = 'Password must be at least 6 characters.';
      resetMsg.className = 'text-[11px] text-red-600';
      return;
    }

    resetMsg.textContent = 'Saving...';
    resetMsg.className = 'text-[11px] text-zinc-600';

    const { data: { session } } = await supabase.auth.getSession();
    const res = await fetch('/api/admin-reset-password', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${session?.access_token}`,
      },
      body: JSON.stringify({ contractorUserId, newPassword }),
    });
    const result = await res.json();

    if (res.ok && result.ok) {
      resetMsg.textContent = `✅ Password updated. Share it with the contractor: "${newPassword}"`;
      resetMsg.className = 'text-[11px] text-green-700 break-all';
    } else {
      resetMsg.textContent = '❌ ' + (result.message || result.error || 'Failed to update password.');
      resetMsg.className = 'text-[11px] text-red-600';
    }
  });
  // --- CREDIT ADJUST ---
  document.getElementById('creditAdjustBtn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const accountId = btn.dataset.accountId;
    const input = document.getElementById('creditAdjustAmount') as HTMLInputElement;
    const msg = document.getElementById('creditAdjustMsg')!;
    const amount = Number(input.value);
    if (!accountId || !amount) {
      msg.textContent = 'Enter a non-zero amount.';
      msg.className = 'text-[11px] mt-2 text-red-600';
      return;
    }
    btn.disabled = true;
    const { data: { session } } = await supabase.auth.getSession();
    const res = await fetch('/api/credit-adjust', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session?.access_token}` },
      body: JSON.stringify({ accountType: 'contractor', accountId, amount }),
    });
    const result = await res.json().catch(() => ({}));
    btn.disabled = false;
    if (res.ok && result.ok) {
      msg.textContent = `✅ New balance: $${result.balance}`;
      msg.className = 'text-[11px] mt-2 text-green-700';
      input.value = '';
      setTimeout(() => window.location.reload(), 900);
    } else {
      msg.textContent = '❌ ' + (result.error || 'Failed to adjust credits.');
      msg.className = 'text-[11px] mt-2 text-red-600';
    }
  });

  // --- CLAIMED LEADS PAGINATION (5 per page) ---
  const claimedRows = Array.from(document.querySelectorAll('.claimed-lead-row')) as HTMLElement[];
  const CLAIMED_PAGE_SIZE = 5;
  let claimedPage = 0;

  function renderClaimedPage() {
    const totalPages = Math.max(1, Math.ceil(claimedRows.length / CLAIMED_PAGE_SIZE));
    claimedRows.forEach((row, i) => {
      const inRange = i >= claimedPage * CLAIMED_PAGE_SIZE && i < (claimedPage + 1) * CLAIMED_PAGE_SIZE;
      row.classList.toggle('hidden', !inRange);
    });
    const pageInfo = document.getElementById('claimedPageInfo');
    if (pageInfo) pageInfo.textContent = `Page ${claimedPage + 1} of ${totalPages}`;
    const prevBtn = document.getElementById('claimedPrevBtn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('claimedNextBtn') as HTMLButtonElement | null;
    if (prevBtn) prevBtn.disabled = claimedPage === 0;
    if (nextBtn) nextBtn.disabled = claimedPage >= totalPages - 1;
  }

  document.getElementById('claimedPrevBtn')?.addEventListener('click', () => {
    if (claimedPage > 0) { claimedPage--; renderClaimedPage(); }
  });
  document.getElementById('claimedNextBtn')?.addEventListener('click', () => {
    const totalPages = Math.max(1, Math.ceil(claimedRows.length / CLAIMED_PAGE_SIZE));
    if (claimedPage < totalPages - 1) { claimedPage++; renderClaimedPage(); }
  });

  if (claimedRows.length > 0) renderClaimedPage();
</script>
