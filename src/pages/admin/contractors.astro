---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabase } from "../../lib/supabase";

// POVLAČIMO TERITORIJE IZ BAZE
const { data: territories } = await supabase.from('service_territories').select('*').order('name');
---

<AdminLayout>
  <button id="openModal" aria-label="Add contractor" title="Add contractor" class="admin-fab admin-fab--icon fixed bottom-24 lg:bottom-8 right-5 lg:right-8 w-14 h-14 bg-green-500 hover:bg-green-400 text-white rounded-full shadow-lg flex items-center justify-center text-2xl font-bold transition-all z-[100]">
    +
  </button>

  <div id="contractorModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-white border border-zinc-200 p-8 rounded-xl max-w-md w-full">
      <h2 class="text-slate-900 font-bold mb-6">Add New Contractor</h2>
      <form id="addContractorForm" class="space-y-4">
        <input type="text" id="newName" placeholder="Company Name" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        <input type="text" id="newContact" placeholder="Contact Name" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        <input type="text" id="newPhone" placeholder="Phone" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        <input type="email" id="newEmail" placeholder="Login Email (used to link their account)" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        
        <!-- DINAMIČKI PADAKUĆI MENI -->
        <select id="newTerritory" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required>
          <option value="" disabled selected>Select Territory</option>
          {territories?.map(t => (
            <option value={t.name}>{t.name}</option>
          ))}
        </select>

        <div class="flex gap-4 mt-6">
          <button type="button" id="closeModal" class="flex-1 bg-zinc-200 p-3 rounded text-slate-900">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-slate-900 font-bold">Save Contractor</button>
        </div>
      </form>
    </div>
  </div>

  <div class="dash-shell flex-1">
  <div class="dash-shell__frozen">
      <div>
        <span class="dash-eyebrow text-blue-700">// Service network</span>
        <h1 class="dash-title">Contractors</h1>
        <p class="dash-subtitle">Everyone registered in your contractor network.</p>
      </div>

      <div class="stat-row grid-cols-4">
        {[
          { id: 'total', label: 'Total', color: '' },
          { id: 'active', label: 'Active', color: 'text-green-700' },
          { id: 'pending', label: 'Pending', color: 'text-amber-600' },
          { id: 'rejected', label: 'Rejected', color: 'text-red-600' },
        ].map(stat => (
          <div class="stat-card">
            <p class="stat-card__label">{stat.label}</p>
            <h2 id={`count-${stat.id}`} class={`stat-card__value ${stat.color}`}>0</h2>
          </div>
        ))}
      </div>

      <div class="filter-bar">
        <select id="statusFilter" class="filter-select">
          <option value="all">All Statuses</option>
          <option value="active">Active</option>
          <option value="pending">Pending</option>
          <option value="rejected">Rejected</option>
        </select>

        <select id="countyFilter" class="filter-select">
          <option value="all">All Territories</option>
          {territories?.map(t => (
            <option value={t.name}>{t.name}</option>
          ))}
        </select>

        <select id="timeFilter" class="filter-select">
          <option value="all">All Time</option>
          <option value="7">Last 7 Days</option>
          <option value="30">Last 30 Days</option>
          <option value="custom">Custom Range</option>
        </select>

        <select id="perPage" class="filter-select">
          <option value="10">10 / page</option>
          <option value="50">50 / page</option>
        </select>
      </div>

      <div id="customDateRange" class="hidden flex flex-wrap gap-2 items-center bg-zinc-100 border border-zinc-200 p-3 rounded-xl">
        <input type="date" id="dateFrom" class="bg-transparent text-[11px] text-zinc-700 outline-none h-6" />
        <span class="text-zinc-400 font-bold text-[10px]">TO</span>
        <input type="date" id="dateTo" class="bg-transparent text-[11px] text-zinc-700 outline-none h-6" />
        <button id="applyDateBtn" class="ml-auto bg-green-500 text-slate-900 px-3 py-1.5 rounded-lg text-[9px] font-bold uppercase hover:bg-green-400">Apply</button>
      </div>
  </div>

  <div class="dash-scroll">
    <div class="flex flex-col xl:flex-row gap-6 lg:gap-8 w-full">
      <div class="flex-1 space-y-3 min-w-0 w-full">
      <div id="allContractorsTable" class="space-y-2">
        <div class="p-8 text-center text-zinc-400 text-sm">Loading...</div>
      </div>

      <div class="dash-pagination">
        <button id="prevPage" class="h-10 px-4 rounded-full bg-zinc-100 border border-zinc-200 text-[11px] font-bold text-zinc-700 hover:text-slate-900 hover:border-zinc-300 transition-colors">← Prev</button>
        <span id="pageInfo" class="text-[11px] text-zinc-500 font-mono">Page 1</span>
        <button id="nextPage" class="h-10 px-4 rounded-full bg-zinc-100 border border-zinc-200 text-[11px] font-bold text-zinc-700 hover:text-slate-900 hover:border-zinc-300 transition-colors">Next →</button>
      </div>
    </div>

    <!-- Sidebar za logove -->
    <div class="w-full xl:w-[400px] shrink-0">
      <div class="bg-white border border-zinc-100 rounded-2xl w-full">
        <div class="p-6 border-b border-zinc-100">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Activity Timeline</h3>
        </div>
        <div class="p-6">
          <div id="contractorLogsContainer" class="space-y-6">
            <div class="text-[11px] font-mono text-zinc-500">Loading logs...</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";
  let currentPage = 0;

  function timeAgo(dateInput: string) {
    const date = new Date(dateInput);
    const now = new Date();
    const diffInSeconds = Math.floor((now.getTime() - date.getTime()) / 1000);
    
    if (diffInSeconds < 60) return 'Just now';
    if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)}m ago`;
    if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)}h ago`;
    return `${Math.floor(diffInSeconds / 86400)}d ago`;
  }

  async function loadLogs() {
    const { data: contractorLogs } = await supabase.from('contractor_logs').select('*, contractors(company_name)').order('created_at', { ascending: false }).limit(10);
    const clContainer = document.getElementById('contractorLogsContainer');
    if (clContainer && contractorLogs) {
      clContainer.innerHTML = contractorLogs.length > 0 ? contractorLogs.map(log => `
        <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-200 before:border-2 before:border-slate-200 before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-24px] after:w-[2px] after:bg-zinc-100 last:after:hidden">
          <p class="text-[10px] text-zinc-600 font-mono mb-1 truncate">${log.contractors?.company_name || 'Unknown Contractor'}</p>
          <p class="text-[11px] text-slate-900 font-bold leading-tight">${log.action || log.status || 'Updated'}</p>
          <div class="flex items-center gap-2 mt-2">
            <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-700 font-bold tracking-wider uppercase">${log.user_email || log.changed_by || 'Stojan M.'}</span></span>
            <span class="text-[7px] text-zinc-300">●</span>
            <span class="text-[9px] text-zinc-400">${timeAgo(log.created_at)}</span>
          </div>
        </div>
      `).join('') : '<div class="text-[10px] text-zinc-500 italic">No activity recorded yet.</div>';
    }
  }

  async function updateDashboard() {
    const timeFilter = (document.getElementById('timeFilter') as HTMLSelectElement).value;
    const statusFilter = (document.getElementById('statusFilter') as HTMLSelectElement).value;
    const countyFilter = (document.getElementById('countyFilter') as HTMLSelectElement).value;
    const dateFrom = (document.getElementById('dateFrom') as HTMLInputElement).value;
    const dateTo = (document.getElementById('dateTo') as HTMLInputElement).value;
    const itemsPerPage = parseInt((document.getElementById('perPage') as HTMLSelectElement).value);
    
    const customUI = document.getElementById('customDateRange');
    timeFilter === 'custom' ? customUI?.classList.remove('hidden') : customUI?.classList.add('hidden');
    
    const { data: allData } = await supabase.from('contractors').select('status');
    if (allData) {
      document.getElementById('count-total')!.textContent = allData.length.toString();
      document.getElementById('count-active')!.textContent = allData.filter(c => c.status === 'active').length.toString();
      document.getElementById('count-pending')!.textContent = allData.filter(c => c.status === 'pending').length.toString();
      document.getElementById('count-rejected')!.textContent = allData.filter(c => c.status === 'rejected').length.toString();
    }

    let query = supabase.from('contractors').select('*');
    if (statusFilter !== 'all') query = query.eq('status', statusFilter);
    if (countyFilter !== 'all') query = query.eq('territory', countyFilter);
    
    if (timeFilter === '7') query = query.gte('created_at', new Date(Date.now() - 7*86400000).toISOString());
    if (timeFilter === '30') query = query.gte('created_at', new Date(Date.now() - 30*86400000).toISOString());
    if (timeFilter === 'custom') {
        if (dateFrom) query = query.gte('created_at', dateFrom);
        if (dateTo) {
            const d = new Date(dateTo);
            d.setDate(d.getDate() + 1);
            query = query.lte('created_at', d.toISOString());
        }
    }
    
    const { data: list } = await query.order('created_at', { ascending: false }).range(currentPage * itemsPerPage, (currentPage + 1) * itemsPerPage - 1);

    const listEl = document.getElementById('allContractorsTable');
    if (listEl && list) {
      listEl.innerHTML = list.length > 0 ? list.map(item => {
        const statusStyles: Record<string, string> = {
          active: 'bg-green-500/10 text-green-700 border-green-500/20',
          rejected: 'bg-red-500/10 text-red-600 border-red-500/20',
        };
        const statusClass = statusStyles[item.status] || 'bg-amber-500/10 text-amber-600 border-amber-500/20';
        const initials = (item.company_name || '?').slice(0, 2).toUpperCase();
        return `
        <div class="group flex items-center gap-3 sm:gap-4 p-3 sm:p-4 rounded-2xl border border-zinc-100 bg-white hover:border-zinc-300 hover:bg-zinc-100/40 transition-all cursor-pointer" onclick="window.location.href='/admin/contractors/${item.id}'">
          <div class="w-10 h-10 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0 text-[10px] font-bold text-zinc-600">${initials}</div>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-bold text-slate-900 truncate">${item.company_name || 'N/A'}</p>
            <div class="mt-0.5 flex items-center gap-2 text-[11px] text-zinc-500 font-mono truncate">
              <span>${item.contact_name || 'No contact'}</span>
              <span class="text-zinc-300">·</span>
              <span>${item.territory || 'No territory'}</span>
            </div>
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            ${item.phone ? `<a href="tel:${item.phone}" onclick="event.stopPropagation()" class="w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title="${item.phone}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </a>` : ''}
            ${item.email ? `<a href="mailto:${item.email}" onclick="event.stopPropagation()" class="hidden sm:flex w-8 h-8 rounded-full items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title="${item.email}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>` : ''}
            <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide ${statusClass}">${item.status || 'pending'}</span>
            <svg class="hidden sm:block w-4 h-4 text-zinc-300 group-hover:text-zinc-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      `}).join('') : '<div class="p-8 text-center text-zinc-400 text-sm border border-dashed border-zinc-100 rounded-2xl">No results match these filters.</div>';
    }
    document.getElementById('pageInfo')!.textContent = `Page ${currentPage + 1}`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('contractorModal');
    document.getElementById('openModal')?.addEventListener('click', () => modal?.classList.remove('hidden'));
    document.getElementById('closeModal')?.addEventListener('click', () => modal?.classList.add('hidden'));

    document.getElementById('addContractorForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      await supabase.from('contractors').insert([{ 
        company_name: (document.getElementById('newName') as HTMLInputElement).value,
        contact_name: (document.getElementById('newContact') as HTMLInputElement).value,
        phone: (document.getElementById('newPhone') as HTMLInputElement).value,
        email: (document.getElementById('newEmail') as HTMLInputElement).value,
        territory: (document.getElementById('newTerritory') as HTMLSelectElement).value,
        status: 'pending',
        created_at: new Date().toISOString()
      }]);
      modal?.classList.add('hidden');
      (e.target as HTMLFormElement).reset();
      updateDashboard();
      loadLogs();
    });

    document.getElementById('applyDateBtn')?.addEventListener('click', () => { currentPage = 0; updateDashboard(); });
    document.querySelectorAll('select').forEach(sel => sel.addEventListener('change', () => { currentPage = 0; updateDashboard(); }));
    document.getElementById('nextPage')?.addEventListener('click', () => { currentPage++; updateDashboard(); });
    document.getElementById('prevPage')?.addEventListener('click', () => { if(currentPage > 0) currentPage--; updateDashboard(); });
    
    updateDashboard();
    loadLogs();
  });
</script>
