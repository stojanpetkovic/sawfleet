---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabase } from "../../lib/supabase";
import { getPermitLeads, buildPermitOutreachUrl } from "../../lib/permitData";

const { data: territories } = await supabase.from('service_territories').select('*').order('name');
---

<AdminLayout>
  <div class="space-y-5 w-full">
    <div>
      <span class="text-[9px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Permit outreach</span>
      <h1 class="mt-1.5 text-2xl sm:text-3xl font-bold text-slate-950 tracking-tight">Potential permit leads</h1>
      <p class="text-sm text-slate-500 mt-1.5">Permit opportunities with contact information - email, phone, or newly scraped.</p>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-xl p-4">
        <p class="text-[9px] font-bold uppercase tracking-wider text-blue-700 mb-1">Active Leads</p>
        <p id="statActiveLeads" class="text-2xl font-bold text-blue-900">0</p>
      </div>
      <div class="bg-gradient-to-br from-orange-50 to-orange-100 border border-orange-200 rounded-xl p-4">
        <p class="text-[9px] font-bold uppercase tracking-wider text-orange-700 mb-1">Archived</p>
        <p id="statArchivedLeads" class="text-2xl font-bold text-orange-900">0</p>
      </div>
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 border border-purple-200 rounded-xl p-4">
        <p class="text-[9px] font-bold uppercase tracking-wider text-purple-700 mb-1">Total Leads</p>
        <p id="statTotalLeads" class="text-2xl font-bold text-purple-900">0</p>
      </div>
      <div class="bg-gradient-to-br from-green-50 to-green-100 border border-green-200 rounded-xl p-4">
        <p class="text-[9px] font-bold uppercase tracking-wider text-green-700 mb-1">New Status</p>
        <p id="statNewLeads" class="text-2xl font-bold text-green-900">0</p>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 mb-4">
      <select id="permitTerritoryFilter" class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-2 text-[11px] font-bold uppercase tracking-wider text-zinc-700">
        <option value="all">All territories</option>
        {territories?.map((t) => <option value={t.name}>{t.name}</option>)}
      </select>
      <select id="permitStatusFilter" class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-2 text-[11px] font-bold uppercase tracking-wider text-zinc-700">
        <option value="all">All statuses</option>
        <option value="new">New</option>
        <option value="invited">Invited</option>
        <option value="responded">Responded</option>
        <option value="converted">Converted</option>
      </select>
      <select id="permitContactFilter" class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-2 text-[11px] font-bold uppercase tracking-wider text-zinc-700">
        <option value="all">All contacts</option>
        <option value="email">Has email</option>
        <option value="phone-only">Phone only</option>
      </select>
      <select id="permitArchiveFilter" class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-2 text-[11px] font-bold uppercase tracking-wider text-zinc-700">
        <option value="active">Active only</option>
        <option value="archived">Archived only</option>
        <option value="all">All leads</option>
      </select>
      <button id="refreshPermitLeadsBtn" class="rounded-lg border border-zinc-200 px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">Refresh</button>
      <button id="runPermitAutomationBtn" class="rounded-lg bg-green-600 px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-white hover:bg-green-500">Run now</button>
      <button id="openSettingsBtn" class="rounded-lg border border-zinc-200 px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">⚙️ Settings</button>
    </div>
    
    <!-- Settings Modal -->
    <div id="settingsModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
      <div class="bg-white rounded-2xl max-w-md w-full max-h-[90vh] overflow-y-auto p-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-slate-900">Scraping Settings</h2>
          <button id="closeSettingsBtn" class="text-zinc-400 hover:text-zinc-600">✕</button>
        </div>
        
        <div class="space-y-4">
          <!-- Enable/Disable -->
          <div>
            <label class="flex items-center gap-2">
              <input type="checkbox" id="enableAutomation" class="w-4 h-4">
              <span class="text-sm font-semibold text-slate-900">Enable automation</span>
            </label>
          </div>
          
          <!-- Min Score -->
          <div>
            <label class="block text-sm font-semibold text-slate-900 mb-2">Minimum lead score</label>
            <input type="number" id="minScore" min="0" max="100" value="0" class="w-full rounded-lg border border-zinc-200 bg-zinc-50 p-2 text-sm">
          </div>
          
          <!-- Archive Days -->
          <div>
            <label class="block text-sm font-semibold text-slate-900 mb-2">Archive leads after (days)</label>
            <input type="number" id="archiveDays" min="7" max="365" value="60" class="w-full rounded-lg border border-zinc-200 bg-zinc-50 p-2 text-sm">
            <p class="mt-1 text-xs text-zinc-500">Leads in "new" status older than this will be auto-archived</p>
          </div>
          
          <!-- Territories -->
          <div>
            <label class="block text-sm font-semibold text-slate-900 mb-3">Select territories to scrape</label>
            <div id="territoriesCheckboxes" class="space-y-2 max-h-48 overflow-y-auto">
              <div class="text-sm text-zinc-500">Loading jurisdictions...</div>
            </div>
          </div>
          
          <button id="saveSettingsBtn" class="w-full rounded-lg bg-green-600 px-4 py-3 text-sm font-bold text-white hover:bg-green-500">Save settings</button>
        </div>
      </div>
    </div>

    <div class="grid gap-4 xl:grid-cols-[1fr_350px]">
      <!-- Permit Leads List -->
      <div class="bg-white border border-zinc-100 rounded-2xl p-4 sm:p-5">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400">Potential contacts</p>
            <p id="permitSummary" class="text-sm font-semibold text-slate-900 mt-1">0 leads</p>
          </div>
          <select id="itemsPerPage" class="rounded-lg border border-zinc-200 bg-zinc-50 px-2 py-1.5 text-[11px] font-bold uppercase tracking-wider text-zinc-700">
            <option value="10">10 per page</option>
            <option value="20" selected>20 per page</option>
            <option value="50">50 per page</option>
            <option value="100">100 per page</option>
          </select>
        </div>
        <div id="permitLeadsTable" class="space-y-2">
          <div class="p-8 text-center text-zinc-400 text-sm">Loading permit leads...</div>
        </div>
        
        <!-- Pagination Controls -->
        <div id="paginationControls" class="flex items-center justify-between mt-4 pt-4 border-t border-zinc-100">
          <div class="text-[11px] text-zinc-500 font-semibold">
            Showing <span id="paginationStart">0</span> to <span id="paginationEnd">0</span> of <span id="paginationTotal">0</span>
          </div>
          <div class="flex items-center gap-2">
            <button id="paginationPrev" class="rounded-lg border border-zinc-200 px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50 disabled:opacity-50 disabled:cursor-not-allowed">← Previous</button>
            <span id="paginationInfo" class="text-[11px] text-zinc-500 font-semibold px-2">Page <span id="currentPage">1</span> of <span id="totalPages">1</span></span>
            <button id="paginationNext" class="rounded-lg border border-zinc-200 px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50 disabled:opacity-50 disabled:cursor-not-allowed">Next →</button>
          </div>
        </div>
      </div>

      <!-- Right Sidebar -->
      <div class="space-y-4">
        <!-- Quick Compose -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-4 sm:p-5">
          <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-3">Quick compose</p>
          <div class="space-y-3">
            <input id="composeName" class="w-full rounded-lg border border-zinc-200 bg-zinc-50 p-3 text-sm text-slate-900" placeholder="Contact name" />
            <input id="composeEmail" class="w-full rounded-lg border border-zinc-200 bg-zinc-50 p-3 text-sm text-slate-900" placeholder="Email address" />
            <textarea id="composeDetails" rows="4" class="w-full rounded-lg border border-zinc-200 bg-zinc-50 p-3 text-sm text-slate-900" placeholder="Permit details..."></textarea>
            <button id="sendOutreachBtn" class="w-full rounded-lg bg-green-600 px-4 py-3 text-sm font-bold text-white hover:bg-green-500">Send email</button>
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-4 sm:p-5">
          <div class="flex items-center justify-between mb-3">
            <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400">Recent activity</p>
            <span class="text-[10px] font-mono text-zinc-500">Live</span>
          </div>
          <div id="permitActivityLog" class="space-y-3 text-sm text-zinc-600">
            <div class="text-[11px] text-zinc-400">Loading...</div>
          </div>
        </div>

        <!-- Audit Log -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-4 sm:p-5">
          <div class="flex items-center justify-between mb-3">
            <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400">Permit runs</p>
            <span class="text-[10px] font-mono text-zinc-500">Last 5</span>
          </div>
          <div id="permitAuditLog" class="space-y-3 text-sm text-zinc-600">
            <div class="text-[11px] text-zinc-400">Loading...</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";

  type PermitLead = {
    id: string;
    source_name: string | null;
    jurisdiction: string | null;
    address: string | null;
    permit_type: string | null;
    permit_description: string | null;
    permit_date: string | null;
    permit_number: string | null;
    lead_score: number | null;
    source_url: string | null;
    discovered_at: string | null;
    owner_name: string | null;
    owner_email: string | null;
    owner_phone: string | null;
    owner_mailing_address: string | null;
    raw_payload_json?: string | null;
    status?: string | null;
    archived_at?: string | null;
    archive_reason?: string | null;
  };

  let allPermitLeads: PermitLead[] = [];
  let currentPage = 1;
  let itemsPerPage = 20;

  function updateStats() {
    const activeLeads = allPermitLeads.filter(lead => !lead.archived_at).length;
    const archivedLeads = allPermitLeads.filter(lead => !!lead.archived_at).length;
    const totalLeads = allPermitLeads.length;
    const newLeads = allPermitLeads.filter(lead => !lead.archived_at && (lead.permit_status || lead.status || 'new') === 'new').length;

    const statActiveEl = document.getElementById('statActiveLeads');
    const statArchivedEl = document.getElementById('statArchivedLeads');
    const statTotalEl = document.getElementById('statTotalLeads');
    const statNewEl = document.getElementById('statNewLeads');

    if (statActiveEl) statActiveEl.textContent = String(activeLeads);
    if (statArchivedEl) statArchivedEl.textContent = String(archivedLeads);
    if (statTotalEl) statTotalEl.textContent = String(totalLeads);
    if (statNewEl) statNewEl.textContent = String(newLeads);
  }

  function getFilteredLeads() {
    const territory = (document.getElementById('permitTerritoryFilter') as HTMLSelectElement | null)?.value || 'all';
    const status = (document.getElementById('permitStatusFilter') as HTMLSelectElement | null)?.value || 'all';
    const contactFilter = (document.getElementById('permitContactFilter') as HTMLSelectElement | null)?.value || 'all';
    const archiveFilter = (document.getElementById('permitArchiveFilter') as HTMLSelectElement | null)?.value || 'active';
    
    return allPermitLeads.filter((lead) => {
      const matchesTerritory = territory === 'all' || !lead.jurisdiction || lead.jurisdiction.toLowerCase().includes(territory.toLowerCase());
      const leadStatus = lead.permit_status || lead.status || 'new';
      const matchesStatus = status === 'all' || leadStatus === status;
      
      let matchesContact = true;
      if (contactFilter === 'email') {
        matchesContact = !!lead.owner_email;
      } else if (contactFilter === 'phone-only') {
        matchesContact = !lead.owner_email && !!lead.owner_phone;
      }
      
      let matchesArchive = true;
      if (archiveFilter === 'active') {
        matchesArchive = !lead.archived_at;
      } else if (archiveFilter === 'archived') {
        matchesArchive = !!lead.archived_at;
      }
      
      return matchesTerritory && matchesStatus && matchesContact && matchesArchive;
    });
  }

  async function loadPermitLeads() {
    const el = document.getElementById('permitLeadsTable');
    if (el) el.innerHTML = '<div class="p-8 text-center text-zinc-400 text-sm">Loading live permits...</div>';

    try {
      const permits = await (window as any).fetchPermitLeads?.() || [];
      allPermitLeads = permits;
    } catch (error) {
      console.error(error);
      allPermitLeads = [];
    }
    renderList();
  }

  function renderList() {
    const el = document.getElementById('permitLeadsTable');
    if (!el) return;

    const filteredLeads = getFilteredLeads();
    const summary = document.getElementById('permitSummary');
    if (summary) summary.textContent = `${filteredLeads.length} leads`;

    if (filteredLeads.length === 0) {
      el.innerHTML = '<div class="p-8 text-center text-zinc-400 text-sm border border-dashed border-zinc-200 rounded-2xl">No permit contacts match these filters.</div>';
      updatePaginationControls(0, 0);
      return;
    }

    updateStats();

    // Calculate pagination
    const totalPages = Math.ceil(filteredLeads.length / itemsPerPage);
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    const startIdx = (currentPage - 1) * itemsPerPage;
    const endIdx = startIdx + itemsPerPage;
    const paginatedLeads = filteredLeads.slice(startIdx, endIdx);

    const sortedLeads = paginatedLeads.sort((a, b) => {
      // Sort: email contacts first, then phone-only
      const aHasEmail = a.owner_email ? 1 : 0;
      const bHasEmail = b.owner_email ? 1 : 0;
      return bHasEmail - aHasEmail;
    });

    el.innerHTML = sortedLeads.map((lead) => {
      const initial = (lead.owner_name || lead.address || '?').charAt(0).toUpperCase();
      const contactType = lead.owner_email ? 'Email' : 'Phone';
      const contactValue = lead.owner_email || lead.owner_phone || 'No contact';
      const statusStyles: Record<string, string> = {
        invited: 'bg-blue-500/10 text-blue-600 border-blue-500/20',
        responded: 'bg-amber-500/10 text-amber-600 border-amber-500/20',
        converted: 'bg-green-500/10 text-green-600 border-green-500/20',
      };
      const statusClass = statusStyles[lead.permit_status || lead.status || 'new'] || 'bg-zinc-200/50 text-zinc-600 border-zinc-300';

      return `
        <div class="group flex items-center gap-3 sm:gap-4 p-3 sm:p-4 rounded-2xl border border-zinc-100 bg-white hover:border-zinc-300 hover:bg-zinc-100/40 transition-all cursor-pointer" onclick="window.location.href='/admin/permit-leads/${lead.id}'">
          <div class="w-10 h-10 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0 text-xs font-bold text-zinc-600">${initial}</div>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-bold text-slate-900 truncate">${lead.owner_name || lead.address || 'Unnamed'}</p>
            <div class="mt-0.5 flex items-center gap-2 text-[11px] text-zinc-500 font-mono truncate">
              <span>${lead.jurisdiction || 'Unknown'}</span>
              <span class="text-zinc-300">·</span>
              <span>${lead.permit_type || 'Permit'}</span>
            </div>
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide ${lead.owner_email ? 'bg-green-50 text-green-700 border-green-200' : 'bg-zinc-100 text-zinc-700 border-zinc-200'}">${contactType}</span>
            ${lead.owner_email ? `<a href="mailto:${lead.owner_email}" onclick="event.stopPropagation()" class="w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title="Email">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>` : ''}
            ${lead.owner_phone ? `<a href="tel:${lead.owner_phone}" onclick="event.stopPropagation()" class="w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title="Call">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </a>` : ''}
            ${lead.archived_at ? `
            <button onclick="event.stopPropagation(); window.unarchivePermit('${lead.id}')" class="w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-amber-700 hover:bg-amber-500/10 transition-colors" title="Unarchive">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            </button>
            ` : ''}
            <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide ${statusClass}">${(lead.permit_status || lead.status || 'new').toUpperCase()}</span>
            ${lead.archived_at ? `<span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide bg-orange-50 text-orange-700 border-orange-200">ARCHIVED</span>` : ''}
            <svg class="hidden sm:block w-4 h-4 text-zinc-300 group-hover:text-zinc-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      `;
    }).join('');
    
    // Update pagination controls
    const filteredCount = getFilteredLeads().length;
    updatePaginationControls(startIdx + 1, Math.min(endIdx, filteredCount), filteredCount, totalPages);
  }

  function updatePaginationControls(start: number, end: number, total: number, pages: number) {
    document.getElementById('paginationStart')!.textContent = String(start);
    document.getElementById('paginationEnd')!.textContent = String(end);
    document.getElementById('paginationTotal')!.textContent = String(total);
    document.getElementById('currentPage')!.textContent = String(currentPage);
    document.getElementById('totalPages')!.textContent = String(pages);
    
    const prevBtn = document.getElementById('paginationPrev') as HTMLButtonElement;
    const nextBtn = document.getElementById('paginationNext') as HTMLButtonElement;
    
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= pages;
  }

  async function loadActivityLog() {
    const el = document.getElementById('permitActivityLog');
    if (!el) return;
    try {
      const { data } = await supabase.from('permit_lead_logs').select('*, permit_leads(address, jurisdiction, owner_name, owner_email)').order('created_at', { ascending: false }).limit(8);
      const logs = (data || []);
      if (!logs.length) {
        el.innerHTML = '<div class="text-[11px] text-zinc-400">No permit activity yet.</div>';
        return;
      }
      el.innerHTML = logs.map((log: any) => `
        <div class="rounded-xl border border-zinc-100 bg-zinc-50 p-3">
          <p class="text-[11px] font-semibold text-slate-900">${log.action}</p>
          <p class="mt-1 text-[10px] text-zinc-500">${log.permit_leads?.owner_email || log.permit_leads?.address || 'Permit'} · ${log.permit_leads?.jurisdiction || 'No territory'}</p>
          <p class="mt-1 text-[9px] uppercase tracking-[0.2em] text-zinc-400">${new Date(log.created_at).toLocaleString()}</p>
        </div>
      `).join('');
    } catch (error) {
      console.error(error);
      el.innerHTML = '<div class="text-[11px] text-zinc-400">Activity unavailable.</div>';
    }
  }

  async function loadAuditLog() {
    const el = document.getElementById('permitAuditLog');
    if (!el) return;
    try {
      const response = await fetch('/api/permit-audit');
      const payload = await response.json().catch(() => ({}));
      const items = payload.audit || [];
      if (!items.length) {
        el.innerHTML = '<div class="text-[11px] text-zinc-400">No permit runs yet.</div>';
        return;
      }
      el.innerHTML = items.map((item: any) => `
        <div class="rounded-xl border border-zinc-100 bg-zinc-50 p-3">
          <div class="flex items-center justify-between gap-2">
            <p class="text-[11px] font-semibold text-slate-900">${item.status.toUpperCase()}</p>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">${new Date(item.timestamp).toLocaleString()}</p>
          </div>
          <p class="mt-1 text-[10px] text-zinc-500">${item.details}</p>
          <p class="mt-1 text-[9px] text-zinc-400">Processed ${item.processed} • Created ${item.created} • Skipped ${item.skipped} • Sent ${item.sent}</p>
        </div>
      `).join('');
    } catch (error) {
      console.error(error);
      el.innerHTML = '<div class="text-[11px] text-zinc-400">Audit unavailable.</div>';
    }
  }

  document.getElementById('refreshPermitLeadsBtn')?.addEventListener('click', async () => {
    await loadPermitLeads();
    await loadActivityLog();
    await loadAuditLog();
  });
  document.getElementById('permitTerritoryFilter')?.addEventListener('change', renderList);
  document.getElementById('permitStatusFilter')?.addEventListener('change', renderList);
  document.getElementById('permitContactFilter')?.addEventListener('change', renderList);
  document.getElementById('permitArchiveFilter')?.addEventListener('change', renderList);

  // Pagination controls
  document.getElementById('paginationPrev')?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderList();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  document.getElementById('paginationNext')?.addEventListener('click', () => {
    const totalPages = Math.ceil(getFilteredLeads().length / itemsPerPage);
    if (currentPage < totalPages) {
      currentPage++;
      renderList();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  document.getElementById('itemsPerPage')?.addEventListener('change', (e) => {
    itemsPerPage = Number((e.target as HTMLSelectElement).value);
    currentPage = 1;
    renderList();
  });

  document.getElementById('runPermitAutomationBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('runPermitAutomationBtn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Running...';
    try {
      const response = await fetch('/api/permit-sync', { method: 'POST' });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || !payload.ok) throw new Error(payload.error || 'Run failed');
      alert(`Permit run completed. Created ${payload.created || 0} leads.`);
      await loadPermitLeads();
      await loadActivityLog();
      await loadAuditLog();
    } catch (error) {
      console.error(error);
      alert('Permit run failed.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Run now';
    }
  });

  document.getElementById('sendOutreachBtn')?.addEventListener('click', async () => {
    const name = (document.getElementById('composeName') as HTMLInputElement).value.trim();
    const email = (document.getElementById('composeEmail') as HTMLInputElement).value.trim();
    const details = (document.getElementById('composeDetails') as HTMLTextAreaElement).value.trim();
    if (!email) {
      alert('Please enter an email address.');
      return;
    }
    const res = await fetch('/api/notify-permit-lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ fullName: name || 'there', email, permitDetails: details || 'Permit opportunity', siteUrl: window.location.origin }),
    });
    const payload = await res.json().catch(() => ({}));
    if (payload.ok) alert('Outreach email sent.'); else alert('Email failed: ' + (payload.error || 'unknown'));
  });

  (window as any).fetchPermitLeads = async () => {
    const response = await fetch('/api/permit-leads');
    const payload = await response.json().catch(() => ({}));
    if (!response.ok || !payload.ok) {
      throw new Error(payload.error || 'Failed to load permit leads');
    }
    return payload.leads || [];
  };

  (window as any).unarchivePermit = async (leadId: string) => {
    if (!confirm('Reactivate this archived lead?')) return;
    try {
      const response = await fetch('/api/unarchive-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: leadId }),
      });
      const result = await response.json();
      if (result.ok) {
        alert('Lead reactivated successfully');
        await loadPermitLeads();
      } else {
        alert('Failed to reactivate: ' + (result.error || 'unknown'));
      }
    } catch (error) {
      console.error(error);
      alert('Error reactivating lead');
    }
  };

  loadPermitLeads();
  loadActivityLog();
  loadAuditLog();

  // Settings Modal Management
  const settingsModal = document.getElementById('settingsModal');
  const openSettingsBtn = document.getElementById('openSettingsBtn');
  const closeSettingsBtn = document.getElementById('closeSettingsBtn');
  const saveSettingsBtn = document.getElementById('saveSettingsBtn');

  openSettingsBtn?.addEventListener('click', async () => {
    if (settingsModal) settingsModal.classList.remove('hidden');
    settingsModal?.classList.add('flex');
    await loadSettingsForm();
  });

  closeSettingsBtn?.addEventListener('click', () => {
    if (settingsModal) settingsModal.classList.add('hidden');
    settingsModal?.classList.remove('flex');
  });

  settingsModal?.addEventListener('click', (e) => {
    if (e.target === settingsModal) {
      settingsModal.classList.add('hidden');
      settingsModal.classList.remove('flex');
    }
  });

  async function loadSettingsForm() {
    try {
      // Load jurisdictions
      const jurisdRes = await fetch('/api/available-jurisdictions');
      const jurisdData = await jurisdRes.json();
      const jurisdictions = jurisdData.jurisdictions || [];

      // Load current settings
      const settingsRes = await fetch('/api/permit-settings');
      const settingsData = await settingsRes.json();
      const settings = settingsData.settings || {};

      // Display enable/disable
      const enableCheckbox = document.getElementById('enableAutomation') as HTMLInputElement;
      if (enableCheckbox) enableCheckbox.checked = settings.enabled !== false;

      // Display min score
      const minScoreInput = document.getElementById('minScore') as HTMLInputElement;
      if (minScoreInput) minScoreInput.value = String(settings.minScore || 0);

      // Display archive days
      const archiveDaysInput = document.getElementById('archiveDays') as HTMLInputElement;
      if (archiveDaysInput) archiveDaysInput.value = String(settings.archiveDays || 60);

      // Display territories
      const container = document.getElementById('territoriesCheckboxes');
      if (container) {
        container.innerHTML = jurisdictions.map((j: string) => {
          const isSelected = Array.isArray(settings.allowedTerritories) && settings.allowedTerritories.includes(j);
          return `
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="jurisdiction-checkbox w-4 h-4" value="${j}" ${isSelected ? 'checked' : ''}>
              <span class="text-sm text-slate-700">${j}</span>
            </label>
          `;
        }).join('');
      }
    } catch (error) {
      console.error(error);
    }
  }

  saveSettingsBtn?.addEventListener('click', async () => {
    try {
      const enableCheckbox = document.getElementById('enableAutomation') as HTMLInputElement;
      const minScoreInput = document.getElementById('minScore') as HTMLInputElement;
      const archiveDaysInput = document.getElementById('archiveDays') as HTMLInputElement;
      const checkboxes = document.querySelectorAll('.jurisdiction-checkbox:checked') as NodeListOf<HTMLInputElement>;

      const selectedTerritories = Array.from(checkboxes).map(cb => cb.value);

      const response = await fetch('/api/permit-settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          enabled: enableCheckbox?.checked || false,
          minScore: Number(minScoreInput?.value || 0),
          allowedTerritories: selectedTerritories,
          archiveDays: Number(archiveDaysInput?.value || 60),
        }),
      });

      const result = await response.json();
      if (result.ok) {
        alert('Settings saved! Run now to scrape selected territories.');
        if (settingsModal) {
          settingsModal.classList.add('hidden');
          settingsModal.classList.remove('flex');
        }
      } else {
        alert('Failed to save settings: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      console.error(error);
      alert('Error saving settings');
    }
  });
</script>
