---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <div id="profileModal" class="fixed inset-0 z-[250] hidden items-center justify-center bg-slate-950/50 p-4 backdrop-blur-sm">
    <div class="max-h-[90vh] w-full max-w-3xl overflow-y-auto rounded-3xl border border-slate-200 bg-white shadow-2xl">
      <div class="sticky top-0 z-10 flex items-start justify-between gap-4 border-b border-slate-100 bg-white/95 p-5 backdrop-blur md:p-7">
        <div><p class="text-[9px] font-bold uppercase tracking-[0.2em] text-amber-700">Unclaimed profile details</p><h2 id="modalTitle" class="mt-2 text-xl font-bold text-slate-950">Profile</h2><p id="modalEquipment" class="mt-1 text-sm font-medium text-green-700"></p></div>
        <button id="closeProfileModal" type="button" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-slate-200 text-lg text-slate-500 hover:bg-slate-50">×</button>
      </div>
      <div id="modalContent" class="p-5 md:p-7"></div>
    </div>
  </div>

  <div class="mx-auto flex w-full max-w-7xl flex-col gap-6">
    <div class="flex flex-col justify-between gap-4 border-b border-slate-200 pb-6 sm:flex-row sm:items-end">
      <div><p class="text-[10px] font-bold uppercase tracking-[0.22em] text-amber-700">Acquisition directory</p><h1 class="mt-2 text-2xl font-bold text-slate-950">Unclaimed truck profiles</h1><p class="mt-2 text-sm text-slate-500">Imported public listings. These profiles are unverified and cannot receive leads.</p></div>
      <a href="/truck-directory" target="_blank" class="inline-flex h-11 items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-[10px] font-bold uppercase tracking-wider text-slate-600">View public directory ↗</a>
    </div>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
      <div class="stat-card"><p class="stat-card__label">Total imported</p><strong id="statTotal" class="stat-card__value">-</strong></div>
      <div class="stat-card"><p class="stat-card__label">Published</p><strong id="statPublished" class="stat-card__value text-green-700">-</strong></div>
      <div class="stat-card"><p class="stat-card__label">Claim pending</p><strong id="statPending" class="stat-card__value text-amber-600">-</strong></div>
      <div class="stat-card"><p class="stat-card__label">Claimed</p><strong id="statClaimed" class="stat-card__value text-blue-600">-</strong></div>
    </div>

    <div class="flex flex-col gap-3 rounded-2xl border border-slate-200 bg-white p-4 sm:flex-row">
      <input id="search" type="search" placeholder="Search company, equipment or location…" class="filter-input flex-1" />
      <select id="status" class="filter-input"><option value="">All statuses</option><option value="unclaimed">Unclaimed</option><option value="claim_pending">Claim pending</option><option value="claimed">Claimed</option><option value="hidden">Hidden</option></select>
    </div>
    <div id="profiles" class="space-y-3"><div class="p-10 text-center text-sm text-slate-400">Loading directory…</div></div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";
  let rows: any[] = [];
  const escape = (value: unknown) => String(value || '').replace(/[&<>"']/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[char] || char));

  async function load() {
    const { data, error } = await supabase.from('unclaimed_truck_directory').select('*').order('created_at', { ascending: false });
    if (error) {
      document.getElementById('profiles')!.innerHTML = `<div class="rounded-xl border border-red-200 bg-red-50 p-5 text-sm text-red-700">${escape(error.message)}</div>`;
      return;
    }
    rows = data || [];
    document.getElementById('statTotal')!.textContent = String(rows.length);
    document.getElementById('statPublished')!.textContent = String(rows.filter((row) => row.is_published).length);
    document.getElementById('statPending')!.textContent = String(rows.filter((row) => row.profile_status === 'claim_pending').length);
    document.getElementById('statClaimed')!.textContent = String(rows.filter((row) => row.profile_status === 'claimed').length);
    render();
  }

  function render() {
    const query = (document.getElementById('search') as HTMLInputElement).value.trim().toLowerCase();
    const status = (document.getElementById('status') as HTMLSelectElement).value;
    const filtered = rows.filter((row) => {
      const haystack = `${row.company_name} ${row.equipment_name} ${row.location_city} ${row.location_state}`.toLowerCase();
      return (!query || haystack.includes(query)) && (!status || row.profile_status === status);
    });
    document.getElementById('profiles')!.innerHTML = filtered.length ? filtered.map((row) => `
      <article class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm lg:flex-row lg:items-center">
        <div class="min-w-0 flex-1"><div class="flex flex-wrap items-center gap-2"><h2 class="text-sm font-bold text-slate-900">${escape(row.company_name)}</h2><span class="rounded-full bg-amber-50 px-2 py-1 text-[8px] font-bold uppercase text-amber-700">${escape(row.profile_status)}</span>${!row.is_published ? '<span class="rounded-full bg-slate-100 px-2 py-1 text-[8px] font-bold uppercase text-slate-500">Hidden</span>' : ''}</div><p class="mt-1 text-xs font-medium text-green-700">${escape(row.equipment_name)}</p><p class="mt-2 text-[10px] text-slate-400">${escape([row.location_city, row.location_state].filter(Boolean).join(', '))} · ${row.lift_capacity_tons || '—'} ton · ${row.working_height_ft || '—'} ft · Source: ${escape(row.source_name)}</p></div>
        <div class="flex shrink-0 gap-2"><button data-id="${row.id}" class="details-btn rounded-lg bg-slate-950 px-3 py-2 text-[9px] font-bold uppercase text-white hover:bg-green-700">Details</button><a href="${escape(row.source_url)}" target="_blank" rel="noopener" class="rounded-lg border border-slate-200 px-3 py-2 text-[9px] font-bold uppercase text-slate-500">Source ↗</a><button data-id="${row.id}" data-published="${row.is_published}" class="visibility-btn rounded-lg border border-slate-200 px-3 py-2 text-[9px] font-bold uppercase text-slate-600">${row.is_published ? 'Hide' : 'Publish'}</button></div>
      </article>`).join('') : '<div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center text-sm text-slate-400">No matching profiles.</div>';
    document.querySelectorAll('.details-btn').forEach((button) => button.addEventListener('click', () => {
      const row = rows.find((item) => item.id === (button as HTMLButtonElement).dataset.id);
      if (row) openDetails(row);
    }));
    document.querySelectorAll('.visibility-btn').forEach((button) => button.addEventListener('click', async () => {
      const element = button as HTMLButtonElement;
      element.disabled = true;
      await supabase.from('unclaimed_truck_directory').update({ is_published: element.dataset.published !== 'true', updated_at: new Date().toISOString() }).eq('id', element.dataset.id);
      load();
    }));
  }

  function detail(label: string, value: unknown) {
    if (value === null || value === undefined || value === '') return '';
    return `<div class="rounded-xl bg-slate-50 p-4"><dt class="text-[9px] font-bold uppercase tracking-wider text-slate-400">${escape(label)}</dt><dd class="mt-1 break-words text-sm font-medium leading-5 text-slate-700">${escape(value)}</dd></div>`;
  }

  function openDetails(row: any) {
    document.getElementById('modalTitle')!.textContent = row.company_name || 'Profile';
    document.getElementById('modalEquipment')!.textContent = row.equipment_name || '';
    const payload = row.source_payload || {};
    document.getElementById('modalContent')!.innerHTML = `
      <div class="mb-5 flex flex-wrap gap-2"><span class="rounded-full bg-amber-50 px-3 py-1.5 text-[9px] font-bold uppercase text-amber-700">${escape(row.profile_status)}</span><span class="rounded-full bg-slate-100 px-3 py-1.5 text-[9px] font-bold uppercase text-slate-600">${escape(row.verification_status)}</span>${row.is_published ? '<span class="rounded-full bg-green-50 px-3 py-1.5 text-[9px] font-bold uppercase text-green-700">Published</span>' : '<span class="rounded-full bg-slate-100 px-3 py-1.5 text-[9px] font-bold uppercase text-slate-500">Hidden</span>'}</div>
      <h3 class="mb-3 text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Public contact</h3>
      <dl class="grid gap-3 sm:grid-cols-2">${detail('Email', payload.public_email || 'Not listed')}${detail('Phone', payload.public_phone || 'Not listed')}${detail('Website', payload.public_website || 'Not listed')}${detail('Location', [row.location_city, row.location_state].filter(Boolean).join(', ') || 'Not listed')}</dl>
      <h3 class="mb-3 mt-7 text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Equipment specifications</h3>
      <dl class="grid gap-3 sm:grid-cols-2">${detail('Manufacturer', row.manufacturer)}${detail('Model', row.model)}${detail('Capacity', row.lift_capacity_tons ? `${row.lift_capacity_tons} tons` : null)}${detail('Working height', row.working_height_ft ? `${row.working_height_ft} ft` : null)}${detail('Service radius', row.service_radius_miles ? `${row.service_radius_miles} miles` : null)}${detail('Storm radius', row.storm_radius_miles ? `${row.storm_radius_miles} miles` : null)}${detail('Listing type', row.listing_type)}${detail('Insurance claim', row.insurance_claim)}${detail('Access', row.access_notes)}${detail('Availability', row.availability_notes)}${detail('Operator experience', row.operator_experience)}</dl>
      ${row.description ? `<div class="mt-7"><h3 class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Description</h3><p class="mt-3 whitespace-pre-line text-sm leading-6 text-slate-600">${escape(row.description)}</p></div>` : ''}
      <div class="mt-7 flex flex-wrap gap-2 border-t border-slate-100 pt-5"><a href="/truck-directory/profile/${encodeURIComponent(row.slug)}" target="_blank" class="rounded-xl bg-green-600 px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-white">Open public profile ↗</a><a href="${escape(row.source_url)}" target="_blank" rel="noopener" class="rounded-xl border border-slate-200 px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-600">Open source ↗</a></div>`;
    const modal = document.getElementById('profileModal')!;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeDetails() {
    const modal = document.getElementById('profileModal')!;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
  document.getElementById('closeProfileModal')?.addEventListener('click', closeDetails);
  document.getElementById('profileModal')?.addEventListener('click', (event) => {
    if (event.target === event.currentTarget) closeDetails();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDetails();
  });
  document.getElementById('search')?.addEventListener('input', render);
  document.getElementById('status')?.addEventListener('change', render);
  load();
</script>
