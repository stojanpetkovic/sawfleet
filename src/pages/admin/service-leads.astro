---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabase } from "../../lib/supabase";

// POVLAČIMO TERITORIJE IZ BAZE
const { data: territories } = await supabase.from('service_territories').select('*').order('name');
---

<AdminLayout>
  <!-- Floating Plus Dugme -->
  <button id="openModal" aria-label="Add service lead" title="Add service lead" class="admin-fab admin-fab--icon fixed bottom-24 lg:bottom-8 right-5 lg:right-8 w-14 h-14 bg-green-500 hover:bg-green-400 text-white rounded-full shadow-lg flex items-center justify-center text-2xl font-bold transition-all z-[100]">
    +
  </button>

  <!-- Modal za dodavanje -->
  <div id="leadModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-white border border-zinc-200 p-6 md:p-8 rounded-xl max-w-md w-full max-h-[90vh] overflow-y-auto">
      <h2 class="text-slate-900 font-bold mb-6">Add New Lead</h2>
      <form id="addLeadForm" class="space-y-4">
        <input type="email" id="newEmail" placeholder="Email" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        <input type="text" id="newPhone" placeholder="Phone" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        
        <!-- DINAMIČKI PADAKUĆI MENI ZA DODAVANJE -->
        <select id="newCounty" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required>
          <option value="" disabled selected>Select County</option>
          {territories?.map(t => (
            <option value={t.name}>{t.name}</option>
          ))}
        </select>

        <textarea id="newDetails" placeholder="Details" class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900"></textarea>
        <div class="flex gap-4 mt-6">
          <button type="button" id="closeModal" class="flex-1 bg-zinc-200 p-3 rounded text-slate-900">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-slate-900 font-bold">Save Lead</button>
        </div>
      </form>
    </div>
  </div>

  <div class="dash-shell flex-1">
  <div class="dash-shell__frozen">
    <!-- HEADER -->
    <div>
      <span class="dash-eyebrow text-green-700">// Demand pipeline</span>
      <h1 class="dash-title">Website leads</h1>
      <p class="dash-subtitle">Every homeowner request that came through the website and its traffic sources.</p>
    </div>

    <!-- Website Leads Stats -->
    <div class="stat-row lg:grid-cols-5">
      <div class="stat-card">
        <p class="stat-card__label">Total</p>
        <h2 id="count-total" class="stat-card__value">0</h2>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">New</p>
        <p id="count-new" class="stat-card__value">-</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">Approved</p>
        <p id="count-approved" class="stat-card__value text-green-700">-</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">Claimed</p>
        <p id="count-claimed" class="stat-card__value text-blue-600">-</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">Rejected</p>
        <p id="count-rejected" class="stat-card__value text-red-600">-</p>
      </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
        <select id="statusFilter" class="filter-select">
          <option value="all">All Statuses</option>
          <option value="new">New</option>
          <option value="approved">Approved</option>
          <option value="claimed">Claimed</option>
          <option value="rejected">Rejected</option>
        </select>

        <select id="countyFilter" class="filter-select">
          <option value="all">All Counties</option>
          {territories?.map(t => (
            <option value={t.name}>{t.name}</option>
          ))}
        </select>

        <select id="timeFilter" class="filter-select">
          <option value="all">All Time</option>
          <option value="7">Last 7 Days</option>
          <option value="30">Last 30 Days</option>
          <option value="custom">Custom Range</option>
        </select>

        <select id="sourceFilter" class="filter-select">
          <option value="all">All Sources</option>
          <option value="website">Website</option>
          <option value="permit_automation">Permit Automation</option>
          <option value="permit_outreach">Permit Outreach</option>
        </select>

        <select id="perPage" class="filter-select">
          <option value="10">10 / page</option>
          <option value="50">50 / page</option>
        </select>
      </div>

      <div id="customDateRange" class="hidden flex flex-wrap gap-2 items-center bg-zinc-100 border border-zinc-200 p-3 rounded-xl">
        <input type="date" id="dateFrom" class="bg-transparent text-[11px] text-zinc-700 outline-none h-6" />
        <span class="text-zinc-400 font-bold text-[10px]">TO</span>
        <input type="date" id="dateTo" class="bg-transparent text-[11px] text-zinc-700 outline-none h-6" />
        <button id="applyDateBtn" class="ml-auto bg-green-500 text-slate-900 px-3 py-1.5 rounded-lg text-[9px] font-bold uppercase hover:bg-green-400">Apply</button>
      </div>
  </div>

  <div class="dash-scroll">
    <div class="flex flex-col xl:flex-row gap-6 lg:gap-8 w-full">
      <div class="flex-1 space-y-3 min-w-0 w-full">
        <!-- LIST -->
        <div id="allLeadsTable" class="space-y-2">
          <div class="p-8 text-center text-zinc-400 text-sm">Loading...</div>
        </div>

        <!-- PAGINATION -->
        <div class="dash-pagination">
          <button id="prevPage" class="h-10 px-4 rounded-full bg-zinc-100 border border-zinc-200 text-[11px] font-bold text-zinc-700 hover:text-slate-900 hover:border-zinc-300 transition-colors">← Prev</button>
          <span id="pageInfo" class="text-[11px] text-zinc-500 font-mono">Page 1</span>
          <button id="nextPage" class="h-10 px-4 rounded-full bg-zinc-100 border border-zinc-200 text-[11px] font-bold text-zinc-700 hover:text-slate-900 hover:border-zinc-300 transition-colors">Next →</button>
        </div>
      </div>

      <!-- Sidebar Logovi -->
      <div class="w-full xl:w-[400px] shrink-0">
        <div class="bg-white border border-zinc-100 rounded-2xl w-full">
          <div class="p-6 border-b border-zinc-100">
            <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Activity Timeline</h3>
          </div>
          <div class="p-6">
            <div id="leadLogsContainer" class="space-y-6">
              <div class="text-[11px] font-mono text-zinc-500">Loading logs...</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";
  let currentPage = 0;

  function timeAgo(dateInput: string) {
    const date = new Date(dateInput);
    const now = new Date();
    const diffInSeconds = Math.floor((now.getTime() - date.getTime()) / 1000);
    
    if (diffInSeconds < 60) return 'Just now';
    if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)}m ago`;
    if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)}h ago`;
    return `${Math.floor(diffInSeconds / 86400)}d ago`;
  }

  async function loadLogs() {
    const { data: leadLogs } = await supabase
      .from('lead_logs')
      .select('*, leads(email, source)')
      .order('created_at', { ascending: false })
      .limit(10);
    
    const llContainer = document.getElementById('leadLogsContainer');
    if (llContainer && leadLogs) {
      llContainer.innerHTML = leadLogs.length > 0 ? leadLogs.map(log => `
        <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-200 before:border-2 before:border-slate-200 before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-24px] after:w-[2px] after:bg-zinc-100 last:after:hidden">
          <p class="text-[10px] text-zinc-600 font-mono mb-1 truncate">${log.leads?.email || 'Unknown Lead'}</p>
          <p class="text-[11px] text-slate-900 font-bold leading-tight">${log.action || log.status || 'Updated'}</p>
          <div class="flex items-center gap-2 mt-2">
            <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-700 font-bold tracking-wider uppercase">${log.user_email || log.changed_by || 'Stojan M.'}</span></span>
            <span class="text-[7px] text-zinc-300">●</span>
            <span class="text-[9px] text-zinc-400">${timeAgo(log.created_at)}</span>
          </div>
        </div>
      `).join('') : '<div class="text-[10px] text-zinc-500 italic">No activity recorded yet.</div>';
    }
  }

  async function updateDashboard() {
    const timeFilter = (document.getElementById('timeFilter') as HTMLSelectElement).value;
    const statusFilter = (document.getElementById('statusFilter') as HTMLSelectElement).value;
    const countyFilter = (document.getElementById('countyFilter') as HTMLSelectElement).value;
    const sourceFilter = (document.getElementById('sourceFilter') as HTMLSelectElement).value;
    const dateFrom = (document.getElementById('dateFrom') as HTMLInputElement).value;
    const dateTo = (document.getElementById('dateTo') as HTMLInputElement).value;
    const itemsPerPage = parseInt((document.getElementById('perPage') as HTMLSelectElement).value);
    
    const customUI = document.getElementById('customDateRange');
    timeFilter === 'custom' ? customUI?.classList.remove('hidden') : customUI?.classList.add('hidden');

    let countQuery = supabase.from('leads').select('status', { count: 'exact', head: false });
    const { data: allData, count: totalCount } = await countQuery;
    if (allData || totalCount !== null) {
      const countTotalEl = document.getElementById('count-total');
      if (countTotalEl) countTotalEl.textContent = (totalCount ?? allData?.length ?? 0).toString();
      // UPDATE STATUS COUNTERS
      const newCount = allData?.filter(l => !l.status || l.status === 'new').length ?? 0;
      const approvedCount = allData?.filter(l => l.status === 'approved').length ?? 0;
      const claimedCount = allData?.filter(l => l.status === 'claimed').length ?? 0;
      const rejectedCount = allData?.filter(l => l.status === 'rejected').length ?? 0;
      document.getElementById('count-new')!.textContent = newCount.toString();
      document.getElementById('count-approved')!.textContent = approvedCount.toString();
      document.getElementById('count-claimed')!.textContent = claimedCount.toString();
      document.getElementById('count-rejected')!.textContent = rejectedCount.toString();
    }

    let query = supabase.from('leads').select('*');
    if (statusFilter !== 'all') query = query.eq('status', statusFilter);
    if (countyFilter !== 'all') query = query.eq('county', countyFilter);
    if (sourceFilter === 'website') {
      query = query.in('source', ['website', 'google', 'facebook', 'bing', 'organic', 'website_form']);
    } else if (sourceFilter !== 'all') {
      query = query.eq('source', sourceFilter);
    }
    
    if (timeFilter === '7') query = query.gte('created_at', new Date(Date.now() - 7*86400000).toISOString());
    if (timeFilter === '30') query = query.gte('created_at', new Date(Date.now() - 30*86400000).toISOString());
    if (timeFilter === 'custom') {
        if (dateFrom) query = query.gte('created_at', dateFrom);
        if (dateTo) {
            const d = new Date(dateTo);
            d.setDate(d.getDate() + 1);
            query = query.lte('created_at', d.toISOString());
        }
    }
    
    const { data: leads } = await query.order('created_at', { ascending: false }).range(currentPage * itemsPerPage, (currentPage + 1) * itemsPerPage - 1);

    const listEl = document.getElementById('allLeadsTable');
    if (listEl && leads) {
      listEl.innerHTML = leads.length > 0 ? leads.map(lead => {
        const statusStyles: Record<string, string> = {
          approved: 'bg-green-500/10 text-green-700 border-green-500/20',
          claimed: 'bg-blue-500/10 text-blue-600 border-blue-500/20',
          rejected: 'bg-red-500/10 text-red-600 border-red-500/20',
        };
        const statusClass = statusStyles[lead.status] || 'bg-zinc-200/50 text-zinc-600 border-zinc-300';
        const sourceValue = (lead.source || 'website').toString();
        const sourceLabel = sourceValue.includes('permit') ? 'Permit dispatch' : sourceValue === 'dispatcher_manual' ? 'Dispatcher' : ['website', 'google', 'facebook', 'bing', 'organic', 'website_form'].includes(sourceValue) ? 'Website' : 'External';
        const sourceClass = sourceLabel === 'Permit dispatch' ? 'bg-amber-500/10 text-amber-700 border-amber-500/20' : sourceLabel === 'External' ? 'bg-teal-500/10 text-teal-700 border-teal-500/20' : sourceLabel === 'Dispatcher' ? 'bg-violet-500/10 text-violet-700 border-violet-500/20' : 'bg-slate-100 text-slate-700 border-slate-200';
        const initial = (lead.email || '?').charAt(0).toUpperCase();
        return `
        <div class="group flex items-center gap-3 sm:gap-4 p-3 sm:p-4 rounded-2xl border border-zinc-100 bg-white hover:border-zinc-300 hover:bg-zinc-100/40 transition-all cursor-pointer" onclick="window.location.href='/admin/leads/${lead.id}'">
          <div class="w-10 h-10 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0 text-xs font-bold text-zinc-600">${initial}</div>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-bold text-slate-900 truncate">${lead.email || 'No email'}</p>
            <div class="mt-0.5 flex items-center gap-2 text-[11px] text-zinc-500 font-mono truncate">
              <span>${lead.county || 'No county'}</span>
              <span class="text-zinc-300">·</span>
              <span>${lead.created_at ? new Date(lead.created_at).toLocaleDateString() : 'N/A'}</span>
            </div>
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide ${sourceClass}">${sourceLabel}</span>
            ${lead.phone ? `<a href="tel:${lead.phone}" onclick="event.stopPropagation()" class="w-8 h-8 rounded-full flex items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title="${lead.phone}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </a>` : ''}
            ${lead.email ? `<a href="mailto:${lead.email}" onclick="event.stopPropagation()" class="hidden sm:flex w-8 h-8 rounded-full items-center justify-center text-zinc-500 hover:text-green-700 hover:bg-green-500/10 transition-colors" title="${lead.email}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>` : ''}
            <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase border tracking-wide ${statusClass}">${lead.status || 'New'}</span>
            <svg class="hidden sm:block w-4 h-4 text-zinc-300 group-hover:text-zinc-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      `}).join('') : '<div class="p-8 text-center text-zinc-400 text-sm border border-dashed border-zinc-100 rounded-2xl">No results match these filters.</div>';
    }
    document.getElementById('pageInfo')!.textContent = `Page ${currentPage + 1}`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('leadModal');
    document.getElementById('openModal')?.addEventListener('click', () => modal?.classList.remove('hidden'));
    document.getElementById('closeModal')?.addEventListener('click', () => modal?.classList.add('hidden'));

    document.getElementById('addLeadForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const response = await fetch('/api/website-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
        email: (document.getElementById('newEmail') as HTMLInputElement).value,
        phone: (document.getElementById('newPhone') as HTMLInputElement).value,
        county: (document.getElementById('newCounty') as HTMLSelectElement).value,
        details: (document.getElementById('newDetails') as HTMLTextAreaElement).value,
        source: 'dispatcher_manual',
        customerSubmitted: false,
        }),
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || !result.ok) {
        alert('Could not publish lead: ' + (result.error || 'Unknown error'));
        return;
      }
      modal?.classList.add('hidden');
      (e.target as HTMLFormElement).reset();
      updateDashboard();
      loadLogs();
    });

    document.getElementById('applyDateBtn')?.addEventListener('click', () => { currentPage = 0; updateDashboard(); });
    document.querySelectorAll('select').forEach(sel => sel.addEventListener('change', () => { currentPage = 0; updateDashboard(); }));
    document.getElementById('nextPage')?.addEventListener('click', () => { currentPage++; updateDashboard(); });
    document.getElementById('prevPage')?.addEventListener('click', () => { if(currentPage > 0) currentPage--; updateDashboard(); });
    
    updateDashboard();
    loadLogs();
  });
</script>
