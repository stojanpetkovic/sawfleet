---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <div class="w-full max-w-7xl mx-auto space-y-6 md:space-y-8 font-sans">
    
    <!-- HEADER -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-slate-800 pb-6">
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-white tracking-wide">Traffic & Lead Analytics</h1>
        <p class="text-[9px] md:text-[10px] uppercase tracking-[0.2em] text-slate-500 mt-1 md:mt-2">Performance and acquisition sources</p>
      </div>
      
      <select id="analyticsFilter" class="w-full sm:w-auto bg-slate-900 border border-slate-700 text-[10px] font-bold uppercase tracking-[0.2em] p-3 rounded-lg text-slate-300 outline-none focus:border-green-500/50 transition-colors cursor-pointer">
        <option value="7">Last 7 Days</option>
        <option value="30">Last 30 Days</option>
        <option value="90">Last 90 Days</option>
      </select>
    </div>

    <!-- KARTICE SA STATISTIKOM PO IZVORIMA -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      <!-- Total Leads -->
      <div class="bg-slate-900 border border-slate-800 p-4 md:p-6 rounded-2xl shadow-sm hover:border-slate-700 transition-colors">
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">Total Leads</p>
        <h2 id="stat-total" class="text-3xl font-bold text-white mt-2 tracking-tighter">0</h2>
      </div>
      <!-- Google Ads -->
      <div class="bg-slate-900 border border-slate-800 p-4 md:p-6 rounded-2xl border-t-4 border-t-blue-500 shadow-sm hover:border-slate-700 transition-colors relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/10 blur-[30px] rounded-full pointer-events-none"></div>
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-blue-400 relative z-10">Google Ads</p>
        <h2 id="stat-google" class="text-3xl font-bold text-white mt-2 tracking-tighter relative z-10">0</h2>
      </div>
      <!-- Meta / FB -->
      <div class="bg-slate-900 border border-slate-800 p-4 md:p-6 rounded-2xl border-t-4 border-t-purple-500 shadow-sm hover:border-slate-700 transition-colors relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-purple-500/10 blur-[30px] rounded-full pointer-events-none"></div>
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-purple-400 relative z-10">Meta / FB</p>
        <h2 id="stat-meta" class="text-3xl font-bold text-white mt-2 tracking-tighter relative z-10">0</h2>
      </div>
      <!-- Organic -->
      <div class="bg-slate-900 border border-slate-800 p-4 md:p-6 rounded-2xl border-t-4 border-t-green-500 shadow-sm hover:border-slate-700 transition-colors relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-green-500/10 blur-[30px] rounded-full pointer-events-none"></div>
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-green-400 relative z-10">Organic</p>
        <h2 id="stat-organic" class="text-3xl font-bold text-white mt-2 tracking-tighter relative z-10">0</h2>
      </div>
    </div>

    <!-- GRAFIKONI -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
      
      <!-- GLAVNI GRAFIKON (Trendovi) -->
      <div class="lg:col-span-2 bg-slate-900 border border-slate-800 p-6 md:p-8 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)]">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-6">Lead Volume Trend</h3>
        <div class="relative w-full h-[250px] md:h-[350px]">
          <canvas id="lineChart"></canvas>
        </div>
      </div>

      <!-- DOUGHNUT GRAFIKON (Izvori) -->
      <div class="lg:col-span-1 bg-slate-900 border border-slate-800 p-6 md:p-8 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)] flex flex-col">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-6">Acquisition Source</h3>
        <div class="relative w-full flex-1 min-h-[250px] flex items-center justify-center">
          <canvas id="donutChart"></canvas>
        </div>
      </div>

    </div>
    
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import Chart from 'chart.js/auto';

  let lineChart: any = null;
  let donutChart: any = null;

  async function updateAnalytics(days: string) {
    const date = new Date();
    date.setDate(date.getDate() - parseInt(days));
    
    // Povlačimo i kolonu "source" iz tabele leads
    const { data: leads } = await supabase
      .from('leads')
      .select('created_at, status, source')
      .gte('created_at', date.toISOString());

    if (!leads) return;

    // 1. OBRADA PODATAKA ZA IZVORE
    let google = 0, meta = 0, organic = 0, other = 0;

    leads.forEach(lead => {
      const src = lead.source ? lead.source.toLowerCase() : 'organic'; 
      if (src.includes('google') || src.includes('gads')) google++;
      else if (src.includes('fb') || src.includes('facebook') || src.includes('meta') || src.includes('ig') || src.includes('instagram')) meta++;
      else if (src.includes('organic') || src.includes('direct') || src.includes('seo')) organic++;
      else other++;
    });

    // Ažuriranje brojčanih kartica
    document.getElementById('stat-total')!.textContent = leads.length.toString();
    document.getElementById('stat-google')!.textContent = google.toString();
    document.getElementById('stat-meta')!.textContent = meta.toString();
    document.getElementById('stat-organic')!.textContent = organic.toString();

    // 2. OBRADA PODATAKA ZA VREMENSKI TREND (Line Chart)
    const labels: string[] = [];
    const counts: number[] = [];
    
    for (let i = parseInt(days) - 1; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      // Koristimo kratki format datuma za lepši prikaz
      const dateStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      labels.push(dateStr);
      counts.push(leads.filter(l => new Date(l.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) === dateStr).length);
    }

    // 3. CRTANJE LINE GRAFIKONA
    const lineCtx = document.getElementById('lineChart') as HTMLCanvasElement;
    if (lineChart) lineChart.destroy();
    
    lineChart = new Chart(lineCtx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Leads',
          data: counts,
          borderColor: '#22c55e',
          backgroundColor: 'rgba(34, 197, 94, 0.05)',
          borderWidth: 2,
          pointBackgroundColor: '#0f172a', // slate-900 (boja pozadine)
          pointBorderColor: '#22c55e',
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6,
          fill: true,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },
        scales: { 
          y: { beginAtZero: true, ticks: { color: '#64748b', stepSize: 1 }, grid: { color: '#1e293b' } }, 
          x: { ticks: { color: '#64748b' }, grid: { color: '#1e293b' } } 
        },
        interaction: { mode: 'nearest', axis: 'x', intersect: false }
      }
    });

    // 4. CRTANJE DOUGHNUT GRAFIKONA
    const donutCtx = document.getElementById('donutChart') as HTMLCanvasElement;
    if (donutChart) donutChart.destroy();

    donutChart = new Chart(donutCtx, {
      type: 'doughnut',
      data: {
        labels: ['Google Ads', 'Meta / FB', 'Organic', 'Other'],
        datasets: [{
          data: [google, meta, organic, other],
          backgroundColor: [
            '#3b82f6', // Plava (Google)
            '#a855f7', // Ljubičasta (Meta)
            '#22c55e', // Zelena (Organic)
            '#334155'  // Slate (Other)
          ],
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '75%', // Debljina krofne
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#94a3b8', font: { family: 'monospace', size: 10 }, padding: 20 }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                let label = context.label || '';
                if (label) { label += ': '; }
                if (context.parsed !== null) { label += context.parsed; }
                return label;
              }
            }
          }
        }
      }
    });
  }

  document.getElementById('analyticsFilter')?.addEventListener('change', (e) => {
    updateAnalytics((e.target as HTMLSelectElement).value);
  });

  // Pokrećemo početno iscrtavanje
  updateAnalytics('7');
</script>