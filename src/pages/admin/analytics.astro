---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <div class="w-full flex flex-col gap-8 min-w-0">
    
    <!-- HEADER -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-zinc-900 pb-6">
      <div>
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Traffic & Conversions</span>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-white sm:text-3xl">Analytics & Performance</h1>
      </div>
      
      <select id="analyticsFilter" class="w-full sm:w-auto bg-[#050505] border border-zinc-800 text-[10px] font-bold uppercase tracking-[0.2em] p-3 rounded-lg text-zinc-300 outline-none focus:border-green-500/50 transition-colors cursor-pointer">
        <option value="7">Last 7 Days</option>
        <option value="30">Last 30 Days</option>
        <option value="90">Last 90 Days</option>
      </select>
    </div>

    <!-- KARTICE SA STATISTIKOM -->
    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4 md:gap-6 w-full">
      
      <!-- Total Leads -->
      <div class="bg-[#050505] border border-zinc-900 p-5 rounded-xl shadow-xl hover:border-zinc-800 transition-colors flex flex-col justify-between">
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Total Leads</p>
        <h2 id="stat-total" class="text-2xl font-mono font-bold text-white mt-4">-</h2>
      </div>

      <!-- Claimed Leads -->
      <div class="bg-[#050505] border border-zinc-900 p-5 rounded-xl border-t-2 border-t-green-500 shadow-xl hover:border-zinc-800 transition-colors relative overflow-hidden flex flex-col justify-between">
        <div class="absolute top-0 right-0 w-24 h-24 bg-green-500/5 blur-[30px] rounded-full pointer-events-none"></div>
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-green-500 relative z-10">Claimed</p>
        <h2 id="stat-claimed" class="text-2xl font-mono font-bold text-white mt-4 relative z-10">-</h2>
      </div>

      <!-- Conversion Rate -->
      <div class="bg-[#050505] border border-zinc-900 p-5 rounded-xl border-t-2 border-t-blue-500 shadow-xl hover:border-zinc-800 transition-colors relative overflow-hidden flex flex-col justify-between">
        <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 blur-[30px] rounded-full pointer-events-none"></div>
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-blue-400 relative z-10">Conversion</p>
        <h2 id="stat-conversion" class="text-2xl font-mono font-bold text-white mt-4 relative z-10">-</h2>
      </div>
      
      <!-- Google Ads -->
      <div class="bg-[#050505] border border-zinc-900 p-5 rounded-xl shadow-xl hover:border-zinc-800 transition-colors flex flex-col justify-between">
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Google Ads</p>
        <h2 id="stat-google" class="text-2xl font-mono font-bold text-white mt-4">-</h2>
      </div>

      <!-- Meta / FB -->
      <div class="bg-[#050505] border border-zinc-900 p-5 rounded-xl shadow-xl hover:border-zinc-800 transition-colors flex flex-col justify-between">
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Meta / FB</p>
        <h2 id="stat-meta" class="text-2xl font-mono font-bold text-white mt-4">-</h2>
      </div>

      <!-- Organic -->
      <div class="bg-[#050505] border border-zinc-900 p-5 rounded-xl shadow-xl hover:border-zinc-800 transition-colors flex flex-col justify-between">
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Organic</p>
        <h2 id="stat-organic" class="text-2xl font-mono font-bold text-white mt-4">-</h2>
      </div>
    </div>

    <!-- GRAFIKONI -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 w-full">
      
      <!-- GLAVNI GRAFIKON (Trendovi) -->
      <div class="xl:col-span-2 bg-[#050505] border border-zinc-900 p-6 md:p-8 rounded-xl shadow-xl flex flex-col">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">Lead Volume vs Conversion Trend</h3>
          <div class="flex gap-4">
            <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-500"></span><span class="text-[9px] text-zinc-400 font-mono">Total</span></div>
            <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-500"></span><span class="text-[9px] text-zinc-400 font-mono">Claimed</span></div>
          </div>
        </div>
        <div class="relative w-full flex-1 min-h-[250px] md:min-h-[350px]">
          <canvas id="lineChart"></canvas>
        </div>
      </div>

      <!-- DOUGHNUT GRAFIKON (Izvori) -->
      <div class="xl:col-span-1 bg-[#050505] border border-zinc-900 p-6 md:p-8 rounded-xl shadow-xl flex flex-col">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6">Acquisition Source</h3>
        <div class="relative w-full flex-1 min-h-[250px] flex items-center justify-center">
          <canvas id="donutChart"></canvas>
        </div>
      </div>

    </div>
    
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import Chart from 'chart.js/auto';

  let lineChart: any = null;
  let donutChart: any = null;

  async function updateAnalytics(days: string) {
    const date = new Date();
    date.setDate(date.getDate() - parseInt(days));
    
    const { data: leads } = await supabase
      .from('leads')
      .select('created_at, status, source')
      .gte('created_at', date.toISOString());

    if (!leads) return;

    // 1. OBRADA PODATAKA ZA IZVORE I KONVERZIJE
    let google = 0, meta = 0, organic = 0, other = 0;
    let claimedCount = 0;

    leads.forEach(lead => {
      // Izbroj izvore
      const src = lead.source ? lead.source.toLowerCase() : 'organic'; 
      if (src.includes('google') || src.includes('gads')) google++;
      else if (src.includes('fb') || src.includes('facebook') || src.includes('meta') || src.includes('ig') || src.includes('instagram')) meta++;
      else if (src.includes('organic') || src.includes('direct') || src.includes('seo')) organic++;
      else other++;

      // Izbroj konverzije (preuzete lidove)
      if (lead.status === 'claimed') claimedCount++;
    });

    const totalCount = leads.length;
    const conversionRate = totalCount > 0 ? ((claimedCount / totalCount) * 100).toFixed(1) : '0.0';

    // Ažuriranje brojčanih kartica
    document.getElementById('stat-total')!.textContent = totalCount.toString();
    document.getElementById('stat-claimed')!.textContent = claimedCount.toString();
    document.getElementById('stat-conversion')!.textContent = `${conversionRate}%`;
    document.getElementById('stat-google')!.textContent = google.toString();
    document.getElementById('stat-meta')!.textContent = meta.toString();
    document.getElementById('stat-organic')!.textContent = organic.toString();

    // 2. OBRADA PODATAKA ZA VREMENSKI TREND (Line Chart)
    const labels: string[] = [];
    const totalCountsArray: number[] = [];
    const claimedCountsArray: number[] = [];
    
    for (let i = parseInt(days) - 1; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      const dateStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      labels.push(dateStr);
      
      const dayLeads = leads.filter(l => new Date(l.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) === dateStr);
      totalCountsArray.push(dayLeads.length);
      claimedCountsArray.push(dayLeads.filter(l => l.status === 'claimed').length);
    }

    // 3. CRTANJE LINE GRAFIKONA SA DVE LINIJE
    const lineCtx = document.getElementById('lineChart') as HTMLCanvasElement;
    if (lineChart) lineChart.destroy();
    
    lineChart = new Chart(lineCtx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'Claimed Leads',
            data: claimedCountsArray,
            borderColor: '#22c55e', // Zelena
            backgroundColor: 'rgba(34, 197, 94, 0.1)',
            borderWidth: 2,
            pointBackgroundColor: '#050505',
            pointBorderColor: '#22c55e',
            pointBorderWidth: 2,
            pointRadius: 3,
            pointHoverRadius: 6,
            fill: true,
            tension: 0.4,
            yAxisID: 'y'
          },
          {
            label: 'Total Leads',
            data: totalCountsArray,
            borderColor: '#3b82f6', // Plava
            backgroundColor: 'transparent',
            borderWidth: 2,
            borderDash: [5, 5], // Isprekidana linija za total da ne guši grafikon
            pointBackgroundColor: '#050505',
            pointBorderColor: '#3b82f6',
            pointBorderWidth: 2,
            pointRadius: 3,
            pointHoverRadius: 6,
            fill: false,
            tension: 0.4,
            yAxisID: 'y'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { 
          legend: { display: false }, 
          tooltip: { 
            mode: 'index', 
            intersect: false,
            backgroundColor: 'rgba(5, 5, 5, 0.9)',
            titleColor: '#a1a1aa',
            bodyColor: '#fff',
            borderColor: '#27272a',
            borderWidth: 1,
            titleFont: { family: 'monospace', size: 10 },
            bodyFont: { family: 'monospace', size: 12 }
          } 
        },
        scales: { 
          y: { 
            beginAtZero: true, 
            ticks: { color: '#71717a', stepSize: 1, font: { family: 'monospace', size: 10 } }, 
            grid: { color: '#18181b' },
            border: { display: false }
          }, 
          x: { 
            ticks: { color: '#71717a', font: { family: 'monospace', size: 10 } }, 
            grid: { color: '#18181b' },
            border: { display: false }
          } 
        },
        interaction: { mode: 'nearest', axis: 'x', intersect: false }
      }
    });

    // 4. CRTANJE DOUGHNUT GRAFIKONA
    const donutCtx = document.getElementById('donutChart') as HTMLCanvasElement;
    if (donutChart) donutChart.destroy();

    donutChart = new Chart(donutCtx, {
      type: 'doughnut',
      data: {
        labels: ['Google Ads', 'Meta / FB', 'Organic', 'Other'],
        datasets: [{
          data: [google, meta, organic, other],
          backgroundColor: [
            '#3b82f6', // Blue
            '#a855f7', // Purple
            '#22c55e', // Green
            '#27272a'  // Zinc-800
          ],
          borderColor: '#050505',
          borderWidth: 2,
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '75%', 
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#a1a1aa', font: { family: 'monospace', size: 10 }, padding: 20, usePointStyle: true, pointStyle: 'circle' }
          },
          tooltip: {
            backgroundColor: 'rgba(5, 5, 5, 0.9)',
            titleColor: '#a1a1aa',
            bodyColor: '#fff',
            borderColor: '#27272a',
            borderWidth: 1,
            bodyFont: { family: 'monospace', size: 12 },
            callbacks: {
              label: function(context) {
                let label = context.label || '';
                if (label) { label += ': '; }
                if (context.parsed !== null) { label += context.parsed; }
                return label;
              }
            }
          }
        }
      }
    });
  }

  document.getElementById('analyticsFilter')?.addEventListener('change', (e) => {
    updateAnalytics((e.target as HTMLSelectElement).value);
  });

  // Pokrećemo početno iscrtavanje
  document.addEventListener('DOMContentLoaded', () => updateAnalytics('7'));
</script>