---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { Activity, CheckCircle2, Globe2, Printer, Target, Users2 } from "lucide-astro";
---

<AdminLayout>
  <div class="mx-auto flex w-full max-w-[1600px] min-w-0 flex-col gap-8 print:gap-4">

    <!-- HEADER -->
    <div class="flex flex-col justify-between gap-5 border-b border-slate-200 pb-7 sm:flex-row sm:items-end print:pb-2">
      <div>
        <div class="mb-3 flex items-center gap-2 text-green-700"><Activity size={15} /><span class="text-[10px] font-mono font-bold uppercase tracking-[0.22em]">Performance intelligence</span></div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">Analytics overview</h1>
        <p class="mt-2 max-w-xl text-sm text-slate-500">Monitor acquisition, conversion and network capacity from one report.</p>
        <p id="reportDate" class="mt-2 text-[10px] text-slate-400 font-mono"></p>
      </div>

      <div class="flex items-center gap-3 w-full sm:w-auto print:hidden">
        <label class="flex flex-1 items-center gap-3 rounded-xl border border-slate-200 bg-white px-3 shadow-sm sm:flex-none">
          <span class="hidden text-[9px] font-bold uppercase tracking-[0.18em] text-slate-400 md:inline">Period</span>
          <select id="analyticsFilter" class="h-11 flex-1 cursor-pointer bg-transparent text-[10px] font-bold uppercase tracking-[0.16em] text-slate-700 outline-none">
          <option value="7">Last 7 Days</option>
          <option value="30" selected>Last 30 Days</option>
          <option value="90">Last 90 Days</option>
          </select>
        </label>
        <button id="printBtn" type="button" class="inline-flex h-[46px] shrink-0 items-center gap-2 whitespace-nowrap rounded-xl border border-slate-200 bg-white px-4 text-[10px] font-bold uppercase tracking-[0.16em] text-slate-600 shadow-sm transition hover:border-slate-300 hover:text-slate-950"><Printer size={14} /> <span class="hidden sm:inline">Export report</span></button>
      </div>
    </div>

    <!-- ============================================================ -->
    <!-- SECTION 1: SERVICE LEADS (glavni sajt) -->
    <!-- ============================================================ -->
    <section class="space-y-6">
      <div class="flex items-end justify-between gap-4"><div><p class="text-[10px] font-bold uppercase tracking-[0.22em] text-green-700">Executive overview</p><h2 class="mt-1 text-lg font-bold text-slate-900">Service lead performance</h2></div><span id="service-period-label" class="text-[10px] font-mono text-slate-400">Selected period</span></div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-start justify-between"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-slate-100 text-slate-600"><Users2 size={17} /></span><span class="text-[9px] font-bold uppercase tracking-[0.16em] text-slate-400">Volume</span></div>
          <h2 id="stat-total" class="mt-5 text-3xl font-bold tabular-nums text-slate-950">-</h2><p class="mt-1 text-xs font-medium text-slate-600">Total service leads</p><p class="mt-3 text-[10px] text-slate-400">Received in selected period</p>
        </div>
        <div class="group rounded-2xl border border-green-200 bg-gradient-to-br from-white to-green-50/70 p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-start justify-between"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-green-100 text-green-700"><CheckCircle2 size={17} /></span><span class="text-[9px] font-bold uppercase tracking-[0.16em] text-green-700">Claimed</span></div>
          <h2 id="stat-claimed" class="mt-5 text-3xl font-bold tabular-nums text-slate-950">-</h2><p class="mt-1 text-xs font-medium text-slate-600">Qualified opportunities</p><p id="claimed-share" class="mt-3 text-[10px] font-medium text-green-700">— of total volume</p>
        </div>
        <div class="group rounded-2xl border border-blue-200 bg-gradient-to-br from-white to-blue-50/70 p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-start justify-between"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700"><Target size={17} /></span><span class="text-[9px] font-bold uppercase tracking-[0.16em] text-blue-700">Efficiency</span></div>
          <h2 id="stat-conversion" class="mt-5 text-3xl font-bold tabular-nums text-slate-950">-</h2><p class="mt-1 text-xs font-medium text-slate-600">Lead claim rate</p><p class="mt-3 text-[10px] text-slate-400">Claimed ÷ total leads</p>
        </div>
        <div class="group rounded-2xl border border-teal-200 bg-gradient-to-br from-white to-teal-50/70 p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-start justify-between"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-teal-100 text-teal-700"><Globe2 size={17} /></span><span class="text-[9px] font-bold uppercase tracking-[0.16em] text-teal-700">External</span></div>
          <h2 id="summary-ext-total" class="mt-5 text-3xl font-bold tabular-nums text-slate-950">-</h2><p class="mt-1 text-xs font-medium text-slate-600">External leads</p><p class="mt-3 text-[10px] text-slate-400">Across connected websites</p>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 w-full print:grid-cols-1">
        <div class="xl:col-span-2 bg-white border border-slate-200 p-5 md:p-7 rounded-2xl shadow-sm flex flex-col print:break-inside-avoid">
          <div class="flex justify-between items-center mb-6">
            <div><h3 class="text-sm font-bold text-slate-900">Lead volume & claims</h3><p class="mt-1 text-[10px] text-slate-400">Daily acquisition and claimed opportunities</p></div>
            <div class="flex gap-4">
              <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-500"></span><span class="text-[9px] text-zinc-600 font-mono">Total</span></div>
              <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-500"></span><span class="text-[9px] text-zinc-600 font-mono">Claimed</span></div>
            </div>
          </div>
          <div class="relative w-full flex-1 min-h-[250px] md:min-h-[350px]">
            <canvas id="lineChart"></canvas>
          </div>
        </div>

        <div class="xl:col-span-1 bg-white border border-slate-200 p-5 md:p-7 rounded-2xl shadow-sm flex flex-col print:break-inside-avoid">
          <div class="mb-5"><h3 class="text-sm font-bold text-slate-900">Acquisition mix</h3><p class="mt-1 text-[10px] text-slate-400">Where service leads originated</p></div>
          <div class="relative w-full flex-1 min-h-[250px] flex items-center justify-center">
            <canvas id="donutChart"></canvas>
          </div>
          <div class="mt-5 grid grid-cols-3 gap-2 border-t border-slate-100 pt-4 text-center"><div><b id="stat-google" class="block text-base tabular-nums text-slate-900">-</b><span class="text-[9px] text-slate-400">Google</span></div><div><b id="stat-meta" class="block text-base tabular-nums text-slate-900">-</b><span class="text-[9px] text-slate-400">Meta</span></div><div><b id="stat-organic" class="block text-base tabular-nums text-slate-900">-</b><span class="text-[9px] text-slate-400">Organic</span></div></div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 2: EXTERNAL LEADS (drugi domeni) -->
    <!-- ============================================================ -->
    <section class="space-y-6 pt-6 border-t border-slate-200">
      <div><p class="text-[10px] font-bold uppercase tracking-[0.22em] text-teal-700">Cross-site pipeline</p><h2 class="mt-1 text-lg font-bold text-slate-900">External lead operations</h2><p class="mt-1 text-xs text-slate-500">Status distribution for the selected period.</p></div>

      <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-3 md:gap-4 w-full">
        <div class="bg-white border border-slate-200 p-4 rounded-xl shadow-sm flex flex-col justify-between">
          <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Total</p>
          <h2 id="ext-total" class="text-2xl font-mono font-bold text-slate-900 mt-4">-</h2>
        </div>
        <div class="bg-white border border-amber-200 p-4 rounded-xl shadow-sm flex flex-col justify-between">
          <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-amber-600">New</p>
          <h2 id="ext-new" class="text-2xl font-mono font-bold text-slate-900 mt-4">-</h2>
        </div>
        <div class="bg-white border border-green-200 p-4 rounded-xl shadow-sm flex flex-col justify-between">
          <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">Approved</p>
          <h2 id="ext-approved" class="text-2xl font-mono font-bold text-slate-900 mt-4">-</h2>
        </div>
        <div class="bg-white border border-red-200 p-4 rounded-xl shadow-sm flex flex-col justify-between">
          <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-red-600">Rejected</p>
          <h2 id="ext-rejected" class="text-2xl font-mono font-bold text-slate-900 mt-4">-</h2>
        </div>
        <div class="bg-white border border-blue-200 p-4 rounded-xl shadow-sm flex flex-col justify-between">
          <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-blue-600">Contacted</p>
          <h2 id="ext-contacted" class="text-2xl font-mono font-bold text-slate-900 mt-4">-</h2>
        </div>
        <div class="bg-white border border-teal-200 p-4 rounded-xl shadow-sm flex flex-col justify-between">
          <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-teal-600">↩ Migrated</p>
          <h2 id="ext-migrated" class="text-2xl font-mono font-bold text-slate-900 mt-4">-</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 w-full print:grid-cols-1">
        <div class="xl:col-span-1 bg-white border border-slate-200 p-6 rounded-2xl shadow-sm flex flex-col print:break-inside-avoid">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6">Volume Trend</h3>
          <div class="relative w-full flex-1 min-h-[220px]">
            <canvas id="extLineChart"></canvas>
          </div>
        </div>
        <div class="xl:col-span-1 bg-white border border-slate-200 p-6 rounded-2xl shadow-sm flex flex-col print:break-inside-avoid">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6">By Site</h3>
          <div class="relative w-full flex-1 min-h-[220px] flex items-center justify-center">
            <canvas id="extSiteChart"></canvas>
          </div>
        </div>
        <div class="xl:col-span-1 bg-white border border-slate-200 p-6 rounded-2xl shadow-sm flex flex-col print:break-inside-avoid">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6">By Form Type</h3>
          <div class="relative w-full flex-1 min-h-[220px] flex items-center justify-center">
            <canvas id="extFormChart"></canvas>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 3: NETWORK — Contractors / Truck Owners / Trucks -->
    <!-- ============================================================ -->
    <section class="space-y-6 pt-6 border-t border-slate-200">
      <div><p class="text-[10px] font-bold uppercase tracking-[0.22em] text-violet-700">Supply health</p><h2 class="mt-1 text-lg font-bold text-slate-900">Network capacity</h2><p class="mt-1 text-xs text-slate-500">Current roster; independent of the date filter.</p></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
        <div class="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm print:break-inside-avoid">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4">Contractors</p>
          <div class="grid grid-cols-3 gap-3 text-center">
            <div><h3 id="net-contractors-total" class="text-xl font-mono font-bold text-slate-900">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Total</p></div>
            <div><h3 id="net-contractors-active" class="text-xl font-mono font-bold text-green-700">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Active</p></div>
            <div><h3 id="net-contractors-pending" class="text-xl font-mono font-bold text-amber-600">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Pending</p></div>
          </div>
        </div>
        <div class="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm print:break-inside-avoid">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4">Truck Owners</p>
          <div class="grid grid-cols-3 gap-3 text-center">
            <div><h3 id="net-owners-total" class="text-xl font-mono font-bold text-slate-900">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Total</p></div>
            <div><h3 id="net-owners-approved" class="text-xl font-mono font-bold text-green-700">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Approved</p></div>
            <div><h3 id="net-owners-pending" class="text-xl font-mono font-bold text-amber-600">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Pending</p></div>
          </div>
        </div>
        <div class="bg-white border border-slate-200 p-6 rounded-2xl shadow-sm print:break-inside-avoid">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4">Grapple Saw Trucks</p>
          <div class="grid grid-cols-3 gap-3 text-center">
            <div><h3 id="net-trucks-total" class="text-xl font-mono font-bold text-slate-900">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Total</p></div>
            <div><h3 id="net-trucks-approved" class="text-xl font-mono font-bold text-green-700">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Approved</p></div>
            <div><h3 id="net-trucks-pending" class="text-xl font-mono font-bold text-amber-600">-</h3><p class="text-[9px] text-zinc-400 uppercase mt-1">Pending</p></div>
          </div>
        </div>
      </div>

      <div class="bg-white border border-slate-200 p-6 md:p-8 rounded-2xl shadow-sm print:break-inside-avoid">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6">Network Status Breakdown</h3>
        <div class="relative w-full min-h-[220px]">
          <canvas id="networkChart"></canvas>
        </div>
      </div>
    </section>

  </div>
</AdminLayout>

<style>
  @media print {
    :global(aside), :global(header), :global(nav) { display: none !important; }
    :global(main) { padding: 0 !important; }
  }
</style>

<script>
  import { supabase } from "../../lib/supabase";
  import Chart from 'chart.js/auto';

  // ------------------------------------------------------------------
  // Zajednička svetla tema za sve grafikone (ranije su ostali tamni
  // stilovi iz pre-light-theme verzije — sad je sve usklađeno)
  // ------------------------------------------------------------------
  const GRID_COLOR = '#F1F5F9';
  const AXIS_TEXT = '#94A3B8';
  const TOOLTIP = {
    backgroundColor: '#FFFFFF',
    titleColor: '#0F172A',
    bodyColor: '#334155',
    borderColor: '#E2E8F0',
    borderWidth: 1,
    padding: 10,
    titleFont: { family: 'monospace', size: 10 },
    bodyFont: { family: 'monospace', size: 12 },
  };
  const LEGEND_LABELS = { color: '#475569', font: { family: 'monospace', size: 10 }, padding: 16, usePointStyle: true, pointStyle: 'circle' };

  document.getElementById('reportDate')!.textContent = `Generated ${new Date().toLocaleString()}`;
  document.getElementById('printBtn')?.addEventListener('click', () => window.print());

  let lineChart: any = null;
  let donutChart: any = null;
  let extLineChart: any = null;
  let extSiteChart: any = null;
  let extFormChart: any = null;
  let networkChart: any = null;

  function dateLabels(days: number) {
    const labels: string[] = [];
    for (let i = days - 1; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      labels.push(d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
    }
    return labels;
  }

  function countByDay(rows: { created_at: string }[], labels: string[]) {
    return labels.map((label) =>
      rows.filter((r) => new Date(r.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) === label).length
    );
  }

  async function updateAnalytics(daysStr: string) {
    const days = parseInt(daysStr);
    const date = new Date();
    date.setDate(date.getDate() - days);
    const sinceIso = date.toISOString();
    const labels = dateLabels(days);
    document.getElementById('service-period-label')!.textContent = `Last ${days} days`;

    // ================= SERVICE LEADS =================
    const { data: leads } = await supabase.from('leads').select('created_at, status, source').gte('created_at', sinceIso);
    const leadRows = leads || [];

    let google = 0, meta = 0, organic = 0, other = 0, claimedCount = 0;
    leadRows.forEach((lead: any) => {
      const src = lead.source ? lead.source.toLowerCase() : 'organic';
      if (src.includes('google') || src.includes('gads')) google++;
      else if (src.includes('fb') || src.includes('facebook') || src.includes('meta') || src.includes('ig') || src.includes('instagram')) meta++;
      else if (src.includes('organic') || src.includes('direct') || src.includes('seo')) organic++;
      else other++;
      if (lead.status === 'claimed') claimedCount++;
    });

    const totalCount = leadRows.length;
    const conversionRate = totalCount > 0 ? ((claimedCount / totalCount) * 100).toFixed(1) : '0.0';

    document.getElementById('stat-total')!.textContent = totalCount.toString();
    document.getElementById('stat-claimed')!.textContent = claimedCount.toString();
    document.getElementById('stat-conversion')!.textContent = `${conversionRate}%`;
    document.getElementById('claimed-share')!.textContent = `${conversionRate}% of total volume`;
    document.getElementById('stat-google')!.textContent = google.toString();
    document.getElementById('stat-meta')!.textContent = meta.toString();
    document.getElementById('stat-organic')!.textContent = organic.toString();

    const totalCountsArray = labels.map((label) => leadRows.filter((l: any) => new Date(l.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) === label).length);
    const claimedCountsArray = labels.map((label) => leadRows.filter((l: any) => l.status === 'claimed' && new Date(l.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) === label).length);

    const lineCtx = document.getElementById('lineChart') as HTMLCanvasElement;
    if (lineChart) lineChart.destroy();
    lineChart = new Chart(lineCtx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Claimed Leads', data: claimedCountsArray, borderColor: '#16A34A', backgroundColor: 'rgba(22, 163, 74, 0.08)', borderWidth: 2, pointBackgroundColor: '#FFFFFF', pointBorderColor: '#16A34A', pointBorderWidth: 2, pointRadius: 3, pointHoverRadius: 6, fill: true, tension: 0.4 },
          { label: 'Total Leads', data: totalCountsArray, borderColor: '#2563EB', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], pointBackgroundColor: '#FFFFFF', pointBorderColor: '#2563EB', pointBorderWidth: 2, pointRadius: 3, pointHoverRadius: 6, fill: false, tension: 0.4 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false, ...TOOLTIP } },
        scales: {
          y: { beginAtZero: true, ticks: { color: AXIS_TEXT, stepSize: 1, font: { family: 'monospace', size: 10 } }, grid: { color: GRID_COLOR }, border: { display: false } },
          x: { ticks: { color: AXIS_TEXT, font: { family: 'monospace', size: 10 } }, grid: { display: false }, border: { display: false } },
        },
        interaction: { mode: 'nearest', axis: 'x', intersect: false },
      },
    });

    const donutCtx = document.getElementById('donutChart') as HTMLCanvasElement;
    if (donutChart) donutChart.destroy();
    donutChart = new Chart(donutCtx, {
      type: 'doughnut',
      data: {
        labels: ['Google Ads', 'Meta / FB', 'Organic', 'Other'],
        datasets: [{ data: [google, meta, organic, other], backgroundColor: ['#2563EB', '#A855F7', '#16A34A', '#CBD5E1'], borderColor: '#FFFFFF', borderWidth: 2, hoverOffset: 4 }],
      },
      options: {
        responsive: true, maintainAspectRatio: false, cutout: '72%',
        plugins: { legend: { position: 'bottom', labels: LEGEND_LABELS }, tooltip: TOOLTIP },
      },
    });

    // ================= EXTERNAL LEADS =================
    const { data: extAll } = await supabase.from('external_leads').select('created_at, status, source_domain, form_type, extra');
    const extAllRows = extAll || [];
    const extRows = extAllRows.filter((r: any) => new Date(r.created_at) >= date);

    document.getElementById('summary-ext-total')!.textContent = extRows.length.toString();
    document.getElementById('ext-total')!.textContent = extRows.length.toString();
    document.getElementById('ext-new')!.textContent = extRows.filter((r: any) => r.status === 'new').length.toString();
    document.getElementById('ext-approved')!.textContent = extRows.filter((r: any) => r.status === 'approved').length.toString();
    document.getElementById('ext-rejected')!.textContent = extRows.filter((r: any) => r.status === 'rejected').length.toString();
    document.getElementById('ext-contacted')!.textContent = extRows.filter((r: any) => r.status === 'contacted').length.toString();
    document.getElementById('ext-migrated')!.textContent = extRows.filter((r: any) => r.extra && (r.extra as any).migrated_from_lead_id).length.toString();

    const extCountsArray = countByDay(extRows, labels);
    const extLineCtx = document.getElementById('extLineChart') as HTMLCanvasElement;
    if (extLineChart) extLineChart.destroy();
    extLineChart = new Chart(extLineCtx, {
      type: 'line',
      data: { labels, datasets: [{ label: 'External Leads', data: extCountsArray, borderColor: '#0D9488', backgroundColor: 'rgba(13, 148, 136, 0.08)', borderWidth: 2, pointBackgroundColor: '#FFFFFF', pointBorderColor: '#0D9488', pointBorderWidth: 2, pointRadius: 3, pointHoverRadius: 6, fill: true, tension: 0.4 }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false, ...TOOLTIP } },
        scales: {
          y: { beginAtZero: true, ticks: { color: AXIS_TEXT, stepSize: 1, font: { family: 'monospace', size: 10 } }, grid: { color: GRID_COLOR }, border: { display: false } },
          x: { ticks: { color: AXIS_TEXT, font: { family: 'monospace', size: 9 } }, grid: { display: false }, border: { display: false } },
        },
      },
    });

    const siteCounts = new Map<string, number>();
    extRows.forEach((r: any) => { const k = r.source_domain || 'Unknown'; siteCounts.set(k, (siteCounts.get(k) || 0) + 1); });
    const siteEntries = Array.from(siteCounts.entries()).sort((a, b) => b[1] - a[1]);
    const siteColors = ['#16A34A', '#2563EB', '#A855F7', '#D97706', '#0D9488', '#DB2777', '#CBD5E1'];

    const extSiteCtx = document.getElementById('extSiteChart') as HTMLCanvasElement;
    if (extSiteChart) extSiteChart.destroy();
    extSiteChart = new Chart(extSiteCtx, {
      type: 'doughnut',
      data: { labels: siteEntries.map(([k]) => k), datasets: [{ data: siteEntries.map(([, v]) => v), backgroundColor: siteColors, borderColor: '#FFFFFF', borderWidth: 2, hoverOffset: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, cutout: '72%', plugins: { legend: { position: 'bottom', labels: LEGEND_LABELS }, tooltip: TOOLTIP } },
    });

    const formLabels: Record<string, string> = { lead: 'Lead', job: 'Free Job' };
    const formCounts = new Map<string, number>();
    extRows.forEach((r: any) => { const k = r.form_type || 'lead'; formCounts.set(k, (formCounts.get(k) || 0) + 1); });
    const formEntries = Array.from(formCounts.entries()).sort((a, b) => b[1] - a[1]);

    const extFormCtx = document.getElementById('extFormChart') as HTMLCanvasElement;
    if (extFormChart) extFormChart.destroy();
    extFormChart = new Chart(extFormCtx, {
      type: 'doughnut',
      data: { labels: formEntries.map(([k]) => formLabels[k] || k), datasets: [{ data: formEntries.map(([, v]) => v), backgroundColor: ['#16A34A', '#2563EB', '#A855F7', '#D97706'], borderColor: '#FFFFFF', borderWidth: 2, hoverOffset: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, cutout: '72%', plugins: { legend: { position: 'bottom', labels: LEGEND_LABELS }, tooltip: TOOLTIP } },
    });

    // ================= NETWORK (current roster, ne zavisi od date filtera) =================
    const { data: contractors } = await supabase.from('contractors').select('status');
    const { data: owners } = await supabase.from('truck_owners').select('status');
    const { data: trucks } = await supabase.from('grapple_saw_trucks').select('approval_status');

    const contractorRows = contractors || [];
    const ownerRows = owners || [];
    const truckRows = trucks || [];

    const cActive = contractorRows.filter((c: any) => c.status === 'active').length;
    const cPending = contractorRows.filter((c: any) => !c.status || c.status === 'pending').length;
    const cRejected = contractorRows.filter((c: any) => c.status === 'rejected').length;

    const oApproved = ownerRows.filter((o: any) => o.status === 'approved').length;
    const oPending = ownerRows.filter((o: any) => !o.status || o.status === 'pending').length;
    const oRejected = ownerRows.filter((o: any) => o.status === 'rejected').length;

    const tApproved = truckRows.filter((t: any) => t.approval_status === 'approved').length;
    const tPending = truckRows.filter((t: any) => !t.approval_status || t.approval_status === 'pending').length;
    const tRejected = truckRows.filter((t: any) => t.approval_status === 'rejected').length;

    document.getElementById('net-contractors-total')!.textContent = contractorRows.length.toString();
    document.getElementById('net-contractors-active')!.textContent = cActive.toString();
    document.getElementById('net-contractors-pending')!.textContent = cPending.toString();

    document.getElementById('net-owners-total')!.textContent = ownerRows.length.toString();
    document.getElementById('net-owners-approved')!.textContent = oApproved.toString();
    document.getElementById('net-owners-pending')!.textContent = oPending.toString();

    document.getElementById('net-trucks-total')!.textContent = truckRows.length.toString();
    document.getElementById('net-trucks-approved')!.textContent = tApproved.toString();
    document.getElementById('net-trucks-pending')!.textContent = tPending.toString();

    const networkCtx = document.getElementById('networkChart') as HTMLCanvasElement;
    if (networkChart) networkChart.destroy();
    networkChart = new Chart(networkCtx, {
      type: 'bar',
      data: {
        labels: ['Contractors', 'Truck Owners', 'Trucks'],
        datasets: [
          { label: 'Approved', data: [cActive, oApproved, tApproved], backgroundColor: '#16A34A', borderRadius: 6 },
          { label: 'Pending', data: [cPending, oPending, tPending], backgroundColor: '#D97706', borderRadius: 6 },
          { label: 'Rejected', data: [cRejected, oRejected, tRejected], backgroundColor: '#DC2626', borderRadius: 6 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: LEGEND_LABELS }, tooltip: TOOLTIP },
        scales: {
          y: { beginAtZero: true, ticks: { color: AXIS_TEXT, stepSize: 1, font: { family: 'monospace', size: 10 } }, grid: { color: GRID_COLOR }, border: { display: false } },
          x: { ticks: { color: '#334155', font: { family: 'monospace', size: 10, weight: 'bold' } }, grid: { display: false }, border: { display: false } },
        },
      },
    });
  }

  document.getElementById('analyticsFilter')?.addEventListener('change', (e) => {
    updateAnalytics((e.target as HTMLSelectElement).value);
  });

  document.addEventListener('DOMContentLoaded', () => updateAnalytics('30'));
</script>
