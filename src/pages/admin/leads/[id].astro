---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";

const { id } = Astro.params;

// Dohvati lid
const { data: lead } = await supabase.from('leads').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await supabase
  .from('lead_logs')
  .select('*')
  .eq('lead_id', id)
  .order('created_at', { ascending: false });

// Dohvati teritorije za Edit modal
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

// PREUSMERAVANJE AKO LID NE POSTOJI
if (!lead) return Astro.redirect('/admin/service-leads');

const leadStatus = lead.status || 'new';
---

<AdminLayout>
  <!-- MODAL ZA IZMENU LIDA -->
  <div id="editModal" class="hidden fixed inset-0 bg-black/80 z-[200] flex items-center justify-center p-4">
    <div class="bg-[#050505] border border-zinc-800 p-8 rounded-xl max-w-md w-full shadow-2xl">
      <h2 class="text-white font-bold mb-6">Edit Lead</h2>
      <form id="editForm" class="space-y-4">
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Email</label>
          <input type="email" id="editEmail" value={lead.email} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Phone</label>
          <input type="text" id="editPhone" value={lead.phone} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">County</label>
          <select id="editCounty" class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required>
            <option value="" disabled>Select County</option>
            {territories?.map(t => (
              <option value={t.name} selected={lead.county === t.name}>{t.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Details</label>
          <textarea id="editDetails" class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white h-24">{lead.details}</textarea>
        </div>
        <div class="flex gap-4 mt-8 pt-4 border-t border-zinc-900/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-800 p-3 rounded text-white font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-700 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-black font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="w-full grid grid-cols-1 xl:grid-cols-12 gap-8">
    
    <!-- Leva strana: Podaci o lidu -->
    <div class="xl:col-span-8 space-y-6">
      
      <!-- HEADER SA AKCIJAMA -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-xl font-bold text-white tracking-wide">Lead Management</h1>
          <p class="text-[10px] font-mono text-zinc-500 mt-1 uppercase">ID: {lead.id.split('-')[0]}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button id="editBtn" class="text-[10px] text-zinc-400 hover:text-white uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-900">
            Edit
          </button>
          <button id="deleteBtn" class="text-[10px] text-red-500/70 hover:text-red-500 uppercase font-bold tracking-[0.2em] transition-colors border border-red-900/30 px-4 py-2 rounded-lg hover:bg-red-950/30">
            Delete
          </button>
          <a href="/admin/service-leads" class="text-[10px] text-zinc-500 hover:text-white uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-900">
            ← Back
          </a>
        </div>
      </div>
      
      <div class="bg-[#050505] border border-zinc-900 p-8 rounded-xl space-y-6 shadow-2xl">
        
        <!-- Prikaz statusa -->
        <div class="pb-6 border-b border-zinc-900">
          <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600 mb-2">Current Status</p>
          <span class={`px-3 py-1.5 rounded text-[10px] font-bold border uppercase tracking-wider
            ${leadStatus === 'approved' ? 'border-green-700/50 text-green-500 bg-green-500/10' : 
              leadStatus === 'rejected' ? 'border-red-700/50 text-red-500 bg-red-500/10' : 'border-zinc-700 text-zinc-400 bg-zinc-800/50'}`}>
            {leadStatus}
          </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Email</p>
            <p class="text-white font-mono mt-1 font-bold text-lg">{lead.email}</p>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Phone</p>
            <p class="text-white font-mono mt-1 text-lg">{lead.phone || 'N/A'}</p>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">County</p>
            <p class="text-white font-mono mt-1 text-lg">{lead.county || 'N/A'}</p>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600">Details</p>
            <p class="text-zinc-300 font-mono mt-1 text-sm">{lead.details || 'No details'}</p>
          </div>
        </div>

        <div class="pt-6 border-t border-zinc-900 mt-8">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
            <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Approval Controls
          </p>
          <div class="flex gap-4">
            <button id="approveBtn" class="flex-1 h-12 rounded-lg bg-green-500/10 border border-green-500/30 text-green-500 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-green-500 hover:text-black transition-all">Approve Lead</button>
            <button id="rejectBtn" class="flex-1 h-12 rounded-lg bg-red-950/20 border border-red-900/30 text-red-500 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-red-900/40 transition-all">Reject Lead</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Desna strana: Logovi -->
    <div class="xl:col-span-4 bg-[#050505] border border-zinc-900 p-6 rounded-xl self-start sticky top-8 shadow-2xl">
      <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white mb-8 border-b border-zinc-900 pb-4">Activity Timeline</h3>
      <div class="space-y-6">
        {logs?.map(log => (
          <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-800 before:border-2 before:border-[#050505] before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-20px] after:w-[2px] after:bg-zinc-900 last:after:hidden">
            <p class="text-[11px] text-white font-bold leading-tight">{log.action}</p>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-300 font-bold tracking-wider uppercase">{log.changed_by || 'Stojan M.'}</span></span>
              <span class="text-[7px] text-zinc-700">●</span>
              <span class="text-[9px] text-zinc-600">{new Date(log.created_at).toLocaleDateString()} {new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            </div>
          </div>
        ))}
        {(!logs || logs.length === 0) && <p class="text-[10px] text-zinc-600 italic">No activity recorded yet.</p>}
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M."; 

  // -- STATUS CONTROLS --
  async function updateStatus(newStatus: string) {
    if (!id) return;
    document.body.style.opacity = '0.5';

    await supabase.from('leads').update({ status: newStatus }).eq('id', id);
    await supabase.from('lead_logs').insert([{
      lead_id: id,
      action: `Status changed to ${newStatus}`,
      changed_by: currentUser
    }]);

    window.location.reload();
  }

  document.getElementById('approveBtn')?.addEventListener('click', () => updateStatus('approved'));
  document.getElementById('rejectBtn')?.addEventListener('click', () => updateStatus('rejected'));

  // -- EDIT CONTROLS --
  document.getElementById('editBtn')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.remove('hidden');
  });
  
  document.getElementById('closeEditModal')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.add('hidden');
  });

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      email: (document.getElementById('editEmail') as HTMLInputElement).value,
      phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      county: (document.getElementById('editCounty') as HTMLSelectElement).value,
      details: (document.getElementById('editDetails') as HTMLTextAreaElement).value,
    };

    await supabase.from('leads').update(updates).eq('id', id);
    await supabase.from('lead_logs').insert([{
      lead_id: id,
      action: 'Updated lead details',
      changed_by: currentUser
    }]);

    window.location.reload();
  });

  // -- DELETE CONTROLS --
  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this lead? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      
      await supabase.from('lead_logs').delete().eq('lead_id', id);
      await supabase.from('leads').delete().eq('id', id);
      
      window.location.href = '/admin/service-leads';
    }
  });
</script>