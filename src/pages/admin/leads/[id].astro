---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;
const db = supabaseAdmin ?? supabase;

// Dohvati lid
const { data: lead } = await db.from('leads').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await db
  .from('lead_logs')
  .select('*')
  .eq('lead_id', id)
  .order('created_at', { ascending: false });

// Dohvati teritorije za Edit modal
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

// PREUSMERAVANJE AKO LID NE POSTOJI
if (!lead) return Astro.redirect('/admin/service-leads');

const leadStatus = lead.status || 'new';
---

<AdminLayout>
  <!-- MODAL ZA IZMENU LIDA -->
  <div id="editModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-white border border-zinc-200 p-8 rounded-xl max-w-md w-full shadow-2xl">
      <h2 class="text-slate-900 font-bold mb-6">Edit Lead</h2>
      <form id="editForm" class="space-y-4">
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Email</label>
          <input type="email" id="editEmail" value={lead.email} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Phone</label>
          <input type="text" id="editPhone" value={lead.phone} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">County</label>
          <select id="editCounty" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required>
            <option value="" disabled>Select County</option>
            {territories?.map(t => (
              <option value={t.name} selected={lead.county === t.name}>{t.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Details</label>
          <textarea id="editDetails" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900 h-24">{lead.details}</textarea>
        </div>
        <div class="flex gap-4 mt-8 pt-4 border-t border-zinc-100/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-200 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-300 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="w-full grid grid-cols-1 xl:grid-cols-12 gap-8">
    
    <!-- Leva strana: Podaci o lidu -->
    <div class="xl:col-span-8 space-y-6">
      
      <!-- HEADER SA AKCIJAMA -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" id="leadMeta" data-county={lead.county} data-details={lead.details}>
        <div>
          <h1 class="text-xl font-bold text-slate-900 tracking-wide">Lead Management</h1>
          <p class="text-[10px] font-mono text-zinc-500 mt-1 uppercase">ID: {lead.id.split('-')[0]}</p>
        </div>
        <div class="flex flex-wrap gap-3 w-full sm:w-auto">
          {lead.phone && (
            <a href={`tel:${lead.phone}`} class="flex-1 sm:flex-none text-center text-[10px] text-green-700 uppercase font-bold tracking-[0.2em] transition-colors border border-green-200 bg-green-50 px-4 py-2.5 rounded-lg hover:bg-green-500 hover:text-slate-50">
              📞 Call
            </a>
          )}
          <a href={`mailto:${lead.email}`} class="flex-1 sm:flex-none text-center text-[10px] text-blue-600 uppercase font-bold tracking-[0.2em] transition-colors border border-blue-200 bg-blue-50 px-4 py-2.5 rounded-lg hover:bg-blue-500 hover:text-slate-50">
            ✉️ Email
          </a>
          <button id="editBtn" class="text-[10px] text-zinc-600 hover:text-slate-900 uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-200 px-4 py-2.5 rounded-lg hover:bg-zinc-100">
            Edit
          </button>
          <button id="deleteBtn" class="text-[10px] text-red-600/70 hover:text-red-600 uppercase font-bold tracking-[0.2em] transition-colors border border-red-200 px-4 py-2.5 rounded-lg hover:bg-red-50">
            Delete
          </button>
          <a href="/admin/service-leads" class="text-[10px] text-zinc-500 hover:text-slate-900 uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-200 px-4 py-2.5 rounded-lg hover:bg-zinc-100">
            ← Back
          </a>
        </div>
      </div>
      
      <div class="bg-white border border-zinc-100 p-8 rounded-xl space-y-6 shadow-2xl">
        
        <!-- Prikaz statusa -->
        <div class="pb-6 border-b border-zinc-100">
          <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 mb-2">Current Status</p>
          <span class={`px-3 py-1.5 rounded text-[10px] font-bold border uppercase tracking-wider
            ${leadStatus === 'approved' ? 'border-green-700/50 text-green-700 bg-green-500/10' : 
              leadStatus === 'rejected' ? 'border-red-700/50 text-red-600 bg-red-500/10' : 'border-zinc-300 text-zinc-600 bg-zinc-200/50'}`}>
            {leadStatus}
          </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Email</p>
            <a href={`mailto:${lead.email}`} class="text-slate-900 font-mono mt-1 font-bold text-lg block hover:text-green-700 transition-colors break-all">{lead.email}</a>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Phone</p>
            {lead.phone ? (
              <a href={`tel:${lead.phone}`} class="text-slate-900 font-mono mt-1 text-lg block hover:text-green-700 transition-colors">{lead.phone}</a>
            ) : (
              <p class="text-slate-900 font-mono mt-1 text-lg">N/A</p>
            )}
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">County</p>
            <p class="text-slate-900 font-mono mt-1 text-lg">{lead.county || 'N/A'}</p>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Details</p>
            <p class="text-zinc-700 font-mono mt-1 text-sm">{lead.details || 'No details'}</p>
          </div>
        </div>

        <div class="pt-6 border-t border-zinc-100 mt-8">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
            <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Approval Controls
          </p>
          <div class="flex gap-4">
            <button id="approveBtn" class="flex-1 h-12 rounded-lg bg-green-500/10 border border-green-500/30 text-green-700 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-green-500 hover:text-slate-900 transition-all">Approve Lead</button>
            <button id="rejectBtn" class="flex-1 h-12 rounded-lg bg-red-50 border border-red-200 text-red-600 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-red-50 transition-all">Reject Lead</button>
          </div>
        </div>

        <div class="pt-6 border-t border-zinc-100">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
            <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Move
          </p>
          <button id="moveToExternalBtn" class="w-full sm:w-auto h-12 px-6 rounded-lg bg-teal-500/10 border border-teal-500/30 text-teal-700 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-teal-500 hover:text-white transition-all">
            🌐 Move to External Leads
          </button>
          <p class="mt-2 text-[10px] text-zinc-400">Moves this record out of Service Leads and into External Leads — this deletes it from here.</p>
        </div>
      </div>
    </div>

    <!-- Desna strana: Logovi -->
    <div class="xl:col-span-4 bg-white border border-zinc-100 p-6 rounded-xl self-start sticky top-8 shadow-2xl">
      <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900 mb-8 border-b border-zinc-100 pb-4">Activity Timeline</h3>
      <div class="space-y-6">
        {logs?.map(log => (
          <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-200 before:border-2 before:border-slate-200 before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-20px] after:w-[2px] after:bg-zinc-100 last:after:hidden">
            <p class="text-[11px] text-slate-900 font-bold leading-tight">{log.action}</p>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-700 font-bold tracking-wider uppercase">{log.changed_by || 'Stojan M.'}</span></span>
              <span class="text-[7px] text-zinc-300">●</span>
              <span class="text-[9px] text-zinc-400">{new Date(log.created_at).toLocaleDateString()} {new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            </div>
          </div>
        ))}
        {(!logs || logs.length === 0) && <p class="text-[10px] text-zinc-400 italic">No activity recorded yet.</p>}
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M."; 

  // -- STATUS CONTROLS --
  async function updateStatus(newStatus: string) {
    if (!id) return;
    document.body.style.opacity = '0.5';

    await supabase.from('leads').update({ status: newStatus }).eq('id', id);
    await supabase.from('lead_logs').insert([{
      lead_id: id,
      action: `Status changed to ${newStatus}`,
      changed_by: currentUser
    }]);

    // Kad se lid odobri, tek ONDA postaje vidljiv kontraktorima —
    // pa im tek sad šaljemo email da imaju novi posao za preuzimanje.
    // VAŽNO: čekamo (await) ovaj fetch PRE reload-a, jer bi ga
    // window.location.reload() inače prekinuo pre nego što stigne do servera.
    if (newStatus === 'approved') {
      const meta = document.getElementById('leadMeta');
      try {
        await fetch('/api/notify-new-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          keepalive: true,
          body: JSON.stringify({
            county: meta?.dataset.county,
            details: meta?.dataset.details,
          }),
        });
      } catch (e) {
        console.error('notify-new-lead failed:', e);
      }
    }

    window.location.reload();
  }

  document.getElementById('approveBtn')?.addEventListener('click', () => updateStatus('approved'));
  document.getElementById('rejectBtn')?.addEventListener('click', () => updateStatus('rejected'));

  // -- MOVE TO EXTERNAL LEADS --
  document.getElementById('moveToExternalBtn')?.addEventListener('click', async () => {
    const meta = document.getElementById('leadMeta');
    const county = meta?.dataset.county || '';
    const details = meta?.dataset.details || '';

    if (!confirm('Move this lead to External Leads? It will be removed from Service Leads.')) return;

    const btn = document.getElementById('moveToExternalBtn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Moving...';

    const { data: leadRow } = await supabase.from('leads').select('*').eq('id', id).single();
    if (!leadRow) { alert('Lead not found.'); btn.disabled = false; return; }

    const { error: insertError } = await supabase.from('external_leads').insert([{
      form_type: 'lead',
      source_domain: leadRow.source || 'service-leads',
      full_name: null,
      email: leadRow.email,
      phone: leadRow.phone,
      message: leadRow.details,
      status: 'new',
      extra: { county: leadRow.county, migrated_from_lead_id: leadRow.id, migrated_from_status: leadRow.status },
    }]);

    if (insertError) {
      alert('Could not move lead: ' + insertError.message);
      btn.disabled = false;
      btn.textContent = '🌐 Move to External Leads';
      return;
    }

    await supabase.from('lead_logs').delete().eq('lead_id', id);
    await supabase.from('leads').delete().eq('id', id);

    window.location.href = '/admin/external-leads';
  });

  // -- EDIT CONTROLS --
  document.getElementById('editBtn')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.remove('hidden');
  });
  
  document.getElementById('closeEditModal')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.add('hidden');
  });

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      email: (document.getElementById('editEmail') as HTMLInputElement).value,
      phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      county: (document.getElementById('editCounty') as HTMLSelectElement).value,
      details: (document.getElementById('editDetails') as HTMLTextAreaElement).value,
    };

    await supabase.from('leads').update(updates).eq('id', id);
    await supabase.from('lead_logs').insert([{
      lead_id: id,
      action: 'Updated lead details',
      changed_by: currentUser
    }]);

    window.location.reload();
  });

  // -- DELETE CONTROLS --
  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this lead? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      
      await supabase.from('lead_logs').delete().eq('lead_id', id);
      await supabase.from('leads').delete().eq('id', id);
      
      window.location.href = '/admin/service-leads';
    }
  });
</script>