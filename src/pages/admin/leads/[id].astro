---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;
const db = supabaseAdmin ?? supabase;

// Dohvati lid
const { data: lead } = await db.from('leads').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await db
  .from('lead_logs')
  .select('*')
  .eq('lead_id', id)
  .order('created_at', { ascending: false });

// Get activity log from extra column (if exists)
const activityLog: { action: string; at: string; by?: string }[] =
  (lead.extra as any)?.activity_log || [];

// Dohvati teritorije za Edit modal
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

const { data: rawTruckApplications } = await db
  .from('truck_lead_applications')
  .select('*')
  .eq('lead_id', id)
  .order('created_at', { ascending: false });
const ownerIds = Array.from(new Set((rawTruckApplications || []).map((application: any) => application.truck_owner_id)));
const truckIds = Array.from(new Set((rawTruckApplications || []).map((application: any) => application.truck_id).filter(Boolean)));
const { data: applicationOwners } = ownerIds.length ? await db.from('truck_owners').select('id,company_name,contact_name,email,phone').in('id', ownerIds) : { data: [] };
const { data: applicationTrucks } = truckIds.length ? await db.from('grapple_saw_trucks').select('id,equipment_type,lift_capacity_tons,working_height_ft').in('id', truckIds) : { data: [] };
const truckApplications = (rawTruckApplications || []).map((application: any) => ({
  ...application,
  owner: (applicationOwners || []).find((owner: any) => owner.id === application.truck_owner_id),
  truck: (applicationTrucks || []).find((truck: any) => truck.id === application.truck_id),
}));

// PREUSMERAVANJE AKO LID NE POSTOJI
if (!lead) return Astro.redirect('/admin/service-leads');

const leadStatus = lead.status || 'new';
---

<AdminLayout>
  <!-- MODAL ZA IZMENU LIDA -->
  <div id="editModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
    <div class="bg-white border border-zinc-200 p-8 rounded-xl max-w-md w-full shadow-2xl">
      <h2 class="text-slate-900 font-bold mb-6">Edit Lead</h2>
      <form id="editForm" class="space-y-4">
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Email</label>
          <input type="email" id="editEmail" value={lead.email} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Phone</label>
          <input type="text" id="editPhone" value={lead.phone} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">County</label>
          <select id="editCounty" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required>
            <option value="" disabled>Select County</option>
            {territories?.map(t => (
              <option value={t.name} selected={lead.county === t.name}>{t.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Details</label>
          <textarea id="editDetails" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900 h-24">{lead.details}</textarea>
        </div>
        <div class="flex gap-4 mt-8 pt-4 border-t border-zinc-100/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-200 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-300 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="dash-shell flex-1"><div class="dash-scroll">
  <div class="w-full grid gap-6 lg:grid-cols-[1fr_380px]">
    
    <!-- Left Column: Lead Data -->
    <div class="space-y-4">
      
      <!-- HEADER -->
      <div class="flex items-center gap-3" id="leadMeta" data-county={lead.county} data-details={lead.details}>
        <a href="/admin/service-leads" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">
          ← Back
        </a>
        <div>
          <span class="dash-eyebrow text-green-700">// Service lead</span>
          <h1 class="mt-1.5 text-2xl font-bold text-slate-950 tracking-tight">Lead management</h1>
          <p class="text-[10px] font-mono text-slate-400 mt-1 uppercase">ID: {lead.id.split('-')[0]}</p>
        </div>
      </div>
      
      <div class="bg-white border border-zinc-100 p-8 rounded-xl space-y-6 shadow-2xl">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Email</p>
            <a href={`mailto:${lead.email}`} class="text-slate-900 font-mono mt-1 font-bold text-lg block hover:text-green-700 transition-colors break-all">{lead.email}</a>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Phone</p>
            {lead.phone ? (
              <a href={`tel:${lead.phone}`} class="text-slate-900 font-mono mt-1 text-lg block hover:text-green-700 transition-colors">{lead.phone}</a>
            ) : (
              <p class="text-slate-900 font-mono mt-1 text-lg">N/A</p>
            )}
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">County</p>
            <p class="text-slate-900 font-mono mt-1 text-lg">{lead.county || 'N/A'}</p>
          </div>
          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400">Details</p>
            <p class="text-zinc-700 font-mono mt-1 text-sm">{lead.details || 'No details'}</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-blue-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-3"><div><p class="text-[9px] font-bold uppercase tracking-[0.18em] text-blue-700">Heavy equipment support</p><h2 class="mt-1 text-base font-bold text-slate-950">Truck owner applications</h2></div><span class="rounded-full bg-blue-50 px-3 py-1 text-[10px] font-bold text-blue-700">{truckApplications.length}</span></div>
        <div class="mt-5 space-y-3">
          {truckApplications.length === 0 ? (
            <p class="rounded-xl border border-dashed border-slate-200 p-6 text-center text-xs text-slate-400">No truck owners have applied to this lead.</p>
          ) : truckApplications.map((application: any) => (
            <div class="rounded-xl border border-slate-200 p-4">
              <div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-start">
                <div>
                  <p class="text-sm font-bold text-slate-950">{application.owner?.company_name || application.owner?.contact_name || 'Fleet partner'}</p>
                  <p class="mt-1 text-[11px] text-slate-500">{application.truck?.equipment_type || 'Equipment not specified'}{application.truck?.lift_capacity_tons ? ` · ${application.truck.lift_capacity_tons} tons` : ''}{application.truck?.working_height_ft ? ` · ${application.truck.working_height_ft} ft` : ''}</p>
                  {application.message && <p class="mt-2 text-xs text-slate-600">{application.message}</p>}
                  <div class="mt-3 flex flex-wrap gap-3 text-[10px]">{application.owner?.phone && <a class="font-bold text-blue-700" href={`tel:${application.owner.phone}`}>Call</a>}{application.owner?.email && <a class="font-bold text-blue-700" href={`mailto:${application.owner.email}`}>Email</a>}</div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="rounded-full border border-slate-200 px-2.5 py-1 text-[9px] font-bold uppercase text-slate-600">{application.status}</span>
                  {application.status === 'pending' && <><button class="truck-application-status rounded-lg bg-green-600 px-3 py-2 text-[9px] font-bold uppercase text-white" data-application-id={application.id} data-status="accepted">Accept</button><button class="truck-application-status rounded-lg bg-red-50 px-3 py-2 text-[9px] font-bold uppercase text-red-600" data-application-id={application.id} data-status="rejected">Reject</button></>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Right Sidebar: Status / Actions / Manage / Activity Log -->
    <div class="detail-sidebar">
      <!-- Current Status -->
      <div class="detail-card">
        <h3 class="detail-card__title">Current Status</h3>
        <span class={`inline-block px-3 py-2 rounded-full text-[11px] font-bold uppercase tracking-wide border
          ${leadStatus === 'approved' ? 'border-green-700/50 text-green-700 bg-green-500/10' : 
            leadStatus === 'rejected' ? 'border-red-700/50 text-red-600 bg-red-500/10' : 'border-zinc-300 text-zinc-600 bg-zinc-200/50'}`}>
          {leadStatus}
        </span>
      </div>

      <!-- Actions -->
      <div class="detail-card">
        <h3 class="detail-card__title">Actions</h3>
        <div class="space-y-2">
          {lead.phone && (
            <a href={`tel:${lead.phone}`} class="detail-btn detail-btn--primary">📞 Call</a>
          )}
          <a href={`mailto:${lead.email}`} class="detail-btn detail-btn--ghost">✉️ Email</a>
          <button id="editBtn" class="detail-btn detail-btn--ghost">✏️ Edit details</button>
          <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 pt-2">Update status</p>
          <div class="grid grid-cols-2 gap-2">
            <button id="approveBtn" class="h-10 rounded-lg bg-green-500/10 border border-green-500/30 text-green-700 font-bold uppercase tracking-wider text-[9px] hover:bg-green-500 hover:text-white transition-all">✓ Approve</button>
            <button id="rejectBtn" class="h-10 rounded-lg bg-red-50 border border-red-200 text-red-600 font-bold uppercase tracking-wider text-[9px] hover:bg-red-500 hover:text-white transition-all">✕ Reject</button>
          </div>
        </div>
      </div>

      <!-- Manage Lead -->
      <div class="detail-card detail-card--danger">
        <h3 class="detail-card__title detail-card__title--danger">Manage Lead</h3>
        <div class="space-y-2">
          <button id="moveToExternalBtn" class="detail-btn detail-btn--warn">
            🌐 Move to External Leads
          </button>
          <button id="deleteBtn" class="detail-btn detail-btn--danger">
            🗑️ Delete
          </button>
        </div>
      </div>

      <!-- Activity Log -->
      <div class="detail-card">
        <h3 class="detail-card__title">Activity Log</h3>
        <div id="activityLog" class="detail-log">
          {activityLog.length === 0
            ? <p class="text-[11px] text-zinc-400 italic">No activity yet.</p>
            : activityLog.slice().reverse().map((entry) => (
                <div class="detail-log__entry">
                  <div class="detail-log__dot"></div>
                  <div>
                    <p class="text-sm text-slate-900">{entry.action}</p>
                    <p class="text-[10px] text-zinc-400 mt-0.5 font-mono">{new Date(entry.at).toLocaleString()}</p>
                  </div>
                </div>
              ))
          }
        </div>

        <!-- Add Note -->
        <div class="mt-4 pt-4 border-t border-zinc-100">
          <textarea id="noteInput" rows="2" placeholder="Add a note…" class="w-full rounded-xl border border-zinc-200 bg-zinc-50 p-3 text-sm text-slate-900 outline-none focus:border-green-500 resize-none"></textarea>
          <button id="addNoteBtn" class="mt-2 px-4 py-2 rounded-lg bg-zinc-100 border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-700 hover:bg-zinc-200 transition-colors">Add Note</button>
        </div>
      </div>
    </div>
  </div>
  </div></div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M.";

  // Add Note functionality
  async function addLogEntry(action: string) {
    const { data: lead } = await supabase.from('leads').select('extra').eq('id', id).single();
    const extra = (lead?.extra as any) || {};
    const log = extra.activity_log || [];
    log.push({ action, at: new Date().toISOString() });
    await supabase.from('leads').update({ extra: { ...extra, activity_log: log } }).eq('id', id);

    const logEl = document.getElementById('activityLog')!;
    const entry = document.createElement('div');
    entry.className = 'flex items-start gap-3 p-3 rounded-xl bg-zinc-50 border border-zinc-100';
    entry.innerHTML = `
      <div class="w-1.5 h-1.5 rounded-full bg-green-500 mt-1.5 shrink-0"></div>
      <div>
        <p class="text-sm text-slate-900">${action}</p>
        <p class="text-[10px] text-zinc-400 mt-0.5 font-mono">${new Date().toLocaleString()}</p>
      </div>
    `;
    logEl.prepend(entry);
  }

  document.getElementById('addNoteBtn')?.addEventListener('click', async () => {
    const input = document.getElementById('noteInput') as HTMLTextAreaElement;
    const text = input.value.trim();
    if (!text) return;
    await addLogEntry(`📝 Note: ${text}`);
    input.value = '';
  });

  document.querySelectorAll<HTMLButtonElement>('.truck-application-status').forEach((button) => {
    button.addEventListener('click', async () => {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session?.access_token) { alert('Admin session expired.'); return; }
      button.disabled = true;
      const response = await fetch('/api/truck-application-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session.access_token}` },
        body: JSON.stringify({ applicationId: button.dataset.applicationId, status: button.dataset.status }),
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || !result.ok) {
        alert('Could not update application: ' + (result.error || 'Unknown error'));
        button.disabled = false;
        return;
      }
      window.location.reload();
    });
  });
  
  // -- STATUS CONTROLS --
  async function updateStatus(newStatus: string) {
    if (!id) return;
    document.body.style.opacity = '0.5';

    await supabase.from('leads').update({ status: newStatus }).eq('id', id);
    await addLogEntry(`Status changed to ${newStatus}`);
    
    // Kad se lid odobri, tek ONDA postaje vidljiv kontraktorima —
    // pa im tek sad šaljemo email da imaju novi posao za preuzimanje.
    // VAŽNO: čekamo (await) ovaj fetch PRE reload-a, jer bi ga
    // window.location.reload() inače prekinuo pre nego što stigne do servera.
    if (newStatus === 'approved') {
      const meta = document.getElementById('leadMeta');
      try {
        const { data: { session } } = await supabase.auth.getSession();
        await fetch('/api/notify-new-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session?.access_token}` },
          keepalive: true,
          body: JSON.stringify({
            county: meta?.dataset.county,
            details: meta?.dataset.details,
          }),
        });
      } catch (e) {
        console.error('notify-new-lead failed:', e);
      }
    }

    window.location.reload();
  }

  document.getElementById('approveBtn')?.addEventListener('click', () => updateStatus('approved'));
  document.getElementById('rejectBtn')?.addEventListener('click', () => updateStatus('rejected'));

  // -- MOVE TO EXTERNAL LEADS --
  document.getElementById('moveToExternalBtn')?.addEventListener('click', async () => {
    const meta = document.getElementById('leadMeta');
    const county = meta?.dataset.county || '';
    const details = meta?.dataset.details || '';

    if (!confirm('Move this lead to External Leads? It will be removed from Service Leads.')) return;

    const btn = document.getElementById('moveToExternalBtn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Moving...';

    const { data: leadRow } = await supabase.from('leads').select('*').eq('id', id).single();
    if (!leadRow) { alert('Lead not found.'); btn.disabled = false; return; }

    const { error: insertError } = await supabase.from('external_leads').insert([{
      form_type: 'lead',
      source_domain: leadRow.source || 'service-leads',
      full_name: null,
      email: leadRow.email,
      phone: leadRow.phone,
      message: leadRow.details,
      status: 'new',
      extra: { county: leadRow.county, migrated_from_lead_id: leadRow.id, migrated_from_status: leadRow.status },
    }]);

    if (insertError) {
      alert('Could not move lead: ' + insertError.message);
      btn.disabled = false;
      btn.textContent = '🌐 Move to External Leads';
      return;
    }

    await addLogEntry('Moved to External Leads');
    await supabase.from('lead_logs').delete().eq('lead_id', id);
    await supabase.from('leads').delete().eq('id', id);

    window.location.href = '/admin/external-leads';
  });

  // -- EDIT CONTROLS --
  document.getElementById('editBtn')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.remove('hidden');
  });
  
  document.getElementById('closeEditModal')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.add('hidden');
  });

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      email: (document.getElementById('editEmail') as HTMLInputElement).value,
      phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      county: (document.getElementById('editCounty') as HTMLSelectElement).value,
      details: (document.getElementById('editDetails') as HTMLTextAreaElement).value,
    };

    await supabase.from('leads').update(updates).eq('id', id);
    await addLogEntry('Updated lead details');

    window.location.reload();
  });

  // -- DELETE CONTROLS --
  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this lead? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      
      await addLogEntry('Lead deleted');
      await supabase.from('lead_logs').delete().eq('lead_id', id);
      await supabase.from('leads').delete().eq('id', id);
      
      window.location.href = '/admin/service-leads';
    }
  });
</script>
