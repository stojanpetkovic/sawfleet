---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";

const { id } = Astro.params;

// Fetch permit lead by ID
async function getPermitLead(leadId: string) {
  try {
    const response = await fetch('http://localhost:4321/api/permit-leads');
    const payload = await response.json();
    if (!payload.ok || !payload.leads) return null;
    return payload.leads.find((l: any) => l.id === leadId);
  } catch (error) {
    console.error('Error fetching permit lead:', error);
    return null;
  }
}

const lead = await getPermitLead(id || '');

if (!lead) {
  return Astro.redirect('/admin/permit-leads');
}

const { data: territories } = await supabase.from('service_territories').select('*').order('name');
---

<AdminLayout>
  <div class="space-y-5 w-full">
    <!-- Back Button -->
    <div class="flex items-center gap-3">
      <a href="/admin/permit-leads" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">
        ← Back
      </a>
      <div>
        <span class="text-[9px] font-mono font-bold uppercase tracking-[0.2em] text-green-700">// Permit details</span>
        <h1 class="mt-1.5 text-2xl sm:text-3xl font-bold text-slate-950 tracking-tight">{lead.address || 'Permit opportunity'}</h1>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1fr_400px]">
      <!-- Main Content -->
      <div class="space-y-4">
        <!-- Property & Permit Info -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Property & Permit Information</h2>
          <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Address</p>
                <p class="text-sm text-slate-900 font-mono">{lead.address || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Jurisdiction</p>
                <p class="text-sm text-slate-900">{lead.jurisdiction || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Permit Type</p>
                <p class="text-sm text-slate-900">{lead.permit_type || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Permit Number</p>
                <p class="text-sm text-slate-900 font-mono">{lead.permit_number || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Permit Date</p>
                <p class="text-sm text-slate-900">{lead.permit_date ? new Date(lead.permit_date).toLocaleDateString() : 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Lead Score</p>
                <p class="text-sm text-slate-900 font-bold text-green-700">{lead.lead_score ?? 'N/A'}</p>
              </div>
            </div>
            {lead.permit_description && (
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-2">Description</p>
                <p class="text-sm text-slate-700 line-clamp-4">{lead.permit_description}</p>
              </div>
            )}
          </div>
        </div>

        <!-- Owner/Contact Info -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Owner Contact Information</h2>
          <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Name</p>
                <p class="text-sm text-slate-900 font-semibold">{lead.owner_name || 'Not provided'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Email</p>
                {lead.owner_email ? (
                  <a href={`mailto:${lead.owner_email}`} class="text-sm text-green-600 hover:text-green-700 font-mono underline">{lead.owner_email}</a>
                ) : (
                  <p class="text-sm text-zinc-400">Not provided</p>
                )}
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Phone</p>
                {lead.owner_phone ? (
                  <a href={`tel:${lead.owner_phone}`} class="text-sm text-green-600 hover:text-green-700 font-mono underline">{lead.owner_phone}</a>
                ) : (
                  <p class="text-sm text-zinc-400">Not provided</p>
                )}
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Mailing Address</p>
                <p class="text-sm text-slate-900">{lead.owner_mailing_address || 'Not provided'}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Source Info -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Source Information</h2>
          <div class="space-y-3">
            <div>
              <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Source</p>
              <p class="text-sm text-slate-900">{lead.source_name || 'Unknown source'}</p>
            </div>
            <div>
              <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Discovered</p>
              <p class="text-sm text-slate-900">{lead.discovered_at ? new Date(lead.discovered_at).toLocaleString() : 'N/A'}</p>
            </div>
            {lead.source_url && (
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Source Link</p>
                <a href={lead.source_url} target="_blank" rel="noopener" class="text-sm text-green-600 hover:text-green-700 underline break-all">{lead.source_url}</a>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-4">
        <!-- Status Card -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm sticky top-8">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-3">Current Status</h3>
          <div class="mb-4 inline-block px-3 py-2 rounded-full text-[11px] font-bold uppercase tracking-wide border {
            lead.permit_status === 'converted' ? 'bg-green-500/10 text-green-600 border-green-500/20' :
            lead.permit_status === 'responded' ? 'bg-amber-500/10 text-amber-600 border-amber-500/20' :
            lead.permit_status === 'invited' ? 'bg-blue-500/10 text-blue-600 border-blue-500/20' :
            'bg-zinc-200/50 text-zinc-600 border-zinc-300'
          }">
            {(lead.permit_status || 'new').toUpperCase()}
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Actions</h3>
          <div class="space-y-3">
            {lead.owner_email && (
              <button id="emailBtn" class="w-full rounded-lg bg-green-600 px-4 py-3 text-sm font-bold text-white hover:bg-green-500 transition-colors">
                📧 Send Email
              </button>
            )}
            {lead.owner_phone && (
              <a href={`tel:${lead.owner_phone}`} class="block w-full rounded-lg bg-blue-600 px-4 py-3 text-sm font-bold text-white text-center hover:bg-blue-500 transition-colors">
                ☎️ Call Owner
              </a>
            )}
            <div class="space-y-2">
              <label class="block text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-600 mb-1">Update Status</label>
              <select id="statusSelect" class="w-full rounded-lg border border-zinc-200 bg-white px-3 py-2 text-sm font-bold text-slate-900 hover:border-zinc-300">
                <option value="">Select status...</option>
                <option value="new">New</option>
                <option value="invited">Invited</option>
                <option value="responded">Responded</option>
                <option value="converted">Converted</option>
              </select>
            </div>
            {lead.source_url && (
              <a href={lead.source_url} target="_blank" rel="noopener" class="block w-full rounded-lg border border-zinc-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 text-center hover:bg-zinc-50 transition-colors">
                🔗 Open Source
              </a>
            )}
          </div>
        </div>

        <!-- Danger Zone -->
        <div class="bg-red-50 border border-red-200 rounded-2xl p-6 shadow-sm">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-red-700 mb-4">Manage Lead</h3>
          <div class="space-y-3">
            <button id="transferBtn" class="w-full rounded-lg border border-orange-300 bg-orange-50 px-4 py-3 text-sm font-bold text-orange-700 hover:bg-orange-100 transition-colors">
              ↗️ Transfer Lead
            </button>
            <button id="deleteBtn" class="w-full rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm font-bold text-red-700 hover:bg-red-100 transition-colors">
              🗑️ Delete Lead
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Transfer Modal -->
    <div id="transferModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
      <div class="bg-white rounded-2xl p-6 max-w-sm w-full mx-4 shadow-lg">
        <h3 class="text-lg font-bold text-slate-900 mb-4">Transfer Lead to Team Member</h3>
        <div class="space-y-3 mb-6">
          <input type="text" id="transferEmail" placeholder="Enter email of team member" class="w-full rounded-lg border border-zinc-200 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
          <p class="text-[11px] text-zinc-500">Enter the email address of the team member to transfer this lead to.</p>
        </div>
        <div class="flex gap-3">
          <button id="transferCancel" class="flex-1 rounded-lg border border-zinc-200 px-4 py-2 text-sm font-bold text-zinc-700 hover:bg-zinc-50">
            Cancel
          </button>
          <button id="transferConfirm" class="flex-1 rounded-lg bg-orange-600 px-4 py-2 text-sm font-bold text-white hover:bg-orange-500">
            Transfer
          </button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ leadId: id }}>
  // Email Button
  document.getElementById('emailBtn')?.addEventListener('click', async (e) => {
    const confirmed = confirm('Send outreach email to this contact?');
    if (!confirmed) return;
    
    const btn = e.target as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Sending...';
    
    try {
      const response = await fetch('/api/permit-send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId })
      });
      
      const result = await response.json();
      if (result.ok) {
        alert('✅ Email sent successfully');
        btn.textContent = '📧 Email Sent';
        btn.disabled = true;
      } else {
        alert('❌ Error sending email: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      alert('❌ Error: ' + error);
    } finally {
      btn.disabled = false;
      btn.textContent = '📧 Send Email';
    }
  });

  // Status Update
  document.getElementById('statusSelect')?.addEventListener('change', async (e) => {
    const status = (e.target as HTMLSelectElement).value;
    if (!status) return;
    
    const select = e.target as HTMLSelectElement;
    select.disabled = true;
    
    try {
      const response = await fetch('/api/permit-update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId, status })
      });
      
      const result = await response.json();
      if (result.ok) {
        alert('✅ Status updated to: ' + status.toUpperCase());
        setTimeout(() => location.reload(), 800);
      } else {
        alert('❌ Error: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      alert('❌ Error: ' + error);
    } finally {
      select.disabled = false;
      select.value = '';
    }
  });

  // Transfer Modal
  const transferModal = document.getElementById('transferModal') as HTMLDivElement;
  const transferBtn = document.getElementById('transferBtn') as HTMLButtonElement;
  const transferCancel = document.getElementById('transferCancel') as HTMLButtonElement;
  const transferConfirm = document.getElementById('transferConfirm') as HTMLButtonElement;
  const transferEmail = document.getElementById('transferEmail') as HTMLInputElement;

  transferBtn?.addEventListener('click', () => {
    transferModal.classList.remove('hidden');
    transferEmail.focus();
  });

  transferCancel?.addEventListener('click', () => {
    transferModal.classList.add('hidden');
    transferEmail.value = '';
  });

  transferConfirm?.addEventListener('click', async () => {
    const email = transferEmail.value.trim();
    if (!email) {
      alert('⚠️ Please enter an email address');
      return;
    }

    transferConfirm.disabled = true;
    transferConfirm.textContent = '⏳ Transferring...';

    try {
      const response = await fetch('/api/permit-transfer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId, assignedTo: email })
      });

      const result = await response.json();
      if (result.ok) {
        alert('✅ Lead transferred successfully');
        setTimeout(() => window.location.href = '/admin/permit-leads', 1000);
      } else {
        alert('❌ Error: ' + (result.error || 'Unknown error'));
        transferConfirm.disabled = false;
        transferConfirm.textContent = '↗️ Transfer';
      }
    } catch (error) {
      alert('❌ Error: ' + error);
      transferConfirm.disabled = false;
      transferConfirm.textContent = '↗️ Transfer';
    }
  });

  // Delete Lead
  document.getElementById('deleteBtn')?.addEventListener('click', async (e) => {
    const confirmed = confirm('🚨 Are you sure you want to delete this lead? This action cannot be undone.');
    if (!confirmed) return;

    const btn = e.target as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Deleting...';

    try {
      const response = await fetch('/api/permit-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId })
      });

      const result = await response.json();
      if (result.ok) {
        alert('✅ Lead deleted successfully');
        setTimeout(() => window.location.href = '/admin/permit-leads', 800);
      } else {
        alert('❌ Error: ' + (result.error || 'Unknown error'));
        btn.disabled = false;
        btn.textContent = '🗑️ Delete Lead';
      }
    } catch (error) {
      alert('❌ Error: ' + error);
      btn.disabled = false;
      btn.textContent = '🗑️ Delete Lead';
    }
  });

  // Close modal on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      transferModal.classList.add('hidden');
    }
  });
</script>
