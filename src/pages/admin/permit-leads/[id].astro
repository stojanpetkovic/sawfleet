---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;

// Fetch permit lead directly from DB (not via localhost)
const { data: lead } = id
  ? await supabaseAdmin
      .from('permit_leads')
      .select('*')
      .eq('id', id)
      .single()
  : { data: null };

if (!lead) {
  return Astro.redirect('/admin/permit-leads');
}

const { data: territories } = await supabase.from('service_territories').select('*').order('name');
const { data: outreachEvents } = await supabaseAdmin
  .from('permit_outreach_events')
  .select('id,email,status,sent_at,delivered_at,opened_at,clicked_at,error_message,created_at')
  .eq('permit_lead_id', lead.id)
  .order('created_at', { ascending: false });

// Get activity log from extra column (if exists)
const activityLog: { action: string; at: string; by?: string }[] =
  (lead.extra as any)?.activity_log || [];
---

<AdminLayout>
  <div class="dash-shell flex-1">
  <div class="dash-shell__frozen">
    <!-- Back Button -->
    <div class="flex items-center gap-3">
      <a href="/admin/permit-leads" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">
        ← Back
      </a>
      <div>
        <span class="dash-eyebrow text-green-700">// Permit details</span>
        <h1 class="mt-1.5 text-2xl sm:text-3xl font-bold text-slate-950 tracking-tight">{lead.address || 'Permit opportunity'}</h1>
      </div>
    </div>
  </div>

  <div class="dash-scroll">
    <div class="grid gap-6 lg:grid-cols-[1fr_380px]">
      <!-- Main Content -->
      <div class="space-y-4">
        <!-- Property & Permit Info -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Property & Permit Information</h2>
          <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Address</p>
                <p class="text-sm text-slate-900 font-mono">{lead.address || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Jurisdiction</p>
                <p class="text-sm text-slate-900">{lead.jurisdiction || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Permit Type</p>
                <p class="text-sm text-slate-900">{lead.permit_type || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Permit Number</p>
                <p class="text-sm text-slate-900 font-mono">{lead.permit_number || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Permit Date</p>
                <p class="text-sm text-slate-900">{lead.permit_date ? new Date(lead.permit_date).toLocaleDateString() : 'N/A'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Lead Score</p>
                <p class="text-sm text-slate-900 font-bold text-green-700">{lead.lead_score ?? 'N/A'}</p>
              </div>
            </div>
            {lead.permit_description && (
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-2">Description</p>
                <p class="text-sm text-slate-700 line-clamp-4">{lead.permit_description}</p>
              </div>
            )}
          </div>
        </div>

        <div class="rounded-2xl border border-zinc-100 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between"><div><h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700">Outreach tracking</h2><p class="mt-1 text-[10px] text-zinc-400">Delivery and engagement history for this permit contact</p></div><span class="rounded-full bg-slate-100 px-3 py-1 text-[9px] font-bold uppercase text-slate-600">{outreachEvents?.length || 0} messages</span></div>
          <div class="mt-5 space-y-3">
            {(outreachEvents || []).map((event: any) => (
              <div class="flex flex-col justify-between gap-3 rounded-xl border border-slate-100 p-4 sm:flex-row sm:items-center">
                <div><p class="text-xs font-medium text-slate-800">{event.email}</p><p class="mt-1 text-[10px] text-slate-400">{new Date(event.created_at).toLocaleString()}{event.error_message ? ` · ${event.error_message}` : ''}</p></div>
                <span class={`w-fit rounded-full px-2.5 py-1 text-[9px] font-bold uppercase ${['bounced','complained','failed','unsubscribed'].includes(event.status) ? 'bg-red-50 text-red-700' : ['delivered','opened','clicked','converted'].includes(event.status) ? 'bg-green-50 text-green-700' : 'bg-blue-50 text-blue-700'}`}>{event.status}</span>
              </div>
            ))}
            {(!outreachEvents || outreachEvents.length === 0) && <p class="rounded-xl border border-dashed border-slate-200 p-5 text-center text-xs text-slate-400">No tracked outreach has been sent yet.</p>}
          </div>
        </div>

        <!-- Owner/Contact Info -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Owner Contact Information</h2>
          <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Name</p>
                <p class="text-sm text-slate-900 font-semibold">{lead.owner_name || 'Not provided'}</p>
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Email</p>
                {lead.owner_email ? (
                  <a href={`mailto:${lead.owner_email}`} class="text-sm text-green-600 hover:text-green-700 font-mono underline">{lead.owner_email}</a>
                ) : (
                  <p class="text-sm text-zinc-400">Not provided</p>
                )}
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Phone</p>
                {lead.owner_phone ? (
                  <a href={`tel:${lead.owner_phone}`} class="text-sm text-green-600 hover:text-green-700 font-mono underline">{lead.owner_phone}</a>
                ) : (
                  <p class="text-sm text-zinc-400">Not provided</p>
                )}
              </div>
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Mailing Address</p>
                <p class="text-sm text-slate-900">{lead.owner_mailing_address || 'Not provided'}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Source Info -->
        <div class="bg-white border border-zinc-100 rounded-2xl p-6 shadow-sm">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-700 mb-4">Source Information</h2>
          <div class="space-y-3">
            <div>
              <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Source</p>
              <p class="text-sm text-slate-900">{lead.source_name || 'Unknown source'}</p>
            </div>
            <div>
              <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Discovered</p>
              <p class="text-sm text-slate-900">{lead.discovered_at ? new Date(lead.discovered_at).toLocaleString() : 'N/A'}</p>
            </div>
            {lead.source_url && (
              <div>
                <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 mb-1">Source Link</p>
                <a href={lead.source_url} target="_blank" rel="noopener" class="text-sm text-green-600 hover:text-green-700 underline break-all">{lead.source_url}</a>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Sidebar: Status / Actions / Manage / Activity Log -->
      <div class="detail-sidebar">
        <!-- Current Status -->
        <div class="detail-card">
          <h3 class="detail-card__title">Current Status</h3>
          <div class={`inline-block px-3 py-2 rounded-full text-[11px] font-bold uppercase tracking-wide border ${
            lead.permit_status === 'converted' ? 'bg-green-500/10 text-green-600 border-green-500/20' :
            lead.permit_status === 'published' ? 'bg-teal-500/10 text-teal-700 border-teal-500/20' :
            lead.permit_status === 'qualified' ? 'bg-violet-500/10 text-violet-600 border-violet-500/20' :
            lead.permit_status === 'responded' ? 'bg-amber-500/10 text-amber-600 border-amber-500/20' :
            lead.permit_status === 'invited' ? 'bg-blue-500/10 text-blue-600 border-blue-500/20' :
            'bg-zinc-200/50 text-zinc-600 border-zinc-300'
          }`}>
            {(lead.permit_status || 'new').toUpperCase()}
          </div>
        </div>

        <!-- Actions -->
        <div class="detail-card">
          <h3 class="detail-card__title">Actions</h3>
          <div class="space-y-2">
            {lead.owner_email && (
              <button id="emailBtn" class="detail-btn detail-btn--primary">
                📧 Send Email
              </button>
            )}
            {lead.owner_phone && (
              <a href={`tel:${lead.owner_phone}`} class="detail-btn detail-btn--primary block text-center">
                ☎️ Call Owner
              </a>
            )}
            <p class="text-[9px] font-bold uppercase tracking-[0.15em] text-zinc-400 pt-2">Update status</p>
            <select id="statusSelect" class="w-full rounded-lg border border-zinc-200 bg-white px-3 py-2 text-[11px] font-bold text-slate-900 hover:border-zinc-300">
              <option value="">Select status…</option>
              <option value="new">New</option>
              <option value="qualified">Qualified</option>
              <option value="invited">Invited</option>
              <option value="responded">Responded</option>
              <option value="published">Published by dispatcher</option>
              <option value="converted">Converted</option>
              <option value="skipped">Skipped</option>
              <option value="expired">Expired</option>
            </select>
            {lead.source_url && (
              <a href={lead.source_url} target="_blank" rel="noopener" class="detail-btn detail-btn--ghost block text-center">
                🔗 Open Source
              </a>
            )}
          </div>
        </div>

        <!-- Manage Lead -->
        <div class="detail-card detail-card--danger">
          <h3 class="detail-card__title detail-card__title--danger">Manage Lead</h3>
          <div class="space-y-2">
            {!lead.website_lead_id ? (
              <>
                <button id="publishPermitBtn" class="detail-btn detail-btn--warn">
                  🌳 Publish to Website Leads
                </button>
                <div id="publishPermitPicker" class="hidden space-y-2 rounded-xl border border-amber-200 bg-amber-50 p-3">
                  <p class="text-[10px] leading-4 text-amber-800">The homeowner has not submitted a request. This will create an unconfirmed dispatcher lead.</p>
                  <select id="publishPermitCounty" class="h-10 w-full rounded-lg border border-amber-200 bg-white px-3 text-[11px] text-slate-900">
                    <option value="" selected disabled>Territory…</option>
                    {territories?.map((t) => <option value={t.name}>{t.name}</option>)}
                  </select>
                  <div class="flex gap-2">
                    <button id="cancelPermitPublish" class="flex-1 h-9 rounded-lg border border-zinc-200 bg-white text-[9px] font-bold uppercase text-zinc-600">Cancel</button>
                    <button id="confirmPermitPublish" class="flex-1 h-9 rounded-lg bg-amber-600 text-[9px] font-bold uppercase text-white">Publish</button>
                  </div>
                </div>
              </>
            ) : (
              <a href={`/admin/leads/${lead.website_lead_id}`} class="detail-btn detail-btn--primary block text-center">Open Website Lead →</a>
            )}
            <button id="transferBtn" class="detail-btn detail-btn--warn">
              ↗️ Transfer
            </button>
            <button id="deleteBtn" class="detail-btn detail-btn--danger">
              🗑️ Delete
            </button>
          </div>
        </div>

        <!-- Activity Log -->
        <div class="detail-card">
          <h3 class="detail-card__title">Activity Log</h3>
          <div id="activityLog" class="detail-log">
            {activityLog.length === 0
              ? <p class="text-[11px] text-zinc-400 italic">No activity yet.</p>
              : activityLog.slice().reverse().map((entry) => (
                  <div class="detail-log__entry">
                    <div class="detail-log__dot"></div>
                    <div>
                      <p class="text-sm text-slate-900">{entry.action}</p>
                      <p class="text-[10px] text-zinc-400 mt-0.5 font-mono">{new Date(entry.at).toLocaleString()}</p>
                    </div>
                  </div>
                ))
            }
          </div>

          <!-- Add Note -->
          <div class="mt-4 pt-4 border-t border-zinc-100">
            <textarea id="noteInput" rows="2" placeholder="Add a note…" class="w-full rounded-xl border border-zinc-200 bg-zinc-50 p-3 text-sm text-slate-900 outline-none focus:border-green-500 resize-none"></textarea>
            <button id="addNoteBtn" class="mt-2 px-4 py-2 rounded-lg bg-zinc-100 border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-700 hover:bg-zinc-200 transition-colors">Add Note</button>
          </div>
        </div>
      </div>
    </div>
  </div>

    <!-- Transfer Modal -->
    <div id="transferModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
      <div class="bg-white rounded-2xl p-6 max-w-sm w-full mx-4 shadow-lg">
        <h3 class="text-lg font-bold text-slate-900 mb-4">Transfer Lead to Team Member</h3>
        <div class="space-y-3 mb-6">
          <input type="text" id="transferEmail" placeholder="Enter email of team member" class="w-full rounded-lg border border-zinc-200 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
          <p class="text-[11px] text-zinc-500">Enter the email address of the team member to transfer this lead to.</p>
        </div>
        <div class="flex gap-3">
          <button id="transferCancel" class="flex-1 rounded-lg border border-zinc-200 px-4 py-2 text-sm font-bold text-zinc-700 hover:bg-zinc-50">
            Cancel
          </button>
          <button id="transferConfirm" class="flex-1 rounded-lg bg-orange-600 px-4 py-2 text-sm font-bold text-white hover:bg-orange-500">
            Transfer
          </button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ leadId: id }}>
  import { supabase } from "../../../lib/supabase";

  // Add Note functionality
  async function addLogEntry(action: string) {
    const { data: lead } = await supabase.from('permit_leads').select('extra').eq('id', leadId).single();
    const extra = (lead?.extra as any) || {};
    const log = extra.activity_log || [];
    log.push({ action, at: new Date().toISOString() });
    await supabase.from('permit_leads').update({ extra: { ...extra, activity_log: log } }).eq('id', leadId);

    const logEl = document.getElementById('activityLog')!;
    const entry = document.createElement('div');
    entry.className = 'flex items-start gap-3 p-3 rounded-xl bg-zinc-50 border border-zinc-100';
    entry.innerHTML = `
      <div class="w-1.5 h-1.5 rounded-full bg-green-500 mt-1.5 shrink-0"></div>
      <div>
        <p class="text-sm text-slate-900">${action}</p>
        <p class="text-[10px] text-zinc-400 mt-0.5 font-mono">${new Date().toLocaleString()}</p>
      </div>
    `;
    logEl.prepend(entry);
  }

  document.getElementById('addNoteBtn')?.addEventListener('click', async () => {
    const input = document.getElementById('noteInput') as HTMLTextAreaElement;
    const text = input.value.trim();
    if (!text) return;
    await addLogEntry(`📝 Note: ${text}`);
    input.value = '';
  });

  document.getElementById('publishPermitBtn')?.addEventListener('click', () => {
    document.getElementById('publishPermitPicker')?.classList.remove('hidden');
  });
  document.getElementById('cancelPermitPublish')?.addEventListener('click', () => {
    document.getElementById('publishPermitPicker')?.classList.add('hidden');
  });
  document.getElementById('confirmPermitPublish')?.addEventListener('click', async () => {
    const county = (document.getElementById('publishPermitCounty') as HTMLSelectElement).value;
    if (!county) { alert('Select a territory first.'); return; }
    if (!confirm('This person has not submitted a service request. Publish as an unconfirmed dispatcher lead?')) return;
    const button = document.getElementById('confirmPermitPublish') as HTMLButtonElement;
    button.disabled = true;
    button.textContent = 'Publishing…';
    const response = await fetch('/api/publish-lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ originType: 'permit_dispatch', originId: leadId, county, confirmUnrequested: true }),
    });
    const result = await response.json().catch(() => ({}));
    if (!response.ok || !result.ok) {
      alert('Publish failed: ' + (result.error || 'Unknown error'));
      button.disabled = false;
      button.textContent = 'Publish';
      return;
    }
    window.location.href = `/admin/leads/${result.leadId}`;
  });

  // Email Button
  document.getElementById('emailBtn')?.addEventListener('click', async (e) => {
    const confirmed = confirm('Send outreach email to this contact?');
    if (!confirmed) return;
    
    const btn = e.target as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Sending...';
    
    try {
      const response = await fetch('/api/permit-send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId })
      });
      
      const result = await response.json();
      if (result.ok) {
        alert('✅ Email sent successfully');
        await addLogEntry('📧 Email sent');
        btn.textContent = '📧 Email Sent';
        btn.disabled = true;
      } else {
        alert('❌ Error sending email: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      alert('❌ Error: ' + error);
    } finally {
      btn.disabled = false;
      btn.textContent = '📧 Send Email';
    }
  });

  // Status Update
  document.getElementById('statusSelect')?.addEventListener('change', async (e) => {
    const status = (e.target as HTMLSelectElement).value;
    if (!status) return;
    
    const select = e.target as HTMLSelectElement;
    select.disabled = true;
    
    try {
      const response = await fetch('/api/permit-update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId, status })
      });
      
      const result = await response.json();
      if (result.ok) {
        alert('✅ Status updated to: ' + status.toUpperCase());
        await addLogEntry(`Status changed to ${status}`);
        setTimeout(() => location.reload(), 800);
      } else {
        alert('❌ Error: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      alert('❌ Error: ' + error);
    } finally {
      select.disabled = false;
      select.value = '';
    }
  });

  // Transfer Modal
  const transferModal = document.getElementById('transferModal') as HTMLDivElement;
  const transferBtn = document.getElementById('transferBtn') as HTMLButtonElement;
  const transferCancel = document.getElementById('transferCancel') as HTMLButtonElement;
  const transferConfirm = document.getElementById('transferConfirm') as HTMLButtonElement;
  const transferEmail = document.getElementById('transferEmail') as HTMLInputElement;

  transferBtn?.addEventListener('click', () => {
    transferModal.classList.remove('hidden');
    transferEmail.focus();
  });

  transferCancel?.addEventListener('click', () => {
    transferModal.classList.add('hidden');
    transferEmail.value = '';
  });

  transferConfirm?.addEventListener('click', async () => {
    const email = transferEmail.value.trim();
    if (!email) {
      alert('⚠️ Please enter an email address');
      return;
    }

    transferConfirm.disabled = true;
    transferConfirm.textContent = '⏳ Transferring...';

    try {
      const response = await fetch('/api/permit-transfer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId, assignedTo: email })
      });

      const result = await response.json();
      if (result.ok) {
        alert('✅ Lead transferred successfully');
        setTimeout(() => window.location.href = '/admin/permit-leads', 1000);
      } else {
        alert('❌ Error: ' + (result.error || 'Unknown error'));
        transferConfirm.disabled = false;
        transferConfirm.textContent = '↗️ Transfer';
      }
    } catch (error) {
      alert('❌ Error: ' + error);
      transferConfirm.disabled = false;
      transferConfirm.textContent = '↗️ Transfer';
    }
  });

  // Delete Lead
  document.getElementById('deleteBtn')?.addEventListener('click', async (e) => {
    const confirmed = confirm('🚨 Are you sure you want to delete this lead? This action cannot be undone.');
    if (!confirmed) return;

    const btn = e.target as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Deleting...';

    try {
      const response = await fetch('/api/permit-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId })
      });

      const result = await response.json();
      if (result.ok) {
        alert('✅ Lead deleted successfully');
        setTimeout(() => window.location.href = '/admin/permit-leads', 800);
      } else {
        alert('❌ Error: ' + (result.error || 'Unknown error'));
        btn.disabled = false;
        btn.textContent = '🗑️ Delete Lead';
      }
    } catch (error) {
      alert('❌ Error: ' + error);
      btn.disabled = false;
      btn.textContent = '🗑️ Delete Lead';
    }
  });

  // Close modal on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      transferModal.classList.add('hidden');
    }
  });
</script>
