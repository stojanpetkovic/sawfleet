---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabase } from "../../lib/supabase";

// Dohvatamo teritorije
const { data: territories } = await supabase
  .from('service_territories')
  .select('*')
  .order('name', { ascending: true });

// Dohvatamo skripte
const { data: tracking } = await supabase
  .from('tracking_settings')
  .select('*')
  .eq('id', 1)
  .single();
---

<AdminLayout>
  <div class="w-full max-w-7xl mx-auto space-y-8">
    
    <div class="flex justify-between items-center border-b border-zinc-900 pb-6">
      <div>
        <h1 class="text-2xl font-bold text-white tracking-wide">System Settings</h1>
        <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-500 mt-2">Manage application configurations</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- LEVI MENI (Tabovi) -->
      <div class="lg:col-span-3 space-y-2 flex lg:flex-col overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 hide-scrollbar">
        <button id="tabBtn-territories" class="tab-btn active flex-shrink-0 lg:w-full text-left px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-white text-[11px] font-bold uppercase tracking-wider flex items-center gap-3 transition-all">
          <span class="indicator w-2 h-2 rounded-full bg-green-500"></span>
          Coverage Areas
        </button>
        <button id="tabBtn-tracking" class="tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-zinc-500 hover:bg-zinc-900/50 hover:text-white rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent flex items-center gap-3">
          <span class="indicator w-2 h-2 rounded-full bg-zinc-800"></span>
          Tracking & Analytics
        </button>
      </div>

      <!-- DESNI SADRŽAJ -->
      <div class="lg:col-span-9 space-y-8 relative">
        
        <!-- POKRIVENOST (Territories) -->
        <div id="section-territories" class="tab-section block bg-[#050505] border border-zinc-900 p-6 md:p-8 rounded-xl shadow-2xl">
          <h2 class="text-sm font-bold text-white uppercase tracking-wider mb-2">Service Coverage Areas</h2>
          <p class="text-[11px] text-zinc-500 mb-8">Add or remove states/counties where your services are available.</p>
          
          <form id="addTerritoryForm" class="flex flex-col sm:flex-row gap-4 mb-8 p-4 md:p-5 bg-black border border-zinc-900 rounded-xl shadow-inner">
            <div class="flex-1">
              <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-600 ml-1 block mb-2">New Territory Name</label>
              <input type="text" id="territoryName" placeholder="e.g. Texas, Miami-Dade, etc." class="w-full bg-zinc-900 border border-zinc-800 p-3 rounded-lg text-white text-[13px] outline-none focus:border-green-500/50 transition-colors" required />
            </div>
            <div class="flex items-end">
              <button type="submit" class="w-full sm:w-auto h-[46px] px-6 bg-green-500/10 border border-green-500/30 text-green-500 font-bold uppercase tracking-[0.2em] text-[10px] rounded-lg hover:bg-green-500 hover:text-black transition-all whitespace-nowrap">
                Add Area
              </button>
            </div>
          </form>

          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-600 mb-4 border-b border-zinc-900 pb-2">Active Territories ({territories?.length || 0})</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
              {territories && territories.length > 0 ? territories.map(t => (
                <div class="flex items-center justify-between bg-zinc-950 border border-zinc-800/70 p-4 rounded-lg group hover:border-zinc-700 transition-colors">
                  <div class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500/50"></span>
                    <span class="text-zinc-200 text-[13px] font-bold truncate pr-2">{t.name}</span>
                  </div>
                  <button data-id={t.id} class="delete-btn flex-shrink-0 text-[10px] text-red-500/70 uppercase font-bold tracking-wider hover:text-red-500 bg-red-950/20 hover:bg-red-950/40 px-3 py-1.5 rounded transition-all opacity-100 lg:opacity-0 group-hover:opacity-100">
                    Remove
                  </button>
                </div>
              )) : (
                <div class="col-span-1 sm:col-span-2 xl:col-span-3 text-center py-8 border border-dashed border-zinc-800 rounded-lg">
                  <p class="text-[11px] text-zinc-500 uppercase tracking-wider">No territories added yet.</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- PRAĆENJE (Tracking) -->
        <div id="section-tracking" class="tab-section hidden bg-[#050505] border border-zinc-900 p-6 md:p-8 rounded-xl shadow-2xl">
          <div class="border-b border-zinc-900 pb-5 mb-6">
            <h2 class="text-sm font-bold text-white uppercase tracking-wider mb-2">Tracking & Analytics</h2>
            <p class="text-[11px] text-zinc-500">Inject Google Analytics, Meta Pixel, and Conversion tags directly into your site.</p>
          </div>

          <form id="trackingForm" class="space-y-6">
            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 font-bold block mb-2">
                Global Scripts (All Pages)
              </label>
              <p class="text-[11px] text-zinc-500 mb-3">Paste your base Google Analytics or Meta Pixel code here. It will run on every page.</p>
              <textarea id="globalScripts" rows="6" class="w-full bg-black border border-zinc-800 p-4 rounded-xl text-zinc-300 font-mono text-xs outline-none focus:border-green-500/50 transition-colors placeholder:text-zinc-700" placeholder="<!-- Paste Global Scripts Here -->">{tracking?.global_scripts || ''}</textarea>
            </div>

            <div class="pt-4 border-t border-zinc-900">
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-400 font-bold block mb-2">
                Conversion Scripts (Thank You Page)
              </label>
              <p class="text-[11px] text-zinc-500 mb-3">Paste your Google Ads Event Snippet or Meta Lead Event here. It will ONLY trigger after a successful form submission.</p>
              <textarea id="conversionScripts" rows="6" class="w-full bg-black border border-zinc-800 p-4 rounded-xl text-zinc-300 font-mono text-xs outline-none focus:border-green-500/50 transition-colors placeholder:text-zinc-700" placeholder="<!-- Paste Conversion Event Scripts Here -->">{tracking?.conversion_scripts || ''}</textarea>
            </div>

            <button type="submit" id="saveTrackingBtn" class="flex h-12 w-full sm:w-auto px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-black transition-all hover:bg-green-400 active:scale-[0.98]">
              Save Tracking Scripts
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  import { supabase } from "../../lib/supabase";

  // --- TABOVI LOGIKA ---
  const tabTerritories = document.getElementById('tabBtn-territories');
  const tabTracking = document.getElementById('tabBtn-tracking');
  const secTerritories = document.getElementById('section-territories');
  const secTracking = document.getElementById('section-tracking');

  function switchTab(activeTab: HTMLElement, inactiveTab: HTMLElement, showSec: HTMLElement, hideSec: HTMLElement) {
    // Reset inactive
    inactiveTab.className = "tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-zinc-500 hover:bg-zinc-900/50 hover:text-white rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent flex items-center gap-3";
    inactiveTab.querySelector('.indicator')!.className = "indicator w-2 h-2 rounded-full bg-zinc-800";
    // Set active
    activeTab.className = "tab-btn active flex-shrink-0 lg:w-full text-left px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-white text-[11px] font-bold uppercase tracking-wider flex items-center gap-3 transition-all";
    activeTab.querySelector('.indicator')!.className = "indicator w-2 h-2 rounded-full bg-green-500";
    // Toggle views
    hideSec.classList.add('hidden');
    hideSec.classList.remove('block');
    showSec.classList.remove('hidden');
    showSec.classList.add('block');
  }

  tabTerritories?.addEventListener('click', () => switchTab(tabTerritories, tabTracking!, secTerritories!, secTracking!));
  tabTracking?.addEventListener('click', () => switchTab(tabTracking, tabTerritories!, secTracking!, secTerritories!));

  // --- DODAVANJE TERITORIJE ---
  document.getElementById('addTerritoryForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = document.getElementById('territoryName') as HTMLInputElement;
    const name = nameInput.value.trim();
    if (!name) return;
    document.body.style.opacity = '0.5';
    const { error } = await supabase.from('service_territories').insert([{ name }]);
    if (error) alert("Error adding territory.");
    window.location.reload();
  });

  // --- BRISANJE TERITORIJE ---
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLButtonElement).dataset.id;
      if (confirm('Are you sure you want to remove this coverage area?')) {
        document.body.style.opacity = '0.5';
        await supabase.from('service_territories').delete().eq('id', id);
        window.location.reload();
      }
    });
  });

  // --- ČUVANJE SKRIPTI ---
  const trackingForm = document.getElementById('trackingForm');
  const saveBtn = document.getElementById('saveTrackingBtn') as HTMLButtonElement;

  trackingForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.innerText = "Saving...";
    saveBtn.disabled = true;

    const globalVal = (document.getElementById('globalScripts') as HTMLTextAreaElement).value;
    const conversionVal = (document.getElementById('conversionScripts') as HTMLTextAreaElement).value;

    const { error } = await supabase.from('tracking_settings').update({
      global_scripts: globalVal,
      conversion_scripts: conversionVal
    }).eq('id', 1);

    if (error) {
      alert("Error saving scripts!");
    } else {
      saveBtn.innerText = "Saved Successfully ✓";
      saveBtn.classList.replace('bg-green-500', 'bg-zinc-700');
      saveBtn.classList.replace('text-black', 'text-green-500');
      setTimeout(() => {
        saveBtn.innerText = "Save Tracking Scripts";
        saveBtn.classList.replace('bg-zinc-700', 'bg-green-500');
        saveBtn.classList.replace('text-green-500', 'text-black');
        saveBtn.disabled = false;
      }, 2000);
    }
  });
</script>