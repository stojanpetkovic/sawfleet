---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabase } from "../../lib/supabase";
import { parsePermitSettings } from "../../lib/permitData";

// Dohvatamo teritorije
const { data: territories } = await supabase
  .from('service_territories')
  .select('*')
  .order('name', { ascending: true });

// Dohvatamo skripte + notifikacione email adrese
const { data: tracking } = await supabase
  .from('tracking_settings')
  .select('*')
  .eq('id', 1)
  .single();

const permitSettings = parsePermitSettings(tracking?.global_scripts);
---

<AdminLayout>
  <div class="w-full max-w-7xl mx-auto space-y-8">
    
    <div class="flex justify-between items-center border-b border-slate-200 pb-7">
      <div>
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-green-700">// Workspace control</span>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">System settings</h1>
        <p class="mt-2 text-sm text-slate-500">Manage coverage, tracking and notification preferences.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- LEVI MENI (Tabovi) -->
      <div class="lg:col-span-3 space-y-2 flex lg:flex-col overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 hide-scrollbar">
        <button id="tabBtn-territories" class="tab-btn active flex-shrink-0 lg:w-full text-left px-4 py-3 bg-green-50 border border-green-200 rounded-xl text-green-800 text-[11px] font-bold uppercase tracking-wider flex items-center gap-3 transition-all">
          <span class="indicator w-2 h-2 rounded-full bg-green-500"></span>
          Coverage Areas
        </button>
        <button id="tabBtn-tracking" class="tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-zinc-500 hover:bg-zinc-100/50 hover:text-slate-900 rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent flex items-center gap-3">
          <span class="indicator w-2 h-2 rounded-full bg-zinc-200"></span>
          Tracking & Analytics
        </button>
        <button id="tabBtn-notifications" class="tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-zinc-500 hover:bg-zinc-100/50 hover:text-slate-900 rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent flex items-center gap-3">
          <span class="indicator w-2 h-2 rounded-full bg-zinc-200"></span>
          Notifications
        </button>
        <button id="tabBtn-permit" class="tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-zinc-500 hover:bg-zinc-100/50 hover:text-slate-900 rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent flex items-center gap-3">
          <span class="indicator w-2 h-2 rounded-full bg-zinc-200"></span>
          Workflow Automation
        </button>
        <button id="tabBtn-truckOutreach" class="tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-zinc-500 hover:bg-zinc-100/50 hover:text-slate-900 rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent flex items-center gap-3">
          <span class="indicator w-2 h-2 rounded-full bg-zinc-200"></span>
          Truck Profile Outreach
        </button>
      </div>

      <!-- DESNI SADRŽAJ -->
      <div class="lg:col-span-9 space-y-8 relative">
        
        <!-- POKRIVENOST (Territories) -->
        <div id="section-territories" class="tab-section block bg-white border border-slate-200 p-6 md:p-8 rounded-2xl shadow-sm">
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-2">Service Coverage Areas</h2>
          <p class="text-[11px] text-zinc-500 mb-8">Add or remove states/counties where your services are available.</p>
          
          <form id="addTerritoryForm" class="flex flex-col sm:flex-row gap-4 mb-8 p-4 md:p-5 bg-white border border-zinc-100 rounded-xl shadow-inner">
            <div class="flex-1">
              <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 ml-1 block mb-2">New Territory Name</label>
              <input type="text" id="territoryName" placeholder="e.g. Texas, Miami-Dade, etc." class="w-full bg-zinc-100 border border-zinc-200 p-3 rounded-lg text-slate-900 text-[13px] outline-none focus:border-green-500/50 transition-colors" required />
            </div>
            <div class="flex items-end">
              <button type="submit" class="w-full sm:w-auto h-[46px] px-6 bg-green-500/10 border border-green-500/30 text-green-700 font-bold uppercase tracking-[0.2em] text-[10px] rounded-lg hover:bg-green-500 hover:text-slate-900 transition-all whitespace-nowrap">
                Add Area
              </button>
            </div>
          </form>

          <div>
            <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 mb-4 border-b border-zinc-100 pb-2">Active Territories ({territories?.length || 0})</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
              {territories && territories.length > 0 ? territories.map(t => (
                <div class="flex items-center justify-between bg-zinc-50 border border-zinc-200/70 p-4 rounded-lg group hover:border-zinc-300 transition-colors">
                  <div class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500/50"></span>
                    <span class="text-zinc-800 text-[13px] font-bold truncate pr-2">{t.name}</span>
                  </div>
                  <button data-id={t.id} class="delete-btn flex-shrink-0 text-[10px] text-red-600/70 uppercase font-bold tracking-wider hover:text-red-600 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded transition-all opacity-100 lg:opacity-0 group-hover:opacity-100">
                    Remove
                  </button>
                </div>
              )) : (
                <div class="col-span-1 sm:col-span-2 xl:col-span-3 text-center py-8 border border-dashed border-zinc-200 rounded-lg">
                  <p class="text-[11px] text-zinc-500 uppercase tracking-wider">No territories added yet.</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- PRAĆENJE (Tracking) -->
        <div id="section-tracking" class="tab-section hidden bg-white border border-slate-200 p-6 md:p-8 rounded-2xl shadow-sm">
          <div class="border-b border-zinc-100 pb-5 mb-6">
            <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-2">Tracking & Analytics</h2>
            <p class="text-[11px] text-zinc-500">Inject Google Analytics, Meta Pixel, and Conversion tags directly into your site.</p>
          </div>

          <form id="trackingForm" class="space-y-6">
            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">
                Global Scripts (All Pages)
              </label>
              <p class="text-[11px] text-zinc-500 mb-3">Paste your base Google Analytics or Meta Pixel code here. It will run on every page.</p>
              <textarea id="globalScripts" rows="6" class="w-full bg-white border border-zinc-200 p-4 rounded-xl text-zinc-700 font-mono text-xs outline-none focus:border-green-500/50 transition-colors placeholder:text-zinc-300" placeholder="<!-- Paste Global Scripts Here -->">{tracking?.global_scripts || ''}</textarea>
            </div>

            <div class="pt-4 border-t border-zinc-100">
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">
                Conversion Scripts (Thank You Page)
              </label>
              <p class="text-[11px] text-zinc-500 mb-3">Paste your Google Ads Event Snippet or Meta Lead Event here. It will ONLY trigger after a successful form submission.</p>
              <textarea id="conversionScripts" rows="6" class="w-full bg-white border border-zinc-200 p-4 rounded-xl text-zinc-700 font-mono text-xs outline-none focus:border-green-500/50 transition-colors placeholder:text-zinc-300" placeholder="<!-- Paste Conversion Event Scripts Here -->">{tracking?.conversion_scripts || ''}</textarea>
            </div>

            <button type="submit" id="saveTrackingBtn" class="flex h-12 w-full sm:w-auto px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-900 transition-all hover:bg-green-400 active:scale-[0.98]">
              Save Tracking Scripts
            </button>
          </form>
        </div>

        <!-- NOTIFIKACIJE -->
        <div id="section-notifications" class="tab-section hidden bg-white border border-slate-200 p-6 md:p-8 rounded-2xl shadow-sm">
          <div class="border-b border-zinc-100 pb-5 mb-6">
            <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-2">Notifications</h2>
            <p class="text-[11px] text-zinc-500">Choose who gets emailed when a new external lead comes in (e.g. from Tree Jaws or other partner sites).</p>
          </div>

          <form id="notificationsForm" class="space-y-6">
            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">
                External Lead Notification Emails
              </label>
              <p class="text-[11px] text-zinc-500 mb-3">Comma-separated list. Leave empty to notify all admins by default.</p>
              <textarea id="externalLeadEmails" rows="3" class="w-full bg-white border border-zinc-200 p-4 rounded-xl text-zinc-700 font-mono text-xs outline-none focus:border-green-500/50 transition-colors placeholder:text-zinc-300" placeholder="e.g. dispatch@sftreeremoval.com, stojan@sftreeremoval.com">{tracking?.external_lead_notification_emails || ''}</textarea>
            </div>

            <div class="pt-4 border-t border-zinc-100">
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">
                When To Send
              </label>
              <p class="text-[11px] text-zinc-500 mb-3">Choose when the notification above fires for a new external lead.</p>
              <div class="space-y-2">
                <label class="flex items-start gap-3 p-4 rounded-xl border border-zinc-200 cursor-pointer hover:border-green-500/40 transition-colors has-[:checked]:border-green-500 has-[:checked]:bg-green-50/50">
                  <input type="radio" name="notifyTiming" id="notifyTimingImmediate" value="immediate" class="mt-1 accent-green-600" checked={!tracking?.external_lead_notify_on_approval_only} />
                  <span>
                    <span class="block text-xs font-bold text-slate-900">Immediately on arrival</span>
                    <span class="block text-[11px] text-zinc-500 mt-0.5">Send the moment a new external lead comes in, before anyone reviews it.</span>
                  </span>
                </label>
                <label class="flex items-start gap-3 p-4 rounded-xl border border-zinc-200 cursor-pointer hover:border-green-500/40 transition-colors has-[:checked]:border-green-500 has-[:checked]:bg-green-50/50">
                  <input type="radio" name="notifyTiming" id="notifyTimingApproval" value="approval" class="mt-1 accent-green-600" checked={!!tracking?.external_lead_notify_on_approval_only} />
                  <span>
                    <span class="block text-xs font-bold text-slate-900">Only after it's approved</span>
                    <span class="block text-[11px] text-zinc-500 mt-0.5">Wait until you click "Approve" on the lead in /admin/external-leads before notifying.</span>
                  </span>
                </label>
              </div>
            </div>

            <button type="submit" id="saveNotificationsBtn" class="flex h-12 w-full sm:w-auto px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-900 transition-all hover:bg-green-400 active:scale-[0.98]">
              Save Notification Settings
            </button>
          </form>
        </div>

        <div id="section-permit" class="tab-section hidden bg-white border border-slate-200 p-6 md:p-8 rounded-2xl shadow-sm">
          <div class="border-b border-zinc-100 pb-5 mb-6">
            <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-2">Lead Workflow Automation</h2>
            <p class="text-[11px] text-zinc-500">Control publishing into Website Leads, contractor notifications, external source rules and permit outreach.</p>
          </div>

          <form id="permitAutomationForm" class="space-y-6">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 space-y-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-700">Website Lead Publishing</p>
                <p class="mt-1 text-[11px] text-slate-500">Website Leads are the only opportunities visible to registered contractors.</p>
              </div>
              <label class="flex items-center justify-between rounded-xl border border-zinc-200 bg-white p-4">
                <span>
                  <span class="block text-xs font-bold text-slate-900">Publish frontend requests automatically</span>
                  <span class="block text-[11px] text-zinc-500">Make customer-submitted requests immediately available to matching contractors.</span>
                </span>
                <input type="checkbox" id="frontendAutoPublish" class="h-5 w-5 accent-green-600" checked={permitSettings.frontendAutoPublish} />
              </label>
              <label class="flex items-center justify-between rounded-xl border border-zinc-200 bg-white p-4">
                <span>
                  <span class="block text-xs font-bold text-slate-900">Notify contractors when published</span>
                  <span class="block text-[11px] text-zinc-500">Email active contractors whose territory matches the Website Lead.</span>
                </span>
                <input type="checkbox" id="notifyContractorsOnPublish" class="h-5 w-5 accent-green-600" checked={permitSettings.notifyContractorsOnPublish} />
              </label>
              <label class="flex items-center justify-between rounded-xl border border-zinc-200 bg-white p-4">
                <span>
                  <span class="block text-xs font-bold text-slate-900">Notify truck owners when published</span>
                  <span class="block text-[11px] text-zinc-500">Email approved fleet owners with available equipment in the lead territory.</span>
                </span>
                <input type="checkbox" id="notifyTruckOwnersOnPublish" class="h-5 w-5 accent-blue-600" checked={permitSettings.notifyTruckOwnersOnPublish} />
              </label>
            </div>

            <div class="rounded-2xl border border-teal-200 bg-teal-50/40 p-5 space-y-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-teal-800">External Lead Automation</p>
                <p class="mt-1 text-[11px] text-teal-700/70">External submissions remain in External Leads unless they pass these rules or a dispatcher publishes them.</p>
              </div>
              <label class="flex items-center justify-between rounded-xl border border-teal-200 bg-white p-4">
                <span>
                  <span class="block text-xs font-bold text-slate-900">Auto-publish qualified external leads</span>
                  <span class="block text-[11px] text-zinc-500">Requires a territory, trusted domain and minimum quality score.</span>
                </span>
                <input type="checkbox" id="externalAutoPublish" class="h-5 w-5 accent-teal-600" checked={permitSettings.externalAutoPublish} />
              </label>
              <div>
                <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Trusted external domains</label>
                <textarea id="externalAutoPublishDomains" rows="3" class="w-full rounded-xl border border-teal-200 bg-white p-3 text-xs font-mono text-slate-700" placeholder="treejaws.com, partner-site.com">{permitSettings.externalAutoPublishDomains.join(', ')}</textarea>
                <p class="mt-2 text-[11px] text-zinc-500">Comma-separated. Empty means every external domain is trusted when auto-publish is enabled.</p>
              </div>
              <div>
                <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Minimum quality score</label>
                <input id="externalMinQualityScore" type="number" min="0" max="100" value={permitSettings.externalMinQualityScore} class="w-full rounded-xl border border-teal-200 bg-white p-3 text-sm text-slate-900" />
              </div>
            </div>

            <div class="rounded-2xl border border-amber-200 bg-amber-50/50 p-5">
              <label class="flex items-center justify-between gap-4">
                <span>
                  <span class="block text-xs font-bold text-slate-900">Confirm manual permit publishing</span>
                  <span class="block text-[11px] text-zinc-500">Require an explicit warning because a permit owner has not requested service.</span>
                </span>
                <input type="checkbox" id="permitManualPublishRequiresConfirmation" class="h-5 w-5 accent-amber-600" checked={permitSettings.permitManualPublishRequiresConfirmation} />
              </label>
            </div>

            <div class="border-t border-slate-200 pt-6">
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-700">Permit Outreach</p>
              <p class="mt-1 text-[11px] text-slate-500">Permits are opportunities, not leads. Outreach sends owners to the frontend where they can submit a real request.</p>
            </div>

            <label class="flex items-center justify-between rounded-xl border border-zinc-200 p-4">
              <span>
                <span class="block text-xs font-bold text-slate-900">Enable permit outreach automation</span>
                <span class="block text-[11px] text-zinc-500">Allow the permit pipeline to create outreach opportunities from the public feed.</span>
              </span>
              <input type="checkbox" id="permitEnabled" class="h-5 w-5 accent-green-600" checked={permitSettings.enabled} />
            </label>

            <label class="flex items-center justify-between rounded-xl border border-zinc-200 p-4">
              <span>
                <span class="block text-xs font-bold text-slate-900">Send outreach emails</span>
                <span class="block text-[11px] text-zinc-500">Send the customized permit email when a new permit opportunity passes the score threshold.</span>
              </span>
              <input type="checkbox" id="permitAutoSend" class="h-5 w-5 accent-green-600" checked={permitSettings.autoSend} />
            </label>

            <label class="flex items-center justify-between rounded-xl border border-zinc-200 p-4">
              <span>
                <span class="block text-xs font-bold text-slate-900">Auto-qualify matching permits</span>
                <span class="block text-[11px] text-zinc-500">Mark imported permits as qualified after territory and score rules pass. This does not create a Website Lead.</span>
              </span>
              <input type="checkbox" id="permitAutoApprove" class="h-5 w-5 accent-green-600" checked={permitSettings.autoApprove} />
            </label>

            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Minimum permit score threshold</label>
              <input id="permitMinScore" type="number" min="0" step="1" value={permitSettings.minScore} class="w-full rounded-xl border border-zinc-200 bg-white p-3 text-sm text-slate-900" />
              <p class="mt-2 text-[11px] text-zinc-500">The public permit feed provides a permit-fit score. Only permits at or above this threshold are processed.</p>
            </div>

            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Target territories</label>
              <p class="text-[11px] text-zinc-500 mb-3">Only permits from the selected territories will be processed by the automation.</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {territories && territories.length > 0 ? territories.map((t) => (
                  <label class="flex items-center gap-3 rounded-xl border border-zinc-200 p-3 text-sm text-slate-700">
                    <input type="checkbox" name="permitTerritory" value={t.name} checked={permitSettings.allowedTerritories.includes(t.name)} class="h-4 w-4 accent-green-600" />
                    <span>{t.name}</span>
                  </label>
                )) : (
                  <div class="rounded-xl border border-dashed border-zinc-200 p-3 text-[11px] text-zinc-500">Add service territories first to enable territory filtering.</div>
                )}
              </div>
            </div>

            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Email subject</label>
              <input id="permitEmailSubject" type="text" value={permitSettings.emailSubject} class="w-full rounded-xl border border-zinc-200 bg-white p-3 text-sm text-slate-900" />
            </div>

            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Email template</label>
              <textarea id="permitEmailTemplate" rows="10" class="w-full rounded-xl border border-zinc-200 bg-white p-4 text-xs font-mono text-zinc-700" placeholder="Use {{fullName}}, {{permitDetails}}, {{siteUrl}} placeholders">{permitSettings.emailTemplate}</textarea>
            </div>

            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Archive leads after (days)</label>
              <input id="permitArchiveDays" type="number" min="7" max="365" value={permitSettings.archiveDays || 60} class="w-full rounded-xl border border-zinc-200 bg-white p-3 text-sm text-slate-900" />
              <p class="mt-2 text-[11px] text-zinc-500">Leads in "new" status older than this many days will be automatically archived. Range: 7-365 days.</p>
            </div>

            <div>
              <label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Maximum outreach attempts</label>
              <input id="permitMaxEmailAttempts" type="number" min="1" max="10" value={permitSettings.permitMaxEmailAttempts} class="w-full rounded-xl border border-zinc-200 bg-white p-3 text-sm text-slate-900" />
              <p class="mt-2 text-[11px] text-zinc-500">Total messages allowed per permit contact, including carefully spaced follow-ups.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div><label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Daily permit email limit</label><input id="permitDailyEmailLimit" type="number" min="1" max="100" value={permitSettings.permitDailyEmailLimit} class="w-full rounded-xl border border-zinc-200 bg-white p-3 text-sm text-slate-900" /><p class="mt-2 text-[11px] text-zinc-500">Hard cap across all automated permit outreach in one UTC day.</p></div>
              <div><label class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold block mb-2">Days between emails</label><input id="permitEmailCooldownDays" type="number" min="3" max="365" value={permitSettings.permitEmailCooldownDays} class="w-full rounded-xl border border-zinc-200 bg-white p-3 text-sm text-slate-900" /><p class="mt-2 text-[11px] text-zinc-500">Minimum wait before a follow-up can be considered.</p></div>
            </div>

            <button type="submit" id="savePermitAutomationBtn" class="flex h-12 w-full sm:w-auto px-8 items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-900 transition-all hover:bg-green-400 active:scale-[0.98]">
              Save Permit Automation
            </button>
          </form>
        </div>

        <div id="section-truckOutreach" class="tab-section hidden space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
            <div class="flex flex-col justify-between gap-4 border-b border-slate-100 pb-5 sm:flex-row sm:items-start">
              <div><h2 class="text-sm font-bold uppercase tracking-wider text-slate-900">Unclaimed Truck Profile Outreach</h2><p class="mt-2 max-w-2xl text-[11px] leading-5 text-slate-500">Controlled invitations to public business emails. Automation suppresses duplicates, bounces, complaints and unsubscribed addresses.</p></div>
              <span id="truckOutreachState" class="rounded-full bg-slate-100 px-3 py-1.5 text-[9px] font-bold uppercase tracking-wider text-slate-500">Loading</span>
            </div>
            <form id="truckOutreachForm" class="mt-6 space-y-6">
              <label class="flex items-center justify-between gap-4 rounded-xl border border-amber-200 bg-amber-50/50 p-4"><span><span class="block text-xs font-bold text-slate-900">Enable scheduled outreach</span><span class="mt-1 block text-[11px] text-slate-500">Disabled by default. When enabled, the existing automation cron processes one rate-limited batch.</span></span><input id="truckOutreachEnabled" type="checkbox" class="h-5 w-5 accent-green-600" /></label>
              <div class="grid gap-4 sm:grid-cols-3">
                <label><span class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-slate-600">Daily email limit</span><input id="truckOutreachDailyLimit" type="number" min="1" max="100" value="10" class="w-full rounded-xl border border-slate-200 p-3 text-sm" /></label>
                <label><span class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-slate-600">Days between contacts</span><input id="truckOutreachCooldown" type="number" min="3" max="365" value="14" class="w-full rounded-xl border border-slate-200 p-3 text-sm" /></label>
                <label><span class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-slate-600">Max attempts / profile</span><input id="truckOutreachAttempts" type="number" min="1" max="5" value="2" class="w-full rounded-xl border border-slate-200 p-3 text-sm" /></label>
              </div>
              <label class="block"><span class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-slate-600">Email subject</span><input id="truckOutreachSubject" type="text" class="w-full rounded-xl border border-slate-200 p-3 text-sm" /></label>
              <label class="block"><span class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-slate-600">Email content</span><textarea id="truckOutreachTemplate" rows="12" class="w-full rounded-xl border border-slate-200 p-4 font-mono text-xs"></textarea><span class="mt-2 block text-[10px] text-slate-400">{'Variables: {{contactName}}, {{companyName}}, {{equipmentName}}, {{location}}, {{claimUrl}}'}</span></label>
              <div class="rounded-xl border border-blue-100 bg-blue-50 p-4 text-[11px] leading-5 text-blue-800"><strong>Anti-spam protection:</strong> one email address per batch, daily cap, cooldown, maximum attempts, permanent suppression after bounce/complaint/unsubscribe and a one-click unsubscribe link in every message.</div>
              <div class="flex flex-col gap-3 sm:flex-row"><button id="saveTruckOutreach" type="submit" class="h-12 rounded-xl bg-slate-950 px-7 text-xs font-bold uppercase tracking-wider text-white hover:bg-green-700">Save outreach settings</button><button id="runTruckOutreach" type="button" class="h-12 rounded-xl border border-slate-200 px-7 text-xs font-bold uppercase tracking-wider text-slate-700 hover:border-green-300 hover:text-green-700">Run safe batch now</button></div>
            </form>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
            <div class="flex items-center justify-between"><div><h3 class="text-sm font-bold text-slate-900">Recent delivery activity</h3><p class="mt-1 text-[10px] text-slate-400">Sent, delivered, opened, clicked and suppression events</p></div><button id="refreshTruckOutreach" class="text-[10px] font-bold uppercase tracking-wider text-green-700">Refresh</button></div>
            <div id="truckOutreachActivity" class="mt-5 space-y-2"><p class="text-xs text-slate-400">No activity loaded.</p></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  import { supabase } from "../../lib/supabase";

  // --- TABOVI LOGIKA ---
  const tabTerritories = document.getElementById('tabBtn-territories');
  const tabTracking = document.getElementById('tabBtn-tracking');
  const tabNotifications = document.getElementById('tabBtn-notifications');
  const tabPermit = document.getElementById('tabBtn-permit');
  const tabTruckOutreach = document.getElementById('tabBtn-truckOutreach');
  const secTerritories = document.getElementById('section-territories');
  const secTracking = document.getElementById('section-tracking');
  const secNotifications = document.getElementById('section-notifications');
  const secPermit = document.getElementById('section-permit');
  const secTruckOutreach = document.getElementById('section-truckOutreach');

  const allTabs = [tabTerritories, tabTracking, tabNotifications, tabPermit, tabTruckOutreach] as HTMLElement[];
  const allSections = [secTerritories, secTracking, secNotifications, secPermit, secTruckOutreach] as HTMLElement[];

  function switchTab(activeTab: HTMLElement, showSec: HTMLElement) {
    allTabs.forEach((tab) => {
      if (tab === activeTab) {
        tab.className = "tab-btn active flex-shrink-0 lg:w-full text-left px-4 py-3 bg-green-50 border border-green-200 rounded-xl text-green-800 text-[11px] font-bold uppercase tracking-wider flex items-center gap-3 transition-all";
        tab.querySelector('.indicator')!.className = "indicator w-2 h-2 rounded-full bg-green-500";
      } else {
        tab.className = "tab-btn flex-shrink-0 lg:w-full text-left px-4 py-3 text-slate-500 hover:bg-white hover:text-slate-900 rounded-xl text-[11px] font-bold uppercase tracking-wider transition-all border border-transparent hover:border-slate-200 flex items-center gap-3";
        tab.querySelector('.indicator')!.className = "indicator w-2 h-2 rounded-full bg-zinc-200";
      }
    });
    allSections.forEach((sec) => {
      const show = sec === showSec;
      sec.classList.toggle('hidden', !show);
      sec.classList.toggle('block', show);
    });
  }

  tabTerritories?.addEventListener('click', () => switchTab(tabTerritories, secTerritories!));
  tabTracking?.addEventListener('click', () => switchTab(tabTracking, secTracking!));
  tabNotifications?.addEventListener('click', () => switchTab(tabNotifications, secNotifications!));
  tabPermit?.addEventListener('click', () => switchTab(tabPermit, secPermit!));
  tabTruckOutreach?.addEventListener('click', () => {
    switchTab(tabTruckOutreach, secTruckOutreach!);
    loadTruckOutreach();
  });

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[char] || char));
  }

  async function adminFetch(url: string, init: RequestInit = {}) {
    const { data } = await supabase.auth.getSession();
    const token = data.session?.access_token;
    return fetch(url, { ...init, headers: { ...(init.headers || {}), ...(token ? { Authorization: `Bearer ${token}` } : {}) } });
  }

  async function loadTruckOutreach() {
    const state = document.getElementById('truckOutreachState')!;
    const response = await adminFetch('/api/truck-outreach/settings');
    const result = await response.json().catch(() => ({}));
    if (!response.ok || !result.ok) {
      state.textContent = 'Migration required';
      state.className = 'rounded-full bg-amber-50 px-3 py-1.5 text-[9px] font-bold uppercase tracking-wider text-amber-700';
      return;
    }
    const settings = result.settings;
    (document.getElementById('truckOutreachEnabled') as HTMLInputElement).checked = settings.enabled;
    (document.getElementById('truckOutreachDailyLimit') as HTMLInputElement).value = settings.daily_limit;
    (document.getElementById('truckOutreachCooldown') as HTMLInputElement).value = settings.cooldown_days;
    (document.getElementById('truckOutreachAttempts') as HTMLInputElement).value = settings.max_attempts;
    (document.getElementById('truckOutreachSubject') as HTMLInputElement).value = settings.subject;
    (document.getElementById('truckOutreachTemplate') as HTMLTextAreaElement).value = settings.email_template;
    state.textContent = settings.enabled ? 'Automation enabled' : 'Automation paused';
    state.className = `rounded-full px-3 py-1.5 text-[9px] font-bold uppercase tracking-wider ${settings.enabled ? 'bg-green-50 text-green-700' : 'bg-slate-100 text-slate-500'}`;
    const activity = document.getElementById('truckOutreachActivity')!;
    activity.innerHTML = result.activity?.length ? result.activity.map((row: any) => {
      const profile = row.unclaimed_truck_directory?.company_name || 'Truck profile';
      const tone = ['bounced','complained','failed','unsubscribed'].includes(row.status) ? 'text-red-700 bg-red-50' : ['opened','clicked','delivered'].includes(row.status) ? 'text-green-700 bg-green-50' : 'text-blue-700 bg-blue-50';
      return `<div class="flex flex-col justify-between gap-2 rounded-xl border border-slate-100 p-3 sm:flex-row sm:items-center"><div><strong class="text-xs text-slate-800">${escapeHtml(profile)}</strong><p class="mt-1 text-[10px] text-slate-400">${escapeHtml(row.email)} · ${new Date(row.created_at).toLocaleString()}</p></div><span class="w-fit rounded-full px-2.5 py-1 text-[9px] font-bold uppercase ${tone}">${escapeHtml(row.status)}</span></div>`;
    }).join('') : '<p class="text-xs text-slate-400">No outreach has been sent yet.</p>';
  }

  document.getElementById('truckOutreachForm')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = document.getElementById('saveTruckOutreach') as HTMLButtonElement;
    button.disabled = true; button.textContent = 'Saving…';
    const payload = {
      enabled: (document.getElementById('truckOutreachEnabled') as HTMLInputElement).checked,
      daily_limit: Number((document.getElementById('truckOutreachDailyLimit') as HTMLInputElement).value),
      cooldown_days: Number((document.getElementById('truckOutreachCooldown') as HTMLInputElement).value),
      max_attempts: Number((document.getElementById('truckOutreachAttempts') as HTMLInputElement).value),
      subject: (document.getElementById('truckOutreachSubject') as HTMLInputElement).value,
      email_template: (document.getElementById('truckOutreachTemplate') as HTMLTextAreaElement).value,
    };
    const response = await adminFetch('/api/truck-outreach/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const result = await response.json().catch(() => ({}));
    button.textContent = response.ok && result.ok ? 'Saved ✓' : 'Save failed';
    setTimeout(() => { button.textContent = 'Save outreach settings'; button.disabled = false; }, 1800);
    if (response.ok) loadTruckOutreach();
  });
  document.getElementById('runTruckOutreach')?.addEventListener('click', async () => {
    if (!confirm('Run one rate-limited outreach batch now? Daily limits and suppression rules still apply.')) return;
    const button = document.getElementById('runTruckOutreach') as HTMLButtonElement;
    button.disabled = true; button.textContent = 'Running…';
    const response = await adminFetch('/api/truck-outreach/run', { method: 'POST' });
    const result = await response.json().catch(() => ({}));
    alert(result.ok ? `Batch complete: ${result.sent || 0} sent, ${result.failed || 0} failed.` : `Batch failed: ${result.error || 'Unknown error'}`);
    button.disabled = false; button.textContent = 'Run safe batch now'; loadTruckOutreach();
  });
  document.getElementById('refreshTruckOutreach')?.addEventListener('click', loadTruckOutreach);

  // --- ČUVANJE NOTIFIKACIONIH EMAIL ADRESA ---
  document.getElementById('notificationsForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const saveNotifBtn = document.getElementById('saveNotificationsBtn') as HTMLButtonElement;
    saveNotifBtn.innerText = "Saving...";
    saveNotifBtn.disabled = true;

    const emailsVal = (document.getElementById('externalLeadEmails') as HTMLTextAreaElement).value;
    const notifyOnApprovalOnly = (document.getElementById('notifyTimingApproval') as HTMLInputElement).checked;

    const { error } = await supabase.from('tracking_settings').update({
      external_lead_notification_emails: emailsVal,
      external_lead_notify_on_approval_only: notifyOnApprovalOnly
    }).eq('id', 1);

    if (error) {
      alert("Error saving notification settings!");
      saveNotifBtn.innerText = "Save Notification Settings";
      saveNotifBtn.disabled = false;
    } else {
      saveNotifBtn.innerText = "Saved Successfully ✓";
      saveNotifBtn.classList.replace('bg-green-500', 'bg-zinc-300');
      saveNotifBtn.classList.replace('text-slate-900', 'text-green-700');
      setTimeout(() => {
        saveNotifBtn.innerText = "Save Notification Settings";
        saveNotifBtn.classList.replace('bg-zinc-300', 'bg-green-500');
        saveNotifBtn.classList.replace('text-green-700', 'text-slate-900');
        saveNotifBtn.disabled = false;
      }, 2000);
    }
  });

  // --- DODAVANJE TERITORIJE ---
  document.getElementById('addTerritoryForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = document.getElementById('territoryName') as HTMLInputElement;
    const name = nameInput.value.trim();
    if (!name) return;
    document.body.style.opacity = '0.5';
    const { error } = await supabase.from('service_territories').insert([{ name }]);
    if (error) alert("Error adding territory.");
    window.location.reload();
  });

  // --- BRISANJE TERITORIJE ---
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLButtonElement).dataset.id;
      if (confirm('Are you sure you want to remove this coverage area?')) {
        document.body.style.opacity = '0.5';
        await supabase.from('service_territories').delete().eq('id', id);
        window.location.reload();
      }
    });
  });

  // --- ČUVANJE PERMIT AUTOMATIZACIJE ---
  document.getElementById('permitAutomationForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const savePermitBtn = document.getElementById('savePermitAutomationBtn') as HTMLButtonElement;
    savePermitBtn.innerText = 'Saving...';
    savePermitBtn.disabled = true;

    const selectedTerritories = Array.from(document.querySelectorAll('input[name="permitTerritory"]:checked')).map((el) => (el as HTMLInputElement).value);

    const payload = {
      enabled: (document.getElementById('permitEnabled') as HTMLInputElement).checked,
      autoSend: (document.getElementById('permitAutoSend') as HTMLInputElement).checked,
      autoApprove: (document.getElementById('permitAutoApprove') as HTMLInputElement).checked,
      frontendAutoPublish: (document.getElementById('frontendAutoPublish') as HTMLInputElement).checked,
      externalAutoPublish: (document.getElementById('externalAutoPublish') as HTMLInputElement).checked,
      externalAutoPublishDomains: (document.getElementById('externalAutoPublishDomains') as HTMLTextAreaElement).value.split(',').map((value) => value.trim()).filter(Boolean),
      externalMinQualityScore: Number((document.getElementById('externalMinQualityScore') as HTMLInputElement).value || 70),
      notifyContractorsOnPublish: (document.getElementById('notifyContractorsOnPublish') as HTMLInputElement).checked,
      notifyTruckOwnersOnPublish: (document.getElementById('notifyTruckOwnersOnPublish') as HTMLInputElement).checked,
      permitManualPublishRequiresConfirmation: (document.getElementById('permitManualPublishRequiresConfirmation') as HTMLInputElement).checked,
      permitMaxEmailAttempts: Number((document.getElementById('permitMaxEmailAttempts') as HTMLInputElement).value || 3),
      permitDailyEmailLimit: Number((document.getElementById('permitDailyEmailLimit') as HTMLInputElement).value || 10),
      permitEmailCooldownDays: Number((document.getElementById('permitEmailCooldownDays') as HTMLInputElement).value || 14),
      minScore: Number((document.getElementById('permitMinScore') as HTMLInputElement).value || 0),
      emailSubject: (document.getElementById('permitEmailSubject') as HTMLInputElement).value,
      emailTemplate: (document.getElementById('permitEmailTemplate') as HTMLTextAreaElement).value,
      allowedTerritories: selectedTerritories,
      archiveDays: Number((document.getElementById('permitArchiveDays') as HTMLInputElement).value || 60),
    };

    const res = await fetch('/api/permit-settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const result = await res.json().catch(() => ({}));

    if (!res.ok || !result.ok) {
      alert('Error saving permit automation settings!');
      savePermitBtn.innerText = 'Save Permit Automation';
      savePermitBtn.disabled = false;
      return;
    }

    savePermitBtn.innerText = 'Saved Successfully ✓';
    savePermitBtn.classList.replace('bg-green-500', 'bg-zinc-300');
    savePermitBtn.classList.replace('text-slate-900', 'text-green-700');
    setTimeout(() => {
      savePermitBtn.innerText = 'Save Permit Automation';
      savePermitBtn.classList.replace('bg-zinc-300', 'bg-green-500');
      savePermitBtn.classList.replace('text-green-700', 'text-slate-900');
      savePermitBtn.disabled = false;
    }, 2000);
  });

  // --- ČUVANJE SKRIPTI ---
  const trackingForm = document.getElementById('trackingForm');
  const saveBtn = document.getElementById('saveTrackingBtn') as HTMLButtonElement;

  trackingForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.innerText = "Saving...";
    saveBtn.disabled = true;

    const globalVal = (document.getElementById('globalScripts') as HTMLTextAreaElement).value;
    const conversionVal = (document.getElementById('conversionScripts') as HTMLTextAreaElement).value;

    const { error } = await supabase.from('tracking_settings').update({
      global_scripts: globalVal,
      conversion_scripts: conversionVal
    }).eq('id', 1);

    if (error) {
      alert("Error saving scripts!");
    } else {
      saveBtn.innerText = "Saved Successfully ✓";
      saveBtn.classList.replace('bg-green-500', 'bg-zinc-300');
      saveBtn.classList.replace('text-slate-900', 'text-green-700');
      setTimeout(() => {
        saveBtn.innerText = "Save Tracking Scripts";
        saveBtn.classList.replace('bg-zinc-300', 'bg-green-500');
        saveBtn.classList.replace('text-green-700', 'text-slate-900');
        saveBtn.disabled = false;
      }, 2000);
    }
  });
</script>
