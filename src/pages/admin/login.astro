---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Staff Login | SawFleet">
  <div class="relative min-h-screen flex items-center justify-center bg-[#000000] p-4 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-blue-500/5 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[400px] h-[400px] bg-green-500/5 blur-[100px] rounded-full"></div>
    </div>

    <div class="relative z-10 w-full max-w-[400px]">
      <div class="mb-8 text-center">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.3em] text-blue-400">// Internal Access</span>
        <h1 class="mt-4 text-3xl font-bold text-white tracking-tighter">Admin &amp; Dispatch</h1>
        <p class="mt-2 text-sm text-zinc-500">Staff sign-in only. Not a contractor or fleet owner? Use the correct portal below.</p>
      </div>

      <div class="rounded-3xl border border-slate-700 bg-slate-900/50 backdrop-blur-sm p-8 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)]">
        <form id="loginForm" class="space-y-5">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Email Address</label>
            <input type="email" name="email" required placeholder="admin@sawfleet.com" class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-white outline-none focus:border-blue-500 transition-all placeholder:text-slate-600"/>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Password</label>
            <input type="password" name="password" required placeholder="••••••••" class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-white outline-none focus:border-blue-500 transition-all placeholder:text-slate-600"/>
          </div>
          <button type="submit" id="submitBtn" class="flex h-12 w-full items-center justify-center rounded-xl bg-blue-500 text-sm font-bold text-slate-950 transition-all hover:bg-blue-400 active:scale-[0.98]">
            Sign In →
          </button>
          <button type="button" id="forgotBtn" class="w-full text-center text-[11px] text-zinc-500 hover:text-zinc-300 transition-colors pt-1">
            Forgot password?
          </button>
        </form>
      </div>

      <div class="mt-6 flex items-center justify-center gap-4 text-[10px] font-mono uppercase tracking-widest text-zinc-600">
        <a href="/login" class="hover:text-zinc-300">Contractor login</a>
        <span>·</span>
        <a href="/truck-login" class="hover:text-zinc-300">Fleet owner login</a>
      </div>

      <p class="mt-8 text-center text-[10px] text-zinc-600 font-mono tracking-widest uppercase">
        &copy; {new Date().getFullYear()} SawFleet Operations
      </p>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from "../../lib/supabase";

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.innerText = "Authenticating...";
    btn.disabled = true;
    btn.classList.add('opacity-70');

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      alert("Authentication failed: " + error.message);
      btn.innerText = "Sign In →";
      btn.disabled = false;
      btn.classList.remove('opacity-70');
      return;
    }

    const { data: isAdmin } = await supabase.rpc('is_admin');

    if (!isAdmin) {
      alert("This account doesn't have admin/dispatch access.");
      await supabase.auth.signOut();
      btn.innerText = "Sign In →";
      btn.disabled = false;
      btn.classList.remove('opacity-70');
      return;
    }

    window.location.assign('/admin');
  });

  document.getElementById('forgotBtn')?.addEventListener('click', async () => {
    const email = (form.elements.namedItem('email') as HTMLInputElement)?.value;
    if (!email) {
      alert('Enter your email in the field above first, then click again.');
      return;
    }
    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/reset-password`,
    });
    if (error) {
      alert('Error: ' + error.message);
    } else {
      alert('We sent you an email with a password reset link (check your spam folder too).');
    }
  });
</script>
