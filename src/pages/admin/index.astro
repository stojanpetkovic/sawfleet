---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <!-- GLAVNI WRAPPER -->
  <div class="w-full flex flex-col gap-8">
    <div class="flex flex-col justify-between gap-4 border-b border-slate-200 pb-7 sm:flex-row sm:items-end">
      <div>
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-green-700">// Command center</span>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl">Platform overview</h1>
        <p class="mt-2 text-sm text-slate-500">Live operational snapshot across leads, contractors and fleet inventory.</p>
      </div>
      <a href="/admin/analytics" class="inline-flex h-11 items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-[10px] font-bold uppercase tracking-[0.16em] text-slate-600 shadow-sm transition hover:border-slate-300 hover:text-slate-950">View analytics →</a>
    </div>

    <div class="w-full flex flex-col xl:flex-row gap-8">
    
    <!-- LEVA STRANA: Glavni sadržaj -->
    <div class="flex-1 space-y-8 min-w-0 w-full">

      <!-- NEEDS ATTENTION — uvek vidljivo, ne zavisi od hover-a (bitno za mobilne) -->
      <div id="attentionBar" class="hidden grid-cols-2 lg:grid-cols-4 gap-3">
        <a href="/admin/service-leads?status=new" class="flex flex-col items-center justify-center gap-1 p-4 rounded-2xl border border-green-200 bg-green-50 hover:bg-green-100 transition-colors">
          <span id="attn-leads" class="text-2xl font-mono font-bold text-green-700">0</span>
          <span class="text-[9px] font-bold uppercase tracking-[0.15em] text-green-700/70 text-center">New Leads</span>
        </a>
        <a href="/admin/external-leads?status=new" class="flex flex-col items-center justify-center gap-1 p-4 rounded-2xl border border-teal-200 bg-teal-50 hover:bg-teal-100 transition-colors">
          <span id="attn-external" class="text-2xl font-mono font-bold text-teal-700">0</span>
          <span class="text-[9px] font-bold uppercase tracking-[0.15em] text-teal-700/70 text-center">New External Leads</span>
        </a>
        <a href="/admin/contractors" class="flex flex-col items-center justify-center gap-1 p-4 rounded-2xl border border-blue-200 bg-blue-50 hover:bg-blue-100 transition-colors">
          <span id="attn-contractors" class="text-2xl font-mono font-bold text-blue-600">0</span>
          <span class="text-[9px] font-bold uppercase tracking-[0.15em] text-blue-600/70 text-center">Pending Contractors</span>
        </a>
        <a href="/admin/grapple-saw-trucks" class="flex flex-col items-center justify-center gap-1 p-4 rounded-2xl border border-purple-200 bg-purple-50 hover:bg-purple-100 transition-colors">
          <span id="attn-trucks" class="text-2xl font-mono font-bold text-purple-600">0</span>
          <span class="text-[9px] font-bold uppercase tracking-[0.15em] text-purple-600/70 text-center">Pending Assets</span>
        </a>
      </div>
      
      <!-- STATISTIKA: KONSOLIDOVANA -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 w-full">
        
        <!-- Karta 1: Leads Summary -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col w-full shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-center justify-between pb-4 border-b border-zinc-100">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Total Leads</p>
            <a href="/admin/service-leads" class="rounded-full border border-zinc-200 px-2.5 py-1 text-[9px] uppercase tracking-[0.1em] text-zinc-500 hover:text-slate-900 hover:border-zinc-300 transition-colors">Manage →</a>
          </div>
          
          <div class="py-5 text-center border-b border-zinc-100">
            <h2 id="count-total" class="text-4xl font-mono font-bold text-slate-900">-</h2>
          </div>
          
          <div class="grid grid-cols-4 gap-2 pt-4">
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">New</p>
              <p id="count-new" class="text-xl font-mono font-bold text-zinc-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Approved</p>
              <p id="count-approved" class="text-xl font-mono font-bold text-green-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Claimed</p>
              <p id="count-claimed" class="text-xl font-mono font-bold text-blue-600">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Rejected</p>
              <p id="count-rejected" class="text-xl font-mono font-bold text-red-600">-</p>
            </div>
          </div>
        </div>

        <!-- Karta 2: External Leads Summary -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col w-full shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-center justify-between pb-4 border-b border-zinc-100">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">External Leads</p>
            <a href="/admin/external-leads" class="rounded-full border border-zinc-200 px-2.5 py-1 text-[9px] uppercase tracking-[0.1em] text-zinc-500 hover:text-slate-900 hover:border-zinc-300 transition-colors">Manage →</a>
          </div>
          
          <div class="py-5 text-center border-b border-zinc-100">
            <h2 id="count-e-total" class="text-4xl font-mono font-bold text-slate-900">-</h2>
          </div>
          
          <div class="grid grid-cols-5 gap-1.5 pt-4">
            <div class="text-center">
              <p class="text-[6px] text-zinc-400 uppercase font-bold tracking-widest mb-2">New</p>
              <p id="count-e-new" class="text-lg font-mono font-bold text-amber-600">-</p>
            </div>
            <div class="text-center">
              <p class="text-[6px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Approved</p>
              <p id="count-e-approved" class="text-lg font-mono font-bold text-green-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[6px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Rejected</p>
              <p id="count-e-rejected" class="text-lg font-mono font-bold text-red-600">-</p>
            </div>
            <div class="text-center">
              <p class="text-[6px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Contacted</p>
              <p id="count-e-contacted" class="text-lg font-mono font-bold text-blue-600">-</p>
            </div>
            <div class="text-center">
              <p class="text-[6px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Closed</p>
              <p id="count-e-closed" class="text-lg font-mono font-bold text-slate-600">-</p>
            </div>
          </div>
        </div>

        <!-- Karta 3: Contractors Summary -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col w-full shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-center justify-between pb-4 border-b border-zinc-100">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Contractors</p>
            <a href="/admin/contractors" class="rounded-full border border-zinc-200 px-2.5 py-1 text-[9px] uppercase tracking-[0.1em] text-zinc-500 hover:text-slate-900 hover:border-zinc-300 transition-colors">Manage →</a>
          </div>
          
          <div class="py-5 text-center border-b border-zinc-100">
            <h2 id="count-c-total" class="text-4xl font-mono font-bold text-slate-900">-</h2>
          </div>
          
          <div class="grid grid-cols-3 gap-2 pt-4">
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Pending</p>
              <p id="count-c-pending" class="text-xl font-mono font-bold text-zinc-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Active</p>
              <p id="count-c-active" class="text-xl font-mono font-bold text-green-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Rejected</p>
              <p id="count-c-rejected" class="text-xl font-mono font-bold text-red-600">-</p>
            </div>
          </div>
        </div>

        <!-- Karta 4: Trucks Summary -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col w-full shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-center justify-between pb-4 border-b border-zinc-100">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Trucks</p>
            <a href="/admin/grapple-saw-trucks" class="rounded-full border border-zinc-200 px-2.5 py-1 text-[9px] uppercase tracking-[0.1em] text-zinc-500 hover:text-slate-900 hover:border-zinc-300 transition-colors">Manage →</a>
          </div>
          
          <div class="py-5 text-center border-b border-zinc-100">
            <h2 id="count-t-total" class="text-4xl font-mono font-bold text-slate-900">-</h2>
          </div>
          
          <div class="grid grid-cols-3 gap-2 pt-4">
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Pending</p>
              <p id="count-t-pending" class="text-xl font-mono font-bold text-zinc-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Approved</p>
              <p id="count-t-approved" class="text-xl font-mono font-bold text-green-700">-</p>
            </div>
            <div class="text-center">
              <p class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest mb-2">Rejected</p>
              <p id="count-t-rejected" class="text-xl font-mono font-bold text-red-600">-</p>
            </div>
          </div>
        </div>
      </div>

      <!-- SEKCIJA: LEADS LISTA -->
      <div class="bg-white border border-zinc-100 rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-zinc-100 flex items-center justify-between">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Recent Service Leads</h3>
          <a href="/admin/service-leads" class="text-[9px] uppercase tracking-widest text-zinc-400 hover:text-slate-900 transition-colors">View all →</a>
        </div>
        <div id="leadsTable" class="p-3 space-y-2">
          <div class="p-6 text-center text-zinc-400 text-sm">Loading...</div>
        </div>
      </div>

      <!-- SEKCIJA: PERMIT ACTIVITY -->
      <div class="bg-white border border-zinc-100 rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-zinc-100 flex items-center justify-between">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Recent Permit Activity</h3>
          <a href="/admin/permit-leads" class="text-[9px] uppercase tracking-widest text-zinc-400 hover:text-slate-900 transition-colors">Manage →</a>
        </div>
        <div id="permitActivityTable" class="p-3 space-y-2">
          <div class="p-6 text-center text-zinc-400 text-sm">Loading...</div>
        </div>
      </div>

      <!-- SEKCIJA: EXTERNAL LEADS LISTA -->
      <div class="bg-white border border-zinc-100 rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-zinc-100 flex items-center justify-between">
          <div>
            <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Recent External Leads</h3>
            <p class="mt-1 text-[10px] text-slate-400">Latest submissions from connected websites</p>
          </div>
          <a href="/admin/external-leads" class="text-[9px] uppercase tracking-widest text-zinc-400 hover:text-slate-900 transition-colors">View all →</a>
        </div>
        <div id="externalLeadsTable" class="p-3 space-y-2">
          <div class="p-6 text-center text-zinc-400 text-sm">Loading...</div>
        </div>
      </div>

      <!-- SEKCIJA: CONTRACTORS LISTA -->
      <div class="bg-white border border-zinc-100 rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-zinc-100 flex items-center justify-between">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Recent Contractors</h3>
          <a href="/admin/contractors" class="text-[9px] uppercase tracking-widest text-zinc-400 hover:text-slate-900 transition-colors">View all →</a>
        </div>
        <div id="contractorsTable" class="p-3 space-y-2">
          <div class="p-6 text-center text-zinc-400 text-sm">Loading...</div>
        </div>
      </div>

      <!-- SEKCIJA TRUCKS LISTA -->
      <div class="bg-white border border-zinc-100 rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-zinc-100 flex items-center justify-between">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Recent Trucks</h3>
          <a href="/admin/grapple-saw-trucks" class="text-[9px] uppercase tracking-widest text-zinc-400 hover:text-slate-900 transition-colors">View all →</a>
        </div>
        <div id="trucksTable" class="p-3 space-y-2">
          <div class="p-6 text-center text-zinc-400 text-sm">Loading...</div>
        </div>
      </div>

    </div>

    <!-- DESNA STRANA: Activity Sidebar -->
    <div class="w-full xl:w-[400px] shrink-0 mt-8 xl:mt-0">
      <div class="bg-white border border-zinc-100 rounded-2xl sticky top-8 w-full">
        <div class="p-6 border-b border-zinc-100">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-900">Activity Timeline</h3>
        </div>
        
        <div class="p-6 space-y-10">
          <!-- Leads Activity -->
          <div class="w-full">
            <h4 class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 mb-6 border-b border-zinc-100/50 pb-2">Leads Log</h4>
            <div id="leadLogsContainer" class="space-y-6">
              <div class="text-[11px] font-mono text-zinc-500">Loading logs...</div>
            </div>
          </div>

          <!-- Permit Activity -->
          <div class="w-full">
            <h4 class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 mb-6 border-b border-zinc-100/50 pb-2">Permit Log</h4>
            <div id="permitLogsContainer" class="space-y-6">
              <div class="text-[11px] font-mono text-zinc-500">Loading logs...</div>
            </div>
          </div>

          <!-- Contractors Activity -->
          <div class="w-full">
            <h4 class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 mb-6 border-b border-zinc-100/50 pb-2">Contractors Log</h4>
            <div id="contractorLogsContainer" class="space-y-6">
              <div class="text-[11px] font-mono text-zinc-500">Loading logs...</div>
            </div>
          </div>

          <!-- Trucks Activity -->
          <div class="w-full">
            <h4 class="text-[9px] uppercase tracking-[0.2em] text-zinc-400 mb-6 border-b border-zinc-100/50 pb-2">Trucks Log</h4>
            <div id="truckLogsContainer" class="space-y-6">
              <div class="text-[11px] font-mono text-zinc-500">Loading logs...</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    </div>

  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";

  function timeAgo(dateInput: string) {
    const date = new Date(dateInput);
    const now = new Date();
    const diffInSeconds = Math.floor((now.getTime() - date.getTime()) / 1000);
    
    if (diffInSeconds < 60) return 'Just now';
    if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)}m ago`;
    if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)}h ago`;
    return `${Math.floor(diffInSeconds / 86400)}d ago`;
  }

  function generateProLogHtml(entityName: string, actionText: string, changedBy: string, dateStr: string) {
    return `
      <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-200 before:border-2 before:border-slate-200 before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-24px] after:w-[2px] after:bg-zinc-100 last:after:hidden">
        <p class="text-[10px] text-zinc-600 font-mono mb-1 truncate">${entityName}</p>
        <p class="text-[11px] text-slate-900 font-bold leading-tight">${actionText}</p>
        <div class="flex items-center gap-2 mt-2">
          <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-700 font-bold tracking-wider uppercase">${changedBy}</span></span>
          <span class="text-[7px] text-zinc-300">●</span>
          <span class="text-[9px] text-zinc-400">${timeAgo(dateStr)}</span>
        </div>
      </div>
    `;
  }

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>'"]/g, (char) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
    })[char]!);
  }

  async function loadData() {
    // === 1. LIDOVI ===
    const { data: leads } = await supabase.from('leads').select('*').order('created_at', { ascending: false });
    if (leads) {
      const newCount = leads.filter(l => !l.status || l.status === 'new').length;
      document.getElementById('count-total')!.textContent = (leads?.length || 0).toString();
      document.getElementById('count-new')!.textContent = newCount.toString();
      document.getElementById('count-approved')!.textContent = leads.filter(l => l.status === 'approved').length.toString();
      document.getElementById('count-claimed')!.textContent = leads.filter(l => l.status === 'claimed').length.toString();
      document.getElementById('count-rejected')!.textContent = leads.filter(l => l.status === 'rejected').length.toString();
      document.getElementById('attn-leads')!.textContent = newCount.toString();
      
      document.getElementById('leadsTable')!.innerHTML = leads.slice(0, 3).map(l => {
        const statusStyles: Record<string, string> = {
          approved: 'bg-green-500/10 text-green-700 border-green-500/20',
          claimed: 'bg-blue-500/10 text-blue-600 border-blue-500/20',
          rejected: 'bg-red-500/10 text-red-600 border-red-500/20',
        };
        const statusClass = statusStyles[l.status] || 'bg-zinc-200/50 text-zinc-600 border-zinc-300';
        return `
        <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-zinc-100/50 transition-colors cursor-pointer" onclick="window.location.href='/admin/leads/${l.id}'">
          <div class="w-9 h-9 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0 text-[10px] font-bold text-zinc-600">${(l.email || '?').charAt(0).toUpperCase()}</div>
          <div class="min-w-0 flex-1">
            <p class="text-[13px] font-bold text-slate-900 truncate">${l.email || 'No email'}</p>
            <p class="text-[10px] text-zinc-500 font-mono truncate">${l.county || 'N/A'} · ${new Date(l.created_at).toLocaleDateString()}</p>
          </div>
          <span class="shrink-0 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase border tracking-wide ${statusClass}">${l.status || 'New'}</span>
        </div>
      `}).join('');
    }

    // === 2. PERMIT ACTIVITY (for separate section below) ===
    const { data: permitAudit } = await supabase.from('tracking_settings').select('global_scripts').eq('id', 1).maybeSingle();
    const permitSettings = permitAudit?.global_scripts ? permitAudit.global_scripts : '';
    const permitAuditEntries = permitSettings.match(/<!--\s*PERMIT_SETTINGS_JSON:(.*?)\s*-->/s)?.[1];
    let permitAuditData: Array<any> = [];
    if (permitAuditEntries) {
      try { permitAuditData = JSON.parse(permitAuditEntries).audit || []; } catch {}
    }

    const permitActivityTable = document.getElementById('permitActivityTable');
    if (permitActivityTable) {
      permitActivityTable.innerHTML = permitAuditData.length ? permitAuditData.slice(0, 3).map((item: any) => `
        <div class="flex items-start gap-3 p-3 rounded-lg hover:bg-zinc-50 transition-colors">
          <div class="w-8 h-8 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center shrink-0 text-[10px] font-bold text-emerald-700">P</div>
          <div class="min-w-0 flex-1">
            <p class="text-[11px] font-bold text-slate-900">${item.status || 'Permit Run'}</p>
            <p class="text-[10px] text-zinc-500 truncate">${item.details || ''}</p>
            <p class="text-[9px] text-zinc-400 mt-0.5">${new Date(item.timestamp).toLocaleString()}</p>
          </div>
        </div>
      `).join('') : '<div class="p-6 text-center text-sm text-slate-400">No permit runs recorded yet.</div>';
    }

    // === 3. POSLEDNJI EXTERNAL LEADOVI ===
    const { data: externalLeads } = await supabase
      .from('external_leads')
      .select('id, full_name, email, phone, source_domain, form_type, status, created_at')
      .order('created_at', { ascending: false });

    if (externalLeads) {
      const externalNewCount = externalLeads.filter((lead) => lead.status === 'new').length;
      document.getElementById('count-e-total')!.textContent = externalLeads.length.toString();
      document.getElementById('count-e-new')!.textContent = externalNewCount.toString();
      document.getElementById('count-e-approved')!.textContent = externalLeads.filter((lead) => lead.status === 'approved').length.toString();
      document.getElementById('count-e-rejected')!.textContent = externalLeads.filter((lead) => lead.status === 'rejected').length.toString();
      document.getElementById('count-e-contacted')!.textContent = externalLeads.filter((lead) => lead.status === 'contacted').length.toString();
      document.getElementById('count-e-closed')!.textContent = externalLeads.filter((lead) => lead.status === 'closed').length.toString();
      document.getElementById('attn-external')!.textContent = externalNewCount.toString();
    }

    const externalContainer = document.getElementById('externalLeadsTable');
    if (externalContainer) {
      const statusStyles: Record<string, string> = {
        new: 'bg-amber-500/10 text-amber-700 border-amber-500/20',
        approved: 'bg-green-500/10 text-green-700 border-green-500/20',
        rejected: 'bg-red-500/10 text-red-600 border-red-500/20',
        contacted: 'bg-blue-500/10 text-blue-600 border-blue-500/20',
        closed: 'bg-slate-100 text-slate-600 border-slate-200',
      };

      externalContainer.innerHTML = externalLeads?.length ? externalLeads.slice(0, 5).map((lead) => {
        const status = lead.status || 'new';
        const contact = [lead.email, lead.phone].filter(Boolean).join(' · ') || 'No contact info';
        return `
          <a href="/admin/external-leads" class="group flex items-center gap-3 rounded-xl p-3 transition-colors hover:bg-slate-50">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-teal-200 bg-teal-50 text-[10px] font-bold text-teal-700">${escapeHtml((lead.full_name || '?').charAt(0).toUpperCase())}</div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <p class="truncate text-[13px] font-bold text-slate-900">${escapeHtml(lead.full_name || 'Unnamed')}</p>
                <span class="hidden rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[8px] font-bold uppercase tracking-wide text-slate-500 sm:inline">${escapeHtml(lead.form_type || 'lead')}</span>
              </div>
              <p class="truncate font-mono text-[10px] text-slate-500">${escapeHtml(contact)}</p>
              <p class="mt-0.5 truncate text-[10px] text-slate-400">${escapeHtml(lead.source_domain || 'Unknown domain')} · ${timeAgo(lead.created_at)}</p>
            </div>
            <span class="shrink-0 rounded-full border px-2 py-0.5 text-[9px] font-bold uppercase tracking-wide ${statusStyles[status] || statusStyles.new}">${escapeHtml(status)}</span>
            <span class="hidden text-slate-300 transition-colors group-hover:text-slate-600 sm:block">→</span>
          </a>
        `;
      }).join('') : '<div class="p-8 text-center text-sm text-slate-400">No external leads received yet.</div>';
    }

    // === 4. KONTRAKTORI ===
    const { data: contractors } = await supabase.from('contractors').select('*').order('created_at', { ascending: false });
    if (contractors) {
      document.getElementById('count-c-total')!.textContent = contractors.length.toString();
      document.getElementById('count-c-active')!.textContent = contractors.filter(c => c.status === 'active').length.toString();
      document.getElementById('count-c-pending')!.textContent = contractors.filter(c => c.status === 'pending').length.toString();
      document.getElementById('count-c-rejected')!.textContent = contractors.filter(c => c.status === 'rejected').length.toString();
      document.getElementById('attn-contractors')!.textContent = contractors.filter(c => c.status === 'pending').length.toString();
      
      document.getElementById('contractorsTable')!.innerHTML = contractors.slice(0, 3).map(c => {
        const statusStyles: Record<string, string> = {
          active: 'bg-green-500/10 text-green-700 border-green-500/20',
          rejected: 'bg-red-500/10 text-red-600 border-red-500/20',
        };
        const statusClass = statusStyles[c.status] || 'bg-amber-500/10 text-amber-600 border-amber-500/20';
        return `
        <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-zinc-100/50 transition-colors cursor-pointer" onclick="window.location.href='/admin/contractors/${c.id}'">
          <div class="w-9 h-9 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0 text-[10px] font-bold text-zinc-600">${(c.company_name || '?').slice(0, 2).toUpperCase()}</div>
          <div class="min-w-0 flex-1">
            <p class="text-[13px] font-bold text-slate-900 truncate">${c.company_name || 'N/A'}</p>
            <p class="text-[10px] text-zinc-500 font-mono truncate">${c.territory || 'N/A'} · ${new Date(c.created_at).toLocaleDateString()}</p>
          </div>
          <span class="shrink-0 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase border tracking-wide ${statusClass}">${c.status || 'pending'}</span>
        </div>
      `}).join('');
    }

    // === 5. KAMIONI ===
    const { data: trucks } = await supabase.from('grapple_saw_trucks').select('*').order('created_at', { ascending: false });
    if (trucks) {
      document.getElementById('count-t-total')!.textContent = trucks.length.toString();
      document.getElementById('count-t-approved')!.textContent = trucks.filter(t => t.approval_status === 'approved').length.toString();
      document.getElementById('count-t-pending')!.textContent = trucks.filter(t => t.approval_status === 'pending' || !t.approval_status).length.toString();
      document.getElementById('count-t-rejected')!.textContent = trucks.filter(t => t.approval_status === 'rejected').length.toString();
      document.getElementById('attn-trucks')!.textContent = trucks.filter(t => t.approval_status === 'pending' || !t.approval_status).length.toString();
      
      document.getElementById('trucksTable')!.innerHTML = trucks.slice(0, 3).map(t => {
        const appStatus = t.approval_status || 'pending';
        const appBadge = appStatus === 'approved' ? 'bg-green-500/10 text-green-700 border-green-500/20' :
                         appStatus === 'rejected' ? 'bg-red-500/10 text-red-600 border-red-500/20' :
                         'bg-amber-500/10 text-amber-600 border-amber-500/20';
        return `
        <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-zinc-100/50 transition-colors cursor-pointer" onclick="window.location.href='/admin/grapple-saw-trucks/${t.id}'">
          <div class="w-9 h-9 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 17h8m-8 0a2 2 0 11-4 0 2 2 0 014 0zm8 0a2 2 0 104 0 2 2 0 00-4 0zM3 17V7a1 1 0 011-1h9l4 4v7M3 10h13"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-[13px] font-bold text-slate-900 truncate">${t.equipment_type || 'N/A'}</p>
            <p class="text-[10px] text-zinc-500 font-mono truncate">${t.lift_capacity_tons ? t.lift_capacity_tons + ' tons · ' : ''}${new Date(t.created_at).toLocaleDateString()}</p>
          </div>
          <span class="shrink-0 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase border tracking-wide ${appBadge}">${appStatus}</span>
        </div>
      `}).join('');
    }

    // === PRIKAŽI "NEEDS ATTENTION" SAMO AKO IMA NEČEG DA SE ODOBRI ===
    const attnTotal = (leads?.filter(l => !l.status || l.status === 'new').length || 0)
      + (externalLeads?.filter(lead => lead.status === 'new').length || 0)
      + (contractors?.filter(c => c.status === 'pending').length || 0)
      + (trucks?.filter(t => t.approval_status === 'pending' || !t.approval_status).length || 0);
    const attentionBar = document.getElementById('attentionBar')!;
    attentionBar.classList.toggle('hidden', attnTotal === 0);
    attentionBar.classList.toggle('grid', attnTotal > 0);

    // === LOGOVI ===
    const limitLogs = 4;

    const { data: leadLogs } = await supabase.from('lead_logs').select('*, leads(email)').order('created_at', { ascending: false }).limit(limitLogs);
    const llContainer = document.getElementById('leadLogsContainer');
    if (llContainer && leadLogs) {
      llContainer.innerHTML = leadLogs.length > 0 ? leadLogs.map(log => generateProLogHtml(log.leads?.email || 'Unknown Lead', log.action || log.status || 'Updated', log.user_email || log.changed_by || 'Stojan M.', log.created_at)).join('') : '<div class="text-[10px] text-zinc-500 italic">No recent activity.</div>';
    }

    const { data: permitLogs } = await supabase.from('lead_logs').select('*, leads(email)').order('created_at', { ascending: false }).limit(limitLogs);
    const permitLogContainer = document.getElementById('permitLogsContainer');
    if (permitLogContainer && permitLogs) {
      const permitOnlyLogs = permitLogs.filter((log: any) => (log.action || '').toLowerCase().includes('permit'));
      permitLogContainer.innerHTML = permitOnlyLogs.length > 0 ? permitOnlyLogs.map(log => generateProLogHtml(log.leads?.email || 'Permit Lead', log.action || 'Permit activity', log.user_email || log.changed_by || 'Permit automation', log.created_at)).join('') : '<div class="text-[10px] text-zinc-500 italic">No permit activity yet.</div>';
    }

    const { data: contractorLogs } = await supabase.from('contractor_logs').select('*, contractors(company_name)').order('created_at', { ascending: false }).limit(limitLogs);
    const clContainer = document.getElementById('contractorLogsContainer');
    if (clContainer && contractorLogs) {
      clContainer.innerHTML = contractorLogs.length > 0 ? contractorLogs.map(log => generateProLogHtml(log.contractors?.company_name || 'Unknown Contractor', log.action || log.status || 'Updated', log.user_email || log.changed_by || 'Stojan M.', log.created_at)).join('') : '<div class="text-[10px] text-zinc-500 italic">No recent activity.</div>';
    }

    const { data: truckLogs } = await supabase.from('truck_logs').select('*, grapple_saw_trucks(equipment_type)').order('created_at', { ascending: false }).limit(limitLogs);
    const tlContainer = document.getElementById('truckLogsContainer');
    if (tlContainer && truckLogs) {
      tlContainer.innerHTML = truckLogs.length > 0 ? truckLogs.map(log => generateProLogHtml(log.grapple_saw_trucks?.equipment_type || 'Unknown Truck', log.action || 'Updated', log.user_email || log.changed_by || 'Stojan M.', log.created_at)).join('') : '<div class="text-[10px] text-zinc-500 italic">No recent activity.</div>';
    }
  }

  window.addEventListener('DOMContentLoaded', loadData);
</script>
