---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;
const db = supabaseAdmin ?? supabase;

// Dohvati kamion
const { data: truck } = await db.from('grapple_saw_trucks').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await db.from('truck_logs').select('*').eq('truck_id', id).order('created_at', { ascending: false });

// POVLAČIMO TERITORIJE IZ BAZE ZA EDIT MODAL
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

if (!truck) return Astro.redirect('/admin/grapple-saw-trucks');

const appStatus = truck.approval_status || 'pending';
const availStatus = truck.availability_status || 'Available';

// Ostali kamioni istog vlasnika (po nalogu ako postoji, inače po emailu)
let siblingTrucks: any[] = [];
if (truck.owner_user_id) {
  const { data } = await db.from('grapple_saw_trucks').select('id, equipment_type, approval_status, availability_status').eq('owner_user_id', truck.owner_user_id).neq('id', id);
  siblingTrucks = data || [];
} else if (truck.owner_email) {
  const { data } = await db.from('grapple_saw_trucks').select('id, equipment_type, approval_status, availability_status').eq('owner_email', truck.owner_email).neq('id', id);
  siblingTrucks = data || [];
}
---

<AdminLayout>
  <!-- MODAL ZA IZMENU KAMIONA -->
  <div id="editModal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[200] flex items-center justify-center p-4 overflow-y-auto">
    <div class="bg-white border border-zinc-200 p-8 rounded-xl max-w-lg w-full shadow-2xl my-8">
      <h2 class="text-slate-900 font-bold mb-6">Edit Truck Details</h2>
      <form id="editForm" class="grid grid-cols-2 gap-4">
        
        <div class="col-span-2">
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Equipment Type</label>
          <input type="text" id="editType" value={truck.equipment_type} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required />
        </div>
        
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Owner Email</label>
          <input type="email" id="editEmail" value={truck.owner_email} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Owner Phone</label>
          <input type="text" id="editPhone" value={truck.owner_phone} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Lift Capacity (tons)</label>
          <input type="number" id="editCapacity" value={truck.lift_capacity_tons} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Working Height (ft)</label>
          <input type="number" id="editHeight" value={truck.working_height_ft} class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" />
        </div>
        
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Access Type</label>
          <select id="editAccess" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900">
            <option value="wheeled" selected={truck.access_type === 'wheeled'}>Wheeled</option>
            <option value="tracked" selected={truck.access_type === 'tracked'}>Tracked</option>
          </select>
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Listing Type</label>
          <select id="editListing" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900">
            <option value="Rent" selected={truck.listing_type === 'Rent'}>Rent</option>
            <option value="Sale" selected={truck.listing_type === 'Sale'}>Sale</option>
          </select>
        </div>
        
        <div class="col-span-2">
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Location</label>
          
          <!-- DINAMIČKI PADAKUĆI MENI ZA LOKACIJU U EDIT-u -->
          <select id="editLocation" class="mt-1 w-full bg-zinc-100 border border-zinc-200 p-3 rounded text-slate-900" required>
            <option value="" disabled>Select Location</option>
            {territories?.map(t => (
              <option value={t.name} selected={truck.location === t.name}>{t.name}</option>
            ))}
          </select>

        </div>

        <div class="col-span-2 flex gap-4 mt-6 pt-4 border-t border-zinc-100/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-200 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-300 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-slate-900 font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="dash-shell flex-1"><div class="dash-scroll">
  <div class="w-full grid grid-cols-1 xl:grid-cols-12 gap-8">
    
    <!-- Podaci o kamionu -->
    <div class="xl:col-span-8 space-y-6">
      
      <!-- HEADER -->
      <div class="flex items-center gap-3">
        <a href="/admin/grapple-saw-trucks" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-zinc-200 text-[11px] font-bold uppercase tracking-wider text-zinc-600 hover:bg-zinc-50">
          ← Back
        </a>
        <div>
          <span class="dash-eyebrow text-violet-700">// Fleet asset</span>
          <h1 class="mt-1.5 text-2xl font-bold text-slate-950 tracking-tight">Truck details</h1>
          <p class="text-[10px] font-mono text-slate-400 mt-1 uppercase">ID: {truck.id.split('-')[0]}</p>
        </div>
      </div>
      
      <div class="bg-white border border-zinc-100 p-8 rounded-xl space-y-8 shadow-2xl">
        
        <div class="space-y-4">
          
          <!-- Statusi -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-zinc-100/50 border border-zinc-200">
                  <span class={`w-2.5 h-2.5 rounded-full ${appStatus === 'approved' ? 'bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]' : appStatus === 'rejected' ? 'bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.5)]' : 'bg-zinc-500 animate-pulse'}`}></span>
                </div>
                <div>
                  <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Status</p>
                  <p class="text-xs font-bold text-slate-900 mt-0.5">Approval</p>
                </div>
              </div>
              <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-md border ${appStatus === 'approved' ? 'text-green-700 border-green-500/20 bg-green-500/10' : appStatus === 'rejected' ? 'text-red-600 border-red-500/20 bg-red-500/10' : 'text-zinc-600 border-zinc-300 bg-zinc-200/50'}`}>
                {appStatus}
              </span>
            </div>

            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-zinc-100/50 border border-zinc-200">
                  <span class={`w-2.5 h-2.5 rounded-full ${availStatus === 'Available' ? 'bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]' : 'bg-yellow-500 shadow-[0_0_10px_rgba(234,179,8,0.5)]'}`}></span>
                </div>
                <div>
                  <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Status</p>
                  <p class="text-xs font-bold text-slate-900 mt-0.5">Availability</p>
                </div>
              </div>
              <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-md border ${availStatus === 'Available' ? 'text-green-700 border-green-500/20 bg-green-500/10' : 'text-yellow-600 border-yellow-500/20 bg-yellow-500/10'} ${appStatus !== 'approved' ? 'opacity-50 grayscale' : ''}`}>
                {appStatus === 'approved' ? availStatus : 'Pending'}
              </span>
            </div>
          </div>

          <!-- Specifikacije -->
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl md:col-span-2">
              <div class="flex items-center justify-between gap-2">
                <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Owner Email</p>
                <span class={`inline-flex items-center gap-1 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full border ${truck.owner_user_id ? 'text-green-700 border-green-200 bg-green-50' : 'text-zinc-500 border-zinc-200 bg-zinc-100'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${truck.owner_user_id ? 'bg-green-500' : 'bg-zinc-400'}`}></span>
                  {truck.owner_user_id ? 'Linked account' : 'No account'}
                </span>
              </div>
              {truck.owner_email ? (
                <a href={`mailto:${truck.owner_email}`} class="text-slate-900 font-mono mt-2 text-[13px] truncate block hover:text-green-700 transition-colors" title={truck.owner_email}>{truck.owner_email}</a>
              ) : (
                <p class="text-slate-900 font-mono mt-2 text-[13px]">N/A</p>
              )}
            </div>
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Owner Phone</p>
              {truck.owner_phone ? (
                <a href={`tel:${truck.owner_phone}`} class="text-slate-900 font-mono mt-2 text-[13px] block hover:text-green-700 transition-colors">{truck.owner_phone}</a>
              ) : (
                <p class="text-slate-900 font-mono mt-2 text-[13px]">N/A</p>
              )}
            </div>

            {siblingTrucks.length > 0 && (
              <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl md:col-span-3">
                <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 mb-3">Other Equipment From This Owner ({siblingTrucks.length})</p>
                <div class="flex flex-wrap gap-2">
                  {siblingTrucks.map((s) => (
                    <a href={`/admin/grapple-saw-trucks/${s.id}`} class="inline-flex items-center gap-2 text-[11px] font-mono px-3 py-1.5 rounded-lg border border-zinc-200 bg-white hover:border-green-300 hover:text-green-700 transition-colors">
                      <span class={`w-1.5 h-1.5 rounded-full ${s.approval_status === 'approved' ? 'bg-green-500' : s.approval_status === 'rejected' ? 'bg-red-500' : 'bg-zinc-400'}`}></span>
                      {s.equipment_type || 'Equipment'}
                    </a>
                  ))}
                </div>
              </div>
            )}

            {truck.owner_user_id && (
              <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl md:col-span-3">
                <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 mb-3">Owner Account Access</p>
                <button id="resetPasswordBtn" data-owner-user-id={truck.owner_user_id} class="w-full sm:w-auto h-11 px-6 rounded-lg bg-blue-500/10 border border-blue-500/30 text-blue-600 font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-blue-500 hover:text-slate-900 transition-all">
                  🔑 Set New Password
                </button>

                <div id="resetPasswordForm" class="hidden mt-4 p-5 bg-white border border-zinc-200 rounded-xl space-y-3">
                  <p class="text-[11px] text-zinc-600">Set a new password for this owner's account. Share it with them directly — this does not send an email.</p>
                  <div class="flex flex-col sm:flex-row gap-3">
                    <input id="newPasswordInput" type="text" placeholder="New password (min. 6 characters)" class="flex-1 bg-zinc-50 border border-zinc-200 p-3 rounded-lg text-slate-900 text-sm" />
                    <button id="generatePasswordBtn" type="button" class="shrink-0 px-4 py-3 rounded-lg bg-zinc-200 text-zinc-700 text-[10px] font-bold uppercase hover:bg-zinc-300 transition-colors">Generate</button>
                  </div>
                  <div class="flex gap-3">
                    <button id="cancelResetBtn" type="button" class="flex-1 h-11 rounded-lg bg-zinc-200 text-slate-900 text-[10px] font-bold uppercase tracking-wider hover:bg-zinc-300 transition-colors">Cancel</button>
                    <button id="confirmResetBtn" type="button" class="flex-1 h-11 rounded-lg bg-blue-500 text-slate-900 text-[10px] font-bold uppercase tracking-wider hover:bg-blue-400 transition-colors">Save Password</button>
                  </div>
                  <p id="resetPasswordMsg" class="text-[11px]"></p>
                </div>
              </div>
            )}

            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Equipment Type</p>
              <p class="text-slate-900 font-mono mt-2 text-[13px]">{truck.equipment_type || 'N/A'}</p>
            </div>
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Lift Capacity</p>
              <p class="text-slate-900 font-mono mt-2 text-[13px]">{truck.lift_capacity_tons ? `${truck.lift_capacity_tons} tons` : '-'}</p>
            </div>
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Working Height</p>
              <p class="text-slate-900 font-mono mt-2 text-[13px]">{truck.working_height_ft ? `${truck.working_height_ft} ft` : '-'}</p>
            </div>
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Access Type</p>
              <p class="text-slate-900 font-mono mt-2 text-[13px] capitalize">{truck.access_type || 'N/A'}</p>
            </div>
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Listing Type</p>
              <p class="text-slate-900 font-mono mt-2 text-[13px]">{truck.listing_type || 'N/A'}</p>
            </div>
            <div class="bg-slate-50 border border-zinc-200/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Location</p>
              <p class="text-slate-900 font-mono mt-2 text-[13px] truncate" title={truck.location}>{truck.location || 'N/A'}</p>
            </div>
          </div>
        </div>

        <!-- Akciona dugmad (Statusi) -->
        <div class="flex flex-col md:flex-row gap-6 pt-8 border-t border-zinc-100/50 mt-8">
          <div class="flex-1 bg-white border border-zinc-100 p-5 rounded-xl shadow-inner">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
              <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Approval Controls
            </p>
            <div class="flex gap-3">
              <button id="approveAppBtn" class="flex-1 h-10 rounded-lg bg-green-500/10 border border-green-500/30 text-green-700 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-green-500 hover:text-slate-900 transition-all">Approve</button>
              <button id="rejectAppBtn" class="flex-1 h-10 rounded-lg bg-red-50 border border-red-200 text-red-600 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-red-50 transition-all">Reject</button>
            </div>
          </div>

          <div class={`flex-1 bg-white border border-zinc-100 p-5 rounded-xl shadow-inner ${appStatus !== 'approved' ? 'opacity-30 pointer-events-none grayscale' : ''}`}>
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
              <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Status Controls
            </p>
            <div class="flex gap-3">
              <button id="availAvailBtn" class="flex-1 h-10 rounded-lg bg-green-50 border border-green-200 text-green-700 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-green-50 transition-all">Available</button>
              <button id="busyAvailBtn" class="flex-1 h-10 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-600 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-yellow-50 transition-all">Busy</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar: Status / Actions / Manage / Activity Log -->
    <div class="xl:col-span-4 detail-sidebar">
      <!-- Current Status -->
      <div class="detail-card">
        <h3 class="detail-card__title">Current Status</h3>
        <div class="flex flex-wrap gap-2">
          <span class={`inline-block px-3 py-2 rounded-full text-[11px] font-bold uppercase tracking-wide border ${appStatus === 'approved' ? 'border-green-700/50 text-green-700 bg-green-500/10' : appStatus === 'rejected' ? 'border-red-700/50 text-red-600 bg-red-500/10' : 'border-zinc-300 text-zinc-600 bg-zinc-200/50'}`}>
            {appStatus}
          </span>
          <span class={`inline-block px-3 py-2 rounded-full text-[11px] font-bold uppercase tracking-wide border ${availStatus === 'Available' ? 'border-green-700/50 text-green-700 bg-green-500/10' : 'border-amber-400/50 text-amber-600 bg-amber-500/10'}`}>
            {appStatus === 'approved' ? availStatus : 'Pending'}
          </span>
        </div>
      </div>

      <!-- Actions -->
      <div class="detail-card">
        <h3 class="detail-card__title">Actions</h3>
        <div class="space-y-2">
          {truck.owner_phone && (
            <a href={`tel:${truck.owner_phone}`} class="detail-btn detail-btn--primary">📞 Call Owner</a>
          )}
          {truck.owner_email && (
            <a href={`mailto:${truck.owner_email}`} class="detail-btn detail-btn--ghost">✉️ Email Owner</a>
          )}
          <button id="editBtn" class="detail-btn detail-btn--ghost">✏️ Edit details</button>
        </div>
      </div>

      <!-- Manage -->
      <div class="detail-card detail-card--danger">
        <h3 class="detail-card__title detail-card__title--danger">Manage</h3>
        <button id="deleteBtn" class="detail-btn detail-btn--danger">
          🗑️ Delete Truck
        </button>
      </div>

      <!-- Activity Log -->
      <div class="detail-card">
        <h3 class="detail-card__title">Activity Log</h3>
        <div class="detail-log">
          {logs?.map(log => (
            <div class="detail-log__entry">
              <div class="detail-log__dot" style="background:#8b5cf6"></div>
              <div>
                <p class="text-sm text-slate-900">{log.action}</p>
                <p class="text-[10px] text-zinc-400 mt-0.5 font-mono">by {log.changed_by || 'Stojan M.'} · {new Date(log.created_at).toLocaleDateString()} {new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</p>
              </div>
            </div>
          ))}
          {(!logs || logs.length === 0) && <p class="text-[11px] text-zinc-400 italic">No activity recorded yet.</p>}
        </div>
      </div>
    </div>
  </div>
  </div></div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M.";

  // -- LOGIKA ZA STATUS I DOSTUPNOST --
  async function updateDb(updates: any, logMessage: string) {
    if (!id) return;
    document.body.style.opacity = '0.5'; 
    await supabase.from('grapple_saw_trucks').update(updates).eq('id', id);
    await supabase.from('truck_logs').insert([{ truck_id: id, action: logMessage, changed_by: currentUser }]);
    window.location.reload();
  }

  document.getElementById('approveAppBtn')?.addEventListener('click', () => updateDb({ approval_status: 'approved' }, 'Approved truck listing'));
  document.getElementById('rejectAppBtn')?.addEventListener('click', () => updateDb({ approval_status: 'rejected' }, 'Rejected truck listing'));
  document.getElementById('availAvailBtn')?.addEventListener('click', () => updateDb({ availability_status: 'Available' }, 'Set availability to Available'));
  document.getElementById('busyAvailBtn')?.addEventListener('click', () => updateDb({ availability_status: 'Busy' }, 'Set availability to Busy'));

  // -- LOGIKA ZA EDITOVANJE --
  document.getElementById('editBtn')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.remove('hidden');
  });
  
  document.getElementById('closeEditModal')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.add('hidden');
  });

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      equipment_type: (document.getElementById('editType') as HTMLInputElement).value,
      owner_email: (document.getElementById('editEmail') as HTMLInputElement).value,
      owner_phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      lift_capacity_tons: (document.getElementById('editCapacity') as HTMLInputElement).value || null,
      working_height_ft: (document.getElementById('editHeight') as HTMLInputElement).value || null,
      access_type: (document.getElementById('editAccess') as HTMLSelectElement).value,
      listing_type: (document.getElementById('editListing') as HTMLSelectElement).value,
      location: (document.getElementById('editLocation') as HTMLSelectElement).value,
    };

    await supabase.from('grapple_saw_trucks').update(updates).eq('id', id);
    await supabase.from('truck_logs').insert([{
      truck_id: id,
      action: 'Updated truck details',
      changed_by: currentUser
    }]);

    window.location.reload();
  });

  // -- LOGIKA ZA BRISANJE --
  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this truck? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      
      await supabase.from('truck_logs').delete().eq('truck_id', id);
      await supabase.from('grapple_saw_trucks').delete().eq('id', id);
      
      window.location.href = '/admin/grapple-saw-trucks';
    }
  });

  // -- RESET PASSWORD ZA VLASNIKA (isti /api/admin-reset-password koji
  //    već koristi admin/contractors/[id].astro — radi za bilo koji
  //    korisnički nalog, ne samo kontraktore) --
  const resetForm = document.getElementById('resetPasswordForm');
  const resetMsg = document.getElementById('resetPasswordMsg');
  const resetBtn = document.getElementById('resetPasswordBtn') as HTMLButtonElement | null;
  const ownerUserId = resetBtn?.dataset.ownerUserId || '';

  resetBtn?.addEventListener('click', () => {
    resetForm?.classList.remove('hidden');
  });
  document.getElementById('cancelResetBtn')?.addEventListener('click', () => {
    resetForm?.classList.add('hidden');
    if (resetMsg) resetMsg.textContent = '';
    (document.getElementById('newPasswordInput') as HTMLInputElement).value = '';
  });

  document.getElementById('generatePasswordBtn')?.addEventListener('click', () => {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789';
    let pwd = '';
    for (let i = 0; i < 10; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
    (document.getElementById('newPasswordInput') as HTMLInputElement).value = pwd;
  });

  document.getElementById('confirmResetBtn')?.addEventListener('click', async () => {
    if (!resetMsg) return;
    const newPassword = (document.getElementById('newPasswordInput') as HTMLInputElement).value;
    if (!newPassword || newPassword.length < 6) {
      resetMsg.textContent = 'Password must be at least 6 characters.';
      resetMsg.className = 'text-[11px] text-red-600';
      return;
    }

    resetMsg.textContent = 'Saving...';
    resetMsg.className = 'text-[11px] text-zinc-600';

    const { data: { session } } = await supabase.auth.getSession();
    const res = await fetch('/api/admin-reset-password', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${session?.access_token}`,
      },
      // Endpoint je generičan — "contractorUserId" je samo ime parametra,
      // radi za bilo koji auth korisnički nalog (ovde: vlasnik kamiona).
      body: JSON.stringify({ contractorUserId: ownerUserId, newPassword }),
    });
    const result = await res.json();

    if (res.ok && result.ok) {
      resetMsg.textContent = `✅ Password updated. Share it with the owner: "${newPassword}"`;
      resetMsg.className = 'text-[11px] text-green-700 break-all';
    } else {
      resetMsg.textContent = '❌ ' + (result.message || result.error || 'Failed to update password.');
      resetMsg.className = 'text-[11px] text-red-600';
    }
  });
</script>
