---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";

const { id } = Astro.params;

// Dohvati kamion
const { data: truck } = await supabase.from('grapple_saw_trucks').select('*').eq('id', id).single();

// Dohvati logove
const { data: logs } = await supabase.from('truck_logs').select('*').eq('truck_id', id).order('created_at', { ascending: false });

// POVLAČIMO TERITORIJE IZ BAZE ZA EDIT MODAL
const { data: territories } = await supabase.from('service_territories').select('*').order('name');

if (!truck) return Astro.redirect('/admin/grapple-saw-trucks');

const appStatus = truck.approval_status || 'pending';
const availStatus = truck.availability_status || 'Available';
---

<AdminLayout>
  <!-- MODAL ZA IZMENU KAMIONA -->
  <div id="editModal" class="hidden fixed inset-0 bg-black/80 z-[200] flex items-center justify-center p-4 overflow-y-auto">
    <div class="bg-[#050505] border border-zinc-800 p-8 rounded-xl max-w-lg w-full shadow-2xl my-8">
      <h2 class="text-white font-bold mb-6">Edit Truck Details</h2>
      <form id="editForm" class="grid grid-cols-2 gap-4">
        
        <div class="col-span-2">
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Equipment Type</label>
          <input type="text" id="editType" value={truck.equipment_type} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required />
        </div>
        
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Owner Email</label>
          <input type="email" id="editEmail" value={truck.owner_email} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Owner Phone</label>
          <input type="text" id="editPhone" value={truck.owner_phone} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" />
        </div>
        
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Lift Capacity (tons)</label>
          <input type="number" id="editCapacity" value={truck.lift_capacity_tons} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" />
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Working Height (ft)</label>
          <input type="number" id="editHeight" value={truck.working_height_ft} class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" />
        </div>
        
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Access Type</label>
          <select id="editAccess" class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white">
            <option value="wheeled" selected={truck.access_type === 'wheeled'}>Wheeled</option>
            <option value="tracked" selected={truck.access_type === 'tracked'}>Tracked</option>
          </select>
        </div>
        <div>
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Listing Type</label>
          <select id="editListing" class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white">
            <option value="Rent" selected={truck.listing_type === 'Rent'}>Rent</option>
            <option value="Sale" selected={truck.listing_type === 'Sale'}>Sale</option>
          </select>
        </div>
        
        <div class="col-span-2">
          <label class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 ml-1">Location</label>
          
          <!-- DINAMIČKI PADAKUĆI MENI ZA LOKACIJU U EDIT-u -->
          <select id="editLocation" class="mt-1 w-full bg-zinc-900 border border-zinc-800 p-3 rounded text-white" required>
            <option value="" disabled>Select Location</option>
            {territories?.map(t => (
              <option value={t.name} selected={truck.location === t.name}>{t.name}</option>
            ))}
          </select>

        </div>

        <div class="col-span-2 flex gap-4 mt-6 pt-4 border-t border-zinc-900/50">
          <button type="button" id="closeEditModal" class="flex-1 bg-zinc-800 p-3 rounded text-white font-bold text-[10px] uppercase tracking-wider hover:bg-zinc-700 transition-colors">Cancel</button>
          <button type="submit" class="flex-1 bg-green-500 p-3 rounded text-black font-bold text-[10px] uppercase tracking-wider hover:bg-green-400 transition-colors">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <div class="w-full grid grid-cols-1 xl:grid-cols-12 gap-8">
    
    <!-- Podaci o kamionu -->
    <div class="xl:col-span-8 space-y-6">
      
      <!-- HEADER SA AKCIJAMA -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-xl font-bold text-white tracking-wide">Truck Details</h1>
          <p class="text-[10px] font-mono text-zinc-500 mt-1 uppercase">ID: {truck.id.split('-')[0]}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button id="editBtn" class="text-[10px] text-zinc-400 hover:text-white uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-900">
            Edit
          </button>
          <button id="deleteBtn" class="text-[10px] text-red-500/70 hover:text-red-500 uppercase font-bold tracking-[0.2em] transition-colors border border-red-900/30 px-4 py-2 rounded-lg hover:bg-red-950/30">
            Delete
          </button>
          <a href="/admin/grapple-saw-trucks" class="text-[10px] text-zinc-500 hover:text-white uppercase font-bold tracking-[0.2em] transition-colors border border-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-900">
            ← Back
          </a>
        </div>
      </div>
      
      <div class="bg-[#050505] border border-zinc-900 p-8 rounded-xl space-y-8 shadow-2xl">
        
        <div class="space-y-4">
          
          <!-- Statusi -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-zinc-900/50 border border-zinc-800">
                  <span class={`w-2.5 h-2.5 rounded-full ${appStatus === 'approved' ? 'bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]' : appStatus === 'rejected' ? 'bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.5)]' : 'bg-zinc-500 animate-pulse'}`}></span>
                </div>
                <div>
                  <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Status</p>
                  <p class="text-xs font-bold text-white mt-0.5">Approval</p>
                </div>
              </div>
              <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-md border ${appStatus === 'approved' ? 'text-green-400 border-green-500/20 bg-green-500/10' : appStatus === 'rejected' ? 'text-red-400 border-red-500/20 bg-red-500/10' : 'text-zinc-400 border-zinc-700 bg-zinc-800/50'}`}>
                {appStatus}
              </span>
            </div>

            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-zinc-900/50 border border-zinc-800">
                  <span class={`w-2.5 h-2.5 rounded-full ${availStatus === 'Available' ? 'bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]' : 'bg-yellow-500 shadow-[0_0_10px_rgba(234,179,8,0.5)]'}`}></span>
                </div>
                <div>
                  <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Status</p>
                  <p class="text-xs font-bold text-white mt-0.5">Availability</p>
                </div>
              </div>
              <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-md border ${availStatus === 'Available' ? 'text-green-400 border-green-500/20 bg-green-500/10' : 'text-yellow-400 border-yellow-500/20 bg-yellow-500/10'} ${appStatus !== 'approved' ? 'opacity-50 grayscale' : ''}`}>
                {appStatus === 'approved' ? availStatus : 'Pending'}
              </span>
            </div>
          </div>

          <!-- Specifikacije -->
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl md:col-span-2">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Owner Email</p>
              <p class="text-white font-mono mt-2 text-[13px] truncate" title={truck.owner_email}>{truck.owner_email || 'N/A'}</p>
            </div>
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Owner Phone</p>
              <p class="text-white font-mono mt-2 text-[13px]">{truck.owner_phone || 'N/A'}</p>
            </div>

            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Equipment Type</p>
              <p class="text-white font-mono mt-2 text-[13px]">{truck.equipment_type || 'N/A'}</p>
            </div>
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Lift Capacity</p>
              <p class="text-white font-mono mt-2 text-[13px]">{truck.lift_capacity_tons ? `${truck.lift_capacity_tons} tons` : '-'}</p>
            </div>
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Working Height</p>
              <p class="text-white font-mono mt-2 text-[13px]">{truck.working_height_ft ? `${truck.working_height_ft} ft` : '-'}</p>
            </div>
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Access Type</p>
              <p class="text-white font-mono mt-2 text-[13px] capitalize">{truck.access_type || 'N/A'}</p>
            </div>
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Listing Type</p>
              <p class="text-white font-mono mt-2 text-[13px]">{truck.listing_type || 'N/A'}</p>
            </div>
            <div class="bg-[#0a0a0a] border border-zinc-800/70 p-5 rounded-xl">
              <p class="text-[9px] uppercase tracking-[0.2em] text-zinc-500">Location</p>
              <p class="text-white font-mono mt-2 text-[13px] truncate" title={truck.location}>{truck.location || 'N/A'}</p>
            </div>
          </div>
        </div>

        <!-- Akciona dugmad (Statusi) -->
        <div class="flex flex-col md:flex-row gap-6 pt-8 border-t border-zinc-900/50 mt-8">
          <div class="flex-1 bg-black border border-zinc-900 p-5 rounded-xl shadow-inner">
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
              <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Approval Controls
            </p>
            <div class="flex gap-3">
              <button id="approveAppBtn" class="flex-1 h-10 rounded-lg bg-green-500/10 border border-green-500/30 text-green-500 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-green-500 hover:text-black transition-all">Approve</button>
              <button id="rejectAppBtn" class="flex-1 h-10 rounded-lg bg-red-950/20 border border-red-900/30 text-red-500 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-red-900/40 transition-all">Reject</button>
            </div>
          </div>

          <div class={`flex-1 bg-black border border-zinc-900 p-5 rounded-xl shadow-inner ${appStatus !== 'approved' ? 'opacity-30 pointer-events-none grayscale' : ''}`}>
            <p class="text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2">
              <span class="w-1 h-1 bg-zinc-500 rounded-full"></span> Status Controls
            </p>
            <div class="flex gap-3">
              <button id="availAvailBtn" class="flex-1 h-10 rounded-lg bg-green-950/20 border border-green-900/30 text-green-500 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-green-900/40 transition-all">Available</button>
              <button id="busyAvailBtn" class="flex-1 h-10 rounded-lg bg-yellow-950/20 border border-yellow-900/30 text-yellow-500 font-bold uppercase tracking-[0.2em] text-[9px] hover:bg-yellow-900/40 transition-all">Busy</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Desna Kolona: Logovi -->
    <div class="xl:col-span-4 bg-[#050505] border border-zinc-900 p-6 rounded-xl self-start sticky top-8 shadow-2xl">
      <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white mb-8 border-b border-zinc-900 pb-4">Activity Timeline</h3>
      <div class="space-y-6">
        {logs?.map(log => (
          <div class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-2 before:h-2 before:bg-zinc-800 before:border-2 before:border-[#050505] before:rounded-full after:content-[''] after:absolute after:left-[3px] after:top-4 after:bottom-[-20px] after:w-[2px] after:bg-zinc-900 last:after:hidden">
            <p class="text-[11px] text-white font-bold leading-tight">{log.action}</p>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[9px] text-zinc-500 font-mono">by <span class="text-zinc-300 font-bold tracking-wider uppercase">{log.changed_by || 'Stojan M.'}</span></span>
              <span class="text-[7px] text-zinc-700">●</span>
              <span class="text-[9px] text-zinc-600">{new Date(log.created_at).toLocaleDateString()} {new Date(log.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            </div>
          </div>
        ))}
        {(!logs || logs.length === 0) && <p class="text-[10px] text-zinc-600 italic">No activity recorded yet.</p>}
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../../lib/supabase";

  const pathParts = window.location.pathname.split('/');
  const id = pathParts[pathParts.length - 1];
  const currentUser = "Stojan M.";

  // -- LOGIKA ZA STATUS I DOSTUPNOST --
  async function updateDb(updates: any, logMessage: string) {
    if (!id) return;
    document.body.style.opacity = '0.5'; 
    await supabase.from('grapple_saw_trucks').update(updates).eq('id', id);
    await supabase.from('truck_logs').insert([{ truck_id: id, action: logMessage, changed_by: currentUser }]);
    window.location.reload();
  }

  document.getElementById('approveAppBtn')?.addEventListener('click', () => updateDb({ approval_status: 'approved' }, 'Approved truck listing'));
  document.getElementById('rejectAppBtn')?.addEventListener('click', () => updateDb({ approval_status: 'rejected' }, 'Rejected truck listing'));
  document.getElementById('availAvailBtn')?.addEventListener('click', () => updateDb({ availability_status: 'Available' }, 'Set availability to Available'));
  document.getElementById('busyAvailBtn')?.addEventListener('click', () => updateDb({ availability_status: 'Busy' }, 'Set availability to Busy'));

  // -- LOGIKA ZA EDITOVANJE --
  document.getElementById('editBtn')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.remove('hidden');
  });
  
  document.getElementById('closeEditModal')?.addEventListener('click', () => {
    document.getElementById('editModal')?.classList.add('hidden');
  });

  document.getElementById('editForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!id) return;
    document.body.style.opacity = '0.5';

    const updates = {
      equipment_type: (document.getElementById('editType') as HTMLInputElement).value,
      owner_email: (document.getElementById('editEmail') as HTMLInputElement).value,
      owner_phone: (document.getElementById('editPhone') as HTMLInputElement).value,
      lift_capacity_tons: (document.getElementById('editCapacity') as HTMLInputElement).value || null,
      working_height_ft: (document.getElementById('editHeight') as HTMLInputElement).value || null,
      access_type: (document.getElementById('editAccess') as HTMLSelectElement).value,
      listing_type: (document.getElementById('editListing') as HTMLSelectElement).value,
      location: (document.getElementById('editLocation') as HTMLSelectElement).value,
    };

    await supabase.from('grapple_saw_trucks').update(updates).eq('id', id);
    await supabase.from('truck_logs').insert([{
      truck_id: id,
      action: 'Updated truck details',
      changed_by: currentUser
    }]);

    window.location.reload();
  });

  // -- LOGIKA ZA BRISANJE --
  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    const isConfirmed = confirm('Are you sure you want to permanently delete this truck? This action cannot be undone.');
    if (isConfirmed && id) {
      document.body.style.opacity = '0.5';
      
      await supabase.from('truck_logs').delete().eq('truck_id', id);
      await supabase.from('grapple_saw_trucks').delete().eq('id', id);
      
      window.location.href = '/admin/grapple-saw-trucks';
    }
  });
</script>