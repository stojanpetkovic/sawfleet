---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Login | SF Tree Removal">
  <div class="relative min-h-screen flex items-center justify-center bg-white p-4 overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-green-500/5 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[400px] h-[400px] bg-blue-500/5 blur-[100px] rounded-full"></div>
    </div>

    <!-- Login container -->
    <div class="relative z-10 w-full max-w-[400px]">
      <div class="mb-8 text-center">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.3em] text-green-700">// System Access</span>
        <h1 class="mt-4 text-3xl font-bold text-slate-900 tracking-tighter">SF Tree Removal Portal</h1>
        <p class="mt-2 text-sm text-zinc-500">Authenticate to manage fleet operations.</p>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-soft-lg">
        <form id="loginForm" class="space-y-5">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Email Address</label>
            <input type="email" name="email" required placeholder="admin@sftreeremoval.com" class="h-12 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 transition-all placeholder:text-slate-400"/>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600">Password</label>
            <input type="password" name="password" required placeholder="••••••••" class="h-12 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 text-sm text-slate-900 outline-none focus:border-green-500 transition-all placeholder:text-slate-400"/>
          </div>
          <button type="submit" id="submitBtn" class="flex h-12 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-50 transition-all hover:bg-green-400 active:scale-[0.98]">
            Sign In →
          </button>
          <button type="button" id="forgotBtn" class="w-full text-center text-[11px] text-zinc-500 hover:text-zinc-700 transition-colors pt-1">
            Forgot password?
          </button>
        </form>
      </div>

      <p class="mt-6 text-center text-xs text-zinc-500">
        Don't have a contractor account? <a href="/contractors-registration" class="text-green-700 hover:text-green-700 font-bold">Register here</a>
      </p>

      <div class="mt-4 flex items-center justify-center gap-4 text-[10px] font-mono uppercase tracking-widest text-zinc-400">
        <a href="/truck-login" class="hover:text-zinc-700">Fleet owner login</a>
        <span>·</span>
        <a href="/admin/login" class="hover:text-zinc-700">Staff login</a>
      </div>

      <p class="mt-8 text-center text-[10px] text-zinc-400 font-mono tracking-widest uppercase">
        &copy; {new Date().getFullYear()} SF Tree Removal
      </p>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Visual feedback
    btn.innerText = "Authenticating...";
    btn.disabled = true;
    btn.classList.add('opacity-70');

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      alert("Authentication failed: " + error.message);
      btn.innerText = "Sign In →";
      btn.disabled = false;
      btn.classList.remove('opacity-70');
    } else {
      // This is the contractor portal — link the account to their profile.
      const { data: contractor } = await supabase.rpc('link_contractor_account');
      if (contractor) {
        window.location.assign('/dashboard');
        return;
      }

      // Not a contractor account — point them to the right portal.
      alert("This account isn't registered as a contractor. If you're staff, use /admin/login. If you're a fleet owner, use /truck-login.");
      await supabase.auth.signOut();
      btn.innerText = "Sign In →";
      btn.disabled = false;
      btn.classList.remove('opacity-70');
    }
  });

  document.getElementById('forgotBtn')?.addEventListener('click', async () => {
    const email = (form.elements.namedItem('email') as HTMLInputElement)?.value;
    if (!email) {
      alert('Enter your email in the field above first, then click again.');
      return;
    }
    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/reset-password`,
    });
    if (error) {
      alert('Error: ' + error.message);
    } else {
      alert('We sent you an email with a password reset link (check your spam folder too).');
    }
  });
</script>
