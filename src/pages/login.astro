---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Login | SawFleet Access">
  <div class="relative min-h-screen flex items-center justify-center bg-[#000000] p-4 overflow-hidden">
    <!-- Dekorativni gradient pozadine -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-green-500/5 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[400px] h-[400px] bg-blue-500/5 blur-[100px] rounded-full"></div>
    </div>

    <!-- Login kontejner -->
    <div class="relative z-10 w-full max-w-[400px]">
      <div class="mb-8 text-center">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.3em] text-green-500">// System Access</span>
        <h1 class="mt-4 text-3xl font-bold text-white tracking-tighter">SawFleet Portal</h1>
        <p class="mt-2 text-sm text-zinc-500">Authenticate to manage fleet operations.</p>
      </div>

      <div class="rounded-3xl border border-slate-700 bg-slate-900/50 backdrop-blur-sm p-8 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)]">
        <form id="loginForm" class="space-y-5">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Email Address</label>
            <input type="email" name="email" required placeholder="admin@sawfleet.com" class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-white outline-none focus:border-green-500 transition-all placeholder:text-slate-600"/>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Password</label>
            <input type="password" name="password" required placeholder="••••••••" class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-white outline-none focus:border-green-500 transition-all placeholder:text-slate-600"/>
          </div>
          <button type="submit" id="submitBtn" class="flex h-12 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-950 transition-all hover:bg-green-400 active:scale-[0.98]">
            Sign In →
          </button>
        </form>
      </div>
      
      <p class="mt-8 text-center text-[10px] text-zinc-600 font-mono tracking-widest uppercase">
        &copy; {new Date().getFullYear()} SawFleet Operations
      </p>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Vizuelni feedback
    btn.innerText = "Authenticating...";
    btn.disabled = true;
    btn.classList.add('opacity-70');
    
    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      alert("Authentication failed: " + error.message);
      btn.innerText = "Sign In →";
      btn.disabled = false;
      btn.classList.remove('opacity-70');
    } else {
      // 1) Da li je ovo pravi admin nalog (upisan u admins tabeli)?
      const { data: isAdmin } = await supabase.rpc('is_admin');
      if (isAdmin) {
        window.location.assign('/admin');
        return;
      }

      // 2) Inače, da li je ovo nalog kontraktora? Poveži ga sa profilom.
      const { data: contractor } = await supabase.rpc('link_contractor_account');
      if (contractor) {
        window.location.assign('/dashboard');
        return;
      }

      // 3) Ni admin ni kontraktor — nema pristup nijednom delu sajta.
      alert("Ovaj nalog nije povezan ni sa admin panelom ni sa profilom kontraktora. Kontaktiraj administratora.");
      await supabase.auth.signOut();
      btn.innerText = "Sign In →";
      btn.disabled = false;
      btn.classList.remove('opacity-70');
    }
  });
</script>