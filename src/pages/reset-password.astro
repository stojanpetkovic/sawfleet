---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Reset Password | SawFleet">
  <div class="relative min-h-screen flex items-center justify-center bg-[#000000] p-4 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-green-500/5 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[400px] h-[400px] bg-blue-500/5 blur-[100px] rounded-full"></div>
    </div>

    <div class="relative z-10 w-full max-w-[400px]">
      <div class="mb-8 text-center">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.3em] text-green-500">// New Password</span>
        <h1 class="mt-4 text-3xl font-bold text-white tracking-tighter">Set a new password</h1>
      </div>

      <div class="rounded-3xl border border-slate-700 bg-slate-900/50 backdrop-blur-sm p-8 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)]">
        <form id="resetForm" class="space-y-5">
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">New Password</label>
            <input type="password" name="password" required minlength="6" placeholder="••••••••" class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-white outline-none focus:border-green-500 transition-all placeholder:text-slate-600"/>
          </div>
          <div>
            <label class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Confirm Password</label>
            <input type="password" name="confirm" required minlength="6" placeholder="••••••••" class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-white outline-none focus:border-green-500 transition-all placeholder:text-slate-600"/>
          </div>
          <button type="submit" id="submitBtn" class="flex h-12 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-950 transition-all hover:bg-green-400 active:scale-[0.98]">
            Save Password →
          </button>
          <p id="statusMsg" class="text-center text-xs text-zinc-500"></p>
        </form>
      </div>

      <p class="mt-8 text-center text-[10px] text-zinc-600 font-mono tracking-widest uppercase">
        &copy; {new Date().getFullYear()} SawFleet Operations
      </p>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById('resetForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const statusMsg = document.getElementById('statusMsg')!;

  // The link from the email logs the user into a temporary session.
  // If someone lands here directly without a session, there's nothing to do.
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (!session) {
      statusMsg.textContent = 'This link is invalid or expired. Request a new one from the login page.';
      form.querySelectorAll('input, button').forEach((el) => (el as HTMLInputElement).disabled = true);
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const password = formData.get('password') as string;
    const confirm = formData.get('confirm') as string;

    if (password !== confirm) {
      statusMsg.textContent = 'Passwords do not match.';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving...';

    const { error } = await supabase.auth.updateUser({ password });

    if (error) {
      statusMsg.textContent = 'Error: ' + error.message;
      btn.disabled = false;
      btn.textContent = 'Save Password →';
      return;
    }

    statusMsg.textContent = 'Password changed! Redirecting...';

    // Same role-based redirect as the login pages
    const { data: isAdmin } = await supabase.rpc('is_admin');
    if (isAdmin) {
      window.location.assign('/admin');
      return;
    }
    const { data: contractor } = await supabase.rpc('link_contractor_account');
    if (contractor) {
      window.location.assign('/dashboard');
      return;
    }
    const { data: trucks } = await supabase.rpc('link_truck_owner_account');
    if (trucks && trucks.length > 0) {
      window.location.assign('/truck-dashboard');
      return;
    }
    window.location.assign('/login');
  });
</script>
