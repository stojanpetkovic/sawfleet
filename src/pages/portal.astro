---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

const portals = [
  {
    key: "contractor",
    label: "Contractors",
    title: "Tree Service Contractors",
    desc: "Claim homeowner leads in your territory. First to claim gets exclusive access to the contact details.",
    login: "/login",
    register: "/contractors-registration",
    accent: "green",
  },
  {
    key: "fleet",
    label: "Fleet Owners",
    title: "Grapple Saw Truck Owners",
    desc: "List your equipment and track the approval status of your submitted listings.",
    login: "/truck-login",
    register: "/truck-registration",
    accent: "blue",
  },
  {
    key: "staff",
    label: "Admin & Dispatch",
    title: "Internal Staff",
    desc: "Manage leads, contractors, equipment listings and platform settings.",
    login: "/admin/login",
    register: null,
    accent: "slate",
  },
];

const accentClasses: Record<string, { border: string; text: string; glow: string; btn: string }> = {
  green: {
    border: "hover:border-green-500/50",
    text: "text-green-500",
    glow: "bg-green-500/5",
    btn: "bg-green-500 hover:bg-green-400 text-slate-950",
  },
  blue: {
    border: "hover:border-blue-500/50",
    text: "text-blue-400",
    glow: "bg-blue-500/5",
    btn: "bg-blue-500 hover:bg-blue-400 text-slate-950",
  },
  slate: {
    border: "hover:border-slate-500/50",
    text: "text-slate-300",
    glow: "bg-slate-500/5",
    btn: "bg-slate-200 hover:bg-white text-slate-950",
  },
};
---

<MainLayout title="Portal | SawFleet">
  <Header />

  <main class="min-h-screen bg-[#000000] pt-32 pb-24">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-8">

      <div class="text-center max-w-xl mx-auto mb-16">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.3em] text-green-500">// Choose Your Portal</span>
        <h1 class="mt-4 text-3xl sm:text-4xl font-bold tracking-tighter text-white">Sign in to SawFleet</h1>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed">
          Pick the portal that matches your role. Each has its own sign-in and dashboard.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {portals.map((p) => {
          const a = accentClasses[p.accent];
          return (
            <div class={`group relative rounded-2xl border border-slate-800 bg-slate-900/60 p-8 flex flex-col transition-all ${a.border}`}>
              <div class={`absolute top-0 right-0 w-32 h-32 blur-[50px] rounded-full pointer-events-none ${a.glow}`}></div>

              <span class={`relative text-[9px] font-mono font-bold uppercase tracking-[0.2em] ${a.text}`}>// {p.label}</span>
              <h2 class="relative mt-3 text-xl font-bold text-white">{p.title}</h2>
              <p class="relative mt-3 text-[13px] leading-relaxed text-slate-400 flex-1">{p.desc}</p>

              <a href={p.login} class={`relative mt-8 h-12 flex items-center justify-center rounded-xl text-sm font-bold transition-all active:scale-[0.98] ${a.btn}`}>
                Sign In →
              </a>

              {p.register && (
                <a href={p.register} class="relative mt-3 text-center text-[11px] text-slate-500 hover:text-slate-300 transition-colors">
                  New here? Register
                </a>
              )}
            </div>
          );
        })}
      </div>

    </div>
  </main>

  <Footer />
</MainLayout>
