---
export const prerender = false;
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MobileNav from "../components/layout/MobileNav.astro";
import { BadgeCheck, FileCheck2, HardHat, MessageSquareText } from "lucide-astro";
const items = [
  { icon: BadgeCheck, title: "Provider information", text: "Contractors and fleet owners submit business and contact details for administrative review before full platform access is activated." },
  { icon: FileCheck2, title: "Listing review", text: "Equipment listings and provider accounts may be reviewed for completeness, status and relevance before being shown or used in dispatch workflows." },
  { icon: HardHat, title: "Job-site responsibility", text: "Independent providers remain responsible for site assessment, crew safety, permits, utilities, equipment operation and compliance with local requirements." },
  { icon: MessageSquareText, title: "Consent records", text: "Forms that support SMS communications record the consent provided by the submitting user and display applicable opt-out information." },
];
---
<MainLayout title="Platform Compliance | SF Tree Removal" description="Overview of provider review, safety responsibility and communication compliance on SF Tree Removal."><Header /><main class="min-h-screen bg-white pt-28 lg:pt-32"><section class="px-4 py-16 sm:px-8 lg:py-24"><div class="mx-auto max-w-[1100px]"><div class="max-w-3xl"><span class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-green-700">// Trust framework</span><h1 class="mt-4 text-4xl font-bold tracking-tighter text-slate-950 sm:text-5xl">Clear responsibilities across the platform.</h1><p class="mt-5 text-base leading-relaxed text-slate-600">Our compliance framework supports accurate routing and account oversight while recognizing that on-site work is performed by independent providers.</p></div><div class="mt-12 grid gap-5 md:grid-cols-2">{items.map(({ icon: Icon, title, text }) => <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft"><span class="flex h-11 w-11 items-center justify-center rounded-xl bg-green-50 text-green-700"><Icon size={21} strokeWidth={1.7} /></span><h2 class="mt-5 text-lg font-bold text-slate-950">{title}</h2><p class="mt-3 text-sm leading-relaxed text-slate-600">{text}</p></article>)}</div><div class="mt-10 rounded-2xl border border-slate-200 bg-slate-50 p-6"><h2 class="text-sm font-bold text-slate-950">Important distinction</h2><p class="mt-2 text-xs leading-relaxed text-slate-600">Administrative review is not a guarantee of future insurance status, licensing, availability or work quality. Property owners should confirm current credentials, project scope and site-specific requirements directly with the provider before work begins.</p></div></div></section></main><Footer /><MobileNav /></MainLayout>
