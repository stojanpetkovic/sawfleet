---
// Možeš dodati props ako želiš da menjaš linkove po stranici
const navigation = [
  { title: "Home", href: "/" },
  { title: "For Contractors", href: "/contractors-registration" },
  { title: "Fleet Ops", href: "/truck-registration" },
  { title: "Service Areas", href: "/service-areas" }
];
---

<header class="fixed inset-x-0 top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200/80 font-sans">
  <div class="mx-auto flex h-16 lg:h-20 max-w-7xl items-center justify-between px-4 sm:px-8">

    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0">
      <img src="/logo/logo.svg" alt="SF Tree Removal" class="h-11 lg:h-24 w-auto" loading="eager" />
    </a>

  <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 lg:flex">
      {navigation.map((item) => (
        <a href={item.href} class="text-[11px] font-mono font-bold uppercase tracking-[0.2em] text-slate-500 hover:text-slate-900 transition-colors">
          {item.title}
        </a>
      ))}
      <!-- Istaknuto Portal dugme -->
      <a href="/portal" class="h-9 px-4 flex items-center justify-center rounded-lg border border-green-600/20 bg-green-50 text-[11px] font-mono font-bold uppercase tracking-[0.2em] text-green-700 hover:bg-green-100 hover:border-green-600/30 transition-all">
        Portal
      </a>
    </nav>

    <!-- Mobilni Okidač -->
    <button id="menu-toggle" class="flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-slate-500 active:scale-95 transition-transform lg:hidden">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Menu Panel -->
<div id="mobile-menu" class="fixed inset-0 z-[60] transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden">
  <div id="menu-backdrop" class="absolute inset-0 bg-slate-900/30 backdrop-blur-sm"></div>

  <div class="absolute top-0 right-0 h-full w-[280px] bg-white border-l border-slate-200 p-8 pt-safe shadow-soft-lg">
    <button id="close-menu" class="absolute top-6 right-6 text-slate-400 hover:text-slate-900 transition-colors">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <nav class="mt-16 flex flex-col gap-6">
      {navigation.map((item) => (
        <a href={item.href} class="text-sm font-bold uppercase tracking-[0.2em] text-slate-900 hover:text-green-700 transition-colors">
          {item.title}
        </a>
      ))}
      <a href="/portal" class="text-sm font-bold uppercase tracking-[0.2em] text-slate-500 hover:text-green-700 transition-colors">Portal</a>
    </nav>
  </div>
</div>

<script>
  function setupMobileMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('close-menu');
    const backdrop = document.getElementById('menu-backdrop');

    // Prekidamo izvršavanje ako neki od elemenata ne postoji
    if (!toggle || !menu || !close || !backdrop) return;

    const openMenu = () => menu.classList.remove('translate-x-full');
    const closeMenu = () => menu.classList.add('translate-x-full');

    toggle.addEventListener('click', openMenu);
    close.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);
  }

  // Pokrećemo funkciju kada se DOM učita
  document.addEventListener('DOMContentLoaded', setupMobileMenu);

  // Opciono: Ako koristiš Astro View Transitions, ovo osigurava da meni radi i prilikom navigacije
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>
