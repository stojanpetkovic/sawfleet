---
import {
  ListChecks,
  UserPlus,
  CirclePlus,
  LogIn,
  UserCircle
} from "lucide-astro";
---

<nav class="fixed bottom-0 left-0 right-0 z-50 border-t border-zinc-900 bg-[#060807]/90 backdrop-blur-md lg:hidden selection:bg-green-500/30 selection:text-white">
  
  <div class="mx-auto flex h-16 max-w-md items-center justify-between px-6 relative">

    <!-- Login -->
    <a href="/login" class="flex flex-col items-center justify-center w-12 h-full text-zinc-500 transition-colors duration-200 hover:text-white group">
      <LogIn size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Login
      </span>
    </a>

    <!-- Register -->
    <a href="/contractors-registration" class="flex flex-col items-center justify-center w-12 h-full text-zinc-500 transition-colors duration-200 hover:text-white group">
      <UserPlus size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Join
      </span>
    </a>

    <!-- Masivno Centralno Dugme: Leads -->
    <div class="absolute left-1/2 bottom-5 -translate-x-1/2 z-50">
      <a 
        href="/dashboard" 
        class="flex h-14 w-14 items-center justify-center rounded-full border border-green-500/30 bg-zinc-950 p-0 shadow-[0_10px_30px_rgba(0,0,0,0.8),0_0_20px_rgba(34,197,94,0.1)] transition-all duration-300 hover:scale-105 hover:border-green-400 hover:bg-[#0b120d] active:scale-95 group"
        aria-label="View Leads"
      >
        <CirclePlus 
          size={26} 
          strokeWidth={1.5} 
          class="text-green-400 transition-transform duration-300 group-hover:rotate-90" 
        />
      </a>
    </div>
    
    <!-- Prazan prostor za centralno dugme -->
    <div class="w-14 h-full pointer-events-none" aria-hidden="true"></div>

    <!-- Leads (Tekstualno ispod ikone u meniju - opciono, ili koristi Profile) -->
    <a href="/dashboard" class="flex flex-col items-center justify-center w-12 h-full text-zinc-500 transition-colors duration-200 hover:text-white group">
      <ListChecks size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Leads
      </span>
    </a>

    <!-- Profile/Account -->
    <a href="/profile" class="flex flex-col items-center justify-center w-12 h-full text-zinc-500 transition-colors duration-200 hover:text-white group">
      <UserCircle size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Profile
      </span>
    </a>

  </div>

</nav>