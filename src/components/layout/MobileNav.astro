---
import {
  House,
  Trees,
  CirclePlus,
  MapPinned,
  MessageSquareWarning
} from "lucide-astro";
const currentPath = Astro.url.pathname;
---

<nav class="fixed bottom-0 left-0 right-0 z-50 border-t border-slate-200 bg-white/90 backdrop-blur-md lg:hidden safe-bottom-nav selection:bg-green-200 selection:text-slate-900">

  <div class="mx-auto flex h-16 max-w-md items-center justify-between px-6 relative">

    <!-- Home -->
    <a href="/" aria-current={currentPath === '/' ? 'page' : undefined} class={`flex flex-col items-center justify-center w-12 h-full transition-colors duration-200 group relative ${currentPath === '/' ? 'text-green-700' : 'text-slate-400 hover:text-green-700'}`}>
      <House size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Home
      </span>
    </a>

    <!-- Services -->
    <a href="/services" aria-current={currentPath === '/services' ? 'page' : undefined} class={`flex flex-col items-center justify-center w-12 h-full transition-colors duration-200 group ${currentPath === '/services' ? 'text-green-700' : 'text-slate-400 hover:text-slate-900'}`}>
      <Trees size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Services
      </span>
    </a>

    <!-- Centralno Dugme -->
    <div class="absolute left-1/2 bottom-5 -translate-x-1/2 z-50">
      <a
        href="#quote"
        class="flex h-14 w-14 items-center justify-center rounded-full border border-green-600/20 bg-white shadow-soft-lg transition-all duration-300 hover:scale-105 hover:border-green-600/40 active:scale-95 group"
        aria-label="Request Quote"
      >
        <CirclePlus
          size={26}
          strokeWidth={1.5}
          class="text-green-600 transition-transform duration-300 group-hover:rotate-90"
        />
      </a>
    </div>

    <div class="w-14 h-full pointer-events-none" aria-hidden="true"></div>

    <!-- Areas -->
    <a href="/service-areas" aria-current={currentPath === '/service-areas' ? 'page' : undefined} class={`flex flex-col items-center justify-center w-12 h-full transition-colors duration-200 group ${currentPath === '/service-areas' ? 'text-green-700' : 'text-slate-400 hover:text-slate-900'}`}>
      <MapPinned size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Areas
      </span>
    </a>

    <!-- Support / Žalbe -->
    <a href="/support" aria-current={currentPath === '/support' ? 'page' : undefined} class={`flex flex-col items-center justify-center w-12 h-full transition-colors duration-200 group ${currentPath === '/support' ? 'text-green-700' : 'text-slate-400 hover:text-slate-900'}`}>
      <MessageSquareWarning size={20} strokeWidth={1.75} />
      <span class="mt-1 text-[9px] font-mono uppercase tracking-wider">
        Support
      </span>
    </a>

  </div>

</nav>
