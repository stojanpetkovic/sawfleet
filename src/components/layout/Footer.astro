---
const currentYear = new Date().getFullYear();

const links = {
  product: [
    { title: "Services", href: "/services" },
    { title: "Service Areas", href: "/service-areas" },
    { title: "Request Estimate", href: "/#quote" }
  ],
  contractors: [
    { title: "Join Network", href: "/contractors#contractor-join" },
    { title: "How It Works", href: "/contractors#how-it-works" },
    { title: "Partner Portal", href: "/login" }
  ],
  legal: [
    { title: "Privacy Policy", href: "/privacy" },
    { title: "Terms of Service", href: "/terms" },
    { title: "Compliance", href: "/compliance" }
  ]
};
---

<footer class="bg-slate-50 border-t border-slate-200 font-sans pb-28 lg:pb-12 pt-16 selection:bg-green-200 selection:text-slate-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">

      <!-- Leva strana -->
      <div class="space-y-4">
        <a href="/" class="flex items-center shrink-0">
          <img src="/logo/logo.svg" alt="SawFleet" class="h-24 w-auto" />
        </a>
        <p class="text-xs text-slate-500 max-w-sm leading-relaxed">
          The premium tree service dispatch pipeline across South Florida. Connecting high-intent property owners with vetted, compliant contractors.
        </p>
      </div>

      <!-- Desna strana -->
      <div class="mt-12 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0 sm:grid-cols-3">

        {Object.entries(links).map(([key, category]) => (
          <div>
            <h3 class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-slate-400">
              // {key.charAt(0).toUpperCase() + key.slice(1)}
            </h3>
            <ul class="mt-4 space-y-2">
              {category.map((link) => (
                <li>
                  <a href={link.href} class="text-xs text-slate-500 hover:text-green-700 transition-colors">
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 border-t border-slate-200 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[10px] font-mono uppercase tracking-[0.1em] text-slate-400">
        &copy; {currentYear} SawFleet Inc. All rights reserved.
      </p>
      <div class="flex items-center gap-2 text-[10px] font-mono uppercase tracking-[0.1em] text-slate-400">
        <span class="h-1.5 w-1.5 rounded-full bg-green-600 animate-pulse"></span>
        Tri-County Network Active
      </div>
    </div>
  </div>
</footer>
