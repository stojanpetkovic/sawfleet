<section class="absolute inset-0 overflow-hidden">

  <!-- Video -->

  <video
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    class="absolute inset-0 h-full w-full object-cover">

    <source
      src="/video/hero.mp4"
      type="video/mp4" />

  </video>

  <!-- Light Dark Overlay -->

  <div class="absolute inset-0 bg-black/35"></div>

  <!-- Left Gradient -->

  <div
    class="absolute inset-0 bg-gradient-to-r
      from-[#08110A]/70
      via-[#08110A]/25
      to-transparent">
  </div>

  <!-- Bottom Fade -->

  <div
    class="absolute inset-x-0 bottom-0 h-56
      bg-gradient-to-t
      from-[#0B0F0C]
      via-[#0B0F0C]/45
      to-transparent">
  </div>

  <!-- Soft Vignette -->

  <div
    class="absolute inset-0
      shadow-[inset_0_0_120px_rgba(0,0,0,.30)]">
  </div>

  <!-- Green Glow -->

  <div
    class="absolute left-[-120px] top-1/2
      h-[600px] w-[600px]
      -translate-y-1/2
      rounded-full
      bg-green-600/10
      blur-[140px]">
  </div>

</section>