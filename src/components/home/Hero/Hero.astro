---
import HeroContent from "./HeroContent.astro";
import HeroForm from "./HeroForm.astro";
---

<!-- Dodat pt-20 (padding-top) da se sadržaj spusti ispod fiksnog headera -->
<section class="relative overflow-hidden bg-[#000000] border-b border-zinc-900 pt-20">

    <div class="relative z-10 mx-auto max-w-[1320px] px-4 sm:px-8">

        <!-- Smanjen početni py-16 na py-12 da kompenzujemo gornji padding -->
        <div class="grid items-center gap-10 py-12 lg:grid-cols-[1fr_auto] lg:gap-16 lg:py-24">

            <div class="w-full">
                <HeroContent />
            </div>

            <div class="flex w-full justify-center lg:justify-end">
                <HeroForm />
            </div>

        </div>

    </div>

</section>