<section class="border-y border-zinc-900 bg-[#000000] py-10 px-4 sm:px-8 font-sans selection:bg-green-500/30 selection:text-white">
  <div class="mx-auto max-w-7xl">
    
    <div class="grid gap-8 lg:grid-cols-2">
      
      <!-- LEVO: Obim Usluga -->
      <div>
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Capabilities</span>
        <h3 class="mt-2 text-2xl font-bold tracking-tight text-zinc-50 sm:text-3xl">Professional Tree Services.</h3>
        
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {["Tree Removal", "Trimming & Pruning", "Stump Grinding", "Lot Clearing"].map((title, i) => (
            <div class="rounded-xl border border-zinc-800 bg-[#070a08] p-4 hover:border-zinc-700 transition-colors">
              <div class="text-xs font-bold text-zinc-100">{title}</div>
              <p class="text-[11px] text-zinc-400 mt-1.5 leading-relaxed">
                {i === 0 && "Safe extraction of dead, dying, or hazardous trees near foundations."}
                {i === 1 && "Precision cutting for canopy health, aesthetics, and storm mitigation prep."}
                {i === 2 && "Complete below-grade grinding to clear land for replanting or construction."}
                {i === 3 && "Full-scale vegetative removal and site preparation for residential projects."}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- DESNO: Regional Bounds -->
      <div class="flex flex-col justify-between">
        <div>
          <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Regional Bounds</span>
          <h3 class="mt-2 text-2xl font-bold tracking-tight text-zinc-50 sm:text-3xl">Active South Florida Dispatch.</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Our dispatch logistics span the entire tri-county area. Verified crews are stationed locally for rapid deployment.
          </p>
          
          <!-- Gradovi -->
          <div class="mt-6 flex flex-wrap gap-2">
            {['Miami', 'Fort Lauderdale', 'West Palm Beach', 'Boca Raton', 'Hollywood', 'Coral Gables'].map(city => (
              <span class="rounded-md bg-[#070a08] border border-zinc-800 px-2.5 py-1 text-[10px] font-mono text-zinc-400 hover:border-zinc-600 transition-colors">
                {city}
              </span>
            ))}
          </div>
        </div>

        <!-- Protokol -->
        <div class="mt-8 rounded-xl border border-green-500/10 bg-green-950/20 p-4 text-[11px] leading-relaxed text-zinc-400">
          <strong class="text-green-400 block mb-0.5">🔒 Anti-Spam Guarantee:</strong>
          Secure routing queue. We match your project with a maximum of 3 highly qualified local specialists. No infinite calls, no sold leads.
        </div>
      </div>

    </div>
  </div>
</section>