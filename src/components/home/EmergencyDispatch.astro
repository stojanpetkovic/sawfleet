---
---
<section class="bg-[#070a08] py-20 font-sans selection:bg-green-500/30 selection:text-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    
    <!-- Crno-crvena asimetrična kartica sa jasnim borderom -->
    <div class="relative overflow-hidden rounded-3xl border border-red-500/25 bg-gradient-to-br from-[#120707] via-[#090d0b] to-[#070a08] p-8 sm:p-12 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.9)]">
      
      <!-- Prigušeni crveni glow duboko u pozadini kartice -->
      <div class="absolute top-0 left-0 h-[300px] w-[300px] rounded-full bg-red-500/5 blur-[80px] pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 flex flex-col justify-between gap-8 lg:flex-row lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-red-500/10 px-3 py-1 text-xs font-mono uppercase text-red-400 border border-red-500/20">
            <span class="h-1.5 w-1.5 rounded-full bg-red-500 animate-pulse"></span> Emergency Hotline Active
          </div>
          <h3 class="mt-4 text-2xl font-black tracking-tight text-white sm:text-3xl">Storm Damage or Immediate Hazard?</h3>
          <p class="mt-2 text-base text-zinc-400 max-w-xl">
            If a tree has fallen on your home, blocked your drive, or tangled with power lines, bypass the standard form for priority emergency routing.
          </p>
        </div>

        <div class="shrink-0">
          <a href="tel:5551234567" class="inline-flex h-12 items-center justify-center rounded-xl bg-white px-6 text-sm font-bold text-black transition-all duration-300 hover:bg-zinc-200 hover:shadow-[0_0_30px_rgba(255,255,255,0.15)]">
            Call Emergency Dispatch
          </a>
        </div>
      </div>

    </div>

  </div>
</section>