---
const requests = [
  ["Miami, FL", "Large Oak Tree Removal", "New Request"],
  ["Hollywood, FL", "Emergency Tree Removal", "Matching Contractor"],
  ["Boca Raton, FL", "Tree Trimming", "Assigned"],
  ["Fort Lauderdale, FL", "Palm Tree Removal", "Contacting Homeowner"],
  ["Hialeah, FL", "Storm Damage Cleanup", "New Request"],
  ["West Palm Beach, FL", "Tree Removal", "Matching Contractor"],
  ["Miami Gardens, FL", "Large Pine Removal", "Assigned"],
  ["Coral Springs, FL", "Stump Grinding", "Contacting Homeowner"]
];

const feed = [...requests, ...requests];
---

<section class="relative overflow-hidden bg-[#0B0F0C] py-20">

    <div class="mx-auto max-w-7xl px-6">

        <!-- Section Header -->

        <div class="mx-auto max-w-4xl text-center">

            <span class="inline-flex items-center gap-2 rounded-full border border-green-500/20 bg-green-500/10 px-5 py-2 text-sm font-semibold text-green-400">

                <span class="h-2.5 w-2.5 animate-pulse rounded-full bg-green-400"></span>

                LIVE PLATFORM ACTIVITY

            </span>

            <h2 class="mt-8 text-5xl font-black tracking-tight text-white">

                Homeowners Are Already Using SawFleet to Find
                Tree Service Professionals

            </h2>

            <p class="mx-auto mt-6 max-w-3xl text-xl leading-9 text-zinc-400">

                Every homeowner submits a single request through SawFleet.
                Our platform reviews the project details and matches it with a
                qualified local contractor based on the requested service and
                coverage area.

            </p>

        </div>

        <!-- Contractor CTA -->

        <div class="mx-auto mt-14 max-w-5xl rounded-3xl border border-green-500/20 bg-gradient-to-r from-green-500/10 via-emerald-500/10 to-green-500/10 p-8 text-center backdrop-blur-xl">

            <span class="inline-flex items-center gap-2 rounded-full bg-green-500/10 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-green-400">

                <span class="h-2 w-2 animate-pulse rounded-full bg-green-400"></span>

                FOR TREE SERVICE CONTRACTORS

            </span>

            <h3 class="mt-6 text-4xl font-black tracking-tight text-white">

                Receive Homeowner Requests Through SawFleet

            </h3>

            <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-zinc-300">

                The activity below shows the types of projects homeowners submit
                through SawFleet. If your company serves South Florida, you can
                join our contractor network and receive qualified requests based
                on your services and coverage area.

            </p>

            <div class="mt-8 flex flex-wrap items-center justify-center gap-4">

                <a
                    href="/contractors"
                    class="inline-flex h-14 items-center justify-center rounded-2xl bg-green-700 px-10 text-lg font-semibold text-white transition duration-300 hover:-translate-y-1 hover:bg-green-600">

                    Join the Contractor Network →

                </a>

                <a
                    href="/how-it-works"
                    class="inline-flex h-14 items-center justify-center rounded-2xl border border-white/15 px-10 text-lg font-semibold text-white transition duration-300 hover:bg-white/10">

                    Learn How It Works

                </a>

            </div>

        </div>

        <!-- Live Feed -->

        <div class="relative mx-auto mt-16 h-[560px] w-full max-w-[1200px] overflow-hidden">

            <!-- Top Fade -->

            <div class="pointer-events-none absolute inset-x-0 top-0 z-20 h-28 bg-gradient-to-b from-[#0B0F0C] via-[#0B0F0C]/90 to-transparent"></div>

            <!-- Bottom Fade -->

            <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 h-28 bg-gradient-to-t from-[#0B0F0C] via-[#0B0F0C]/90 to-transparent"></div>

            <div class="feed">

                {
                    feed.map(([city, service, status]) => (

                        <article class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl transition duration-300 hover:translate-x-2 hover:border-green-500/30 hover:bg-white/10">

                            <div class="flex items-center justify-between">

                                <div class="flex items-center gap-3">

                                    <span class="h-3 w-3 animate-pulse rounded-full bg-green-500 shadow-[0_0_18px_rgba(34,197,94,.8)]"></span>

                                    <span class="text-xs font-bold uppercase tracking-[0.2em] text-green-400">

                                        {status}

                                    </span>

                                </div>

                                <span class="text-sm text-zinc-500">

                                    Just now

                                </span>

                            </div>

                            <h3 class="mt-5 text-2xl font-bold text-white">

                                {service}

                            </h3>

                            <div class="mt-3 flex items-center gap-2 text-zinc-400">

                                <svg xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor">

                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0L6.343 16.657a8 8 0 1111.314 0z"/>

                                </svg>

                                {city}

                            </div>

                            <div class="mt-6 flex flex-wrap gap-3">

                                <span class="rounded-full bg-white/10 px-4 py-2 text-sm text-zinc-300">

                                    Residential

                                </span>

                                <span class="rounded-full bg-white/10 px-4 py-2 text-sm text-zinc-300">

                                    South Florida

                                </span>

                            </div>

                        </article>

                    ))
                }

            </div>

        </div>

    </div>

</section>

<style>

.feed{

    display:flex;

    flex-direction:column;

    gap:20px;

    animation:feedScroll 30s linear infinite;

}

.feed:hover{

    animation-play-state:paused;

}

@keyframes feedScroll{

    from{

        transform:translateY(0);

    }

    to{

        transform:translateY(-50%);

    }

}

@media (max-width:768px){

    .feed{

        gap:16px;

    }

    .feed article{

        padding:20px;

    }

    .feed h3{

        font-size:1.3rem;

    }

}

</style>