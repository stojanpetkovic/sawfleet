---
import HeroContent from "./HeroContent.astro";
import HeroDashboard from "./HeroDashboard.astro";
---

<section class="relative overflow-hidden bg-[#0B0F0C]">

    <div
        class="absolute inset-0
        bg-[radial-gradient(circle_at_20%_20%,rgba(22,163,74,.12),transparent_40%),
             radial-gradient(circle_at_80%_60%,rgba(37,99,235,.10),transparent_45%)]">
    </div>

    <div class="relative z-10 mx-auto max-w-[1320px] px-8">

        <div class="grid min-h-screen items-center gap-20 py-36 lg:grid-cols-[6fr_5fr]">

            <HeroContent />

            <HeroDashboard />

        </div>

    </div>

</section>