<section class="max-w-[640px] font-sans selection:bg-green-500/30 selection:text-white px-4 sm:px-0 -mt-4">

  <!-- Premium Minimal Badge: ostaje ovde -->
  <div class="inline-flex items-center gap-2 rounded-md border border-zinc-800 bg-[#070a08] px-3 py-1">
    <span class="relative flex h-2 w-2">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
    </span>
    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">
      Contractor Network
    </span>
  </div>

  <!-- Editorial Heading: Smanjen mt-6 na mt-4 -->
  <h1 class="mt-4 text-[2.75rem] sm:text-[3.5rem] font-bold leading-[1] tracking-tighter text-white">
    Grow Your 
    <span class="block mt-1 bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">
      Tree Service
    </span> 
    Business.
  </h1>

  <!-- High-Contrast Subtitle -->
  <p class="mt-5 text-base sm:text-lg leading-7 text-zinc-300 font-medium">
    Receive qualified homeowner requests from the exact cities and counties you choose to serve.
  </p>

  <!-- Clean System Description -->
  <p class="mt-5 text-sm leading-7 text-zinc-400 border-l border-zinc-800 pl-4 py-1">
    SawFleet automatically routes localized requests based on your specific service criteria, capacity, and real-time availability.
  </p>

  <!-- Benefits Grid: Kompaktni "App" layout -->
  <div class="mt-8 space-y-4 border-t border-zinc-900 pt-6">
    
    {["Qualified Homeowner Requests", "Smart Request Matching", "No Cold Calling"].map((title, i) => (
      <div class="flex items-start gap-4">
        <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded border border-zinc-800 bg-[#070a08] text-[9px] font-mono text-green-500">
          0{i + 1}
        </div>
        <div>
          <h3 class="text-xs font-bold text-white uppercase tracking-wider">{title}</h3>
          <p class="mt-0.5 text-[11px] leading-relaxed text-zinc-500">
            {i === 0 && "Direct integration with homeowners intent on booking."}
            {i === 1 && "Projects filtered by your strict coverage radius."}
            {i === 2 && "Build your pipeline on high-intent inbound dispatch."}
          </p>
        </div>
      </div>
    ))}

  </div>

</section>