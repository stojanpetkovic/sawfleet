<section class="relative">

    <!-- Background Glow -->
    <div class="absolute w-[320px] h-[320px] left-[-140px] top-[35%] rounded-full bg-green-600/[0.22] blur-[140px] pointer-events-none"></div>
    <div class="absolute w-[260px] h-[260px] right-[-80px] top-[40px] rounded-full bg-blue-600/[0.16] blur-[140px] pointer-events-none"></div>

    <!-- Dashboard -->
    <div class="relative overflow-hidden rounded-[24px] sm:rounded-[32px] border border-white/[0.08] bg-gradient-to-b from-[#141618] to-[#0e1012] backdrop-blur-[24px] shadow-[0_40px_120px_rgba(0,0,0,0.45),inset_0_1px_rgba(255,255,255,0.05)]">

        <!-- Header -->
        <header class="flex justify-between items-start p-5 sm:p-6 lg:p-8 border-bottom border-b border-white/[0.08]">
            <div>
                <div class="flex items-center gap-[10px] color text-[#4ade80] text-[0.75rem] font-bold tracking-[0.18em] uppercase">
                    <span class="w-[10px] h-[10px] rounded-full bg-[#22c55e] shadow-[0_0_18px_rgba(34,197,94,0.8)] animate-[pulse_1.8s_infinite]"></span>
                    LIVE DISPATCH
                </div>
                <h3 class="mt-[14px] text-[1.45rem] sm:text-[1.7rem] lg:text-[2rem] font-extrabold text-white">
                    SawFleet Dashboard
                </h3>
            </div>
            <div class="padding px-[18px] py-[10px] rounded-full bg-green-500/[0.12] text-[#4ade80] font-semibold">
                Online
            </div>
        </header>

        <!-- Request Card -->
        <section class="request-card p-5 sm:p-6 lg:p-8 border-b border-white/[0.08] transition-all duration-350">
            <div class="flex justify-between items-center">
                <span id="requestStatus" class="status inline-flex items-center px-[14px] py-2 rounded-full text-[0.72rem] font-bold tracking-[0.14em] uppercase transition-all duration-350">
                    NEW REQUEST
                </span>
                <span id="requestTime" class="text-[#71717a] text-[0.9rem] transition-all duration-350">
                    Just now
                </span>
            </div>
            <h2 id="requestService" class="mt-[26px] text-[1.45rem] sm:text-[1.7rem] lg:text-[2.1rem] font-extrabold line-height leading-[1.2] text-white transition-all duration-350">
                Emergency Tree Removal
            </h2>
            <p id="requestCity" class="mt-3 text-[#9ca3af] text-[1.05rem] transition-all duration-350">
                Miami, FL
            </p>
            <div class="flex gap-3 mt-[28px]">
                <span id="requestProperty" class="px-4 py-[9px] rounded-full bg-white/[0.06] text-[#d4d4d8] text-[0.85rem]">
                    Residential
                </span>
                <span class="px-4 py-[9px] rounded-full bg-white/[0.06] text-[#d4d4d8] text-[0.85rem]">
                    South Florida
                </span>
            </div>
        </section>

        <!-- Progress -->
        <section class="px-5 py-6 sm:p-6 lg:p-8 border-b border-white/[0.08]">
            <div class="flex justify-between mb-[14px] text-[#d4d4d8] text-[0.9rem]">
                <span>
                    Dispatch Progress
                </span>
                <span id="progressPercent">
                    25%
                </span>
            </div>
            <div class="h-[10px] rounded-full bg-white/[0.06] overflow-hidden">
                <div id="progressFill" class="w-[25%] h-full rounded-full bg-gradient-to-r from-[#16a34a] to-[#22c55e] transition-[width] duration-700 ease-in-out"></div>
            </div>
        </section>

        <!-- Timeline -->
        <section class="timeline p-5 sm:p-6 lg:p-8 grid gap-[22px]">
            <div id="step1" class="timeline-item flex gap-[18px] items-start transition-all duration-350">
                <div class="timeline-icon flex items-center justify-center w-[42px] h-[42px] rounded-full bg-[#27272a] text-white font-bold shrink-0 transition-all duration-350">
                    ✓
                </div>
                <div>
                    <strong class="block text-white text-[1rem]">
                        Request Received
                    </strong>
                    <small class="block mt-[5px] text-[#71717a] text-[0.9rem]">
                        Homeowner submitted project.
                    </small>
                </div>
            </div>

            <div id="step2" class="timeline-item flex gap-[18px] items-start transition-all duration-350">
                <div class="timeline-icon flex items-center justify-center w-[42px] h-[42px] rounded-full bg-[#27272a] text-white font-bold shrink-0 transition-all duration-350">
                    2
                </div>
                <div>
                    <strong class="block text-white text-[1rem]">
                        Matching Contractor
                    </strong>
                    <small class="block mt-[5px] text-[#71717a] text-[0.9rem]">
                        Searching qualified contractor.
                    </small>
                </div>
            </div>

            <div id="step3" class="timeline-item flex gap-[18px] items-start transition-all duration-350">
                <div class="timeline-icon flex items-center justify-center w-[42px] h-[42px] rounded-full bg-[#27272a] text-white font-bold shrink-0 transition-all duration-350">
                    3
                </div>
                <div>
                    <strong class="block text-white text-[1rem]">
                        Contractor Assigned
                    </strong>
                    <small class="block mt-[5px] text-[#71717a] text-[0.9rem]">
                        Waiting for acceptance.
                    </small>
                </div>
            </div>

            <div id="step4" class="timeline-item flex gap-[18px] items-start transition-all duration-350">
                <div class="timeline-icon flex items-center justify-center w-[42px] h-[42px] rounded-full bg-[#27272a] text-white font-bold shrink-0 transition-all duration-350">
                    4
                </div>
                <div>
                    <strong class="block text-white text-[1rem]">
                        Homeowner Connected
                    </strong>
                    <small class="block mt-[5px] text-[#71717a] text-[0.9rem]">
                        Contractor contacts homeowner.
                    </small>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="grid grid-cols-1 sm:grid-cols-3 border-t border-white/[0.08]">
            <div class="p-[26px] text-center border-t sm:border-t-0 border-white/[0.08] sm:border-r sm:border-white/[0.08]">
                <strong id="activeRequests" class="block text-[2rem] text-white font-extrabold">
                    24
                </strong>
                <span class="block mt-2 text-[#71717a] text-[0.85rem]">
                    Active Requests
                </span>
            </div>
            <div class="p-[26px] text-center border-t sm:border-t-0 border-white/[0.08] sm:border-r sm:border-white/[0.08]">
                <strong id="matchTime" class="block text-[2rem] text-white font-extrabold">
                    5 min
                </strong>
                <span class="block mt-2 text-[#71717a] text-[0.85rem]">
                    Avg. Match
                </span>
            </div>
            <div class="p-[26px] text-center border-t sm:border-t-0 border-white/[0.08]">
                <strong class="block text-[2rem] text-white font-extrabold">
                    3
                </strong>
                <span class="block mt-2 text-[#71717a] text-[0.85rem]">
                    Counties
                </span>
            </div>
        </footer>

    </div>

</section>

<!-- Pomoćne klase za dinamičke JS promene stanja kako bismo izbegli pisanje dugačkog inline CSS-a kroz skriptu -->
<style>
  .status-new { background: rgba(34,197,94,.12) !important; color: #4ade80 !important; }
  .status-matching { background: rgba(251,191,36,.12) !important; color: #fbbf24 !important; }
  .status-assigned { background: rgba(59,130,246,.12) !important; color: #60a5fa !important; }
  .status-connected { background: rgba(168,85,247,.12) !important; color: #c084fc !important; }
  
  .timeline-item { opacity: 0.35; }
  .timeline-item.active { opacity: 1; }
  .timeline-item.active .timeline-icon { background: #16a34a !important; }
</style>

<script>
const requests = [
  {
    service: "Emergency Tree Removal",
    city: "Miami, FL",
    property: "Residential",
    active: 24,
    match: "4 min"
  },
  {
    service: "Large Oak Removal",
    city: "Fort Lauderdale, FL",
    property: "Residential",
    active: 19,
    match: "6 min"
  },
  {
    service: "Palm Tree Trimming",
    city: "Hollywood, FL",
    property: "Commercial",
    active: 27,
    match: "5 min"
  },
  {
    service: "Storm Damage Cleanup",
    city: "West Palm Beach, FL",
    property: "Residential",
    active: 31,
    match: "3 min"
  },
  {
    service: "Tree Removal",
    city: "Boca Raton, FL",
    property: "Residential",
    active: 18,
    match: "5 min"
  },
  {
    service: "Stump Grinding",
    city: "Coral Springs, FL",
    property: "Commercial",
    active: 22,
    match: "4 min"
  }
];

const statuses = [
  {
    label:"NEW REQUEST",
    className:"status-new",
    percent:25
  },
  {
    label:"MATCHING",
    className:"status-matching",
    percent:50
  },
  {
    label:"CONTRACTOR ASSIGNED",
    className:"status-assigned",
    percent:75
  },
  {
    label:"HOMEOWNER CONNECTED",
    className:"status-connected",
    percent:100
  }
];

let requestIndex = 0;
let statusIndex = 0;

const status = document.getElementById("requestStatus");
const service = document.getElementById("requestService");
const city = document.getElementById("requestCity");
const property = document.getElementById("requestProperty");
const progress = document.getElementById("progressFill");
const progressPercent = document.getElementById("progressPercent");
const active = document.getElementById("activeRequests");
const match = document.getElementById("matchTime");
const time = document.getElementById("requestTime");

const steps=[
document.getElementById("step1"),
document.getElementById("step2"),
document.getElementById("step3"),
document.getElementById("step4")
];

function render(){

    const job=requests[requestIndex];
    const state=statuses[statusIndex];

    status.className="status "+state.className;
    status.textContent=state.label;

    service.style.opacity=0;
    city.style.opacity=0;

    setTimeout(()=>{

        service.textContent=job.service;
        city.textContent=job.city;
        property.textContent=job.property;

        active.textContent=job.active;
        match.textContent=job.match;

        service.style.opacity=1;
        city.style.opacity=1;

    },180);

    progress.style.width=state.percent+"%";
    progressPercent.textContent=state.percent+"%";

    steps.forEach((el,i)=>{

        if(i<=statusIndex){

            el.classList.add("active");

        }else{

            el.classList.remove("active");

        }

    });

    const times=[
        "Just now",
        "15 sec ago",
        "32 sec ago",
        "1 min ago"
    ];

    time.textContent=times[statusIndex];

    statusIndex++;

    if(statusIndex===statuses.length){

        statusIndex=0;

        requestIndex++;

        if(requestIndex===requests.length){

            requestIndex=0;

        }

    }

}

render();

setInterval(render,3500);
</script>