<section class="w-full max-w-[520px] rounded-2xl sm:rounded-3xl border border-slate-700 bg-slate-900 p-5 sm:p-8 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)]">

  <!-- Header -->
  <div class="border-b border-slate-700/50 pb-5">
    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-400">
      // Partner Intake
    </span>
    <h2 class="mt-2 text-2xl font-bold tracking-tight text-white sm:text-3xl">
      Join Contractor Network
    </h2>
    <p class="mt-1.5 text-sm text-slate-400">
      Build your pipeline with high-intent inbound dispatch.
    </p>
  </div>

  <!-- Form -->
  <form class="mt-6 space-y-5">
    
    <!-- Company -->
    <div>
      <label for="company" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Company Name</label>
      <input id="company" type="text" required placeholder="e.g. South Florida Tree Care LLC" class="h-12 w-full rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 placeholder:text-slate-500"/>
    </div>

    <!-- Contact Info -->
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="name" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Contact Name</label>
        <input id="name" type="text" required placeholder="John Doe" class="h-12 w-full rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 placeholder:text-slate-500"/>
      </div>
      <div>
        <label for="phone" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Direct Phone</label>
        <input id="phone" type="tel" required placeholder="(555) 000-0000" class="h-12 w-full rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 placeholder:text-slate-500"/>
      </div>
    </div>

    <!-- Territory -->
    <div>
      <label for="county" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Service Territory</label>
      <div class="relative">
        <select id="county" required class="h-12 w-full appearance-none rounded-xl border border-slate-600 bg-slate-800 px-4 text-sm text-white outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500">
          <option selected disabled class="text-slate-500">Select Main Territory</option>
          <option>Miami-Dade County</option>
          <option>Broward County</option>
          <option>Palm Beach County</option>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </div>
      </div>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="flex h-12 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-950 transition-all hover:bg-green-400 active:scale-[0.98]">
      Apply For Network Access →
    </button>
  </form>

  <!-- Footer -->
  <div class="mt-6 flex items-center justify-center gap-2 border-t border-slate-700 pt-5 text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-slate-500">
    <span>🔒 Vetted Operator Screening</span>
  </div>
</section>