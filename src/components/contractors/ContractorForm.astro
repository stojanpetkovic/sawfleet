---
---
<section 
  id="contractor-join" 
  class="relative overflow-hidden bg-[#070a08] py-24 font-sans selection:bg-green-500/30 selection:text-white border-t border-zinc-900 scroll-mt-24"
>
  <!-- scroll-mt-24 obezbeđuje da zaglavlje ne prekrije vrh sekcije kada se skroluje -->
  
  <!-- Diskretan svetlosni odsjaj u pozadini sekcije -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-green-500/[0.01] blur-[130px] pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 flex flex-col items-center">
    
    <!-- Centralni Uvod Sekcije -->
    <div class="text-center max-w-2xl mb-12">
      <span class="text-xs font-mono uppercase tracking-wider text-green-400">// Network Expansion</span>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">Ready to Scale Your Volume?</h2>
      <p class="mt-4 text-sm text-zinc-400 leading-relaxed">
        Complete the onboarding intake below. Our team reviews field capabilities, insurance limits, and service density requirements within 24 business hours.
      </p>
    </div>

    <!-- Kontrastna, Svetlija Premium Kartica (Profesionalni Grafitni Izgled) -->
    <div class="w-full max-w-[520px] rounded-3xl border border-zinc-800 bg-zinc-900 p-6 sm:p-8 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.8),inset_0_1px_1px_rgba(255,255,255,0.05)]">
      
      <!-- Header forme -->
      <div class="border-b border-zinc-800 pb-6">
        <span class="text-xs font-mono uppercase tracking-wider text-zinc-400">
          // Partner Intake Form
        </span>
        <h3 class="mt-1 text-xl font-bold text-white">
          Join Contractor Network
        </h3>
        <p class="mt-1 text-xs text-zinc-400">
          Acquire high-intent commercial and residential tree service leads.
        </p>
      </div>

      <!-- Form -->
      <form class="mt-6 space-y-5">

        <!-- Company Name -->
        <div>
          <label for="company" class="mb-2 block text-xs font-bold uppercase tracking-wider text-zinc-300">
            Company Name
          </label>
          <input
            id="company"
            type="text"
            required
            placeholder="e.g. South Florida Tree Care LLC"
            class="h-12 w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 text-sm text-white outline-none transition-all duration-300 placeholder:text-zinc-600 hover:border-zinc-700 focus:border-green-500 focus:ring-1 focus:ring-green-500"/>
        </div>

        <!-- Contact Name + Phone -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="contact-name" class="mb-2 block text-xs font-bold uppercase tracking-wider text-zinc-300">
              Contact Name
            </label>
            <input
              id="contact-name"
              type="text"
              required
              placeholder="John Doe"
              class="h-12 w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 text-sm text-white outline-none transition-all duration-300 placeholder:text-zinc-600 hover:border-zinc-700 focus:border-green-500 focus:ring-1 focus:ring-green-500"/>
          </div>

          <div>
            <label for="contractor-phone" class="mb-2 block text-xs font-bold uppercase tracking-wider text-zinc-300">
              Direct Phone
            </label>
            <input
              id="contractor-phone"
              type="tel"
              required
              placeholder="(555) 000-0000"
              class="h-12 w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 text-sm text-white outline-none transition-all duration-300 placeholder:text-zinc-600 hover:border-zinc-700 focus:border-green-500 focus:ring-1 focus:ring-green-500"/>
          </div>
        </div>

        <!-- Operating Region -->
        <div>
          <label for="primary-county" class="mb-2 block text-xs font-bold uppercase tracking-wider text-zinc-300">
            Primary Service County
          </label>
          <div class="relative">
            <select
              id="primary-county"
              required
              class="h-12 w-full appearance-none rounded-xl border border-zinc-800 bg-zinc-950 px-4 text-sm text-white outline-none transition-all duration-300 hover:border-zinc-700 focus:border-green-500 focus:ring-1 focus:ring-green-500">
              <option selected disabled class="bg-zinc-950 text-zinc-500">Select Main Territory</option>
              <option class="bg-zinc-950 text-white">Miami-Dade County</option>
              <option class="bg-zinc-950 text-white">Broward County</option>
              <option class="bg-zinc-950 text-white">Palm Beach County</option>
              <option class="bg-zinc-950 text-white">All Tri-County Area</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-zinc-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Crew Size & Heavy Equipment -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="crew-count" class="mb-2 block text-xs font-bold uppercase tracking-wider text-zinc-300">
              Active Field Crews
            </label>
            <div class="relative">
              <select
                id="crew-count"
                class="h-12 w-full appearance-none rounded-xl border border-zinc-800 bg-zinc-950 px-4 text-sm text-white outline-none transition-all duration-300 hover:border-zinc-700 focus:border-green-500 focus:ring-1 focus:ring-green-500">
                <option class="bg-zinc-950 text-white">1 Crew</option>
                <option class="bg-zinc-950 text-white">2 - 4 Crews</option>
                <option class="bg-zinc-950 text-white">5+ Crews</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-zinc-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </div>
          </div>

          <div>
            <label for="heavy-gear" class="mb-2 block text-xs font-bold uppercase tracking-wider text-zinc-300">
              Heavy Equipment
            </label>
            <div class="relative">
              <select
                id="heavy-gear"
                class="h-12 w-full appearance-none rounded-xl border border-zinc-800 bg-zinc-950 px-4 text-sm text-white outline-none transition-all duration-300 hover:border-zinc-700 focus:border-green-500 focus:ring-1 focus:ring-green-500">
                <option class="bg-zinc-950 text-white">Climbing Gear Only</option>
                <option class="bg-zinc-950 text-white">Bucket Truck / Lift</option>
                <option class="bg-zinc-950 text-white">Crane Operations</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-zinc-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="group relative flex h-12 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-black transition-all duration-300 hover:bg-green-400 hover:shadow-[0_0_30px_rgba(34,197,94,0.2)] border border-transparent active:scale-[0.99]">
          Apply For Network Access
          <span class="ml-2 transition-transform duration-300 group-hover:translate-x-0.5">→</span>
        </button>

      </form>

      <!-- Footer -->
      <div class="mt-6 flex items-center justify-center gap-2 border-t border-zinc-800 pt-5 text-xs font-mono uppercase tracking-wider text-zinc-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span>Vetted Operator Screening</span>
      </div>

    </div>

  </div>
</section>