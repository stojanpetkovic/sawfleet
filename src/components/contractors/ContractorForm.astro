<section 
  id="contractor-join" 
  class="relative overflow-hidden bg-[#070a08] py-24 font-sans selection:bg-green-500/30 selection:text-white border-t border-slate-900 scroll-mt-24"
>
  <!-- Odsjaj -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-green-500/[0.03] blur-[130px] pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 flex flex-col items-center">
    
    <div class="text-center max-w-2xl mb-12">
      <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-green-500">// Network Expansion</span>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">Ready to Scale Your Volume?</h2>
      <p class="mt-4 text-sm text-slate-400 leading-relaxed">
        Complete the onboarding intake below. Our team reviews field capabilities, insurance limits, and service density requirements within 24 business hours.
      </p>
    </div>

    <!-- "Pro" Kartica -->
    <div class="w-full max-w-[520px] rounded-3xl border border-slate-800 bg-slate-900/90 backdrop-blur-md p-6 sm:p-8 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.05)]">
      
      <div class="border-b border-slate-800 pb-6">
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-slate-500">
          // Partner Intake Form
        </span>
        <h3 class="mt-1 text-xl font-bold text-slate-100">
          Join Contractor Network
        </h3>
        <p class="mt-1 text-xs text-slate-400">
          Acquire high-intent commercial and residential tree service leads.
        </p>
      </div>

      <form class="mt-6 space-y-5">

        <!-- Company Name -->
        <div>
          <label for="company" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Company Name</label>
          <input
            id="company"
            type="text"
            required
            placeholder="e.g. South Florida Tree Care LLC"
            class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-slate-200 outline-none transition-all duration-300 placeholder:text-slate-700 hover:border-slate-600 focus:border-green-500 focus:ring-2 focus:ring-green-500/20"/>
        </div>

        <!-- Contact Name + Phone -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="contact-name" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Contact Name</label>
            <input
              id="contact-name"
              type="text"
              required
              placeholder="John Doe"
              class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-slate-200 outline-none transition-all duration-300 placeholder:text-slate-700 hover:border-slate-600 focus:border-green-500 focus:ring-2 focus:ring-green-500/20"/>
          </div>

          <div>
            <label for="contractor-phone" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Direct Phone</label>
            <input
              id="contractor-phone"
              type="tel"
              required
              placeholder="(555) 000-0000"
              class="h-12 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-slate-200 outline-none transition-all duration-300 placeholder:text-slate-700 hover:border-slate-600 focus:border-green-500 focus:ring-2 focus:ring-green-500/20"/>
          </div>
        </div>

        <!-- Region -->
        <div>
          <label for="primary-county" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Primary Service County</label>
          <div class="relative">
            <select
              id="primary-county"
              required
              class="h-12 w-full appearance-none rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-slate-200 outline-none transition-all duration-300 hover:border-slate-600 focus:border-green-500 focus:ring-2 focus:ring-green-500/20">
              <option selected disabled class="bg-slate-950 text-slate-600">Select Main Territory</option>
              <option class="bg-slate-950 text-slate-200">Miami-Dade County</option>
              <option class="bg-slate-950 text-slate-200">Broward County</option>
              <option class="bg-slate-950 text-slate-200">Palm Beach County</option>
              <option class="bg-slate-950 text-slate-200">All Tri-County Area</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Crew & Gear -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="crew-count" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Active Field Crews</label>
            <select id="crew-count" class="h-12 w-full appearance-none rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-slate-200 outline-none transition-all duration-300 hover:border-slate-600 focus:border-green-500 focus:ring-2 focus:ring-green-500/20">
              <option class="bg-slate-950 text-slate-200">1 Crew</option>
              <option class="bg-slate-950 text-slate-200">2 - 4 Crews</option>
              <option class="bg-slate-950 text-slate-200">5+ Crews</option>
            </select>
          </div>
          <div>
            <label for="heavy-gear" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">Heavy Equipment</label>
            <select id="heavy-gear" class="h-12 w-full appearance-none rounded-xl border border-slate-700 bg-slate-950 px-4 text-sm text-slate-200 outline-none transition-all duration-300 hover:border-slate-600 focus:border-green-500 focus:ring-2 focus:ring-green-500/20">
              <option class="bg-slate-950 text-slate-200">Climbing Gear Only</option>
              <option class="bg-slate-950 text-slate-200">Bucket Truck / Lift</option>
              <option class="bg-slate-950 text-slate-200">Crane Operations</option>
            </select>
          </div>
        </div>

        <button
          type="submit"
          class="group relative flex h-12 w-full items-center justify-center rounded-xl bg-green-500 text-sm font-bold text-slate-950 transition-all duration-300 hover:bg-green-400 hover:shadow-[0_0_20px_rgba(34,197,94,0.3)] active:scale-[0.98]">
          Apply For Network Access
          <span class="ml-2 transition-transform duration-300 group-hover:translate-x-1">→</span>
        </button>
      </form>

      <div class="mt-6 flex items-center justify-center gap-2 border-t border-slate-800 pt-5 text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span>Vetted Operator Screening</span>
      </div>
    </div>
  </div>
</section>