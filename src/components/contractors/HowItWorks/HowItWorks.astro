<section id="how-it-works" class="relative overflow-hidden bg-[#000000] py-20 font-sans selection:bg-green-500/30 selection:text-white">
  
  <div class="relative z-10 mx-auto max-w-[1320px] px-4 sm:px-8">
    
    <!-- Header -->
    <div class="mb-16 max-w-2xl">
      <span class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-green-500">
        // Workflow architecture
      </span>
      <h2 class="mt-4 text-4xl sm:text-5xl font-bold tracking-tighter text-white">
        Engineered for simplicity.
      </h2>
      <p class="mt-6 text-sm leading-7 text-zinc-400">
        Every request moves through a strictly optimized, deterministic pipeline. No friction, no black boxes—just a seamless transition from intake to match.
      </p>
    </div>

    <!-- Mreža (Optimizovana za Pro App izgled) -->
    <div class="grid gap-6 lg:grid-cols-3">
      
      <!-- FAZA 1 -->
      <div class="rounded-2xl border border-zinc-900 bg-[#070a08] p-6">
        <div class="flex items-center justify-between border-b border-zinc-900 pb-4 mb-6">
          <span class="text-[9px] font-bold tracking-[0.2em] text-zinc-600 uppercase">Phase 01</span>
          <span class="text-[9px] font-mono text-green-500">Intake</span>
        </div>
        <div class="space-y-6">
          {[
            { n: "01", t: "Homeowner Submits", d: "Project details and location are captured instantly." },
            { n: "02", t: "System Validation", d: "Service type and regional bounds are verified." }
          ].map(step => (
            <div>
              <div class="flex items-baseline gap-3">
                <span class="font-mono text-[10px] font-bold text-zinc-700">{step.n} //</span>
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">{step.t}</h3>
              </div>
              <p class="mt-2 text-[11px] leading-relaxed text-zinc-500 pl-8">{step.d}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- FAZA 2: Istaknuta -->
      <div class="rounded-2xl border border-green-500/20 bg-green-950/5 p-6 relative">
        <div class="flex items-center justify-between border-b border-green-500/20 pb-4 mb-6">
          <span class="text-[9px] font-bold tracking-[0.2em] text-green-500 uppercase">Phase 02</span>
          <span class="animate-pulse h-1.5 w-1.5 rounded-full bg-green-500"></span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="font-mono text-[10px] font-bold text-green-500">03 //</span>
          <h3 class="text-sm font-bold text-white uppercase tracking-wider">Smart Matching</h3>
        </div>
        <p class="mt-4 text-[11px] leading-relaxed text-zinc-400 pl-8">
          Proprietary routing algorithm cross-references availability, rating metrics, and proximity to match qualified contractors in the micro-market.
        </p>
      </div>

      <!-- FAZA 3 -->
      <div class="rounded-2xl border border-zinc-900 bg-[#070a08] p-6">
        <div class="flex items-center justify-between border-b border-zinc-900 pb-4 mb-6">
          <span class="text-[9px] font-bold tracking-[0.2em] text-zinc-600 uppercase">Phase 03</span>
          <span class="text-[9px] font-mono text-zinc-500">Handshake</span>
        </div>
        <div class="space-y-6">
          {[
            { n: "04", t: "Contractor Alert", d: "Instant access to project specifications and metadata." },
            { n: "05", t: "Direct Connection", d: "Seamless scheduling and estimate finalization." }
          ].map(step => (
            <div>
              <div class="flex items-baseline gap-3">
                <span class="font-mono text-[10px] font-bold text-zinc-700">{step.n} //</span>
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">{step.t}</h3>
              </div>
              <p class="mt-2 text-[11px] leading-relaxed text-zinc-500 pl-8">{step.d}</p>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="mt-12 flex items-center gap-6 border-t border-zinc-900 pt-8 text-[9px] font-mono font-bold uppercase tracking-[0.2em] text-zinc-600">
      <span>// Avg. Dispatch: 4.2 min</span>
      <span>// Pipeline: Secure</span>
    </div>

  </div>
</section>